#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
cd "$SCRIPT_DIR"

COMPOSE_CMD="docker compose"
SERVICE_NAME="tak-portal"

usage() {
  cat <<EOF
Usage: $0 {setup|config|bookmarks|start|stop|restart|update|logs|status|remove}

Commands:
  setup      Create/edit .env and make sure script is ready (also ensures bookmarks.env exists)
  config     Alias for 'setup'
  bookmarks  Create/edit bookmarks.env for dashboard quick links, then restart
  start      Build (if needed) and start the stack in the background
  stop       Stop the stack and keep data volume
  restart    Restart containers (rebuild if needed)
  update     git pull + rebuild & restart containers, then optionally prune old images
  logs       Follow logs from the container
  status     Show container status
  remove     Completely remove containers, volumes, network, and images
EOF
}

ensure_env() {
  if [[ -f .env ]]; then
    echo ".env already exists — opening in nano..."
    nano .env
  else
    if [[ -f .env.example ]]; then
      echo "Creating .env from .env.example..."
      cp .env.example .env
      echo "Opening .env in nano..."
      nano .env
    else
      echo "ERROR: Neither .env nor .env.example found."
      exit 1
    fi
  fi
}

ensure_bookmarks_env() {
  if [[ -f bookmarks.env ]]; then
    echo "bookmarks.env already exists — opening in nano..."
    nano bookmarks.env
  else
    if [[ -f bookmarks.env.example ]]; then
      echo "Creating bookmarks.env from bookmarks.env.example..."
      cp bookmarks.env.example bookmarks.env
      echo "Opening bookmarks.env in nano..."
      nano bookmarks.env
    else
      echo "ERROR: Neither bookmarks.env nor bookmarks.env.example found."
      echo "Create bookmarks.env.example or bookmarks.env first."
      exit 1
    fi
  fi
}

CMD="${1:-}"

case "$CMD" in
  setup|config)
    echo "Running setup/config..."
    ensure_env

    # Ensure bookmarks.env exists on initial setup, but don't open nano here.
    if [[ ! -f bookmarks.env ]] && [[ -f bookmarks.env.example ]]; then
      echo "Creating default bookmarks.env from bookmarks.env.example..."
      cp bookmarks.env.example bookmarks.env
    fi

    echo
    echo "Setup complete. You can now run:"
    echo "  ./$(basename "${BASH_SOURCE[0]}") start"
    echo "Optional: ./$(basename "${BASH_SOURCE[0]}") bookmarks   # to edit dashboard bookmarks"
    ;;

  bookmarks)
    echo "Configuring dashboard bookmarks..."
    ensure_bookmarks_env

    echo
    echo "Restarting TAK Portal to apply bookmark changes..."
    if [[ -f .env ]]; then
      $COMPOSE_CMD down
      $COMPOSE_CMD up -d --build
      echo "Restart complete."
    else
      echo ".env not found; skipping restart. Run ./$(basename "${BASH_SOURCE[0]}") setup first."
    fi
    ;;

  start)
    if [[ ! -f .env ]]; then
      echo "ERROR: .env missing. Run:"
      echo "  ./$(basename "${BASH_SOURCE[0]}") setup"
      exit 1
    fi
    echo "Starting TAK Portal..."
    $COMPOSE_CMD up -d --build
    ;;

  stop)
    echo "Stopping containers (keeping data volume)..."
    $COMPOSE_CMD down
    ;;

  restart)
    echo "Restarting..."
    $COMPOSE_CMD down
    $COMPOSE_CMD up -d --build
    ;;

  update)
    echo "Updating repository and containers..."

    if [[ -d .git ]]; then
      echo "Fetching latest code..."
      git pull --rebase --autostash || git pull
    else
      echo "No .git directory found; skipping git pull."
    fi

    echo "Rebuilding and recreating containers..."
    $COMPOSE_CMD up -d --build

    echo
    echo "Waiting 20 seconds for the app to start..."
    sleep 20

    echo
    echo "Check logs to verify everything looks healthy:"
    echo
    echo "  ./$(basename "${BASH_SOURCE[0]}") logs"
    echo
    read -p "Does everything look good? Type 'yes' to remove old images: " confirm

    if [[ "$confirm" == "yes" ]]; then
      echo "Removing unused Docker images..."
      docker image prune -f
      echo "Old images cleaned up."
    else
      echo "Skipping cleanup — old images retained."
    fi
    ;;

  logs)
    echo "Following logs (Ctrl+C to exit)..."
    $COMPOSE_CMD logs -f "$SERVICE_NAME"
    ;;

  status)
    $COMPOSE_CMD ps
    ;;

  remove)
    echo "⚠️  This will DELETE containers, volumes, networks, and images."
    read -p "Type 'yes' to continue: " confirm
    if [[ "$confirm" != "yes" ]]; then
      echo "Canceled."
      exit 0
    fi

    echo "Removing EVERYTHING created by docker compose..."
    $COMPOSE_CMD down -v --rmi local

    echo "Cleanup complete."
    ;;

  *)
    usage
    exit 1
    ;;
esac
