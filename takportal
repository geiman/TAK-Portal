#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
cd "$SCRIPT_DIR"

COMPOSE_CMD="docker compose"
SERVICE_NAME="tak-portal"

usage() {
  cat <<EOF
Usage: $0 {setup|config|start|stop|restart|update|logs|status|remove}

Commands:
  setup      Open .env in nano for editing
  config     Alias for 'setup'
  start      Build (if needed) and start the stack in the background
  stop       Stop the stack and keep data volume
  restart    Restart containers (rebuild if needed)
  update     git pull, rebuild, restart containers, and prune old images
  logs       Follow logs from the container
  status     Show container status
  remove     Completely remove containers, volumes, network, and images
EOF
}

edit_env() {
  if [[ -f .env ]]; then
    echo "Opening .env in nano..."
    nano .env
  else
    echo "ERROR: .env not found in $(pwd)"
    echo "There should be a default .env included with the download."
    echo "Create it manually or re-download the project, then rerun this command."
    exit 1
  fi
}

CMD="${1:-}"

case "$CMD" in
  setup|config)
    echo "Opening .env for configuration..."
    edit_env

    echo
    echo "Setup complete. You can now run:"
    echo "  ./$(basename "${BASH_SOURCE[0]}") start"
    ;;

  start)
    if [[ ! -f .env ]]; then
      echo "ERROR: .env missing. Run:"
      echo "  ./$(basename "${BASH_SOURCE[0]}") setup"
      exit 1
    fi
    echo "Starting TAK Portal..."
    $COMPOSE_CMD up -d --build
    ;;

  stop)
    echo "Stopping containers (keeping data volume)..."
    $COMPOSE_CMD down
    ;;

  restart)
    echo "Restarting..."
    $COMPOSE_CMD down
    $COMPOSE_CMD up -d --build
    ;;

  update)
    echo "Updating repository and containers..."

    if [[ -d .git ]]; then
      echo "Fetching latest code..."
      git pull --rebase --autostash || git pull
    else
      echo "No .git directory found; skipping git pull."
    fi

    echo "Rebuilding and recreating containers..."
    $COMPOSE_CMD up -d --build

    echo
    sleep 5

    echo "Removing unused Docker images..."
    docker image prune -f
    echo "Old images cleaned up."
    ;;

  logs)
    echo "Following logs (Ctrl+C to exit)..."
    $COMPOSE_CMD logs -f "$SERVICE_NAME"
    ;;

  status)
    $COMPOSE_CMD ps
    ;;

  remove)
    echo "⚠️  This will DELETE containers, volumes, networks, and images."
    read -p "Type 'yes' to continue: " confirm
    if [[ "$confirm" != "yes" ]]; then
      echo "Canceled."
      exit 0
    fi

    echo "Removing EVERYTHING created by docker compose..."
    $COMPOSE_CMD down -v --rmi local

    echo "Cleanup complete."
    ;;

  *)
    usage
    exit 1
    ;;
esac
