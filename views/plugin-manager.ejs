<%- include("partials/header") %>
<%- include("partials/sidebar") %>

<main class="main">
  <h1>Plugin Manager</h1>
  <p class="muted" style="margin-top: 4px;">Link your TAK.gov account to discover plugins, and store downloaded plugins in TAK Portal for your users. Plugins are stored in <code>data/plugins</code>.</p>

  <!-- Link TAK.gov Account (OAuth 2.0 device flow – same as OpenTAKServer). When linked, only show badge. -->
  <div class="card">
    <h2>Link TAK.gov Account</h2>
    <div id="linkSetupBlock">
      <p>1) Click <strong>Get Link Code</strong> to receive a code from TAK.gov. 2) Open the TAK.gov link below and enter that code there, then sign in and authorize. 3) Return here and click <strong>Link Account</strong> to complete linking.</p>
      <div id="linkSection" class="row" style="flex-wrap: wrap; gap: 12px; align-items: flex-start;">
        <div id="linkCodeArea" style="display: none;">
          <label>Code to enter on TAK.gov (issued by TAK.gov)</label>
          <div class="row" style="align-items: center; gap: 8px; flex-wrap: wrap;">
            <code id="linkCodeDisplay" style="font-size: 1.2rem; padding: 8px 12px; background: var(--card-bg, #1e1e1e); border-radius: 6px;"></code>
            <span id="linkCodeExpiry" class="muted"></span>
          </div>
          <p style="margin-top: 8px;">
            <a id="verificationUriLink" href="https://tak.gov/register-device" target="_blank" rel="noopener">Open TAK.gov to enter this code</a>
          </p>
        </div>
        <div class="row" style="gap: 8px; align-items: flex-end;">
          <button class="btn" type="button" id="getLinkCodeBtn">Get Link Code</button>
          <button class="btn success" type="button" id="linkAccountBtn">Link Account</button>
        </div>
      </div>
    </div>
    <div id="linkStatus" class="msg"></div>
    <div id="linkedBadge" class="row" style="display: none; margin-top: 8px; align-items: center; gap: 10px;">
      <span class="status-pill status-connected">TAK.gov account linked</span>
      <button class="btn" type="button" id="unlinkBtnBadge">Unlink account</button>
    </div>
  </div>

  <!-- Downloaded plugins: cards (above Plugin Browser) -->
  <div class="card">
    <h2 style="margin-top: 0;">Downloaded Plugins</h2>
    <p class="muted" style="margin-top: 4px;">Plugins stored in <code>data/plugins</code>. You can download or delete each one.</p>
    <div id="pluginsMsg" class="msg"></div>
    <div id="pluginCards" class="plugin-cards" style="display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 16px; margin-top: 16px;">
      <!-- Filled by JS -->
    </div>
    <div id="pluginsEmpty" style="display: none; margin-top: 16px; color: var(--muted, #888);">
      No plugins yet. Add plugins from the Plugin Browser below or use Manual Plugin Upload at the bottom.
    </div>
  </div>

  <!-- TAK.gov Plugin Browser (visible when linked) -->
  <div class="card" id="marketplaceCard">
    <h2 style="margin-top: 0;">TAK Plugin Browser</h2>
    <div id="marketplaceBrowse" style="display: none;">
      <p class="muted" style="margin-top: 4px;">Choose ATAK version and click <strong>Browse</strong> to load ATAK-CIV plugins available to your account.</p>
      <div class="row" style="flex-wrap: wrap; gap: 12px; align-items: flex-end; margin-top: 12px;">
        <label>ATAK version
          <select id="takgovVersion" style="min-width: 120px;">
            <option value="5.6.0" selected>5.6.0</option>
            <option value="5.5.0">5.5.0</option>
            <option value="5.4.0">5.4.0</option>
            <option value="5.3.0">5.3.0</option>
            <option value="5.2.0">5.2.0</option>
            <option value="5.1.0">5.1.0</option>
            <option value="5.0.0">5.0.0</option>
          </select>
        </label>
        <button class="btn" type="button" id="browseTakgovBtn">Browse plugins</button>
      </div>
      <div id="marketplaceMsg" class="msg" style="margin-top: 8px;"></div>
      <div id="marketplaceGrid" class="plugin-cards marketplace-grid" style="display: none; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 16px; margin-top: 16px;">
        <!-- TAK.gov plugin cards -->
      </div>
      <div id="marketplaceEmpty" style="display: none; margin-top: 16px; color: var(--muted, #888);">
        No plugins returned. Try a different ATAK version.
      </div>
    </div>
  </div>

  <!-- Manual Plugin Upload (collapsed) -->
  <details class="card settings-section" style="margin-top: 24px;">
    <summary class="settings-summary" style="cursor: pointer; padding: 4px 0;">Manual Plugin Upload</summary>
    <div class="settings-body" style="margin-top: 12px;">
      <p class="muted" style="margin-top: 4px;">Upload an APK from your computer or download from a URL (e.g. after linking TAK.gov you can use plugin URLs from TAK.gov).</p>
      <div class="row" style="flex-wrap: wrap; gap: 16px;">
        <div style="flex: 1; min-width: 280px;">
          <label>Upload plugin file (APK)
            <input type="file" id="pluginFile" accept=".apk,.zip,.jar" />
          </label>
          <label style="margin-top: 8px;">Display name (optional)
            <input type="text" id="uploadName" placeholder="e.g. Mission Package Tools" style="width: 100%;" />
          </label>
          <button class="btn" type="button" id="uploadPluginBtn" style="margin-top: 8px;">Upload Plugin</button>
        </div>
        <div style="flex: 1; min-width: 280px;">
          <label>Or download from URL
            <input type="url" id="pluginUrl" placeholder="https://..." style="width: 100%;" />
          </label>
          <label style="margin-top: 8px;">Display name (optional)
            <input type="text" id="downloadName" placeholder="e.g. Mission Package Tools" style="width: 100%;" />
          </label>
          <button class="btn" type="button" id="downloadPluginBtn" style="margin-top: 8px;">Download Plugin</button>
        </div>
      </div>
      <div id="addPluginMsg" class="msg"></div>
    </div>
  </details>
</main>

<style>
  .plugin-cards .plugin-card {
    background: var(--card-bg, #1a1a1a);
    border: 1px solid var(--border, #333);
    border-radius: 8px;
    padding: 14px;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }
  .plugin-cards .plugin-card .plugin-card-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 8px;
  }
  .plugin-cards .plugin-card .plugin-name { font-weight: 600; flex: 1; min-width: 0; }
  .plugin-cards .plugin-card .plugin-version-pill {
    flex-shrink: 0;
    font-size: 0.75rem;
    padding: 2px 8px;
    border-radius: 999px;
    background: var(--border, #333);
    color: var(--muted, #888);
  }
  .plugin-cards .plugin-card .plugin-desc { font-size: 0.85rem; color: var(--muted, #888); max-height: 2.6em; overflow: hidden; text-overflow: ellipsis; }
  .plugin-cards .plugin-card .plugin-meta { font-size: 0.9rem; color: var(--muted, #888); }
  .plugin-cards .plugin-card .plugin-actions { display: flex; gap: 8px; flex-wrap: wrap; margin-top: 4px; align-items: center; }
  .btn.favorite { background: #e6c200; color: #000; border-color: #e6c200; }
  .btn.favorite:hover { filter: brightness(1.08); }
  .btn.favorite.is-favorite { background: #f0d000; color: #000; }
  .marketplace-grid .plugin-card .plugin-desc { font-size: 0.85rem; color: var(--muted, #888); max-height: 2.6em; overflow: hidden; text-overflow: ellipsis; }
</style>

<script>
(function () {
  const getLinkCodeBtn = document.getElementById("getLinkCodeBtn");
  const linkAccountBtn = document.getElementById("linkAccountBtn");
  const unlinkBtn = document.getElementById("unlinkBtnBadge");
  const linkCodeDisplay = document.getElementById("linkCodeDisplay");
  const linkCodeExpiry = document.getElementById("linkCodeExpiry");
  const linkCodeArea = document.getElementById("linkCodeArea");
  const verificationUriLink = document.getElementById("verificationUriLink");
  const linkStatus = document.getElementById("linkStatus");
  const linkedBadge = document.getElementById("linkedBadge");
  const pluginFile = document.getElementById("pluginFile");
  const uploadName = document.getElementById("uploadName");
  const uploadPluginBtn = document.getElementById("uploadPluginBtn");
  const pluginUrl = document.getElementById("pluginUrl");
  const downloadName = document.getElementById("downloadName");
  const downloadPluginBtn = document.getElementById("downloadPluginBtn");
  const addPluginMsg = document.getElementById("addPluginMsg");
  const pluginCards = document.getElementById("pluginCards");
  const pluginsEmpty = document.getElementById("pluginsEmpty");
  const pluginsMsg = document.getElementById("pluginsMsg");
  const marketplaceIntro = document.getElementById("marketplaceIntro");
  const marketplaceBrowse = document.getElementById("marketplaceBrowse");
  const takgovVersion = document.getElementById("takgovVersion");
  const browseTakgovBtn = document.getElementById("browseTakgovBtn");
  const marketplaceMsg = document.getElementById("marketplaceMsg");
  const marketplaceGrid = document.getElementById("marketplaceGrid");
  const marketplaceEmpty = document.getElementById("marketplaceEmpty");

  let takgovPluginsCache = [];
  let downloadedPluginsCache = [];
  let updateStatusCache = {};

  function esc(s) {
    if (s == null || s === undefined) return "";
    const div = document.createElement("div");
    div.textContent = s;
    return div.innerHTML;
  }

  function setLinkStatus(text, ok) {
    linkStatus.textContent = text || "";
    linkStatus.style.color = ok === false ? "var(--error, #c00)" : "";
  }

  function setAddPluginMsg(text, ok) {
    addPluginMsg.textContent = text || "";
    addPluginMsg.style.color = ok === false ? "var(--error, #c00)" : "";
  }

  function setPluginsMsg(text, ok) {
    pluginsMsg.textContent = text || "";
    pluginsMsg.style.color = ok === false ? "var(--error, #c00)" : "";
  }

  function formatSize(bytes) {
    if (bytes == null) return "—";
    if (bytes < 1024) return bytes + " B";
    if (bytes < 1024 * 1024) return (bytes / 1024).toFixed(1) + " KB";
    return (bytes / (1024 * 1024)).toFixed(2) + " MB";
  }

  function formatDate(iso) {
    if (!iso) return "—";
    try {
      const d = new Date(iso);
      return isNaN(d.getTime()) ? iso : d.toLocaleDateString() + " " + d.toLocaleTimeString([], { hour: "2-digit", minute: "2-digit" });
    } catch (_) { return iso; }
  }

  function renderPluginCards(plugins) {
    const list = Array.isArray(plugins) ? plugins : [];
    if (list.length === 0) {
      pluginCards.innerHTML = "";
      pluginCards.style.display = "none";
      pluginsEmpty.style.display = "block";
      return;
    }
    pluginsEmpty.style.display = "none";
    pluginCards.style.display = "grid";
    pluginCards.innerHTML = list.map(function (p) {
      const name = esc(p.name || p.filename || p.id);
      const desc = (p.description || "").slice(0, 120);
      const meta = [];
      if (p.version) meta.push("v" + esc(p.version));
      if (p.package_name) meta.push(esc(p.package_name));
      if (p.atakVersion || p.atak_version) meta.push("ATAK " + esc(p.atakVersion || p.atak_version));
      meta.push(formatSize(p.sizeBytes != null ? p.sizeBytes : p.size));
      meta.push(formatDate(p.downloadedAt));
      if (p.source) meta.push("Source: " + esc(p.source));
      const metaStr = meta.join(" · ");
      const exists = p.exists !== false;
      const downloadUrl = "/api/plugins/" + esc(p.id) + "/download";
      const isFavorite = p.favorite === true;
      const updateAvailable = p.source === "tak.gov" && p.package_name && updateStatusCache[p.id] === true;
      const versionPill = p.version ? "<span class=\"plugin-version-pill\">v" + esc(p.version) + "</span>" : "";
      return "<div class=\"plugin-card\" data-id=\"" + esc(p.id) + "\">" +
        "<div class=\"plugin-card-header\">" +
        "<div class=\"plugin-name\">" + name + "</div>" +
        (versionPill || "") +
        "</div>" +
        (desc ? "<div class=\"plugin-desc\">" + esc(desc) + (desc.length >= 120 ? "…" : "") + "</div>" : "") +
        "<div class=\"plugin-meta\">" + metaStr + "</div>" +
        (exists ? "" : "<div class=\"plugin-meta\" style=\"color: var(--error, #c00);\">File missing on disk</div>") +
        "<div class=\"plugin-actions\">" +
        "<button class=\"btn favorite " + (isFavorite ? "is-favorite" : "") + "\" type=\"button\" data-favorite=\"" + esc(p.id) + "\" title=\"" + (isFavorite ? "Unfavorite" : "Favorite") + "\">" + (isFavorite ? "★ Unfavorite" : "☆ Favorite") + "</button>" +
        (exists ? "<a href=\"" + downloadUrl + "\" class=\"btn\" download>Download</a>" : "") +
        (updateAvailable ? "<button class=\"btn\" type=\"button\" data-update=\"" + esc(p.id) + "\">Check for Updates</button>" : "") +
        "<button class=\"btn danger\" type=\"button\" data-delete=\"" + esc(p.id) + "\">Delete</button>" +
        "</div></div>";
    }).join("");
    pluginCards.querySelectorAll("[data-delete]").forEach(function (btn) {
      btn.addEventListener("click", function () {
        const id = btn.getAttribute("data-delete");
        if (!id) return;
        if (!confirm("Remove this plugin and delete its file from the server? This cannot be undone.")) return;
        deletePlugin(id);
      });
    });
    pluginCards.querySelectorAll("[data-favorite]").forEach(function (btn) {
      btn.addEventListener("click", function () {
        const id = btn.getAttribute("data-favorite");
        if (!id) return;
        const isFavorite = btn.classList.contains("is-favorite");
        toggleFavorite(id, !isFavorite, btn);
      });
    });
    pluginCards.querySelectorAll("[data-update]").forEach(function (btn) {
      btn.addEventListener("click", function () {
        const id = btn.getAttribute("data-update");
        if (!id) return;
        updatePluginFromTakgov(id, btn);
      });
    });
  }

  function toggleFavorite(id, favorite, btnEl) {
    fetch("/api/plugins/" + encodeURIComponent(id), {
      method: "PATCH",
      headers: { "Content-Type": "application/json" },
      body: JSON.stringify({ favorite: favorite }),
    })
      .then(function (res) { return res.json().then(function (data) { return { res, data }; }); })
      .then(function (_ref) {
        const res = _ref.res;
        const data = _ref.data;
        if (!res.ok) {
          setPluginsMsg(data.error || "Failed to update favorite", false);
          return;
        }
        if (btnEl) {
          btnEl.classList.toggle("is-favorite", favorite);
          btnEl.textContent = favorite ? "★ Unfavorite" : "☆ Favorite";
          btnEl.title = favorite ? "Unfavorite" : "Favorite";
        }
        loadState();
      })
      .catch(function (err) {
        setPluginsMsg(err.message || "Failed to update favorite", false);
      });
  }

  function updatePluginFromTakgov(id, btnEl) {
    if (btnEl) { btnEl.disabled = true; btnEl.textContent = "Checking…"; }
    setPluginsMsg("", true);
    fetch("/api/plugins/" + encodeURIComponent(id) + "/update-from-takgov", { method: "POST" })
      .then(function (res) {
        return res.text().then(function (text) {
          var data = {};
          try { data = text ? JSON.parse(text) : {}; } catch (_) {}
          return { res, data, text };
        });
      })
      .then(function (_ref) {
        const res = _ref.res;
        const data = _ref.data;
        if (!res.ok) {
          setPluginsMsg((data && data.error) || "Update failed", false);
          if (btnEl) { btnEl.disabled = false; btnEl.textContent = "Check for Updates"; }
          return;
        }
        setPluginsMsg("Plugin updated.", true);
        loadState();
        if (btnEl) { btnEl.disabled = false; btnEl.textContent = "Check for Updates"; }
      })
      .catch(function (err) {
        setPluginsMsg(err.message || "Update failed", false);
        if (btnEl) { btnEl.disabled = false; btnEl.textContent = "Check for Updates"; }
      });
  }

  async function loadState() {
    try {
      const res = await fetch("/api/plugins/state");
      const data = await res.json();
      if (!res.ok) throw new Error(data.error || "Failed to load state");
      const link = data.takGovLink || {};
      const plugins = data.plugins || [];
      if (link.linked) {
        linkedBadge.style.display = "flex";
        const linkSetup = document.getElementById("linkSetupBlock");
        if (linkSetup) linkSetup.style.display = "none";
        linkCodeArea.style.display = "none";
        setLinkStatus("", true);
        if (marketplaceIntro) marketplaceIntro.style.display = "none";
        if (marketplaceBrowse) marketplaceBrowse.style.display = "block";
      } else {
        const linkSetup = document.getElementById("linkSetupBlock");
        if (linkSetup) linkSetup.style.display = "";
        if (marketplaceIntro) marketplaceIntro.style.display = "block";
        if (marketplaceBrowse) marketplaceBrowse.style.display = "none";
        linkedBadge.style.display = "none";
        if (link.linkCode && link.linkCodeExpiry && Date.now() < link.linkCodeExpiry) {
          linkCodeArea.style.display = "block";
          linkCodeDisplay.textContent = link.linkCode;
          if (link.verificationUri && verificationUriLink) {
            verificationUriLink.href = link.verificationUri;
            verificationUriLink.textContent = "Open TAK.gov to enter this code";
          }
          const sec = Math.max(0, Math.floor((link.linkCodeExpiry - Date.now()) / 1000));
          linkCodeExpiry.textContent = "Expires in " + sec + "s";
        } else {
          linkCodeArea.style.display = "none";
        }
      }
      downloadedPluginsCache = plugins;
      updateStatusCache = {};
      if (link.linked && plugins.some(function (p) { return p.source === "tak.gov" && p.package_name; })) {
        try {
          const statusRes = await fetch("/api/plugins/update-status");
          const statusData = await statusRes.json();
          if (statusData.updateStatus) updateStatusCache = statusData.updateStatus;
        } catch (_) {}
      }
      renderPluginCards(plugins);
      if (takgovPluginsCache.length > 0) renderTakgovMarketplace(takgovPluginsCache);
    } catch (err) {
      setPluginsMsg(err.message || "Failed to load plugins", false);
    }
  }

  function setMarketplaceMsg(text, ok) {
    if (!marketplaceMsg) return;
    marketplaceMsg.textContent = text || "";
    marketplaceMsg.style.color = ok === false ? "var(--error, #c00)" : "";
  }

  function renderTakgovMarketplace(plugins) {
    if (!marketplaceGrid || !marketplaceEmpty) return;
    const list = Array.isArray(plugins) ? plugins : [];
    if (list.length === 0) {
      marketplaceGrid.innerHTML = "";
      marketplaceGrid.style.display = "none";
      marketplaceEmpty.style.display = "block";
      return;
    }
    marketplaceEmpty.style.display = "none";
    marketplaceGrid.style.display = "grid";
    const downloaded = downloadedPluginsCache || [];
    marketplaceGrid.innerHTML = list.map(function (p, idx) {
      const name = esc(p.display_name || p.package_name || p.name || "Plugin");
      const desc = (p.description || "").slice(0, 120);
      const meta = [];
      if (p.version) meta.push("v" + esc(p.version));
      if (p.package_name) meta.push(esc(p.package_name));
      if (p.atak_version) meta.push("ATAK " + esc(p.atak_version));
      const metaStr = meta.join(" · ");
      const alreadyInstalled = p.package_name && downloaded.some(function (d) { return d.package_name === p.package_name; });
      const btnLabel = alreadyInstalled ? "Update" : "Add to server";
      const btnClass = alreadyInstalled ? "btn" : "btn success";
      const versionPill = p.version ? "<span class=\"plugin-version-pill\">v" + esc(p.version) + "</span>" : "";
      return "<div class=\"plugin-card\" data-takgov-index=\"" + idx + "\">" +
        "<div class=\"plugin-card-header\">" +
        "<div class=\"plugin-name\">" + name + "</div>" +
        (versionPill || "") +
        "</div>" +
        (desc ? "<div class=\"plugin-desc\">" + esc(desc) + (desc.length >= 120 ? "…" : "") + "</div>" : "") +
        "<div class=\"plugin-meta\">" + metaStr + "</div>" +
        "<div class=\"plugin-actions\">" +
        "<button class=\"" + btnClass + "\" type=\"button\" data-takgov-download data-takgov-index=\"" + idx + "\">" + btnLabel + "</button>" +
        "</div></div>";
    }).join("");
    marketplaceGrid.querySelectorAll("[data-takgov-download]").forEach(function (btn) {
      btn.addEventListener("click", function () {
        const idx = parseInt(btn.getAttribute("data-takgov-index"), 10);
        const pluginItem = takgovPluginsCache[idx];
        if (!pluginItem || !pluginItem.apk_url) return;
        btn.disabled = true;
        btn.textContent = "Adding…";
        setMarketplaceMsg("", true);
        fetch("/api/plugins/takgov/download", {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({ plugin: pluginItem }),
        })
          .then(function (res) {
            return res.text().then(function (text) {
              var data = {};
              try { data = text ? JSON.parse(text) : {}; } catch (_) {}
              return { res, data, text };
            });
          })
          .then(function (_ref) {
            const res = _ref.res;
            const data = _ref.data;
            const text = _ref.text;
            const errMsg = (data && data.error) || (typeof text === "string" && text.slice(0, 200)) || "Download failed";
            if (!res.ok) {
              setMarketplaceMsg(errMsg, false);
              btn.textContent = btn.textContent === "Update" ? "Update" : "Add to server";
              btn.disabled = false;
              return;
            }
            btn.textContent = "Update";
            setMarketplaceMsg("Plugin added/updated on server.", true);
            loadState();
          })
          .catch(function (err) {
            btn.textContent = btn.classList.contains("success") ? "Add to server" : "Update";
            btn.disabled = false;
            setMarketplaceMsg(err.message || "Failed to add plugin", false);
          });
      });
    });
  }

  browseTakgovBtn.addEventListener("click", async function () {
    const version = (takgovVersion && takgovVersion.value || "5.5.0").trim();
    setMarketplaceMsg("Loading…", true);
    try {
      const res = await fetch("/api/plugins/takgov/plugins?product=ATAK-CIV&product_version=" + encodeURIComponent(version));
      const data = await res.json();
      if (!res.ok) throw new Error(data.error || "Failed to load plugins");
      takgovPluginsCache = data.plugins || [];
      setMarketplaceMsg(takgovPluginsCache.length ? "" : "No plugins found for this product/version.", true);
      renderTakgovMarketplace(takgovPluginsCache);
    } catch (err) {
      setMarketplaceMsg(err.message || "Failed to load", false);
      takgovPluginsCache = [];
      renderTakgovMarketplace([]);
      loadState();
    }
  });

  getLinkCodeBtn.addEventListener("click", async function () {
    setLinkStatus("Requesting code from TAK.gov…", true);
    try {
      const res = await fetch("/api/plugins/link-code", { method: "POST", headers: { "Content-Type": "application/json" } });
      const data = await res.json();
      if (!res.ok) throw new Error(data.error || "Failed to get code");
      linkCodeArea.style.display = "block";
      linkCodeDisplay.textContent = data.linkCode || "";
      if (data.verificationUri && verificationUriLink) {
        verificationUriLink.href = data.verificationUri;
        verificationUriLink.textContent = "Open TAK.gov to enter this code";
      }
      setLinkStatus(data.message || "Enter the code above on TAK.gov, then click Link Account.", true);
      if (data.linkCodeExpiry) {
        const interval = setInterval(function () {
          const sec = Math.max(0, Math.floor((data.linkCodeExpiry - Date.now()) / 1000));
          linkCodeExpiry.textContent = "Expires in " + sec + "s";
          if (sec <= 0) clearInterval(interval);
        }, 1000);
      }
    } catch (err) {
      setLinkStatus(err.message || "Error", false);
    }
  });

  linkAccountBtn.addEventListener("click", async function () {
    setLinkStatus("Linking…", true);
    try {
      const res = await fetch("/api/plugins/link", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({}),
      });
      const data = await res.json();
      if (!res.ok) throw new Error(data.error || "Link failed");
      setLinkStatus(data.message || "Linked.", true);
      loadState();
    } catch (err) {
      setLinkStatus(err.message || "Error", false);
    }
  });

  unlinkBtn.addEventListener("click", async function () {
    if (!confirm("Unlink your TAK.gov account? Downloaded plugins will remain stored.")) return;
    try {
      const res = await fetch("/api/plugins/unlink", { method: "POST", headers: { "Content-Type": "application/json" } });
      const data = await res.json();
      if (!res.ok) throw new Error(data.error || "Unlink failed");
      setLinkStatus("Account unlinked.", true);
      loadState();
    } catch (err) {
      setLinkStatus(err.message || "Error", false);
    }
  });

  uploadPluginBtn.addEventListener("click", function () {
    const file = pluginFile && pluginFile.files && pluginFile.files[0];
    if (!file) {
      setAddPluginMsg("Select a plugin file first.", false);
      return;
    }
    setAddPluginMsg("Uploading…", true);
    const form = new FormData();
    form.append("plugin", file);
    const name = (uploadName && uploadName.value || "").trim();
    if (name) form.append("name", name);
    fetch("/api/plugins/upload", { method: "POST", body: form })
