        pluginFile.value = "";
        if (uploadName) uploadName.value = "";
        loadState();
      })
      .catch(function (err) {
        setAddPluginMsg(err.message || "Upload failed", false);
      });
  });

  downloadPluginBtn.addEventListener("click", function () {
    const url = (pluginUrl && pluginUrl.value || "").trim();
    if (!url) {
      setAddPluginMsg("Enter a plugin URL.", false);
      return;
    }
    setAddPluginMsg("Downloading…", true);
    const body = { url: url };
    const name = (downloadName && downloadName.value || "").trim();
    if (name) body.name = name;
    fetch("/api/plugins/download", {
      method: "POST",
      headers: { "Content-Type": "application/json" },
      body: JSON.stringify(body),
    })
      .then(function (res) { return res.json().then(function (data) { return { res, data }; }); })
      .then(function (_ref) {
        const res = _ref.res;
        const data = _ref.data;
        if (!res.ok) throw new Error(data.error || "Download failed");
        setAddPluginMsg("Plugin downloaded: " + (data.plugin && data.plugin.name) + ".", true);
        if (pluginUrl) pluginUrl.value = "";
        if (downloadName) downloadName.value = "";
        loadState();
      })
      .catch(function (err) {
        setAddPluginMsg(err.message || "Download failed", false);
      });
  });

  async function deletePlugin(id) {
    setPluginsMsg("Deleting…", true);
    try {
      const res = await fetch("/api/plugins/" + encodeURIComponent(id), { method: "DELETE" });
      const data = await res.json();
      if (!res.ok) throw new Error(data.error || "Delete failed");
      setPluginsMsg("Plugin removed.", true);
      loadState();
    } catch (err) {
      setPluginsMsg(err.message || "Delete failed", false);
    }
  }

  // Initial state from server-rendered data (optional; we refetch for consistency)
  const initialPlugins = typeof plugins !== "undefined" && Array.isArray(plugins) ? plugins : [];
  const initialLink = typeof takGovLink !== "undefined" && takGovLink ? takGovLink : { linked: false };
  if (initialLink.linked) {
    linkedBadge.style.display = "flex";
    if (marketplaceIntro) marketplaceIntro.style.display = "none";
    if (marketplaceBrowse) marketplaceBrowse.style.display = "block";
  } else {
    if (marketplaceIntro) marketplaceIntro.style.display = "block";
    if (marketplaceBrowse) marketplaceBrowse.style.display = "none";
  }
  renderPluginCards(initialPlugins.length ? initialPlugins : []);
  loadState();
