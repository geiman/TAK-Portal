<%- include("partials/header") %>
<%- include("partials/sidebar") %>

<main class="main">
  <h1>Integrations</h1>

  <div class="card">
    <h2>Create Integration</h2>

    <form id="createForm" autocomplete="off">
      <div class="row">
        <label>Integration Type
          <select id="integrationType" name="type" style="min-width: 160px;">
            <option value="global">Global</option>
            <option value="state">State-Specific</option>
            <option value="county">County-Specific</option>
            <option value="agency">Agency-Specific</option>
          </select>
        </label>

        <label id="agencyWrap" style="display: none;">Select Agency
          <select id="agencySelect" name="agencySuffix" style="min-width: 140px;">
            <option value="">Select Agency</option>
          </select>
        </label>

        <label id="countyWrap" style="display: none;">Select County
          <select id="countySelect" name="county" style="min-width: 140px;">
            <option value="">Select County</option>
          </select>
        </label>

        <label id="stateWrap" style="display: none;">Select State
          <select id="stateSelect" name="state" style="min-width: 120px;">
            <option value="">Select State</option>
          </select>
        </label>

        <label style="flex: 1; min-width: 160px;">Title
          <input type="text" id="integrationTitle" name="title" placeholder="e.g. Weather API" style="width: 100%;" required />
          <small id="integrationTitleHint" style="display: block; color: var(--text-2); font-size: 0.85em; margin-top: 4px;"></small>
        </label>

        <label style="min-width: 200px;">Group
          <select name="groupId" id="groupSelect" style="min-width: 160px;" required>
            <option value="">Select a group</option>
          </select>
        </label>
        
        <label style="min-width: 250px;">Make Streaming Data Feed?
          <select name="makeDataFeed" id="makeDataFeed" style="min-width: 100px;">
            <option value="yes">Yes</option>
            <option value="no">No</option>
          </select>
        </label>

        <label>&nbsp;
          <button class="btn" type="submit">Create Integration</button>
        </label>
      </div>
      <div id="createMsg" class="msg"></div>
    </form>
  </div>

  <div class="card">
    <h2 style="margin-top: 0;">Existing Integrations</h2>

    <input
      id="integrationFilter"
      placeholder="Search integrations..."
      style="margin: 10px 0; width: 100%; box-sizing: border-box;"
    />

    <div id="tableMsg" class="msg"></div>

    <table class="table">
      <thead>
        <tr>
          <th>Username</th>
          <th>Group</th>
          <th>Data Feed</th>
          <th>Port</th>
          <th>Status</th>
          <th>Actions</th>
        </tr>
      </thead>
      <tbody id="tbody"></tbody>
    </table>
  </div>
</main>

<!-- Edit Integration (Group assignment only) -->
<div class="modalOverlay" id="editIntegrationOverlay" style="display: none;">
  <div class="modal" role="dialog" aria-modal="true" aria-labelledby="editIntegrationTitle">
    <div class="modalHeader">
      <h2 id="editIntegrationTitle" style="margin: 0;">Edit Integration</h2>
      <button class="btn" id="editIntegrationCloseBtn" type="button">Close</button>
    </div>
    <div class="modalBody">
      <div class="card" style="margin: 0;">
        <h2 style="margin-top: 0;">Edit Group Assignment</h2>
        <div class="row">
          <label style="flex: 1; min-width: 0;">Integration (read-only)
            <input type="text" id="editIntegrationUsername" readonly style="width: 100%;" />
          </label>
        </div>
        <div class="row" style="margin-top: 12px;">
          <label style="min-width: 200px;">Group
            <select id="editGroupSelect" style="min-width: 200px;"></select>
          </label>
        </div>
        <div class="row" style="margin-top: 16px; align-items: center;">
          <button class="btn success" id="editIntegrationSaveBtn" type="button">Save Changes</button>
          <span id="editIntegrationMsg" class="msg"></span>
        </div>
      </div>
    </div>
</div>
</div>

<!-- Data Feed Modal -->
<div class="modalOverlay" id="dataFeedModalOverlay" style="display: none;">
  <div class="modal" role="dialog" aria-modal="true" aria-labelledby="dataFeedTitle">
    <div class="modalHeader">
      <h2 id="dataFeedTitle" style="margin: 0;">Create Streaming Data Feed</h2>
      <button class="btn" id="dataFeedCloseBtn" type="button">Close</button>
    </div>
    <div class="modalBody">
      <form id="dataFeedForm" autocomplete="off" style="margin: 0;">
        <div class="card" style="margin: 0;">
          <h2 style="margin-top: 0; font-size: 1.1em; color: var(--text-muted);">Enter Data Feed Details</h2>
          
          <div class="row">
            <label style="display: block; margin-bottom: 8px; font-weight: bold;">Data Feed Name (TAK)
              <input type="text" name="dataFeedName" disabled style="width: 100%; color: var(--text-2);" placeholder="(letters/numbers from title, max 30)" />
              <small style="display: block; color: var(--text-2); font-size: 0.85em; margin-top: 4px;">Auto-filled from the integration title only (no nodered-global- prefix). Max 30 characters for TAK Server.</small>
            </label>
          </div>
          <div class="row" style="margin-top: 12px;">
            <label style="flex: 1; min-width: 200px;">Tags
              <textarea name="tags" rows="2" style="width: 100%; resize: vertical;" placeholder="Provide 0 or more tags separated by newlines. Example:&#10;red&#10;green"></textarea>
            </label>
          </div>
          <div class="row" style="margin-top: 12px;">
            <label style="flex: 1; min-width: 200px;">*Protocol
              <select name="protocol" style="width: 100%;" required>
                <option value="tls" selected>Secure Streaming TCP (TLS) CoT or Protobuf</option>
                <option value="tcp">Streaming TCP CoT or Protobuf</option>
                <option value="stcp">Streaming TCP (Legacy)</option>
              </select>
            </label>
            <label style="flex: 1; min-width: 140px;">*Authentication Type
              <select name="authType" style="width: 100%;" required>
                <option value="X_509" selected>X.509</option>
                <option value="ANONYMOUS">Anonymous</option>
                <option value="BEARER">Bearer</option>
              </select>
            </label>
          </div>
          <div class="row" style="margin-top: 12px;">
             <label style="flex: 1; min-width: 200px;">*Port
              <input type="number" name="port" required style="width: 100%;" placeholder="e.g. 8089" min="1" max="65535" />
              <small style="display: block; color: var(--text-2); font-size: 0.85em; margin-top: 4px;">Note: Ensure this port is opened in your firewall prior to establishing a data connection.</small>
            </label>
            <label style="flex: 1; min-width: 200px;">Core Messaging Version
              <select name="coreVersion" style="width: 100%;">
                <option value="2" selected>2 (high performance)</option>
                <option value="1">1</option>
              </select>
              <div style="font-size: 0.85em; margin-top: 6px; display: flex; gap: 10px; align-items: center;">
                <span>TLS Versions:</span>
                <label style="font-weight: normal; margin: 0;"><input type="checkbox" name="tlsv1" /> TLSv1</label>
                <label style="font-weight: normal; margin: 0;"><input type="checkbox" name="tlsv1_1" /> TLSv1.1</label>
                <label style="font-weight: normal; margin: 0;"><input type="checkbox" name="tlsv1_2" checked /> TLSv1.2</label>
                <label style="font-weight: normal; margin: 0;"><input type="checkbox" name="tlsv1_3" checked /> TLSv1.3</label>
              </div>
            </label>
          </div>
          <div class="row" style="margin-top: 12px;">
            <label style="flex: 1; min-width: 200px;">Multicast Group
              <input type="text" name="multicastGroup" style="width: 100%;" />
            </label>
            <label style="flex: 1; min-width: 140px;">Interface
              <input type="text" name="interface" style="width: 100%;" />
            </label>
          </div>
          
          <div class="row" style="margin-top: 12px;">
             <label style="flex: 1; min-width: 200px;">Sync Cache Retention
              <input type="number" name="syncCacheRetention" value="3600" style="width: 100%;" />
            </label>
             <label style="flex: 1; min-width: 140px;">Archive
              <select name="archive" style="width: 100%;">
                <option value="true">True</option>
                <option value="false" selected>False</option>
              </select>
            </label>
          </div>

          <div class="row" style="margin-top: 12px;">
             <label style="flex: 1; min-width: 200px;">Anonymous Group
              <select name="anongroup" style="width: 100%;">
                <option value="true">True</option>
                <option value="false" selected>False</option>
              </select>
            </label>
             <label style="flex: 1; min-width: 140px;">Archive Only
              <select name="archiveOnly" style="width: 100%;">
                <option value="true">True</option>
                <option value="false" selected>False</option>
              </select>
            </label>
          </div>

          <div style="margin-top: 16px;">
            <label style="display: block; margin-bottom: 8px; font-weight: bold;">Filter Groups</label>
            <div id="filterGroupsCheckboxList" style="max-height: 150px; overflow-y: auto; border: 1px solid var(--border-color); border-radius: 4px; padding: 8px;">
              <!-- Checkboxes populate here -->
            </div>
          </div>
          
           <div class="row" style="margin-top: 12px;">
             <label style="flex: 1; min-width: 200px;">Sync
              <select name="sync" style="width: 100%;">
                <option value="true">True</option>
                <option value="false" selected>False</option>
              </select>
            </label>
             <label style="flex: 1; min-width: 140px;">Federated
              <select name="federated" style="width: 100%;">
                <option value="true" selected>True</option>
                <option value="false">False</option>
              </select>
            </label>
          </div>

          <div class="row" style="margin-top: 16px; align-items: center;">
            <button id="dataFeedSubmitBtn" class="btn success" type="submit">Submit & Create Integration</button>
          </div>
        </div>
      </form>
    </div>
  </div>
</div>

<script>
(function () {
  const createForm = document.getElementById("createForm");
  const integrationType = document.getElementById("integrationType");
  const agencyWrap = document.getElementById("agencyWrap");
  const countyWrap = document.getElementById("countyWrap");
  const stateWrap = document.getElementById("stateWrap");
  const agencySelect = document.getElementById("agencySelect");
  const countySelect = document.getElementById("countySelect");
  const stateSelect = document.getElementById("stateSelect");
  const groupSelect = document.getElementById("groupSelect");
  const createMsg = document.getElementById("createMsg");
  const tableMsg = document.getElementById("tableMsg");
  const tbody = document.getElementById("tbody");
  const integrationFilter = document.getElementById("integrationFilter");
  const integrationTitleInput = document.getElementById("integrationTitle");
  const integrationTitleHint = document.getElementById("integrationTitleHint");
  const makeDataFeedSelect = document.getElementById("makeDataFeed");

  var STREAMING_DATA_FEED_NAME_MAX_LEN = 30;

  function toTitleSlug(s) {
    return String(s || "")
      .trim()
      .toLowerCase()
      .replace(/\s+/g, "")
      .replace(/[^a-z0-9]/g, "");
  }

  function updateIntegrationTitleConstraints() {
    if (!integrationTitleInput || !integrationTitleHint) return;
    var feedOn = makeDataFeedSelect && makeDataFeedSelect.value === "yes";
    if (feedOn) {
      integrationTitleInput.setAttribute("maxlength", String(STREAMING_DATA_FEED_NAME_MAX_LEN));
      integrationTitleHint.textContent =
        "With a streaming data feed: title is limited to " +
        STREAMING_DATA_FEED_NAME_MAX_LEN +
        " characters. The feed name on TAK uses letters and numbers from the title only (no nodered- prefix).";
    } else {
      integrationTitleInput.removeAttribute("maxlength");
      integrationTitleHint.textContent =
        "No data feed: integration username may be longer; certificates are not limited by title length.";
    }
  }

  if (makeDataFeedSelect) {
    makeDataFeedSelect.addEventListener("change", updateIntegrationTitleConstraints);
  }

  const dataFeedModalOverlay = document.getElementById("dataFeedModalOverlay");
  const dataFeedCloseBtn = document.getElementById("dataFeedCloseBtn");
  const dataFeedForm = document.getElementById("dataFeedForm");
  const filterGroupsCheckboxList = document.getElementById("filterGroupsCheckboxList");

  let agenciesCache = [];
  let groupsCache = [];
  let usersCache = [];
  let connectedUsernamesSet = new Set();

  function stripTakPrefix(name) {
    if (name == null || name === undefined) return "";
    var n = String(name).trim();
    if (!n) return "";
    return n.toLowerCase().indexOf("tak_") === 0 ? n.slice(4) : n;
  }

  function setCreateMsg(text, ok) {
    createMsg.textContent = text || "";
    createMsg.style.color = ok ? "" : "var(--error, #c00)";
  }

  function setTableMsg(text, ok) {
    tableMsg.textContent = text || "";
    tableMsg.style.color = ok ? "" : "var(--error, #c00)";
  }

  async function downloadIntegrationCertBundle(pk, username) {
    const res = await fetch("/api/integrations/" + encodeURIComponent(pk) + "/certs/download");
    if (!res.ok) {
      let msg = "Download failed";
      try {
        var err = await res.json();
        msg = err && (err.error || err.message) ? (err.error || err.message) : msg;
      } catch (_) {}
      throw new Error(msg);
    }

    const blob = await res.blob();
    const url = URL.createObjectURL(blob);
    const a = document.createElement("a");
    a.href = url;
    a.download = (String(username || "integration").replace(/[^a-z0-9-]/gi, "").toLowerCase() || "integration") + "-certs.zip";
    document.body.appendChild(a);
    a.click();
    a.remove();
    URL.revokeObjectURL(url);
  }

  function esc(s) {
    if (s == null || s === undefined) return "";
    const div = document.createElement("div");
    div.textContent = s;
    return div.innerHTML;
  }

  integrationType.addEventListener("change", function () {
    const v = integrationType.value;
    agencyWrap.style.display = v === "agency" ? "flex" : "none";
    countyWrap.style.display = v === "county" ? "flex" : "none";
    stateWrap.style.display = v === "state" ? "flex" : "none";
  });

  async function loadAgencies() {
    const res = await fetch("/api/agencies");
    const out = await res.json();
    if (!res.ok) {
      agenciesCache = [];
      agencySelect.innerHTML = "<option value=\"\">No agencies loaded</option>";
      countySelect.innerHTML = "<option value=\"\">No counties loaded</option>";
      stateSelect.innerHTML = "<option value=\"\">No states loaded</option>";
      return;
    }
    agenciesCache = Array.isArray(out) ? out : [];

    const prefixList = agenciesCache
      .filter(function (a) { return String(a.groupPrefix || "").trim(); })
      .slice()
      .sort(function (a, b) { return String(a.name || "").localeCompare(String(b.name || "")); });
    agencySelect.innerHTML =
      "<option value=\"\">Select Agency</option>" +
      prefixList.map(function (a) {
        const prefix = String(a.groupPrefix || "").trim().toUpperCase();
        const label = (a.name || "") + " (" + prefix + ")";
        return "<option value=\"" + esc(prefix) + "\">" + esc(label) + "</option>";
      }).join("");

    const stateSet = new Set(
      agenciesCache.map(function (a) { return String(a.state || "").trim(); }).filter(Boolean)
    );
    const stateList = Array.from(stateSet).sort(function (a, b) { return a.localeCompare(b); });
    stateSelect.innerHTML =
      "<option value=\"\">Select State</option>" +
      stateList.map(function (s) { return "<option value=\"" + esc(s) + "\">" + esc(s) + "</option>"; }).join("");

    const countySet = new Set(
      agenciesCache.map(function (a) { return String(a.county || "").trim(); }).filter(Boolean)
    );
    const countyList = Array.from(countySet).sort(function (a, b) { return a.localeCompare(b); });
    countySelect.innerHTML =
      "<option value=\"\">Select County</option>" +
      countyList.map(function (c) { return "<option value=\"" + esc(c) + "\">" + esc(c) + "</option>"; }).join("");
  }

  async function loadGroups() {
    const res = await fetch("/api/groups");
    const data = await res.json();
    if (!res.ok) throw new Error(data.error || "Failed to load groups");
    groupsCache = Array.isArray(data) ? data : (data.groups || []);
    var optionsHtml =
      "<option value=\"\">Select a group</option>" +
      groupsCache.map(function (g) {
        var displayName = stripTakPrefix(g.name) || g.pk;
        return "<option value=\"" + esc(g.pk) + "\">" + esc(displayName) + "</option>";
      }).join("");
    groupSelect.innerHTML = optionsHtml;
    if (editGroupSelect) editGroupSelect.innerHTML = optionsHtml;
  }

  function renderIntegrations() {
    var needle = String(integrationFilter ? integrationFilter.value : "").trim().toLowerCase();
    var list = needle
      ? usersCache.filter(function (u) {
          var username = String(u.username || "").toLowerCase();
          var name = String(u.name || "").toLowerCase();
          var groupNames = (u.groupNames || []).join(" ").toLowerCase();
          return username.indexOf(needle) !== -1 ||
            name.indexOf(needle) !== -1 ||
            groupNames.indexOf(needle) !== -1;
        })
      : usersCache;
    if (list.length === 0) {
      tbody.innerHTML = "<tr><td colspan=\"6\">" + (needle ? "No integrations match your search." : "No integration users found.") + "</td></tr>";
    } else {
      tbody.innerHTML = list.map(function (u) {
        var groupDisplay = (u.groupNames || []).join(", ") || "—";
        var currentGroupPk = (u.groups && u.groups[0]) ? String(u.groups[0]) : "";
        var username = String(u.username || "").trim();
        var isConnected = connectedUsernamesSet.has(username);
        var statusPill = isConnected
          ? "<span class=\"status-pill status-connected\">Connected</span>"
          : "<span class=\"status-pill status-disconnected\">Disconnected</span>";

        var dataFeedButtonHtml;
        if (u.dataFeedName) {
          dataFeedButtonHtml = "<button class=\"btn success\" type=\"button\" data-action=\"data-feed\" data-mode=\"view\" data-username=\"" + esc(u.username) + "\">DF Enabled</button>";
        } else {
          dataFeedButtonHtml = "<button class=\"btn danger\" type=\"button\" data-action=\"data-feed\" data-mode=\"create\" data-username=\"" + esc(u.username) + "\" data-grouppk=\"" + esc(currentGroupPk) + "\" data-integration-title=\"" + esc(u.integrationTitle || "") + "\">No DF</button>";
        }

        var portCell = "";
        if (u.dataFeedName && u.dataFeedPort != null && u.dataFeedPort !== "") {
          portCell = esc(String(u.dataFeedPort));
        }

        return "<tr>" +
          "<td>" + esc(u.username) + "</td>" +
          "<td>" + esc(groupDisplay) + "</td>" +
          "<td>" + dataFeedButtonHtml + "</td>" +
          "<td>" + portCell + "</td>" +
          "<td>" + statusPill + "</td>" +
          "<td><div class=\"row\" style=\"gap:8px; flex-wrap:wrap;\">" +
          "<button class=\"btn success\" type=\"button\" data-action=\"download-certs\" data-pk=\"" + esc(u.pk) + "\" data-username=\"" + esc(u.username) + "\">Download Certs</button>" +
          "<button class=\"btn\" type=\"button\" data-action=\"edit\" data-pk=\"" + esc(u.pk) + "\" data-username=\"" + esc(u.username) + "\" data-group=\"" + esc(currentGroupPk) + "\">Edit Group</button>" +
          "<button class=\"btn danger\" type=\"button\" data-action=\"delete\" data-pk=\"" + esc(u.pk) + "\" data-username=\"" + esc(u.username) + "\">Delete</button>" +
          "</div></td>" +
          "</tr>";
      }).join("");
    }
    bindTableActions();
  }

  async function loadConnectedUsernames() {
    try {
      const res = await fetch("/api/tak/subscriptions", { headers: { Accept: "application/json" } });
      const data = await res.json();
      if (!res.ok || !data.configured) {
        connectedUsernamesSet = new Set();
        return;
      }
      var list = Array.isArray(data.data) ? data.data : [];
      var nodered = list.filter(function (item) {
        var u = (item.username != null ? String(item.username).trim() : "").toLowerCase();
        return u.indexOf("nodered-") === 0;
      });
      connectedUsernamesSet = new Set(nodered.map(function (item) { return String(item.username || "").trim(); }).filter(Boolean));
    } catch (e) {
      connectedUsernamesSet = new Set();
    }
  }

  async function loadIntegrations(silent) {
    if (!silent) setTableMsg("Loading…");
    try {
      var res = await fetch("/api/integrations");
      var data = await res.json();
      if (!res.ok) throw new Error(data.error || "Failed to load integrations");
      usersCache = data.users || [];
      setTableMsg("");
      renderIntegrations();
      loadConnectedUsernames().then(function () { renderIntegrations(); });
    } catch (err) {
      if (!silent) {
        setTableMsg(err.message || "Failed to load integrations", false);
        usersCache = [];
        tbody.innerHTML = "";
      }
    }
  }

  if (integrationFilter) integrationFilter.addEventListener("input", renderIntegrations);

  var editIntegrationOverlay = document.getElementById("editIntegrationOverlay");
  var editIntegrationCloseBtn = document.getElementById("editIntegrationCloseBtn");
  var editIntegrationUsername = document.getElementById("editIntegrationUsername");
  var editGroupSelect = document.getElementById("editGroupSelect");
  var editIntegrationSaveBtn = document.getElementById("editIntegrationSaveBtn");
  var editIntegrationMsg = document.getElementById("editIntegrationMsg");

  var editCurrentPk = null;

  function setEditMsg(text, ok) {
    editIntegrationMsg.textContent = text || "";
    editIntegrationMsg.style.color = ok ? "" : "var(--error, #c00)";
  }

  function openEditModal(pk, username, currentGroupPk) {
    editCurrentPk = pk;
    editIntegrationUsername.value = username || "";
    editGroupSelect.innerHTML =
      "<option value=\"\">Select a group</option>" +
      groupsCache.map(function (g) {
        var displayName = stripTakPrefix(g.name) || g.pk;
        return "<option value=\"" + esc(g.pk) + "\">" + esc(displayName) + "</option>";
      }).join("");
    editGroupSelect.value = currentGroupPk || "";
    setEditMsg("");
    editIntegrationOverlay.style.display = "flex";
  }

  function closeEditModal() {
    editIntegrationOverlay.style.display = "none";
    editCurrentPk = null;
  }

  function bindTableActions() {
    tbody.querySelectorAll("button[data-action=\"edit\"]").forEach(function (btn) {
      btn.addEventListener("click", function () {
        var pk = btn.getAttribute("data-pk");
        var username = btn.getAttribute("data-username");
        var groupPk = btn.getAttribute("data-group");
        openEditModal(pk, username, groupPk);
      });
    });
    tbody.querySelectorAll("button[data-action=\"data-feed\"]").forEach(function (btn) {
      btn.addEventListener("click", async function () {
        const username = btn.getAttribute("data-username");
        const mode = btn.getAttribute("data-mode");
        const integrationTitleAttr = btn.getAttribute("data-integration-title");
        const groupPk = btn.getAttribute("data-grouppk");
        
        if (mode === "create") {
            integrationRetroactiveUsername = username;
            filterGroupsCheckboxList.innerHTML = groupsCache.map(function(g) {
               const isChecked = (g.pk === groupPk) ? "checked" : "";
               const displayName = stripTakPrefix(g.name) || g.pk;
               return `<label style="display: flex; flex-direction: row; align-items: center; font-weight: normal; margin-bottom: 6px; width: 100%;">
                         <input type="checkbox" value="${esc(g.name)}" style="margin-right: 8px; margin-top: 0;" ${isChecked} />
                         ${esc(displayName)}
                       </label>`;
            }).join("");
            
            dataFeedForm.reset();
            document.getElementById("dataFeedTitle").innerText = "Create Streaming Data Feed";
            Array.from(dataFeedForm.elements).forEach(el => {
                if (el.name !== "dataFeedName") el.disabled = false;
            });
            document.getElementById("dataFeedSubmitBtn").style.display = "block";
            var retroSlug = toTitleSlug(integrationTitleAttr || "") || "integration";
            if (retroSlug.length > STREAMING_DATA_FEED_NAME_MAX_LEN) {
              setTableMsg(
                "This integration’s title is too long for a TAK data feed name (max " +
                  STREAMING_DATA_FEED_NAME_MAX_LEN +
                  " letters/numbers). Shorten integration_title in Authentik, then try again.",
                false
              );
              integrationRetroactiveUsername = null;
              return;
            }
            dataFeedForm.dataFeedName.value = retroSlug;
            dataFeedModalOverlay.style.display = "flex";
            
        } else if (mode === "view") {
            try {
              btn.disabled = true;
              setTableMsg("Fetching mapped Data Feed for " + username + "...");
              const res = await fetch(`/api/integrations/${encodeURIComponent(username)}/datafeed`);
              const feed = await res.json();
              if (res.ok && feed.dataFeed) {
                 const f = feed.dataFeed;
                 
                 dataFeedForm.reset();
                 document.getElementById("dataFeedTitle").innerText = "Data Feed Details";
                 document.getElementById("dataFeedSubmitBtn").style.display = "none";
                 
                 dataFeedForm.dataFeedName.value = f.name || "";
                 dataFeedForm.tags.value = (f.tag || []).join("\n");
                 dataFeedForm.protocol.value = f.protocol || "tls";
                 dataFeedForm.authType.value = f.auth || "X_509";
                 dataFeedForm.port.value = f.port || 8089;
                 dataFeedForm.coreVersion.value = f.coreVersion || "2";

                 const tls = String(f.coreVersion2TlsVersions || "").split(",");
                 dataFeedForm.tlsv1.checked = tls.includes("TLSv1");
                 dataFeedForm.tlsv1_1.checked = tls.includes("TLSv1.1");
                 dataFeedForm.tlsv1_2.checked = tls.includes("TLSv1.2");
                 dataFeedForm.tlsv1_3.checked = tls.includes("TLSv1.3");

                 dataFeedForm.multicastGroup.value = f.group || "";
                 dataFeedForm.interface.value = f.iface || "";
                 dataFeedForm.syncCacheRetention.value = f.syncCacheRetentionSeconds || "3600";
                 dataFeedForm.archive.value = f.archive === true ? "true" : "false";
                 dataFeedForm.anongroup.value = f.anongroup === true ? "true" : "false";
                 dataFeedForm.archiveOnly.value = f.archiveOnly === true ? "true" : "false";
                 dataFeedForm.sync.value = f.sync === true ? "true" : "false";
                 dataFeedForm.federated.value = f.federated === true ? "true" : "false";

                 filterGroupsCheckboxList.innerHTML = ((f.filtergroup || [])).map(function(grp) {
                     const displayName = stripTakPrefix(grp);
                     return `<label style="display: flex; flex-direction: row; align-items: center; font-weight: normal; margin-bottom: 6px; width: 100%;">
                               <input type="checkbox" checked disabled style="margin-right: 8px; margin-top: 0;"/>
                               ${esc(displayName)}
                             </label>`;
                 }).join("");
                 
                 Array.from(dataFeedForm.elements).forEach(el => el.disabled = true);
                 document.getElementById("dataFeedCloseBtn").disabled = false;
                 dataFeedModalOverlay.style.display = "flex";
                 setTableMsg("");
              } else {
                 setTableMsg("Could not load Data Feed.", false);
              }
            } catch (err) {
              setTableMsg("Failed fetching external Data Feed metadata", false);
            } finally {
              btn.disabled = false;
            }
        }
      });
    });
    tbody.querySelectorAll("button[data-action=\"download-certs\"]").forEach(function (btn) {
      btn.addEventListener("click", async function () {
        const pk = btn.getAttribute("data-pk");
        const username = btn.getAttribute("data-username");
        try {
          btn.disabled = true;
          setTableMsg("Preparing cert bundle for " + (username || "integration") + "...");
          await downloadIntegrationCertBundle(pk, username);
          setTableMsg("Cert bundle downloaded for " + (username || "integration") + ".", true);
        } catch (err) {
          setTableMsg(err.message || "Cert download failed", false);
        } finally {
          btn.disabled = false;
        }
      });
    });
    tbody.querySelectorAll("button[data-action=\"delete\"]").forEach(function (btn) {
      btn.addEventListener("click", function () {
        var pk = btn.getAttribute("data-pk");
        var username = btn.getAttribute("data-username");
        if (!confirm("Delete integration user \"" + (username || pk) + "\"? This cannot be undone.")) return;
        fetch("/api/integrations/" + encodeURIComponent(pk), { method: "DELETE" })
          .then(function (res) { return res.json(); })
          .then(function (out) {
            if (!out.error) {
              loadIntegrations();
            } else {
              setTableMsg(out.error || "Delete failed", false);
            }
          })
          .catch(function (err) {
            setTableMsg(err.message || "Delete failed", false);
          });
      });
    });
  }

  if (editIntegrationCloseBtn) {
    editIntegrationCloseBtn.addEventListener("click", closeEditModal);
  }
  if (editIntegrationOverlay) {
    editIntegrationOverlay.addEventListener("click", function (e) {
      if (e.target === editIntegrationOverlay) closeEditModal();
    });
  }
  if (editIntegrationSaveBtn) {
    editIntegrationSaveBtn.addEventListener("click", function () {
      var groupId = editGroupSelect.value;
      if (!editCurrentPk || !groupId) {
        setEditMsg("Please select a group.", false);
        return;
      }
      setEditMsg("");
      fetch("/api/integrations/" + encodeURIComponent(editCurrentPk) + "/group", {
        method: "PUT",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ groupId: groupId }),
      })
        .then(function (res) { return res.json(); })
        .then(function (out) {
          if (out.error) {
            setEditMsg(out.error, false);
            return;
          }
          closeEditModal();
          loadIntegrations();
        })
        .catch(function (err) {
          setEditMsg(err.message || "Save failed", false);
        });
    });
  }

  createForm.addEventListener("submit", async function (e) {
    e.preventDefault();
    setCreateMsg("");
    const type = integrationType.value || "global";
    const title = createForm.title.value.trim();
    const groupId = groupSelect.value;
    if (!groupId) {
      setCreateMsg("Please select a group.", false);
      return;
    }
    if (type === "agency" && !agencySelect.value) {
      setCreateMsg("Please select an agency.", false);
      return;
    }
    if (type === "county" && !countySelect.value) {
      setCreateMsg("Please select a county.", false);
      return;
    }
    if (type === "state" && !stateSelect.value) {
      setCreateMsg("Please select a state.", false);
      return;
    }
    const payload = {
      type: type,
      title: title,
      groupId: groupId,
    };
    if (type === "agency") payload.agencySuffix = agencySelect.value;
    if (type === "county") payload.county = countySelect.value;
    if (type === "state") payload.state = stateSelect.value;

    const mkFeeds = document.getElementById("makeDataFeed");
    const isSkipDataFeed = mkFeeds && mkFeeds.value === "no";
    
    if (isSkipDataFeed) {
       payload.skipDataFeed = true;
       submitIntegration(payload);
       return;
    }

    var titleSlugForFeed = toTitleSlug(title);
    if (titleSlugForFeed.length > STREAMING_DATA_FEED_NAME_MAX_LEN) {
      setCreateMsg(
        "With a streaming data feed, letters and numbers from the title must be at most " +
          STREAMING_DATA_FEED_NAME_MAX_LEN +
          " characters. Shorten the title.",
        false
      );
      return;
    }

    integrationPayloadCache = payload;
    integrationRetroactiveUsername = null;
    
    // Render Filter Groups checkboxes for standard flow
    filterGroupsCheckboxList.innerHTML = groupsCache.map(function(g) {
        const isChecked = (g.pk === groupId) ? "checked" : "";
        const displayName = stripTakPrefix(g.name) || g.pk;
        return `<label style="display: flex; flex-direction: row; align-items: center; font-weight: normal; margin-bottom: 6px; width: 100%;">
                  <input type="checkbox" value="${esc(g.name)}" style="margin-right: 8px; margin-top: 0;" ${isChecked} />
                  ${esc(displayName)}
                </label>`;
    }).join("");

    dataFeedForm.reset();
    document.getElementById("dataFeedTitle").innerText = "Create Streaming Data Feed";
    Array.from(dataFeedForm.elements).forEach(el => {
        if (el.name !== "dataFeedName") el.disabled = false;
    });
    document.getElementById("dataFeedSubmitBtn").style.display = "block";
    dataFeedForm.dataFeedName.value = titleSlugForFeed;

    dataFeedModalOverlay.style.display = "flex";
  });

  let integrationPayloadCache = null;
  let integrationRetroactiveUsername = null;

  if (dataFeedCloseBtn) {
    dataFeedCloseBtn.addEventListener("click", function() {
      dataFeedModalOverlay.style.display = "none";
      integrationPayloadCache = null;
      integrationRetroactiveUsername = null;
    });
  }

  dataFeedForm.addEventListener("submit", async function(e) {
    e.preventDefault();
    if (!integrationPayloadCache) return;

    const payload = integrationPayloadCache;
    
    payload.dataFeedName = dataFeedForm.dataFeedName.value.trim();
    payload.tags = dataFeedForm.tags.value;
    payload.protocol = dataFeedForm.protocol.value;
    payload.authType = dataFeedForm.authType.value;
    payload.port = dataFeedForm.port.value;
    payload.coreVersion = dataFeedForm.coreVersion.value;
    
    const tlsVersions = [];
    if (dataFeedForm.tlsv1.checked) tlsVersions.push("TLSv1");
    if (dataFeedForm.tlsv1_1.checked) tlsVersions.push("TLSv1.1");
    if (dataFeedForm.tlsv1_2.checked) tlsVersions.push("TLSv1.2");
    if (dataFeedForm.tlsv1_3.checked) tlsVersions.push("TLSv1.3");
    payload.coreVersion2TlsVersions = tlsVersions.join(",");

    payload.multicastGroup = dataFeedForm.multicastGroup.value.trim();
    payload.iface = dataFeedForm.interface.value.trim();
    payload.syncCacheRetention = dataFeedForm.syncCacheRetention.value;
    payload.archive = dataFeedForm.archive.value;
    payload.anongroup = dataFeedForm.anongroup.value;
    payload.archiveOnly = dataFeedForm.archiveOnly.value;
    payload.sync = dataFeedForm.sync.value;
    payload.federated = dataFeedForm.federated.value;

    const checkedBoxes = filterGroupsCheckboxList.querySelectorAll('input[type="checkbox"]:checked');
    const filterGroups = [];
    checkedBoxes.forEach(function(box) {
        filterGroups.push(box.value);
    });
    
    const dataFeedPayloadSegment = {
      dataFeedName: dataFeedForm.dataFeedName.value.trim(),
      tags: dataFeedForm.tags.value,
      protocol: dataFeedForm.protocol.value,
      authType: dataFeedForm.authType.value,
      port: dataFeedForm.port.value,
      coreVersion: dataFeedForm.coreVersion.value,
      coreVersion2TlsVersions: tlsVersions.join(","),
      multicastGroup: dataFeedForm.multicastGroup.value.trim(),
      iface: dataFeedForm.interface.value.trim(),
      syncCacheRetention: dataFeedForm.syncCacheRetention.value,
      archive: dataFeedForm.archive.value,
      anongroup: dataFeedForm.anongroup.value,
      archiveOnly: dataFeedForm.archiveOnly.value,
      sync: dataFeedForm.sync.value,
      federated: dataFeedForm.federated.value,
      filterGroups: filterGroups
    };

    dataFeedModalOverlay.style.display = "none";

    // Handle Retroactive Data Feed mode
    if (integrationRetroactiveUsername) {
       setTableMsg("Generating Data Feed for " + integrationRetroactiveUsername + "...", false);
       try {
         const res = await fetch(`/api/integrations/${encodeURIComponent(integrationRetroactiveUsername)}/datafeed`, {
           method: "POST",
           headers: { "Content-Type": "application/json" },
           body: JSON.stringify(dataFeedPayloadSegment)
         });
         const out = await res.json();
         if (!res.ok) {
           setTableMsg(out.error || "Retroactive Data Feed creation failed", false);
         } else {
           setTableMsg("Successfully created and mapped Data Feed.", true);
           loadIntegrations();
         }
       } catch (err) {
         setTableMsg(err.message || "Request failed", false);
       }
       integrationRetroactiveUsername = null;
       return;
    }

    // Default Creation Flow
    Object.assign(payload, dataFeedPayloadSegment);
    submitIntegration(payload);
  });

  async function submitIntegration(payload) {
    setCreateMsg("Creating integration...", true);
    try {
      const res = await fetch("/api/integrations", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify(payload),
      });
      const out = await res.json();
      if (!res.ok) {
        setCreateMsg(out.error || "Create failed", false);
        return;
      }
      const username = (out.user && out.user.username) || "";
      
      let msgStr = "Integration \"" + username + "\" created successfully.";
      if (out.certError) {
        msgStr += " Cert automation failed: " + out.certError + ".";
      }
      if (out.dataFeedError) {
        msgStr += " Data feed creation failed: " + out.dataFeedError + ".";
      }

      if (out.certError || out.dataFeedError) {
        setCreateMsg(msgStr, false);
      } else {
        setCreateMsg(msgStr + " Downloading cert bundle...", true);
      }
      
      createForm.reset();
      groupSelect.value = "";
      integrationType.value = "global";
      integrationType.dispatchEvent(new Event("change"));
      updateIntegrationTitleConstraints();
      await loadGroups();
      await loadIntegrations();
      if (out.user && out.user.pk && !out.certError) {
        try {
          await downloadIntegrationCertBundle(out.user.pk, username);
        } catch (downloadErr) {
          setCreateMsg("Integration \"" + username + "\" created. Cert download failed: " + (downloadErr.message || "Download failed"), false);
        }
      }
    } catch (err) {
      setCreateMsg(err.message || "Create failed", false);
    }
  }

  (async function init() {
    try {
      await loadAgencies();
      await loadGroups();
      await loadIntegrations();
      integrationType.dispatchEvent(new Event("change"));
      updateIntegrationTitleConstraints();
    } catch (err) {
      setTableMsg(err.message || "Failed to load page", false);
    }
  })();

  (function () {
    var refreshTimer = null;
    var REFRESH_MS = 20000;

    function startRefresh() {
      if (refreshTimer) return;
      refreshTimer = setInterval(function () { loadIntegrations(true); }, REFRESH_MS);
    }

    function stopRefresh() {
      if (refreshTimer) {
        clearInterval(refreshTimer);
        refreshTimer = null;
      }
    }

    document.addEventListener("visibilitychange", function () {
      if (document.visibilityState === "visible") {
        loadIntegrations(true);
        startRefresh();
      } else {
        stopRefresh();
      }
    });

    if (document.visibilityState === "visible") {
      startRefresh();
    }
  })();
})();
</script>

