.status-pill { display: inline-block; padding: 4px 10px; border-radius: 999px; font-size: 12px; font-weight: 600; }
.status-connected { background: rgba(24, 179, 90, 0.2); color: var(--success, #18b35a); }
.status-disconnected { background: rgba(255, 59, 59, 0.2); color: var(--danger, #ff3b3b); }
</style>
