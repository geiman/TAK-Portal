<%- include("partials/header") %>
<%- include("partials/sidebar") %>

<main class="main">
  <h1>Integrations</h1>

  <div class="card">
    <h2>Create Integration</h2>

    <form id="createForm" autocomplete="off">
      <div class="row">
        <label>Integration Type
          <select id="integrationType" name="type" style="min-width: 160px;">
            <option value="global">Global</option>
            <option value="state">State-Specific</option>
            <option value="county">County-Specific</option>
            <option value="agency">Agency-Specific</option>
          </select>
        </label>

        <label id="agencyWrap" style="display: none;">Select Agency
          <select id="agencySelect" name="agencySuffix" style="min-width: 140px;">
            <option value="">Select Agency</option>
          </select>
        </label>

        <label id="countyWrap" style="display: none;">Select County
          <select id="countySelect" name="county" style="min-width: 140px;">
            <option value="">Select County</option>
          </select>
        </label>

        <label id="stateWrap" style="display: none;">Select State
          <select id="stateSelect" name="state" style="min-width: 120px;">
            <option value="">Select State</option>
          </select>
        </label>

        <label style="flex: 1; min-width: 160px;">Title
          <input type="text" name="title" placeholder="e.g. Weather API" style="width: 100%;" required />
        </label>

        <label style="min-width: 200px;">Group
          <select name="groupId" id="groupSelect" style="min-width: 160px;" required>
            <option value="">Select a group</option>
          </select>
        </label>

        <label>&nbsp;
          <button class="btn" type="submit">Create Integration</button>
        </label>
      </div>
      <div id="createMsg" class="msg"></div>
    </form>
  </div>

  <div class="card">
    <h2 style="margin-top: 0;">Existing Integrations</h2>

    <input
      id="integrationFilter"
      placeholder="Search integrations..."
      style="margin: 10px 0; width: 100%; box-sizing: border-box;"
    />

    <div id="tableMsg" class="msg"></div>

    <table class="table">
      <thead>
        <tr>
          <th>Username</th>
          <th>Group</th>
          <th>Status</th>
          <th>Actions</th>
        </tr>
      </thead>
      <tbody id="tbody"></tbody>
    </table>
  </div>
</main>

<!-- Edit Integration (Group assignment only) -->
<div class="modalOverlay" id="editIntegrationOverlay" style="display: none;">
  <div class="modal" role="dialog" aria-modal="true" aria-labelledby="editIntegrationTitle">
    <div class="modalHeader">
      <h2 id="editIntegrationTitle" style="margin: 0;">Edit Integration</h2>
      <button class="btn" id="editIntegrationCloseBtn" type="button">Close</button>
    </div>
    <div class="modalBody">
      <div class="card" style="margin: 0;">
        <h2 style="margin-top: 0;">Edit Group Assignment</h2>
        <div class="row">
          <label style="flex: 1; min-width: 0;">Integration (read-only)
            <input type="text" id="editIntegrationUsername" readonly style="width: 100%;" />
          </label>
        </div>
        <div class="row" style="margin-top: 12px;">
          <label style="min-width: 200px;">Group
            <select id="editGroupSelect" style="min-width: 200px;"></select>
          </label>
        </div>
        <div class="row" style="margin-top: 16px; align-items: center;">
          <button class="btn success" id="editIntegrationSaveBtn" type="button">Save Changes</button>
          <span id="editIntegrationMsg" class="msg"></span>
        </div>
      </div>
    </div>
  </div>
</div>

<script>
(function () {
  const createForm = document.getElementById("createForm");
  const integrationType = document.getElementById("integrationType");
  const agencyWrap = document.getElementById("agencyWrap");
  const countyWrap = document.getElementById("countyWrap");
  const stateWrap = document.getElementById("stateWrap");
  const agencySelect = document.getElementById("agencySelect");
  const countySelect = document.getElementById("countySelect");
  const stateSelect = document.getElementById("stateSelect");
  const groupSelect = document.getElementById("groupSelect");
  const createMsg = document.getElementById("createMsg");
  const tableMsg = document.getElementById("tableMsg");
  const tbody = document.getElementById("tbody");
  const integrationFilter = document.getElementById("integrationFilter");

  let agenciesCache = [];
  let groupsCache = [];
  let usersCache = [];
  let connectedUsernamesSet = new Set();

  function stripTakPrefix(name) {
    if (name == null || name === undefined) return "";
    var n = String(name).trim();
    if (!n) return "";
    return n.toLowerCase().indexOf("tak_") === 0 ? n.slice(4) : n;
  }

  function setCreateMsg(text, ok) {
    createMsg.textContent = text || "";
    createMsg.style.color = ok ? "" : "var(--error, #c00)";
  }

  function setTableMsg(text, ok) {
    tableMsg.textContent = text || "";
    tableMsg.style.color = ok ? "" : "var(--error, #c00)";
  }

  function esc(s) {
    if (s == null || s === undefined) return "";
    const div = document.createElement("div");
    div.textContent = s;
    return div.innerHTML;
  }

  integrationType.addEventListener("change", function () {
    const v = integrationType.value;
    agencyWrap.style.display = v === "agency" ? "flex" : "none";
    countyWrap.style.display = v === "county" ? "flex" : "none";
    stateWrap.style.display = v === "state" ? "flex" : "none";
  });

  async function loadAgencies() {
    const res = await fetch("/api/agencies");
    const out = await res.json();
    if (!res.ok) {
      agenciesCache = [];
      agencySelect.innerHTML = "<option value=\"\">No agencies loaded</option>";
      countySelect.innerHTML = "<option value=\"\">No counties loaded</option>";
      stateSelect.innerHTML = "<option value=\"\">No states loaded</option>";
      return;
    }
    agenciesCache = Array.isArray(out) ? out : [];

    const prefixList = agenciesCache
      .filter(function (a) { return String(a.groupPrefix || "").trim(); })
      .slice()
      .sort(function (a, b) { return String(a.name || "").localeCompare(String(b.name || "")); });
    agencySelect.innerHTML =
      "<option value=\"\">Select Agency</option>" +
      prefixList.map(function (a) {
        const prefix = String(a.groupPrefix || "").trim().toUpperCase();
        const label = (a.name || "") + " (" + prefix + ")";
        return "<option value=\"" + esc(prefix) + "\">" + esc(label) + "</option>";
      }).join("");

    const stateSet = new Set(
      agenciesCache.map(function (a) { return String(a.state || "").trim(); }).filter(Boolean)
    );
    const stateList = Array.from(stateSet).sort(function (a, b) { return a.localeCompare(b); });
    stateSelect.innerHTML =
      "<option value=\"\">Select State</option>" +
      stateList.map(function (s) { return "<option value=\"" + esc(s) + "\">" + esc(s) + "</option>"; }).join("");

    const countySet = new Set(
      agenciesCache.map(function (a) { return String(a.county || "").trim(); }).filter(Boolean)
    );
    const countyList = Array.from(countySet).sort(function (a, b) { return a.localeCompare(b); });
    countySelect.innerHTML =
      "<option value=\"\">Select County</option>" +
      countyList.map(function (c) { return "<option value=\"" + esc(c) + "\">" + esc(c) + "</option>"; }).join("");
  }

  async function loadGroups() {
    const res = await fetch("/api/groups");
    const data = await res.json();
    if (!res.ok) throw new Error(data.error || "Failed to load groups");
    groupsCache = Array.isArray(data) ? data : (data.groups || []);
    var optionsHtml =
      "<option value=\"\">Select a group</option>" +
      groupsCache.map(function (g) {
        var displayName = stripTakPrefix(g.name) || g.pk;
        return "<option value=\"" + esc(g.pk) + "\">" + esc(displayName) + "</option>";
      }).join("");
    groupSelect.innerHTML = optionsHtml;
    if (editGroupSelect) editGroupSelect.innerHTML = optionsHtml;
  }

  function renderIntegrations() {
    var needle = String(integrationFilter ? integrationFilter.value : "").trim().toLowerCase();
    var list = needle
      ? usersCache.filter(function (u) {
          var username = String(u.username || "").toLowerCase();
          var name = String(u.name || "").toLowerCase();
          var groupNames = (u.groupNames || []).join(" ").toLowerCase();
          return username.indexOf(needle) !== -1 ||
            name.indexOf(needle) !== -1 ||
            groupNames.indexOf(needle) !== -1;
        })
      : usersCache;
    if (list.length === 0) {
      tbody.innerHTML = "<tr><td colspan=\"4\">" + (needle ? "No integrations match your search." : "No integration users found.") + "</td></tr>";
    } else {
      tbody.innerHTML = list.map(function (u) {
        var groupDisplay = (u.groupNames || []).join(", ") || "—";
        var currentGroupPk = (u.groups && u.groups[0]) ? String(u.groups[0]) : "";
        var username = String(u.username || "").trim();
        var isConnected = connectedUsernamesSet.has(username);
        var statusPill = isConnected
          ? "<span class=\"status-pill status-connected\">Connected</span>"
          : "<span class=\"status-pill status-disconnected\">Disconnected</span>";
        return "<tr>" +
          "<td>" + esc(u.username) + "</td>" +
          "<td>" + esc(groupDisplay) + "</td>" +
          "<td>" + statusPill + "</td>" +
          "<td><div class=\"row\" style=\"gap:8px; flex-wrap:wrap;\">" +
          "<button class=\"btn\" type=\"button\" data-action=\"edit\" data-pk=\"" + esc(u.pk) + "\" data-username=\"" + esc(u.username) + "\" data-group=\"" + esc(currentGroupPk) + "\">Edit Group</button>" +
          "<button class=\"btn danger\" type=\"button\" data-action=\"delete\" data-pk=\"" + esc(u.pk) + "\" data-username=\"" + esc(u.username) + "\">Delete</button>" +
          "</div></td>" +
          "</tr>";
      }).join("");
    }
    bindTableActions();
  }

  async function loadConnectedUsernames() {
    try {
      const res = await fetch("/api/tak/subscriptions", { headers: { Accept: "application/json" } });
      const data = await res.json();
      if (!res.ok || !data.configured) {
        connectedUsernamesSet = new Set();
        return;
      }
      var list = Array.isArray(data.data) ? data.data : [];
      var nodered = list.filter(function (item) {
        var u = (item.username != null ? String(item.username).trim() : "").toLowerCase();
        return u.indexOf("nodered-") === 0;
      });
      connectedUsernamesSet = new Set(nodered.map(function (item) { return String(item.username || "").trim(); }).filter(Boolean));
    } catch (e) {
      connectedUsernamesSet = new Set();
    }
  }

  async function loadIntegrations(silent) {
    if (!silent) setTableMsg("Loading…");
    try {
      var res = await fetch("/api/integrations");
      var data = await res.json();
      if (!res.ok) throw new Error(data.error || "Failed to load integrations");
      usersCache = data.users || [];
      setTableMsg("");
      renderIntegrations();
      loadConnectedUsernames().then(function () { renderIntegrations(); });
    } catch (err) {
      if (!silent) {
        setTableMsg(err.message || "Failed to load integrations", false);
        usersCache = [];
        tbody.innerHTML = "";
      }
    }
  }

  if (integrationFilter) integrationFilter.addEventListener("input", renderIntegrations);

  var editIntegrationOverlay = document.getElementById("editIntegrationOverlay");
  var editIntegrationCloseBtn = document.getElementById("editIntegrationCloseBtn");
  var editIntegrationUsername = document.getElementById("editIntegrationUsername");
  var editGroupSelect = document.getElementById("editGroupSelect");
  var editIntegrationSaveBtn = document.getElementById("editIntegrationSaveBtn");
  var editIntegrationMsg = document.getElementById("editIntegrationMsg");

  var editCurrentPk = null;

  function setEditMsg(text, ok) {
    editIntegrationMsg.textContent = text || "";
    editIntegrationMsg.style.color = ok ? "" : "var(--error, #c00)";
  }

  function openEditModal(pk, username, currentGroupPk) {
    editCurrentPk = pk;
    editIntegrationUsername.value = username || "";
    editGroupSelect.innerHTML =
      "<option value=\"\">Select a group</option>" +
      groupsCache.map(function (g) {
        var displayName = stripTakPrefix(g.name) || g.pk;
        return "<option value=\"" + esc(g.pk) + "\">" + esc(displayName) + "</option>";
      }).join("");
    editGroupSelect.value = currentGroupPk || "";
    setEditMsg("");
    editIntegrationOverlay.style.display = "flex";
  }

  function closeEditModal() {
    editIntegrationOverlay.style.display = "none";
    editCurrentPk = null;
  }

  function bindTableActions() {
    tbody.querySelectorAll("button[data-action=\"edit\"]").forEach(function (btn) {
      btn.addEventListener("click", function () {
        var pk = btn.getAttribute("data-pk");
        var username = btn.getAttribute("data-username");
        var groupPk = btn.getAttribute("data-group");
        openEditModal(pk, username, groupPk);
      });
    });
    tbody.querySelectorAll("button[data-action=\"delete\"]").forEach(function (btn) {
      btn.addEventListener("click", function () {
        var pk = btn.getAttribute("data-pk");
        var username = btn.getAttribute("data-username");
        if (!confirm("Delete integration user \"" + (username || pk) + "\"? This cannot be undone.")) return;
        fetch("/api/integrations/" + encodeURIComponent(pk), { method: "DELETE" })
          .then(function (res) { return res.json(); })
          .then(function (out) {
            if (!out.error) {
              loadIntegrations();
            } else {
              setTableMsg(out.error || "Delete failed", false);
            }
          })
          .catch(function (err) {
            setTableMsg(err.message || "Delete failed", false);
          });
      });
    });
  }

  if (editIntegrationCloseBtn) {
    editIntegrationCloseBtn.addEventListener("click", closeEditModal);
  }
  if (editIntegrationOverlay) {
    editIntegrationOverlay.addEventListener("click", function (e) {
      if (e.target === editIntegrationOverlay) closeEditModal();
    });
  }
  if (editIntegrationSaveBtn) {
    editIntegrationSaveBtn.addEventListener("click", function () {
      var groupId = editGroupSelect.value;
      if (!editCurrentPk || !groupId) {
        setEditMsg("Please select a group.", false);
        return;
      }
      setEditMsg("");
      fetch("/api/integrations/" + encodeURIComponent(editCurrentPk) + "/group", {
        method: "PUT",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ groupId: groupId }),
      })
        .then(function (res) { return res.json(); })
        .then(function (out) {
          if (out.error) {
            setEditMsg(out.error, false);
            return;
          }
          closeEditModal();
          loadIntegrations();
        })
        .catch(function (err) {
          setEditMsg(err.message || "Save failed", false);
        });
    });
  }

  createForm.addEventListener("submit", async function (e) {
    e.preventDefault();
    setCreateMsg("");
    const type = integrationType.value || "global";
    const title = createForm.title.value.trim();
    const groupId = groupSelect.value;
    if (!groupId) {
      setCreateMsg("Please select a group.", false);
      return;
    }
    if (type === "agency" && !agencySelect.value) {
      setCreateMsg("Please select an agency.", false);
      return;
    }
    if (type === "county" && !countySelect.value) {
      setCreateMsg("Please select a county.", false);
      return;
    }
    if (type === "state" && !stateSelect.value) {
      setCreateMsg("Please select a state.", false);
      return;
    }
    const payload = {
      type: type,
      title: title,
      groupId: groupId,
    };
    if (type === "agency") payload.agencySuffix = agencySelect.value;
    if (type === "county") payload.county = countySelect.value;
    if (type === "state") payload.state = stateSelect.value;
    try {
      const res = await fetch("/api/integrations", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify(payload),
      });
      const out = await res.json();
      if (!res.ok) {
        setCreateMsg(out.error || "Create failed", false);
        return;
      }
      const username = (out.user && out.user.username) || "";
      setCreateMsg("Integration \"" + username + "\" created successfully.", true);
      createForm.reset();
      groupSelect.value = "";
      integrationType.value = "global";
      integrationType.dispatchEvent(new Event("change"));
      await loadGroups();
      await loadIntegrations();
    } catch (err) {
      setCreateMsg(err.message || "Create failed", false);
    }
  });

  (async function init() {
    try {
      await loadAgencies();
      await loadGroups();
      await loadIntegrations();
      integrationType.dispatchEvent(new Event("change"));
    } catch (err) {
      setTableMsg(err.message || "Failed to load page", false);
    }
  })();

  (function () {
    var refreshTimer = null;
    var REFRESH_MS = 20000;

    function startRefresh() {
      if (refreshTimer) return;
      refreshTimer = setInterval(function () { loadIntegrations(true); }, REFRESH_MS);
    }

    function stopRefresh() {
      if (refreshTimer) {
        clearInterval(refreshTimer);
        refreshTimer = null;
      }
    }

    document.addEventListener("visibilitychange", function () {
      if (document.visibilityState === "visible") {
        loadIntegrations(true);
        startRefresh();
      } else {
        stopRefresh();
      }
    });

    if (document.visibilityState === "visible") {
      startRefresh();
    }
  })();
})();
</script>

<style>
.status-pill { display: inline-block; padding: 4px 10px; border-radius: 999px; font-size: 12px; font-weight: 600; }
.status-connected { background: rgba(24, 179, 90, 0.2); color: var(--success, #18b35a); }
.status-disconnected { background: rgba(255, 59, 59, 0.2); color: var(--danger, #ff3b3b); }
</style>
