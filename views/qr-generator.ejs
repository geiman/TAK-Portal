<%- include("partials/header") %>
<%- include("partials/sidebar") %>

<main class="main">
  <h1>QR Code Generator</h1>

  <div class="card">
    <h2>TAK Enrollment QR</h2>

    <form id="qrForm" class="grid2" autocomplete="off">
      <label>Username
        <input name="username" placeholder="Username" required />
      </label>

      <label>Password
        <input name="password" type="password" placeholder="Password" required />
      </label>

      <div style="grid-column: 1 / -1;">
        <button class="btn" type="submit">Generate QR Code</button>
        <span id="msg" class="msg"></span>
      </div>
    </form>
  </div>

  <div class="card" id="outCard" style="display:none;">
    <h2>Result</h2>

    <div class="row" style="gap: 24px; align-items: flex-start; flex-wrap: wrap;">
      <div style="text-align:center; min-width: 260px;">
        <img
          id="qrImg"
          alt="Enrollment QR Code"
          style="max-width: 280px; width: 100%; height: auto; border-radius: 14px;"
        />

        <div class="row" style="gap: 10px; margin-top: 14px; justify-content: center;">
          <button class="btn" type="button" id="copyBtn" disabled>Copy URL</button>
          <button class="btn" type="button" id="saveBtn" disabled>Save Image</button>
        </div>
      </div>
    </div>
  </div>
</main>

<script>
  const form = document.getElementById("qrForm");
  const msg = document.getElementById("msg");
  const outCard = document.getElementById("outCard");
  const qrImg = document.getElementById("qrImg");
  const copyBtn = document.getElementById("copyBtn");
  const saveBtn = document.getElementById("saveBtn");

  // Keep sensitive values out of the DOM
  let enrollUrl = "";
  let qrUsername = "";
  let qrToken = "";

  function setMsg(text, ok = true) {
    msg.textContent = text || "";
    msg.className = "msg " + (ok ? "ok" : "bad");
  }

  async function copyToClipboard(text) {
    try {
      await navigator.clipboard.writeText(text);
      setMsg("Copied!", true);
    } catch (e) {
      const ta = document.createElement("textarea");
      ta.value = text;
      ta.style.position = "fixed";
      ta.style.opacity = "0";
      document.body.appendChild(ta);
      ta.select();
      document.execCommand("copy");
      document.body.removeChild(ta);
      setMsg("Copied!", true);
    }
  }

  form.addEventListener("submit", async (e) => {
    e.preventDefault();
    setMsg("");

    // Reset state/UI
    outCard.style.display = "none";
    copyBtn.disabled = true;
    saveBtn.disabled = true;
    enrollUrl = "";
    qrUsername = "";
    qrToken = "";
    qrImg.src = "";

    const fd = new FormData(form);
    const username = String(fd.get("username") || "").trim();
    const password = String(fd.get("password") || "").trim();

    if (!username || !password) {
      setMsg("Username and password are required.", false);
      return;
    }

    qrUsername = username;
    qrToken = password;

    try {
      const res = await fetch("/api/qr", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ username, password })
      });

      const data = await res.json();
      if (!res.ok) throw new Error(data.error || "Failed to generate QR code");

      enrollUrl = data.enrollUrl;
      qrImg.src = data.qrCode;

      outCard.style.display = "block";
      copyBtn.disabled = false;
      saveBtn.disabled = false;

      setMsg("QR generated.", true);
    } catch (err) {
      setMsg(err.message || String(err), false);
    }
  });

  copyBtn.addEventListener("click", () => {
    if (enrollUrl) copyToClipboard(enrollUrl);
  });

  // Download higher quality than displayed using the server endpoint
  saveBtn.addEventListener("click", () => {
    if (!qrUsername || !qrToken) {
      setMsg("Generate a QR first.", false);
      return;
    }

    const url =
      `/api/qr/download?username=${encodeURIComponent(qrUsername)}` +
      `&token=${encodeURIComponent(qrToken)}`;

    // Trigger download (server returns high-res PNG with filename headers)
    const a = document.createElement("a");
    a.href = url;
    a.download = ""; // let server Content-Disposition filename win
    document.body.appendChild(a);
    a.click();
    document.body.removeChild(a);

    setMsg("Downloading high-res QR...", true);
  });
</script>

</div></body></html>
