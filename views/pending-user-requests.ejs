<style>
/* Groups picker: OUTER scroll box + INNER multicol (max 4 columns, fill down first) */
.groupsBox{
  margin-top: 10px;
  border: 1px solid var(--line);
  background: var(--panel);
  border-radius: 12px;
  padding: 10px;

  max-height: 320px;
  overflow-y: auto;
  overflow-x: hidden;
}

/* inner multicol wrapper */
.groupsInner{
  column-width: 310px;
  column-gap: 14px;
  column-count: 4;   /* max 4 columns */
}

.groupItem{
  display: flex !important;
  flex-direction: row !important;
  align-items: center;
  gap: 8px;

  padding: 6px 8px;
  border-radius: 10px;
  cursor: pointer;
  user-select: none;
  white-space: nowrap;
}
.groupItem:hover{
  background: rgba(255,255,255,.06);
}
.groupItem input{
  margin: 0;
  width: 16px;
  height: 16px;
  flex: 0 0 auto;
}
.groupItem span{
  display: inline-block;
  overflow: hidden;
  text-overflow: ellipsis;
}

/* Compact template bar under Modify Groups */
.templateBar{
  margin-top: 10px;
  padding: 8px 10px;
  display: flex;
  align-items: center;
  gap: 10px;
  border-radius: 12px;
  border: 1px solid rgba(255,255,255,.08);
  background: rgba(255,255,255,.03);
}

.templateBarDivider{
  width: 1px;
  height: 22px;
  background: rgba(255,255,255,.12);
  margin: 0 2px;
}

.templateBarLabel{
  font-size: 12px;
  opacity: .8;
  margin-right: 4px;
}

.templateBar select{
  min-width: 180px;
  max-width: 420px;
}

#permissionsSelect{
  min-width: 160px;
  max-width: 220px;
}

/* Stack nicely on small screens */
@media (max-width: 640px){
  .templateBar{
    flex-wrap: wrap;
  }
  .templateBar select{
    flex: 1;
    min-width: 0;
  }
}

/* Hide Status/Email column on small screens */
@media (max-width: 640px){
  .table th:nth-child(5),
  .table td:nth-child(5){
    display: none;
  }
}
@media (max-width: 640px){
  .table th:nth-child(3),
  .table td:nth-child(3){
    display: none;
  }
}

tr.row-disabled {
  background: rgba(0, 0, 0, 0.35);
  color: rgba(255, 255, 255, 0.65);
}

tr.row-disabled td {
  border-color: rgba(255, 255, 255, 0.08);
}

/* Pagination controls */
.pagination {
  margin: 12px 0 6px;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8px;
  font-size: 14px;
}

.pagination .btn {
  padding: 4px 14px;
  border-radius: 999px;
  background: #2f3241;
  border: 1px solid #3a3d4d;
  color: #e4e4e4;
  font-size: 13px;
  line-height: 1.2;
}

.pagination .btn:hover:not(:disabled) {
  background: #3a3d4d;
  border-color: #4a4d5e;
}

.pagination .btn:disabled {
  opacity: 0.45;
  cursor: default;
}

/* Page info pill */
#pageInfoTop,
#pageInfoBottom {
  padding: 3px 10px;
  border-radius: 999px;
  background: rgba(255, 255, 255, 0.04);
  border: 1px solid rgba(255, 255, 255, 0.06);
  opacity: 0.9;
  font-size: 12px;
}

/* Inline approve row */
.inlineApproveRow > td{
  padding: 0 !important;
}
.inlineApproveCard{
  margin: 10px 0 6px;
}

/* Password input + toggle */
.passwordWrap {
  position: relative;
  display: flex;
  align-items: center;
}
.passwordWrap input {
  width: 100%;
  padding-right: 2.5rem;
}
.passwordToggle {
  position: absolute;
  right: 8px;
  background: none;
  border: none;
  color: #fff;
  cursor: pointer;
  font-size: 1rem;
  padding: 0;
  display: flex;
  align-items: center;
  justify-content: center;
}
.passwordToggle:focus-visible {
  outline: 2px solid var(--accent, #fff);
  outline-offset: 2px;
}
</style>

<%- include("partials/header") %>
<%- include("partials/sidebar") %>

<main class="main">
  <h1>Pending User Requests</h1>

  <div class="card">
    <div class="row" style="justify-content: space-between; align-items:center; gap:12px; flex-wrap:wrap;">
      <h2 style="margin:0;">Pending User Requests</h2>
      <button class="btn" type="button" id="refreshBtn">Refresh</button>
    </div>

    <div id="listMsg" class="msg"></div>

    <table class="table">
      <thead>
        <tr>
          <th>Submitted</th>
          <th>Name</th>
          <th>Email</th>
          <th>Badge</th>
          <th>Agency</th>
          <th>Actions</th>
        </tr>
      </thead>
      <tbody id="reqTbody"></tbody>
    </table>
  </div>

  <!-- Inline approve form template (injected under the clicked row) -->
  <template id="inlineApproveTemplate">
    <tr class="inlineApproveRow">
      <td>
        <div class="card inlineApproveCard">
          <h2>Create User (Approve Request)</h2>
          <p class="muted approveNote"></p>

          <form class="grid2 approveForm" autocomplete="off">
            <input type="hidden" name="requestId" />

            <label>Badge Number / Username
              <input type="text" name="badge" placeholder="Enter Badge Number or Username" required />
            </label>

            <label>Agency
              <select name="agencySuffix" class="agencySelect" required></select>
            </label>

            <label>First Name
              <input name="firstName" placeholder="John" required />
            </label>

            <label>Last Name
              <input name="lastName" placeholder="Doe" required />
            </label>

            <label>Email (optional)
              <input name="email" type="email" placeholder="example@agency.gov" />
            </label>

            <label>Password (optional)
              <div class="passwordWrap">
                <input
                  class="passwordInput"
                  name="password"
                  type="password"
                  placeholder="Min 12 characters: upper, lower, number, and symbol"
                  minlength="12"
                  pattern="(?=.*[A-Z])(?=.*[a-z])(?=.*\d)(?=.*[^A-Za-z0-9]).{12,}"
                />
                <button
                  type="button"
                  class="passwordToggle"
                  aria-label="Show password"
                >👁</button>
              </div>
            </label>

            <label>Template
              <select name="templateIndex" class="templateSelect"></select>
            </label>

            <!-- Manual Groups (checkbox picker) -->
            <div class="manualGroupsWrap" style="display:none; grid-column: 1 / -1;">
              <h3 style="margin-top:0;">Manual Groups</h3>

              <label style="display:block;">
                Groups
                <input class="groupFilter" placeholder="Search groups..." />

                <div class="row" style="gap:10px; margin-top:8px;">
                  <button class="btn selectAllBtn" type="button">Select All</button>
                  <button class="btn clearAllBtn" type="button">Clear</button>
                </div>

                <div class="groupsBox">
                  <div class="groupsInner"></div>
                </div>
              </label>
            </div>

            <div style="grid-column: 1 / -1; display:flex; align-items:center; gap:10px; flex-wrap: wrap;">
              <button class="btn" type="submit">Create User</button>
              <button class="btn cancelBtn" type="button">Cancel</button>
              <span class="msg createMsg"></span>
            </div>
          </form>
        </div>
      </td>
    </tr>
  </template>
</main>

<script>
(function(){
  window.IS_GLOBAL_ADMIN = <%- JSON.stringify(!!isGlobalAdmin) %>;
  const tbody = document.getElementById('reqTbody');
  const listMsg = document.getElementById('listMsg');
  const refreshBtn = document.getElementById('refreshBtn');
  const tpl = document.getElementById('inlineApproveTemplate');

  let requestsCache = [];
  let groupsCache = [];
  let agenciesCache = [];

  function setListMsg(text, ok = true) {
    listMsg.textContent = text || '';
    listMsg.className = 'msg ' + (ok ? 'ok' : 'bad');
  }

  function setInlineMsg(el, text, ok = true) {
    if (!el) return;
    el.textContent = text || '';
    el.className = 'msg createMsg ' + (ok ? 'ok' : 'bad');
  }

  function esc(s) {
    return String(s ?? '')
      .replaceAll('&', '&amp;')
      .replaceAll('<', '&lt;')
      .replaceAll('>', '&gt;')
      .replaceAll('"', '&quot;')
      .replaceAll("'", '&#39;');
  }

  function fmtDate(iso) {
    const d = iso ? new Date(iso) : null;
    if (!d || isNaN(d.getTime())) return '';
    return d.toLocaleString();
  }

  // ----- Password validator -----
  function isValidPassword(pwd) {
    if (!pwd) return true;
    const re = /^(?=.*[A-Z])(?=.*[a-z])(?=.*\d)(?=.*[^A-Za-z0-9]).{12,}$/;
    return re.test(pwd);
  }

  function closeInlineApprove() {
    const existing = document.querySelector('tr.inlineApproveRow');
    if (existing) existing.remove();
  }

  async function loadRequests() {
    setListMsg('');
    const res = await fetch('/api/user-requests');
    const out = await res.json();
    if (!res.ok) throw new Error(out.error || 'Failed to load requests');
    requestsCache = Array.isArray(out) ? out : [];
    renderTable();
  }

  function renderTable() {
    if (!tbody) return;
    closeInlineApprove(); // inline form is tied to specific rows; close on rerender

    if (!requestsCache.length) {
      const colSpan = 6;
      tbody.innerHTML = `<tr><td colspan="${colSpan}" class="muted">No pending requests.</td></tr>`;
      return;
    }

    tbody.innerHTML = requestsCache.map(r => {
      const agencyLabel = r.agencySuffix === '__other__'
        ? 'Other / Not Listed'
        : (r.agencyName ? `${r.agencyName} (${r.agencySuffix})` : r.agencySuffix);
      return `
        <tr data-request-row="1" data-request-id="${esc(r.id)}">
          <td>${esc(fmtDate(r.createdAt))}</td>
          <td>${esc((r.lastName || '') + ', ' + (r.firstName || ''))}</td>  
          <td>${esc(r.email||'')}</td>
          <td>${esc(r.badgeNumber||'')}</td>
          <td>${esc(agencyLabel)}</td>
          <td>
            <div class="row" style="gap:8px; flex-wrap:wrap;">
              ${
                r.agencySuffix === '__other__'
                  ? `<button class="btn" type="button" data-action="approve" data-id="${esc(r.id)}">Review Request</button>`
                  : `<button class="btn success" type="button" data-action="approve" data-id="${esc(r.id)}">Approve</button>`
              }
              <button class="btn danger" type="button" data-action="reject" data-id="${esc(r.id)}">Reject</button>
            </div>
          </td>
        </tr>
      `;
    }).join('');
  }

  // -------------------- Agencies (cache once) --------------------
  async function loadAgencies() {
    const res = await fetch('/api/agencies');
    const agencies = await res.json();
    if (!res.ok) throw new Error(agencies.error || 'Failed to load agencies');
    agenciesCache = Array.isArray(agencies) ? agencies : [];
  }

  function fillAgencySelect(selectEl) {
    if (!selectEl) return;
    selectEl.innerHTML = agenciesCache
      .slice()
      .sort((a, b) => String(a.name || '').localeCompare(String(b.name || '')))
      .map(a => `<option value="${esc(a.suffix)}">${esc(a.name)} (${esc(a.suffix)})</option>`)
      .join('');
  }

  // -------------------- Groups (cache once) --------------------
  async function loadGroups() {
    const res = await fetch('/api/users/groups');
    const out = await res.json();
    if (!res.ok) throw new Error(out.error || 'Failed to load groups');
    groupsCache = Array.isArray(out) ? out : [];
  }

  // -------------------- Templates (per form) --------------------
  async function loadTemplatesForAgency(agencySuffix) {
    const sfx = agencySuffix || '';
    const res = await fetch('/api/users/meta?agencySuffix=' + encodeURIComponent(sfx));
    const meta = await res.json();
    if (!res.ok) throw new Error(meta.error || 'Failed to load templates');

    const raw = Array.isArray(meta.templates) ? meta.templates : [];
    const all = raw.map((t, idx) => ({ ...t, name: t.name || t.label || `Template ${idx + 1}` }));

    const manual =
      all[0] && String(all[0].name || '').toLowerCase().includes('manual')
        ? all[0]
        : { name: 'Manual Group Selection', groups: [] };

    const rest = all.slice(1).slice().sort((a, b) => String(a.name || '').localeCompare(String(b.name || '')));
    const templates = [manual, ...rest];

    let defaultIndex = 0;
    const defaultInRest = rest.findIndex((t) => !!t.isDefault);
    if (defaultInRest >= 0) defaultIndex = 1 + defaultInRest;
    else if (templates.length > 1) defaultIndex = 1;

    return { templates, defaultIndex };
  }

  // -------------------- Inline approve form --------------------
  function openInlineApprove(reqObj, clickedRow) {
    closeInlineApprove();

    const frag = tpl.content.cloneNode(true);
    const approveRow = frag.querySelector('tr.inlineApproveRow');
    const approveTd = frag.querySelector('tr.inlineApproveRow > td');
    const form = frag.querySelector('form.approveForm');
    const note = frag.querySelector('.approveNote');
    const msg = frag.querySelector('.createMsg');

    // Make td span the whole table
    approveTd.colSpan = 6;

    // Attach under clicked row
    clickedRow.parentNode.insertBefore(approveRow, clickedRow.nextSibling);

    // Fill initial values
    form.requestId.value = reqObj.id;
    form.badge.value = reqObj.badgeNumber || '';
    form.firstName.value = reqObj.firstName || '';
    form.lastName.value = reqObj.lastName || '';
    form.email.value = reqObj.email || '';

    const agencySelect = form.querySelector('select.agencySelect');
    const templateSelect = form.querySelector('select.templateSelect');
    const manualGroupsWrap = form.querySelector('.manualGroupsWrap');
    const groupFilter = form.querySelector('.groupFilter');
    const groupsBox = form.querySelector('.groupsBox');
    const groupsInner = form.querySelector('.groupsInner');
    const selectAllBtn = form.querySelector('.selectAllBtn');
    const clearAllBtn = form.querySelector('.clearAllBtn');
    const cancelBtn = form.querySelector('.cancelBtn');

    // Password toggle
    const passwordInput = form.querySelector('.passwordInput');
    const passwordToggle = form.querySelector('.passwordToggle');
    if (passwordInput && passwordToggle) {
      passwordToggle.textContent = '👁';
      passwordToggle.addEventListener('click', () => {
        const isHidden = passwordInput.type === 'password';
        passwordInput.type = isHidden ? 'text' : 'password';
        passwordToggle.setAttribute('aria-label', isHidden ? 'Hide password' : 'Show password');
      });
    }

    // Note for agency + reason
    const isOther = reqObj.agencySuffix === '__other__';

    if (isOther) {
      const agencyName = esc(reqObj.otherAgency || 'Other');
      const reason = esc(reqObj.otherReason || '');

      note.innerHTML = `
        <strong>Requested Agency:</strong> ${agencyName}<br>
        ${reason ? `<strong>Reason for Access:</strong> ${reason}` : ''}
      `;
    } else {
      note.textContent = '';
    }

    // Setup cancel
    cancelBtn.addEventListener('click', () => approveRow.remove());

    // Manual groups state (per form)
    const pickedManualGroupIds = new Set();

    function renderGroupsBox() {
      const needle = String(groupFilter.value || '').trim().toLowerCase();
      const sorted = groupsCache
        .slice()
        .sort((a, b) => String(a.name || '').localeCompare(String(b.name || '')));
      const filtered = needle
        ? sorted.filter((g) => String(g.name || '').toLowerCase().includes(needle))
        : sorted;

      groupsInner.innerHTML = filtered
        .map((g) => {
          const id = String(g.pk);
          const rawName = String(g.name || '');
          const name = rawName.replace(/^tak_/, '');
          return `
            <label class="groupItem">
              <input type="checkbox" value="${esc(id)}" />
              <span>${esc(name)}</span>
            </label>
          `;
        })
        .join('');

      Array.from(groupsBox.querySelectorAll('input[type="checkbox"]')).forEach((cb) => {
        cb.checked = pickedManualGroupIds.has(String(cb.value));
      });
    }

    groupsBox.addEventListener('change', (e) => {
      const cb = e.target;
      if (!cb || cb.tagName !== 'INPUT' || cb.type !== 'checkbox') return;
      const id = String(cb.value);
      if (cb.checked) pickedManualGroupIds.add(id);
      else pickedManualGroupIds.delete(id);
    });

    groupFilter.addEventListener('input', () => renderGroupsBox());

    selectAllBtn.addEventListener('click', () => {
      Array.from(groupsBox.querySelectorAll('input[type="checkbox"]')).forEach((cb) => {
        cb.checked = true;
        pickedManualGroupIds.add(String(cb.value));
      });
    });

    clearAllBtn.addEventListener('click', () => {
      Array.from(groupsBox.querySelectorAll('input[type="checkbox"]')).forEach((cb) => (cb.checked = false));
      pickedManualGroupIds.clear();
    });

    function getPickedManualGroupIds() {
      return Array.from(pickedManualGroupIds);
    }

    // Templates state (per form)
    let templatesCache = [];

    async function refreshTemplates() {
      setInlineMsg(msg, '');
      const sfx = agencySelect.value || '';
      const meta = await loadTemplatesForAgency(sfx);

      templatesCache = meta.templates;

      templateSelect.innerHTML = templatesCache
        .map((t, i) => `<option value="${i}">${esc(t.name)}</option>`)
        .join('');

      templateSelect.value = String(meta.defaultIndex);
      templateSelect.dispatchEvent(new Event('change'));
    }

    templateSelect.addEventListener('change', () => {
      const isManual = templateSelect.value === '0';
      manualGroupsWrap.style.display = isManual ? 'block' : 'none';
      // When switching to manual, render immediately
      if (isManual) renderGroupsBox();
    });

    // Agency select setup
    fillAgencySelect(agencySelect);
    if (!isOther && agencySelect) {
      // best-effort preselect
      const desired = String(reqObj.agencySuffix || '');
      if (desired && Array.from(agencySelect.options).some(o => String(o.value) === desired)) {
        agencySelect.value = desired;
      }
    }

    agencySelect.addEventListener('change', () => {
      pickedManualGroupIds.clear();
      groupFilter.value = '';
      renderGroupsBox();
      refreshTemplates().catch(err => setInlineMsg(msg, err.message || 'Failed to load templates', false));
    });

    // Prime groups render + templates
    renderGroupsBox();
    refreshTemplates().catch(err => setInlineMsg(msg, err.message || 'Failed to load templates', false));

    // Submit handler
    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      setInlineMsg(msg, '');

      const fd = new FormData(form);
      const payload = Object.fromEntries(fd.entries());

      const pwd = String(payload.password || '').trim();
      if (!isValidPassword(pwd)) {
        setInlineMsg(msg, 'Password must be at least 12 characters with upper, lower, number, and symbol.', false);
        return;
      }

      payload.templateIndex = Number(payload.templateIndex);

      if (String(payload.templateIndex) === '0') {
        payload.manualGroupIds = getPickedManualGroupIds();
      }

      const requestId = String(payload.requestId || '').trim();
      delete payload.requestId;

      try {
        const res = await fetch('/api/users', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(payload),
        });
        const out = await res.json();
        if (!res.ok) throw new Error(out.error?.message || out.error || 'Failed to create user');

        if (requestId) {
          await fetch('/api/user-requests/' + encodeURIComponent(requestId), { method: 'DELETE' });
        }

        // Confirmation message
        const createdUsername = out?.username || out?.badge || payload.badge || '';
        setInlineMsg(msg, createdUsername ? `User created: ${createdUsername}` : 'User created.', true);
        setListMsg('Request approved.', true);

        approveRow.remove();
        await loadRequests();
      } catch (err) {
        setInlineMsg(msg, err.message || 'Failed to create user', false);
      }
    });
  }

  // Table actions (approve/reject)
  tbody.addEventListener('click', async (e) => {
    const btn = e.target && e.target.closest ? e.target.closest('button[data-action]') : null;
    if (!btn) return;
    const id = btn.getAttribute('data-id');
    const action = btn.getAttribute('data-action');
    const reqObj = requestsCache.find(r => String(r.id) === String(id));
    if (!reqObj) return;

    if (action === 'reject') {
      if (!confirm('Reject this request? This will delete it.')) return;
      try {
        const res = await fetch('/api/user-requests/' + encodeURIComponent(id), { method: 'DELETE' });
        const out = await res.json();
        if (!res.ok) throw new Error(out.error || 'Failed to delete request');
        setListMsg('Request rejected.', true);
        closeInlineApprove();
        await loadRequests();
      } catch (err) {
        setListMsg(err.message || 'Failed to reject request', false);
      }
      return;
    }

    if (action === 'approve') {
      const row = btn.closest('tr');
      openInlineApprove(reqObj, row);
    }
  });

  refreshBtn.addEventListener('click', () => {
    loadRequests().catch(err => setListMsg(err.message || 'Failed to load requests', false));
  });

  // Init
  (async function init(){
    try {
      await loadAgencies();
      await loadGroups();
      await loadRequests();
    } catch (err) {
      setListMsg(err.message || 'Failed to load page data', false);
    }
  })();
})();
</script>

</div></body></html>
