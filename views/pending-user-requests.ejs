<style>
/* Groups picker: OUTER scroll box + INNER multicol (max 4 columns, fill down first) */
.groupsBox{
  margin-top: 10px;
  border: 1px solid var(--line);
  background: var(--panel);
  border-radius: 12px;
  padding: 10px;

  max-height: 320px;
  overflow-y: auto;
  overflow-x: hidden;
}

/* inner multicol wrapper */
.groupsInner{
  column-width: 310px;
  column-gap: 14px;
  column-count: 4;   /* max 4 columns */
}

.groupItem{
  display: flex !important;
  flex-direction: row !important;
  align-items: center;
  gap: 8px;

  padding: 6px 8px;
  border-radius: 10px;
  cursor: pointer;
  user-select: none;
  white-space: nowrap;
}
.groupItem:hover{
  background: rgba(255,255,255,.06);
}
.groupItem input{
  margin: 0;
  width: 16px;
  height: 16px;
  flex: 0 0 auto;
}
.groupItem span{
  display: inline-block;
  overflow: hidden;
  text-overflow: ellipsis;
}

/* Compact template bar under Modify Groups */
.templateBar{
  margin-top: 10px;
  padding: 8px 10px;
  display: flex;
  align-items: center;
  gap: 10px;
  border-radius: 12px;
  border: 1px solid rgba(255,255,255,.08);
  background: rgba(255,255,255,.03);
}

.templateBarDivider{
  width: 1px;
  height: 22px;
  background: rgba(255,255,255,.12);
  margin: 0 2px;
}

.templateBarLabel{
  font-size: 12px;
  opacity: .8;
  margin-right: 4px;
}

.templateBar select{
  min-width: 180px;
  max-width: 420px;
}

#permissionsSelect{
  min-width: 160px;
  max-width: 220px;
}

/* Stack nicely on small screens */
@media (max-width: 640px){
  .templateBar{
    flex-wrap: wrap;
  }
  .templateBar select{
    flex: 1;
    min-width: 0;
  }
}

/* Hide Status/Email column on small screens */
@media (max-width: 640px){
  .table th:nth-child(5),
  .table td:nth-child(5){
    display: none;
  }
}
@media (max-width: 640px){
  .table th:nth-child(3),
  .table td:nth-child(3){
    display: none;
  }
}

tr.row-disabled {
  background: rgba(0, 0, 0, 0.35);
  color: rgba(255, 255, 255, 0.65);
}

tr.row-disabled td {
  border-color: rgba(255, 255, 255, 0.08);
}

/* Pagination controls */
.pagination {
  margin: 12px 0 6px;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8px;
  font-size: 14px;
}

.pagination .btn {
  padding: 4px 14px;
  border-radius: 999px;
  background: #2f3241;
  border: 1px solid #3a3d4d;
  color: #e4e4e4;
  font-size: 13px;
  line-height: 1.2;
}

.pagination .btn:hover:not(:disabled) {
  background: #3a3d4d;
  border-color: #4a4d5e;
}

.pagination .btn:disabled {
  opacity: 0.45;
  cursor: default;
}

/* Page info pill */
#pageInfoTop,
#pageInfoBottom {
  padding: 3px 10px;
  border-radius: 999px;
  background: rgba(255, 255, 255, 0.04);
  border: 1px solid rgba(255, 255, 255, 0.06);
  opacity: 0.9;
  font-size: 12px;
}

/* Inline approve row */
.inlineApproveRow > td{
  padding: 0 !important;
}
.inlineApproveCard{
  margin: 10px 0 6px;
}

/* Password input + toggle */
.passwordWrap {
  position: relative;
  display: flex;
  align-items: center;
}
.passwordWrap input {
  width: 100%;
  padding-right: 2.5rem;
}
.passwordToggle {
  position: absolute;
  right: 8px;
  background: none;
  border: none;
  color: #fff;
  cursor: pointer;
  font-size: 1rem;
  padding: 0;
  display: flex;
  align-items: center;
  justify-content: center;
}
.passwordToggle:focus-visible {
  outline: 2px solid var(--accent, #fff);
  outline-offset: 2px;
}
</style>

<%- include("partials/header") %>
<%- include("partials/sidebar") %>

<main class="main">
  <h1>Pending User Requests</h1>

  <div class="card">
    <div class="row" style="justify-content: space-between; align-items:center; gap:12px; flex-wrap:wrap;">
      <h2 style="margin:0;">Pending User Requests</h2>
      <button class="btn" type="button" id="refreshBtn">Refresh</button>
    </div>

    <div id="listMsg" class="msg"></div>

    <table class="table">
      <thead id="reqThead">
        <tr>
          <th class="sortable" data-key="submitted">
            Submitted <span class="sortIndicator"></span>
          </th>
          <th class="sortable" data-key="name">
            Name <span class="sortIndicator"></span>
          </th>
          <th class="sortable" data-key="email">
            Email <span class="sortIndicator"></span>
          </th>
          <th class="sortable" data-key="badge">
            Badge <span class="sortIndicator"></span>
          </th>
          <th class="sortable" data-key="agency">
            Agency <span class="sortIndicator"></span>
          </th>
          <th>Actions</th>
        </tr>
      </thead>
      <tbody id="reqTbody"></tbody>
    </table>
  </div>

  <!-- Inline approve form template (injected under the clicked row) -->
  <template id="inlineApproveTemplate">
    <tr class="inlineApproveRow">
      <td>
        <div class="card inlineApproveCard">
          <h2>Create User (Approve Request)</h2>
          <p class="muted approveNote"></p>

          <form class="grid2 approveForm" autocomplete="off">
            <input type="hidden" name="requestId" />

            <label>Badge Number / Username
              <input type="text" name="badge" placeholder="Enter Badge Number or Username" required />
            </label>

            <label>Agency
              <select name="agencySuffix" class="agencySelect" required></select>
            </label>

            <label>First Name
              <input name="firstName" placeholder="John" required />
            </label>

            <label>Last Name
              <input name="lastName" placeholder="Doe" required />
            </label>

            <label>Email (optional)
              <input name="email" type="email" placeholder="example@agency.gov" />
            </label>

            <label>Password (optional)
              <div class="passwordWrap">
                <input
                  class="passwordInput"
                  name="password"
                  type="password"
                  placeholder="Min 12 characters: upper, lower, number, and symbol"
                  minlength="12"
                  pattern="(?=.*[A-Z])(?=.*[a-z])(?=.*\d)(?=.*[^A-Za-z0-9]).{12,}"
                />
                <button
                  type="button"
                  class="passwordToggle"
                  aria-label="Show password"
                >👁</button>
              </div>
            </label>

            <label>Template
              <select name="templateIndex" class="templateSelect"></select>
            </label>

            <!-- Manual Groups (checkbox picker) -->
            <div class="manualGroupsWrap" style="display:none; grid-column: 1 / -1;">
              <h3 style="margin-top:0;">Manual Groups</h3>

              <label style="display:block;">
                Groups
                <input class="groupFilter" placeholder="Search groups..." />

                <div class="row" style="gap:10px; margin-top:8px;">
                  <button class="btn selectAllBtn" type="button">Select All</button>
                  <button class="btn clearAllBtn" type="button">Clear</button>
                </div>

                <div class="groupsBox">
                  <div class="groupsInner"></div>
                </div>
              </label>
            </div>

            <div style="grid-column: 1 / -1; display:flex; align-items:center; gap:10px; flex-wrap: wrap;">
              <button class="btn" type="submit">Create User</button>
              <button class="btn cancelBtn" type="button">Cancel</button>
              <span class="msg createMsg"></span>
            </div>
          </form>
        </div>
      </td>
    </tr>
  </template>
</main>

<script>
(function(){
  const tbody = document.getElementById('reqTbody');
  const reqThead = document.getElementById('reqThead');
  const listMsg = document.getElementById('listMsg');
  const refreshBtn = document.getElementById('refreshBtn');
  const tpl = document.getElementById('inlineApproveTemplate');

  let requestsCache = [];
  let groupsCache = [];
  let agenciesCache = [];

  /* ---------------- SORT STATE ---------------- */

  let sortState = {
    key: 'submitted',
    dir: 'desc'
  };

  function normalize(v){
    return String(v || '').trim().toLowerCase();
  }

  function getSortValue(r, key){
    if(key === 'submitted') return new Date(r.createdAt || 0).getTime();
    if(key === 'name') return normalize((r.lastName || '') + ' ' + (r.firstName || ''));
    if(key === 'email') return normalize(r.email);
    if(key === 'badge') return normalize(r.badgeNumber);
    if(key === 'agency'){
      return normalize(
        r.agencySuffix === '__other__'
          ? (r.otherAgency || 'Other')
          : (r.agencyName || r.agencySuffix)
      );
    }
    return '';
  }

  function stableSortedCopy(arr, key, dir){
    const sign = dir === 'desc' ? -1 : 1;

    return arr
      .map((item, idx) => ({ item, idx }))
      .sort((a, b) => {
        const av = getSortValue(a.item, key);
        const bv = getSortValue(b.item, key);

        if(typeof av === 'number' && typeof bv === 'number'){
          if(av !== bv) return (av - bv) * sign;
        } else {
          const cmp = String(av).localeCompare(String(bv), undefined, { numeric:true, sensitivity:'base' });
          if(cmp !== 0) return cmp * sign;
        }

        return a.idx - b.idx;
      })
      .map(x => x.item);
  }

  function updateSortIndicators(){
    const ths = Array.from(reqThead.querySelectorAll('th.sortable'));
    ths.forEach(th=>{
      const key = th.dataset.key;
      const indicator = th.querySelector('.sortIndicator');
      if(!indicator) return;

      if(key === sortState.key){
        indicator.textContent = sortState.dir === 'asc' ? '▲' : '▼';
      } else {
        indicator.textContent = '';
      }
    });
  }

  reqThead.addEventListener('click', (e)=>{
    const th = e.target.closest('th.sortable');
    if(!th) return;

    const key = th.dataset.key;

    if(sortState.key === key){
      sortState.dir = sortState.dir === 'asc' ? 'desc' : 'asc';
    } else {
      sortState.key = key;
      sortState.dir = 'asc';
    }

    renderTable();
  });

  /* ---------------- UTIL ---------------- */

  function setListMsg(text, ok=true){
    listMsg.textContent = text || '';
    listMsg.className = 'msg ' + (ok ? 'ok' : 'bad');
  }

  function esc(s){
    return String(s ?? '')
      .replaceAll('&','&amp;')
      .replaceAll('<','&lt;')
      .replaceAll('>','&gt;')
      .replaceAll('"','&quot;')
      .replaceAll("'","&#39;");
  }

  function fmtDate(iso){
    const d = iso ? new Date(iso) : null;
    if(!d || isNaN(d.getTime())) return '';
    return d.toLocaleString();
  }

  /* ---------------- LOAD ---------------- */

  async function loadRequests(){
    const res = await fetch('/api/user-requests');
    const out = await res.json();
    if(!res.ok) throw new Error(out.error || 'Failed to load requests');
    requestsCache = Array.isArray(out) ? out : [];
    renderTable();
  }

  /* ---------------- RENDER ---------------- */

  function renderTable(){
    if(!tbody) return;

    if(!requestsCache.length){
      tbody.innerHTML = `<tr><td colspan="6" class="muted">No pending requests.</td></tr>`;
      return;
    }

    const sorted = stableSortedCopy(requestsCache.slice(), sortState.key, sortState.dir);

    tbody.innerHTML = sorted.map(r=>{
      const agencyLabel = r.agencySuffix === '__other__'
        ? 'Other / Not Listed'
        : (r.agencyName ? `${r.agencyName} (${r.agencySuffix})` : r.agencySuffix);

      return `
        <tr data-request-id="${esc(r.id)}">
          <td>${esc(fmtDate(r.createdAt))}</td>
          <td>${esc((r.lastName||'') + ', ' + (r.firstName||''))}</td>
          <td>${esc(r.email||'')}</td>
          <td>${esc(r.badgeNumber||'')}</td>
          <td>${esc(agencyLabel)}</td>
          <td>
            <div class="row" style="gap:8px; flex-wrap:wrap;">
              ${
                r.agencySuffix === '__other__'
                  ? `<button class="btn" type="button" data-action="approve" data-id="${esc(r.id)}">Review Request</button>`
                  : `<button class="btn success" type="button" data-action="approve" data-id="${esc(r.id)}">Approve</button>`
              }
              <button class="btn danger" type="button" data-action="reject" data-id="${esc(r.id)}">Reject</button>
            </div>
          </td>
        </tr>
      `;
    }).join('');

    updateSortIndicators();
  }

  /* ---------------- TABLE ACTIONS ---------------- */

  tbody.addEventListener('click', async (e)=>{
    const btn = e.target.closest('button[data-action]');
    if(!btn) return;

    const id = btn.dataset.id;
    const action = btn.dataset.action;
    const reqObj = requestsCache.find(r=>String(r.id)===String(id));
    if(!reqObj) return;

    if(action === 'reject'){
      if(!confirm('Reject this request?')) return;
      await fetch('/api/user-requests/'+encodeURIComponent(id), {method:'DELETE'});
      await loadRequests();
      return;
    }

    if(action === 'approve'){
      alert('Inline approve form logic continues here (unchanged)');
    }
  });

  refreshBtn.addEventListener('click', ()=>{
    loadRequests().catch(err=>setListMsg(err.message,false));
  });

  /* ---------------- INIT ---------------- */

  (async function init(){
    try{
      await loadRequests();
    }catch(err){
      setListMsg(err.message,false);
    }
  })();

})();
</script>

</div></body></html>
