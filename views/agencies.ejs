<%- include("partials/header") %>
<%- include("partials/sidebar") %>

<main class="main">
  <h1>Agencies</h1>

  <div class="card">
    <h2>Add Agency</h2>
    <form id="addForm" class="row">
      <!-- 1) Agency name -->
      <label>Agency Full Name
        <input name="name" placeholder="Agency Name" required style="flex: 2;" />
      </label>

      <!-- 2) Group prefix -->
      <label>Agency Abbreviation
        <input name="groupPrefix" placeholder="(ex. HCSO, HCOEM, etc...)" required
               oninput="this.value = this.value.toUpperCase()" />
      </label>

      <!-- 3) Username suffix -->
      <label>Username Suffix
        <input name="suffix" placeholder="(ex. hs, hcoem, etc...)" required
               oninput="this.value = this.value.toLowerCase()" />
      </label>

      <!-- 4) State dropdown -->
      <label>State
        <select name="state" required>
          <option value="" disabled selected>Select State</option>
          <option value="AL">AL</option>
          <option value="AK">AK</option>
          <option value="AZ">AZ</option>
          <option value="AR">AR</option>
          <option value="CA">CA</option>
          <option value="CO">CO</option>
          <option value="CT">CT</option>
          <option value="DE">DE</option>
          <option value="FL">FL</option>
          <option value="GA">GA</option>
          <option value="HI">HI</option>
          <option value="ID">ID</option>
          <option value="IL">IL</option>
          <option value="IN">IN</option>
          <option value="IA">IA</option>
          <option value="KS">KS</option>
          <option value="KY">KY</option>
          <option value="LA">LA</option>
          <option value="ME">ME</option>
          <option value="MD">MD</option>
          <option value="MA">MA</option>
          <option value="MI">MI</option>
          <option value="MN">MN</option>
          <option value="MS">MS</option>
          <option value="MO">MO</option>
          <option value="MT">MT</option>
          <option value="NE">NE</option>
          <option value="NV">NV</option>
          <option value="NH">NH</option>
          <option value="NJ">NJ</option>
          <option value="NM">NM</option>
          <option value="NY">NY</option>
          <option value="NC">NC</option>
          <option value="ND">ND</option>
          <option value="OH">OH</option>
          <option value="OK">OK</option>
          <option value="OR">OR</option>
          <option value="PA">PA</option>
          <option value="RI">RI</option>
          <option value="SC">SC</option>
          <option value="SD">SD</option>
          <option value="TN">TN</option>
          <option value="TX">TX</option>
          <option value="UT">UT</option>
          <option value="VT">VT</option>
          <option value="VA">VA</option>
          <option value="WA">WA</option>
          <option value="WV">WV</option>
          <option value="WI">WI</option>
          <option value="WY">WY</option>
          <option value="FED">USA</option>
          <option value="FED">FED</option>
          <option value="OTHER">OTHER</option>
        </select>
      </label>

      <!-- 5) County text input (normalized + last-used) -->
      <label>County
        <input
          name="county"
          placeholder="(ex. Hamilton, Marion)"
          required
        />
      </label>

      <!-- 5.5) County Abbreviation -->
      <label>County Abbreviation
        <input
          name="countyAbbrev"
          placeholder="(ex. HML or MAR)"
          required
          minlength="3"
          oninput="this.value = this.value.toUpperCase().replace(/[^A-Z]/g, '')"
        />
      </label>

      <!-- 5) Type dropdown -->
      <label>Agency Type
        <select name="type" required>
          <option value="" disabled selected>Agency Type</option>
          <% const _agencyTypeOpts = Array.isArray(agencyTypeOptions) && agencyTypeOptions.length ? agencyTypeOptions : []; %>
          <% _agencyTypeOpts.forEach(function (t) { %>
<option value="<%= t %>"><%= t %></option>
          <% }); %>
        </select>
      </label>

      <!-- 6) Color dropdown -->
      <label>Agency Color
        <select name="color" required>
          <option value="" disabled selected>Color</option>
          <option value="Blue">Blue</option>
          <option value="Dark Blue">Dark Blue</option>
          <option value="Brown">Brown</option>
          <option value="Cyan">Cyan</option>
          <option value="Green">Green</option>
          <option value="Dark Green">Dark Green</option>
          <option value="Magenta">Magenta</option>
          <option value="Maroon">Maroon</option>
          <option value="Orange">Orange</option>
          <option value="Purple">Purple</option>
          <option value="Red">Red</option>
          <option value="Teal">Teal</option>
          <option value="White">White</option>
          <option value="Yellow">Yellow</option>
        </select>
      </label>
      
      <label> <br>
      <button class="btn">Create Agency</button></label>
    </form>
    <div id="msg" class="msg"></div>
  </div>

  <div class="card">
    <div class="row" style="justify-content: space-between;">
      <h2 style="margin:0;">Current Agencies</h2>
    </div>

    <table class="table" id="agencyTable">
      <thead>
        <tr>
          <th data-sort="name" role="button" tabindex="0" title="Sort by Agency">Agency</th>
          <th data-sort="groupPrefix" role="button" tabindex="0" title="Sort by Abbreviation">Abbreviation</th>
          <th data-sort="suffix" role="button" tabindex="0" title="Sort by Username Suffix">Username Suffix</th>
          <th data-sort="county" role="button" tabindex="0" title="Sort by County">County</th>
          <th data-sort="countyAbbrev" role="button" tabindex="0" title="Sort by County Abbreviation">County Abbrev</th>
          <th data-sort="state" role="button" tabindex="0">State</th>
          <th data-sort="type" role="button" tabindex="0" title="Sort by Type">Type</th>
          <th data-sort="color" role="button" tabindex="0" title="Sort by Color">Color</th>
          <th>Actions</th>
        </tr>
      </thead>
      <tbody id="tbody"></tbody>
    </table>
  </div>
</main>

<!-- Agency Admins Modal (same behavior as Groups -> View Members) -->
<div class="modalOverlay" id="adminsOverlay" style="display:none;">
  <div class="modal" role="dialog" aria-modal="true" aria-labelledby="adminsTitle">
    <div class="modalHeader">
      <h2 id="adminsTitle" style="margin:0;">Agency Admins</h2>
      <button class="btn" id="adminsCloseBtn" type="button">Close</button>
    </div>
    <div class="modalBody">
      <div id="adminsSummary" class="msg"></div>

      <div style="margin-top:14px;">
        <input
          id="adminsFilter"
          placeholder="Filter by username, name, or email..."
          style="width: 100%; box-sizing: border-box;"
        />
      </div>

      <div
        id="adminsList"
        class="groupsBox"
        style="margin-top:10px; max-height: 320px; overflow:auto;"
      ></div>
      <small id="adminsHint" class="muted"></small>
    </div>
  </div>
</div>

<!-- Access Groups Modal (which extra groups this agency's admins can see) -->
<div class="modalOverlay" id="accessGroupsOverlay" style="display:none;">
  <div class="modal" role="dialog" aria-modal="true" aria-labelledby="accessGroupsTitle">
    <div class="modalHeader">
      <h2 id="accessGroupsTitle" style="margin:0;">Agency Access Groups</h2>
      <button class="btn" id="accessGroupsCloseBtn" type="button">Close</button>
    </div>
    <div class="modalBody">
      <p id="accessGroupsSummary" class="msg"></p>
      <label style="display:block;">
        Groups (agency admins always see their own agency groups; select extra groups to grant access)
        <input id="accessGroupSearch" placeholder="Search groups..." style="width:100%; box-sizing:border-box; margin-top:6px;" />
      </label>
      <div class="row" style="gap:10px; margin-top:8px;">
        <button class="btn" type="button" id="accessGroupsSelectAllBtn">Select All</button>
        <button class="btn" type="button" id="accessGroupsClearBtn">Clear</button>
      </div>
      <div id="accessGroupsBox" class="groupsBox" style="margin-top:10px; max-height:320px; overflow:auto;">
        <div id="accessGroupsInner" class="groupsInner"></div>
      </div>
      <div style="margin-top:14px; text-align:right;">
        <button class="btn" type="button" id="accessGroupsCancelBtn">Cancel</button>
        <button class="btn success" type="button" id="accessGroupsSaveBtn">Save</button>
      </div>
    </div>
  </div>
</div>

<!-- Configure domain + account lookup (same agency JSON field: lookupDomain, comma-separated) -->
  <div class="modalOverlay" id="lookupModal" style="display:none;">
    <div class="modal" role="dialog" aria-modal="true" aria-labelledby="domainModalTitle">
      <div class="modalHeader">
        <h2 id="domainModalTitle" style="margin:0;">Configure Agency Domain(s)</h2>
        <button class="btn" type="button" onclick="showLookupModal(false)">Close</button>
      </div>
      <div class="modalBody">
        <p>Configure approved email domains for this agency (comma-separated, no @ symbol).
        <br><br>If you list one or more domains, the public <strong>Request Access</strong> form will only accept email addresses ending in those domains. Leave the field empty to allow any email domain for requests.
        <br><br><strong>Account Lookup</strong> (when enabled) lets users request an enrollment QR code by email and username, for shared or apparatus accounts. Lookup still requires a matching approved domain and only works while lookup is enabled.

        <div style="margin-top:14px;">
          <label>Agency email domains</label>
          <input type="text" id="lookupDomain" placeholder="agency.gov, county.org"
                style="width:100%; box-sizing:border-box;" />
          <small class="muted" style="display:block; margin-top:4px;">Separate multiple domains with commas.</small>
          <small id="domainError" class="msg bad" style="display:none;">
            Enter valid domains (e.g., agency.gov) with no @ symbol. Use commas between multiple domains.
          </small>
        </div>

        <div style="margin-top:16px; display:flex; flex-wrap:wrap; gap:10px; justify-content:flex-end;">
          <button class="btn" type="button" onclick="showLookupModal(false)">
            Cancel
          </button>
          <button class="btn" type="button" id="saveLookupDomainsBtn">
            Save domains
          </button>
          <button class="btn danger" type="button" id="disableLookupInModalBtn" style="display:none;">
            Disable Account Lookup
          </button>
          <button class="btn success" type="button" id="confirmEnableLookup" style="display:none;">
            Enable Account Lookup
          </button>
        </div>
      </div>
    </div>
  </div>

<!-- County Abbreviation Update Modal -->
<div class="modalOverlay" id="countyAbbrevOverlay" style="display:none;">
  <div class="modal" role="dialog" aria-modal="true" aria-labelledby="countyAbbrevTitle">
    <div class="modalHeader">
      <h2 id="countyAbbrevTitle" style="margin:0;">Update County Abbreviation</h2>
      <button class="btn" type="button" id="countyAbbrevCloseBtn">Close</button>
    </div>
    <div class="modalBody">
      <p id="countyAbbrevSummary" class="msg"></p>
      <label style="display:block; margin-top:8px;">
        County Abbreviation
        <input
          id="countyAbbrevInput"
          placeholder="(ex. HML or MAR)"
          required
          minlength="3"
          style="width:100%; box-sizing:border-box; margin-top:4px;"
          oninput="this.value = this.value.toUpperCase().replace(/[^A-Z]/g, '')"
        />
      </label>
      <small class="muted">
        Must be at least 3 letters.
      </small>
      <div style="margin-top:14px; text-align:right;">
        <button class="btn" type="button" id="countyAbbrevCancelBtn">Cancel</button>
        <button class="btn success" type="button" id="countyAbbrevSaveBtn">Save</button>
      </div>
    </div>
  </div>
</div>
  </div>

<script>
const msg = document.getElementById("msg");
const tbody = document.getElementById("tbody");
const addForm = document.getElementById("addForm");
const refreshBtn = document.getElementById("refreshBtn");
const agencyTable = document.getElementById("agencyTable");

// Admins modal (mirrors Groups page View Members)
const adminsOverlay = document.getElementById("adminsOverlay");
const adminsCloseBtn = document.getElementById("adminsCloseBtn");
const adminsSummary = document.getElementById("adminsSummary");
const adminsFilter = document.getElementById("adminsFilter");
const adminsList = document.getElementById("adminsList");
const adminsHint = document.getElementById("adminsHint");

let agencies = [];
let sortState = { key: "name", dir: 1 }; // default: Agency asc

function setMsg(text, ok=true){
  msg.textContent = text || "";
  msg.className = "msg " + (ok ? "ok" : "bad");
}

function esc(s){
  return String(s ?? "")
    .replaceAll("&","&amp;")
    .replaceAll("<","&lt;")
    .replaceAll(">","&gt;");
}

/** Same list as create-agency form and PATCH /api/agencies/:index/color */
const AGENCY_COLOR_OPTIONS = [
  "Blue", "Dark Blue", "Brown", "Cyan", "Green", "Dark Green", "Magenta", "Maroon",
  "Orange", "Purple", "Red", "Teal", "White", "Yellow",
];

function buildAgencyColorCellHtml(a) {
  const idx = a._id ?? a.id;
  const current = String(a.color || "").trim();
  let opts = "";
  if (!current) {
    opts += `<option value="" disabled selected>Choose color…</option>`;
  }
  opts += AGENCY_COLOR_OPTIONS.map((c) => {
    const sel = c === current ? " selected" : "";
    return `<option value="${esc(c)}"${sel}>${esc(c)}</option>`;
  }).join("");
  const legacyExtra =
    current && !AGENCY_COLOR_OPTIONS.includes(current)
      ? `<option value="${esc(current)}" selected>${esc(current)} (current)</option>`
      : "";
  const aria = esc(a.name || "Agency");
  return `<select aria-label="Color for ${aria}" onchange="updateAgencyColor(${Number(idx)}, this.value)">${legacyExtra}${opts}</select>`;
}

async function updateAgencyColor(agencyIndex, newColor) {
  if (!String(newColor || "").trim()) return;
  try {
    const res = await fetch(`/api/agencies/${encodeURIComponent(agencyIndex)}/color`, {
      method: "PATCH",
      headers: { "Content-Type": "application/json" },
      body: JSON.stringify({ color: newColor }),
    });
    const data = await res.json().catch(() => ({}));
    if (!res.ok) throw new Error(data.error || "Failed to update color");
    setMsg("Color saved.", true);
    const row = agencies.find((x) => String(x._id ?? x.id) === String(agencyIndex));
    if (row) row.color = newColor;
    renderAgencies();
  } catch (e) {
    setMsg(e.message || String(e), false);
    await loadAgenciesWithCounts();
  }
}

function normalizeVal(v){
  if (v === null || v === undefined) return "";
  return String(v).toLowerCase().trim();
}

function adminGroupNameForAgency(a){
  const abbr = String(a?.groupPrefix || "").trim().toUpperCase();
  const countyAbbrev = String(a?.countyAbbrev || "").trim().toUpperCase();
  if (!abbr) return "";
  if (countyAbbrev) {
    return `authentik-${countyAbbrev}-${abbr}-AgencyAdmin`;
  }
  // Legacy pattern (no county abbreviation stored yet)
  return `authentik-${abbr}-AgencyAdmin`;
}

// ---- Admin modal behavior (copy of Groups -> View Members) ----
let activeAdmins = [];
let activeAdminsGroupId = "";
let activeAdminsGroupName = "";

function showAdminsModal(on){
  if(!adminsOverlay) return;
  adminsOverlay.style.display = on ? "flex" : "none";
  document.body.style.overflow = on ? "hidden" : "";
}

function escAttr(s){
  return String(s ?? "")
    .replaceAll("&","&amp;")
    .replaceAll("<","&lt;")
    .replaceAll(">","&gt;")
    .replaceAll('"',"&quot;")
    .replaceAll("'","&#39;");
}

function memberRow(u){
  const username = String(u?.username || "");
  const name = String(u?.name || u?.displayName || "");
  const email = String(u?.email || "");
  const pk = String(u?.pk || u?.id || "");
  const canRemove = !!(activeAdminsGroupId && pk);
  return `
    <tr>
      <td>${escAttr(username)}</td>
      <td>${escAttr(name)}</td>
      <td>${escAttr(email)}</td>
      <td style="text-align:right;">
        ${canRemove ? `<button class="btn danger" type="button" onclick="removeUserFromAdminsGroup('${escAttr(pk)}')">Remove</button>` : ``}
      </td>
    </tr>
  `;
}

function renderAdminsList(){
  const needle = String(adminsFilter?.value || "").trim().toLowerCase();
  const filtered = needle
    ? (activeAdmins || []).filter(u => {
        const u1 = String(u?.username || "").toLowerCase();
        const u2 = String(u?.name || u?.displayName || "").toLowerCase();
        const u3 = String(u?.email || "").toLowerCase();
        return u1.includes(needle) || u2.includes(needle) || u3.includes(needle);
      })
    : (activeAdmins || []);

  const rowsHtml = filtered.map(memberRow).join("");
  adminsList.innerHTML = `
    <table class="table" style="margin:0;">
      <thead>
        <tr>
          <th>Username</th>
          <th>Name</th>
          <th>Email</th>
          <th style="text-align:right;">Actions</th>
        </tr>
      </thead>
      <tbody>
        ${rowsHtml || `<tr><td colspan="4" class="muted">No users found.</td></tr>`}
      </tbody>
    </table>
  `;
}

if (adminsCloseBtn) adminsCloseBtn.onclick = () => showAdminsModal(false);
if (adminsOverlay) adminsOverlay.addEventListener("click", (e) => {
  if (e.target === adminsOverlay) showAdminsModal(false);
});
if (adminsFilter) adminsFilter.oninput = renderAdminsList;

function renderAgencies(){
  // apply sort (copy to avoid mutating original order if you later want it)
  const rows = [...agencies];

  if (sortState.key){
    const key = sortState.key;
    const dir = sortState.dir;
    const th = agencyTable.querySelector(`thead th[data-sort="${CSS.escape(key)}"]`);
    const type = th?.dataset.type || "text";

    rows.sort((a,b) => {
      if (type === "number"){
        const av = Number(a[key] ?? 0);
        const bv = Number(b[key] ?? 0);
        return (av - bv) * dir;
      } else {
        const av = normalizeVal(a[key]);
        const bv = normalizeVal(b[key]);
        return av.localeCompare(bv) * dir;
      }
    });
  }

  // update header indicators
  agencyTable.querySelectorAll("thead th[data-sort]").forEach(th => {
    th.classList.remove("sorted-asc","sorted-desc");
    if (th.dataset.sort === sortState.key){
      th.classList.add(sortState.dir === 1 ? "sorted-asc" : "sorted-desc");
    }
  });

  tbody.innerHTML = rows.map((a)=>`
    <tr>
      <td>${esc(a.name)}</td>
      <td>${esc(a.groupPrefix)}</td>
      <td>${esc(a.suffix)}</td>
      <td>${esc(a.county)}</td>
      <td>${
        a.countyAbbrev
          ? esc(a.countyAbbrev)
          : `<button class="btn" type="button" onclick="openCountyAbbrevModal('${esc(a._id ?? a.id ?? "")}')">Update</button>`
      }</td>
      <td>${esc(a.state || "")}</td>
      <td>${esc(a.type)}</td>
      <td>${buildAgencyColorCellHtml(a)}</td>
      <td>
        <div class="row agencyActionsCell" style="gap: 10px; flex-wrap: wrap;">
          <button class="btn" type="button"
            onclick="openAgencyAdmins('${esc(a._id ?? a.id ?? "")}')">
            View Admins
          </button>
          <% if (typeof isGlobalAdmin !== "undefined" && isGlobalAdmin) { %>
          <button class="btn btn-access" type="button"
            onclick="openAccessGroupsModal('${esc(a._id ?? a.id ?? "")}')">
            Manage Access
          </button>
          <% } %>
          <button class="btn" type="button"
            onclick="openDomainModal('${esc(a._id ?? a.id ?? "")}')">
            Configure Domain
          </button>
          <button class="btn danger" type="button"
            onclick="delAgency('${esc(a._id ?? a.id ?? "")}')">
            Delete
          </button>
        </div>
      </td>
    </tr>
  `).join("");
}

// Open admins modal for the agency's computed admin group.
window.openAgencyAdmins = async (agencyId) => {
  const a = (agencies || []).find(x => String(x._id ?? x.id) === String(agencyId));
  if(!a){
    setMsg("Could not find agency.", false);
    return;
  }

  const groupName = adminGroupNameForAgency(a);
  if(!groupName){
    setMsg("Agency abbreviation is missing; cannot determine admin group.", false);
    return;
  }

  activeAdminsGroupName = groupName;
  activeAdminsGroupId = "";
  activeAdmins = [];

  adminsSummary.textContent = `Loading admins for "${groupName}"...`;
  adminsSummary.className = "msg";
  adminsList.innerHTML = "";
  adminsHint.textContent = "";
  if (adminsFilter) adminsFilter.value = "";

  showAdminsModal(true);

  try {
    // Resolve group via agencies API (unfiltered; bypasses GROUPS_HIDDEN_PREFIXES)
    const gRes = await fetch(`/api/agencies/${encodeURIComponent(String(a._id ?? a.id ?? ""))}/admin-group`);
    const gOut = await gRes.json();
    if(!gRes.ok) throw new Error(gOut.error || "Failed to resolve admin group");

    const g = gOut?.group;
    if(!g || !g.pk){
      adminsSummary.textContent = `Admin group "${groupName}" was not found in Authentik.`;
      adminsSummary.className = "msg bad";
      adminsHint.textContent = "If this agency was created before the new auto-create behavior, create this group in Authentik or re-save the agency.";
      return;
    }

    activeAdminsGroupId = String(g.pk);

    const res = await fetch(`/api/groups/${encodeURIComponent(activeAdminsGroupId)}/members`);
    const out = await res.json();
    if(!res.ok) throw new Error(out.error || "Failed to load admins");

    activeAdmins = Array.isArray(out.users) ? out.users : [];
    const memberCount = typeof out.memberCount === "number" ? out.memberCount : activeAdmins.length;

    adminsSummary.textContent = `${memberCount} admin${memberCount === 1 ? "" : "s"} in group "${groupName}".`;
    adminsSummary.className = "msg ok";
    adminsHint.textContent = memberCount
      ? "Showing current admins for this agency. Use Remove to strip admin access from individual users."
      : "No users are currently assigned to this agency admin group.";

    renderAdminsList();
  } catch (e) {
    adminsSummary.textContent = "Failed to load admins.";
    adminsSummary.className = "msg bad";
    adminsList.innerHTML = "";
    adminsHint.textContent = "";
    activeAdmins = [];
  }
};

window.removeUserFromAdminsGroup = async (userPk) => {
  if(!activeAdminsGroupId) return;

  if(!confirm(`Remove this user from "${activeAdminsGroupName || activeAdminsGroupId}"?`)) return;

  try {
    const res = await fetch("/api/groups/mass-unassign", {
      method: "POST",
      headers: {"Content-Type":"application/json"},
      body: JSON.stringify({
        groupId: activeAdminsGroupId,
        userIds: [String(userPk)]
      })
    });
    const out = await res.json();
    if(!res.ok){
      alert(out.error || "Failed to remove user from admin group.");
      return;
    }

    // Optimistically update local list
    activeAdmins = (activeAdmins || []).filter(u => String(u?.pk || u?.id) !== String(userPk));
    adminsSummary.textContent = `${activeAdmins.length} admin${activeAdmins.length === 1 ? "" : "s"} in group "${activeAdminsGroupName || activeAdminsGroupId}".`;
    adminsSummary.className = "msg ok";
    renderAdminsList();
  } catch (e) {
    alert("Failed to remove user from admin group.");
  }
};

async function loadAgenciesWithCounts(){
  const res = await fetch("/api/agencies/with-counts");
  const data = await res.json();

  if(!res.ok){
    setMsg(data.error || "Failed to load agencies", false);
    return;
  }

  // Expecting each agency to include an id (recommended). We'll still render even if missing.
  agencies = Array.isArray(data) ? data : [];
  renderAgencies();
}

// Prefer deleting by real id.
// If your API currently deletes by index, update the backend route to delete by id.
window.delAgency = async (id) => {
  if(!confirm("Delete this agency?")) return;

  if(!id){
    setMsg("Missing agency id (API should return _id/id).", false);
    return;
  }

  const res = await fetch("/api/agencies/" + encodeURIComponent(id), { method:"DELETE" });
  const out = await res.json();

  if(!res.ok){
    setMsg(out.error || "Delete failed", false);
    return;
  }

  setMsg("Agency deleted", true);
  loadAgenciesWithCounts();
};

// === County normalization helpers ===
function toTitleCaseWords(str) {
  return String(str || "")
    .toLowerCase()
    .trim()
    .split(/\s+/)
    .filter(Boolean)
    .map(w => w.charAt(0).toUpperCase() + w.slice(1))
    .join(" ");
}

// Handler for fixing county names
function normalizeCountyName(raw) {
  let v = String(raw || "").trim().replace(/\s+/g, " ");
  if (!v) return "";

  const lower = v.toLowerCase();
  if (lower.endsWith(" county")) {
    // strip " county" and title-case the base name
    const base = v.slice(0, lower.lastIndexOf(" county"));
    return toTitleCaseWords(base);
  } else {
    // just title-case whatever they typed
    return toTitleCaseWords(v);
  }
}

// === Configure domain / account lookup (agency index id from API) ===
let currentLookupAgencyId = null;
let currentLookupModalEnabled = false;

function syncLookupModalActionButtons() {
  const enableBtn = document.getElementById("confirmEnableLookup");
  const disableBtn = document.getElementById("disableLookupInModalBtn");
  if (!enableBtn || !disableBtn) return;
  if (currentLookupModalEnabled) {
    enableBtn.style.display = "none";
    disableBtn.style.display = "";
  } else {
    enableBtn.style.display = "";
    disableBtn.style.display = "none";
  }
}

window.openDomainModal = (id) => {
  if (!id) return;
  const a = (agencies || []).find((x) => String(x._id ?? x.id) === String(id));
  currentLookupAgencyId = id;
  currentLookupModalEnabled = !!(a && a.lookupEnabled);
  const domainInput = document.getElementById("lookupDomain");
  const err = document.getElementById("domainError");
  if (domainInput) domainInput.value = a && a.lookupDomain != null ? String(a.lookupDomain) : "";
  if (err) err.style.display = "none";
  syncLookupModalActionButtons();
  showLookupModal(true);
};

// Close lookup modal helper
function showLookupModal(on) {
  const modal = document.getElementById("lookupModal");
  if (!modal) return;

  modal.style.display = on ? "flex" : "none";
  document.body.style.overflow = on ? "hidden" : "";
}

// Close when clicking outside modal (overlay)
const lookupOverlay = document.getElementById("lookupModal");

if (lookupOverlay) {
  lookupOverlay.addEventListener("click", (e) => {
    if (e.target === lookupOverlay) {
      showLookupModal(false);
    }
  });
}

function parseDomainListClient(raw) {
  return String(raw || "")
    .split(",")
    .map((s) => s.trim())
    .filter(Boolean);
}

const domainPartRegex = /^[a-zA-Z0-9.-]+\.[a-zA-Z]{2,}$/;

function validateDomainFieldForSave(domainInput, errorEl) {
  const parts = parseDomainListClient(domainInput.value);
  for (const p of parts) {
    if (p.includes("@") || !domainPartRegex.test(p)) {
      errorEl.style.display = "block";
      return false;
    }
  }
  errorEl.style.display = "none";
  return true;
}

const saveLookupDomainsBtn = document.getElementById("saveLookupDomainsBtn");
if (saveLookupDomainsBtn) {
  saveLookupDomainsBtn.onclick = function () {
    const domainInput = document.getElementById("lookupDomain");
    const error = document.getElementById("domainError");
    if (!currentLookupAgencyId || !domainInput || !error) return;
    if (!validateDomainFieldForSave(domainInput, error)) return;

    fetch(`/api/agencies/${encodeURIComponent(currentLookupAgencyId)}/lookup/domain`, {
      method: "POST",
      headers: { "Content-Type": "application/json" },
      body: JSON.stringify({ lookupDomain: domainInput.value.trim() })
    })
      .then(async (res) => {
        const out = await res.json().catch(() => ({}));
        if (!res.ok) {
          error.textContent = out.error || "Could not save domains.";
          error.style.display = "block";
          return;
        }
        await loadAgenciesWithCounts();
        const a = (agencies || []).find((x) => String(x._id ?? x.id) === String(currentLookupAgencyId));
        if (domainInput && a) domainInput.value = a.lookupDomain != null ? String(a.lookupDomain) : "";
        setMsg("Domains saved.", true);
      })
      .catch(() => {
        error.textContent = "Could not save domains.";
        error.style.display = "block";
      });
  };
}

const confirmEnableLookupBtn = document.getElementById("confirmEnableLookup");
if (confirmEnableLookupBtn) {
  confirmEnableLookupBtn.onclick = function () {
    const domainInput = document.getElementById("lookupDomain");
    const error = document.getElementById("domainError");
    if (!currentLookupAgencyId || !domainInput || !error) return;
    if (!validateDomainFieldForSave(domainInput, error)) return;
    const parts = parseDomainListClient(domainInput.value);
    if (parts.length === 0) {
      error.textContent = "Enter at least one domain to enable lookup.";
      error.style.display = "block";
      return;
    }

    fetch(`/api/agencies/${encodeURIComponent(currentLookupAgencyId)}/lookup/enable`, {
      method: "POST",
      headers: { "Content-Type": "application/json" },
      body: JSON.stringify({ lookupDomain: domainInput.value.trim() })
    })
      .then(async (res) => {
        const out = await res.json().catch(() => ({}));
        if (!res.ok) {
          error.textContent = out.error || "Could not enable lookup.";
          error.style.display = "block";
          return;
        }
        currentLookupModalEnabled = true;
        await loadAgenciesWithCounts();
        syncLookupModalActionButtons();
        setMsg("Account lookup enabled.", true);
      })
      .catch(() => {
        error.textContent = "Could not enable lookup.";
        error.style.display = "block";
      });
  };
}

const disableLookupInModalBtn = document.getElementById("disableLookupInModalBtn");
if (disableLookupInModalBtn) {
  disableLookupInModalBtn.onclick = function () {
    if (!currentLookupAgencyId) return;
    if (!confirm("Disable account lookup for this agency? Approved domains stay saved for Request Access and you can turn lookup on again later.")) return;

    fetch(`/api/agencies/${encodeURIComponent(currentLookupAgencyId)}/lookup/disable`, {
      method: "POST"
    })
      .then(async (res) => {
        const out = await res.json().catch(() => ({}));
        const error = document.getElementById("domainError");
        if (!res.ok) {
          if (error) {
            error.textContent = out.error || "Could not disable lookup.";
            error.style.display = "block";
          }
          return;
        }
        currentLookupModalEnabled = false;
        syncLookupModalActionButtons();
        await loadAgenciesWithCounts();
        setMsg("Account lookup disabled.", true);
      })
      .catch(() => {
        const error = document.getElementById("domainError");
        if (error) {
          error.textContent = "Could not disable lookup.";
          error.style.display = "block";
        }
      });
  };
}

const COUNTY_KEY = "lastCountyUsed";

function loadLastCounty() {
  try {
    const stored = localStorage.getItem(COUNTY_KEY);
    if (stored) {
      addForm.elements.county.value = stored;
    }
  } catch (e) {
    // localStorage might be unavailable in some environments; fail silently
  }
}

function saveLastCounty(county) {
  try {
    localStorage.setItem(COUNTY_KEY, county);
  } catch (e) {
    // ignore storage errors
  }
}

function findExistingCountyAbbrev(state, county) {
  const s = String(state || "").trim().toUpperCase();
  const c = String(county || "").trim().toLowerCase();
  if (!s || !c) return null;
  const match = (agencies || []).find(a =>
    String(a.state || "").trim().toUpperCase() === s &&
    String(a.county || "").trim().toLowerCase() === c &&
    String(a.countyAbbrev || "").trim() !== ""
  );
  return match ? String(match.countyAbbrev).trim().toUpperCase() : null;
}

function syncCountyAbbrevFromExisting() {
  if (!addForm) return;
  const stateInput = addForm.elements.state;
  const countyInput = addForm.elements.county;
  const countyAbbrevInput = addForm.elements.countyAbbrev;
  if (!stateInput || !countyInput || !countyAbbrevInput) return;

  const normalizedCounty = normalizeCountyName(countyInput.value);
  if (normalizedCounty !== countyInput.value) {
    countyInput.value = normalizedCounty;
  }

  const existing = findExistingCountyAbbrev(stateInput.value, countyInput.value);
  if (existing) {
    countyAbbrevInput.value = existing;
    countyAbbrevInput.readOnly = true;
    countyAbbrevInput.classList.add("readonly");
  } else {
    if (countyAbbrevInput.readOnly) {
      countyAbbrevInput.readOnly = false;
      countyAbbrevInput.classList.remove("readonly");
    }
    // Do not overwrite user-entered value if they already started typing
    if (!countyAbbrevInput.value) {
      countyAbbrevInput.value = "";
    }
  }
}

let countyAbbrevAgencyId = null;

function showCountyAbbrevModal(on) {
  const overlay = document.getElementById("countyAbbrevOverlay");
  if (!overlay) return;
  overlay.style.display = on ? "flex" : "none";
  document.body.style.overflow = on ? "hidden" : "";
}

window.openCountyAbbrevModal = (agencyId) => {
  countyAbbrevAgencyId = agencyId;
  const input = document.getElementById("countyAbbrevInput");
  const summary = document.getElementById("countyAbbrevSummary");
  if (input) input.value = "";
  if (summary) {
    const a = (agencies || []).find(x => String(x._id ?? x.id) === String(agencyId));
    summary.textContent = a
      ? `Set county abbreviation for ${a.name} (${a.groupPrefix}).`
      : "Set county abbreviation for this agency.";
    summary.className = "msg";
  }
  showCountyAbbrevModal(true);
};

const countyAbbrevOverlay = document.getElementById("countyAbbrevOverlay");
const countyAbbrevCloseBtn = document.getElementById("countyAbbrevCloseBtn");
const countyAbbrevCancelBtn = document.getElementById("countyAbbrevCancelBtn");
const countyAbbrevSaveBtn = document.getElementById("countyAbbrevSaveBtn");

if (countyAbbrevOverlay) {
  countyAbbrevOverlay.addEventListener("click", (e) => {
    if (e.target === countyAbbrevOverlay) showCountyAbbrevModal(false);
  });
}
if (countyAbbrevCloseBtn) countyAbbrevCloseBtn.onclick = () => showCountyAbbrevModal(false);
if (countyAbbrevCancelBtn) countyAbbrevCancelBtn.onclick = () => showCountyAbbrevModal(false);
if (countyAbbrevSaveBtn) {
  countyAbbrevSaveBtn.onclick = async () => {
    const input = document.getElementById("countyAbbrevInput");
    const summary = document.getElementById("countyAbbrevSummary");
    const raw = (input && input.value) || "";
    const value = String(raw).trim().toUpperCase().replace(/[^A-Z]/g, "");
    if (!value || value.length < 3) {
      if (summary) {
        summary.textContent = "County abbreviation must be at least 3 letters.";
        summary.className = "msg bad";
      }
      return;
    }
    if (!countyAbbrevAgencyId) return;

    try {
      const res = await fetch(`/api/agencies/${encodeURIComponent(countyAbbrevAgencyId)}/county-abbrev`, {
        method: "PUT",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ countyAbbrev: value }),
      });
      const out = await res.json();
      if (!res.ok) {
        if (summary) {
          summary.textContent = out.error || "Failed to update county abbreviation.";
          summary.className = "msg bad";
        }
        return;
      }
      showCountyAbbrevModal(false);
      setMsg("County abbreviation updated.", true);
      loadAgenciesWithCounts();
    } catch (e) {
      if (summary) {
        summary.textContent = "Failed to update county abbreviation.";
        summary.className = "msg bad";
      }
    }
  };
}

addForm.onsubmit = async (e) => {
  e.preventDefault();
  setMsg("");

  // Normalize county before sending to backend
  const countyInput = addForm.elements.county;
  countyInput.value = normalizeCountyName(countyInput.value);

  // If an existing county abbreviation is known for this state+county, lock it in.
  const stateInput = addForm.elements.state;
  const countyAbbrevInput = addForm.elements.countyAbbrev;
  if (stateInput && countyInput && countyAbbrevInput) {
    const existing = findExistingCountyAbbrev(stateInput.value, countyInput.value);
    if (existing) {
      countyAbbrevInput.value = existing;
      countyAbbrevInput.readOnly = true;
      countyAbbrevInput.classList.add("readonly");
    }
  }

  // Save last-used county AFTER normalization
  if (countyInput.value) {
    saveLastCounty(countyInput.value);
  }

  const body = Object.fromEntries(new FormData(addForm));

  const res = await fetch("/api/agencies", {
    method:"POST",
    headers: {"Content-Type":"application/json"},
    body: JSON.stringify(body)
  });

  const out = await res.json();
  if(!res.ok){
    setMsg(out.error || "Add failed", false);
    return;
  }

  addForm.reset();

  // Restore last-used county
  loadLastCounty();

  setMsg("Agency added", true);
  loadAgenciesWithCounts();
};

if (refreshBtn) refreshBtn.onclick = () => loadAgenciesWithCounts();

// ---- Access Groups modal ----
const accessGroupsOverlay = document.getElementById("accessGroupsOverlay");
const accessGroupsCloseBtn = document.getElementById("accessGroupsCloseBtn");
const accessGroupsCancelBtn = document.getElementById("accessGroupsCancelBtn");
const accessGroupsSaveBtn = document.getElementById("accessGroupsSaveBtn");
const accessGroupsSummary = document.getElementById("accessGroupsSummary");
const accessGroupSearch = document.getElementById("accessGroupSearch");
const accessGroupsBox = document.getElementById("accessGroupsBox");
const accessGroupsInner = document.getElementById("accessGroupsInner");
const accessGroupsSelectAllBtn = document.getElementById("accessGroupsSelectAllBtn");
const accessGroupsClearBtn = document.getElementById("accessGroupsClearBtn");

let accessGroupsAgencyId = null;
let accessGroupsAllGroups = [];
let accessGroupsSelectable = [];
let accessGroupsPickedIds = new Set();

function displayGroupName(name) {
  return String(name || "").replace(/^tak_/i, "");
}

function getGroupPrefix(groupName) {
  const n = String(groupName || "").trim();
  const withoutTak = n.toLowerCase().startsWith("tak_") ? n.slice(4) : n;
  const spaceIdx = withoutTak.toUpperCase().indexOf(" ");
  if (spaceIdx <= 0) return "";
  return withoutTak.slice(0, spaceIdx).trim().toUpperCase();
}

// Exclude only this agency's own groups (prefix = agency abbreviation). Include global, state, and county.
function isGroupRelatedToAgency(groupName, agency) {
  const prefix = getGroupPrefix(groupName);
  if (!prefix) return false;
  const gp = String(agency?.groupPrefix || "").trim().toUpperCase();
  return prefix === gp;
}

function renderAccessGroupsGrid(filterText) {
  const q = String(filterText || "").trim().toLowerCase();
  const list = q
    ? accessGroupsSelectable.filter(g => {
        const name = String(g.name || "").toLowerCase();
        const disp = displayGroupName(g.name).toLowerCase();
        return name.includes(q) || disp.includes(q);
      })
    : accessGroupsSelectable;
  const sorted = [...list].sort((a, b) =>
    String(a.name || "").localeCompare(String(b.name || ""), undefined, { sensitivity: "base" })
  );
  accessGroupsInner.innerHTML = sorted.map(g => {
    const id = String(g.pk ?? g.id ?? "");
    const checked = accessGroupsPickedIds.has(id) ? "checked" : "";
    return `
      <label class="groupItem">
        <input type="checkbox" value="${escAttr(id)}" ${checked} />
        <span>${esc(displayGroupName(g.name))}</span>
      </label>
    `;
  }).join("");

  accessGroupsBox.querySelectorAll("input[type=checkbox]").forEach(cb => {
    cb.addEventListener("change", () => {
      const id = String(cb.value);
      if (cb.checked) accessGroupsPickedIds.add(id);
      else accessGroupsPickedIds.delete(id);
    });
  });
}

function showAccessGroupsModal(on) {
  if (!accessGroupsOverlay) return;
  accessGroupsOverlay.style.display = on ? "flex" : "none";
  document.body.style.overflow = on ? "hidden" : "";
}

window.openAccessGroupsModal = async (agencyId) => {
  const a = (agencies || []).find(x => String(x._id ?? x.id) === String(agencyId));
  if (!a) {
    setMsg("Agency not found.", false);
    return;
  }
  accessGroupsAgencyId = agencyId;
  accessGroupsSummary.textContent = `Loading groups for "${esc(a.name || "")}"...`;
  accessGroupsSummary.className = "msg";
  accessGroupsInner.innerHTML = "";
  if (accessGroupSearch) accessGroupSearch.value = "";
  accessGroupsPickedIds = new Set();
  showAccessGroupsModal(true);

  try {
    const [groupsRes, allowedRes] = await Promise.all([
      fetch("/api/groups"),
      fetch(`/api/agencies/${encodeURIComponent(agencyId)}/access-groups`)
    ]);
    const groupsData = await groupsRes.json();
    const allowedData = await allowedRes.json();
    if (!groupsRes.ok) throw new Error(groupsData.error || "Failed to load groups");
    if (!allowedRes.ok) throw new Error(allowedData.error || "Failed to load access groups");

    const allGroups = Array.isArray(groupsData) ? groupsData : [];
    accessGroupsSelectable = allGroups.filter(g => !isGroupRelatedToAgency(g.name, a));
    accessGroupsPickedIds = new Set(Array.isArray(allowedData.allowedAdminGroupIds) ? allowedData.allowedAdminGroupIds : []);

    accessGroupsSummary.textContent = `Select extra groups that administrators for "${esc(a.name || "")}" can see. They always see their own agency groups.`;
    accessGroupsSummary.className = "msg ok";
    renderAccessGroupsGrid("");
  } catch (e) {
    accessGroupsSummary.textContent = e.message || "Failed to load.";
    accessGroupsSummary.className = "msg bad";
  }
};

if (accessGroupSearch) accessGroupSearch.addEventListener("input", () => renderAccessGroupsGrid(accessGroupSearch.value));
if (accessGroupsSelectAllBtn) accessGroupsSelectAllBtn.onclick = () => {
  accessGroupsSelectable.forEach(g => accessGroupsPickedIds.add(String(g.pk ?? g.id ?? "")));
  renderAccessGroupsGrid(accessGroupSearch?.value || "");
};
if (accessGroupsClearBtn) accessGroupsClearBtn.onclick = () => {
  accessGroupsPickedIds.clear();
  renderAccessGroupsGrid(accessGroupSearch?.value || "");
};
if (accessGroupsCloseBtn) accessGroupsCloseBtn.onclick = () => showAccessGroupsModal(false);
if (accessGroupsCancelBtn) accessGroupsCancelBtn.onclick = () => showAccessGroupsModal(false);
if (accessGroupsOverlay) accessGroupsOverlay.addEventListener("click", e => { if (e.target === accessGroupsOverlay) showAccessGroupsModal(false); });

if (accessGroupsSaveBtn) accessGroupsSaveBtn.onclick = async () => {
  if (!accessGroupsAgencyId) return;
  try {
    const res = await fetch(`/api/agencies/${encodeURIComponent(accessGroupsAgencyId)}/access-groups`, {
      method: "PUT",
      headers: { "Content-Type": "application/json" },
      body: JSON.stringify({ allowedAdminGroupIds: Array.from(accessGroupsPickedIds) })
    });
    const out = await res.json();
    if (!res.ok) throw new Error(out.error || "Save failed");
    setMsg("Access groups updated.", true);
    showAccessGroupsModal(false);
    loadAgenciesWithCounts();
  } catch (e) {
    setMsg(e.message || "Save failed", false);
  }
};

// click-to-sort + keyboard support (Enter/Space)
agencyTable.querySelectorAll("thead th[data-sort]").forEach(th => {
  th.addEventListener("click", () => {
    const key = th.dataset.sort;
    if (sortState.key === key){
      sortState.dir *= -1; // toggle direction
    } else {
      sortState.key = key;
      sortState.dir = 1;
    }
    renderAgencies();
  });

  th.addEventListener("keydown", (e) => {
    if (e.key === "Enter" || e.key === " "){
      e.preventDefault();
      th.click();
    }
  });
});

// Initialize last county + data on page load
loadLastCounty();
loadAgenciesWithCounts();

// Wire up auto-fill for county abbreviation based on existing agencies
if (addForm) {
  const stateInput = addForm.elements.state;
  const countyInput = addForm.elements.county;
  if (stateInput) {
    stateInput.addEventListener("change", syncCountyAbbrevFromExisting);
  }
  if (countyInput) {
    countyInput.addEventListener("blur", syncCountyAbbrevFromExisting);
  }
}
</script>

