<%- include("partials/header") %>
<%- include("partials/sidebar") %>

<main class="main">
  <h1>Manage Agencies</h1>

  <div class="card">
    <h2>Add Agency</h2>
    <form id="addForm" class="row">
      <!-- 1) Agency name -->
      <label>Agency Full Name
        <input name="name" placeholder="Agency Name" required style="flex: 2;" />
      </label>

      <!-- 2) Group prefix -->
      <label>Agency Abbreviation
        <input name="groupPrefix" placeholder="(ex. HCSO, HCOEM, etc...)" required
               oninput="this.value = this.value.toUpperCase()" />
      </label>

      <!-- 3) Username suffix -->
      <label>Username Suffix
        <input name="suffix" placeholder="(ex. hs, hcoem, etc...)" required
               oninput="this.value = this.value.toLowerCase()" />
      </label>

      <!-- 4) County text input (normalized + last-used) -->
      <label>County
        <input
          name="county"
          placeholder="(ex. Hamilton, Marion)"
          required
        />
      </label>

      <!-- 5) Type dropdown -->
      <label>Agency Type
        <select name="type" required>
          <option value="" disabled selected>Agency Type</option>
          <option value="Law Enforcement">Law Enforcement</option>
          <option value="Fire">Fire</option>
          <option value="EMS">EMS</option>
          <option value="State Defense">State Defense</option>
          <option value="Military">Military</option>
          <option value="TWRA / NPS / Forestry">TWRA / NPS / Forestry</option>
          <option value="CBRNE / HAZMAT">CBRNE / HAZMAT</option>
          <option value="SAR / Technical">SAR / Technical</option>
          <option value="Emergency Management">Emergency Management</option>
          <option value="Dispatch / Communications">Dispatch / Communications</option>
          <option value="Public Works">Public Works</option>
          <option value="Volunteer">Volunteer</option>
          <option value="Other">Other</option>
        </select>
      </label>

      <!-- 6) Color dropdown -->
      <label>Agency Color
        <select name="color" required>
          <option value="" disabled selected>Color</option>
          <option value="Blue">Blue</option>
          <option value="Dark Blue">Dark Blue</option>
          <option value="Brown">Brown</option>
          <option value="Cyan">Cyan</option>
          <option value="Green">Green</option>
          <option value="Dark Green">Dark Green</option>
          <option value="Magenta">Magenta</option>
          <option value="Maroon">Maroon</option>
          <option value="Orange">Orange</option>
          <option value="Purple">Purple</option>
          <option value="Red">Red</option>
          <option value="Teal">Teal</option>
          <option value="White">White</option>
          <option value="Yellow">Yellow</option>
        </select>
      </label>
      
      <label> <br>
      <button class="btn">Create Agency</button></label>
    </form>
    <div id="msg" class="msg"></div>
  </div>

  <div class="card">
    <div class="row" style="justify-content: space-between;">
      <h2 style="margin:0;">Current Agencies</h2>
    </div>

    <table class="table" id="agencyTable">
      <thead>
        <tr>
          <th data-sort="name" role="button" tabindex="0" title="Sort by Agency">Agency</th>
          <th data-sort="groupPrefix" role="button" tabindex="0" title="Sort by Abbreviation">Abbreviation</th>
          <th data-sort="suffix" role="button" tabindex="0" title="Sort by Username Suffix">Username Suffix</th>
          <th data-sort="county" role="button" tabindex="0" title="Sort by County">County</th>
          <th data-sort="type" role="button" tabindex="0" title="Sort by Type">Type</th>
          <th data-sort="color" role="button" tabindex="0" title="Sort by Color">Color</th>
          <th>Admin Group</th>
          <th>Actions</th>
        </tr>
      </thead>
      <tbody id="tbody"></tbody>
    </table>
  </div>
</main>

<!-- Agency Admins Modal (same behavior as Groups -> View Members) -->
<div class="modalOverlay" id="adminsOverlay" style="display:none;">
  <div class="modal" role="dialog" aria-modal="true" aria-labelledby="adminsTitle">
    <div class="modalHeader">
      <h2 id="adminsTitle" style="margin:0;">Agency Admins</h2>
      <button class="btn" id="adminsCloseBtn" type="button">Close</button>
    </div>
    <div class="modalBody">
      <div id="adminsSummary" class="msg"></div>

      <div style="margin-top:14px;">
        <input
          id="adminsFilter"
          placeholder="Filter by username, name, or email..."
          style="width: 100%; box-sizing: border-box;"
        />
      </div>

      <div
        id="adminsList"
        class="groupsBox"
        style="margin-top:10px; max-height: 320px; overflow:auto;"
      ></div>
      <small id="adminsHint" class="muted"></small>
    </div>
  </div>
</div>

<script>
const msg = document.getElementById("msg");
const tbody = document.getElementById("tbody");
const addForm = document.getElementById("addForm");
const refreshBtn = document.getElementById("refreshBtn");
const agencyTable = document.getElementById("agencyTable");

// Admins modal (mirrors Groups page View Members)
const adminsOverlay = document.getElementById("adminsOverlay");
const adminsCloseBtn = document.getElementById("adminsCloseBtn");
const adminsSummary = document.getElementById("adminsSummary");
const adminsFilter = document.getElementById("adminsFilter");
const adminsList = document.getElementById("adminsList");
const adminsHint = document.getElementById("adminsHint");

let agencies = [];
let sortState = { key: "name", dir: 1 }; // default: Agency asc

function setMsg(text, ok=true){
  msg.textContent = text || "";
  msg.className = "msg " + (ok ? "ok" : "bad");
}

function esc(s){
  return String(s ?? "")
    .replaceAll("&","&amp;")
    .replaceAll("<","&lt;")
    .replaceAll(">","&gt;");
}

function normalizeVal(v){
  if (v === null || v === undefined) return "";
  return String(v).toLowerCase().trim();
}

function adminGroupNameForAgency(a){
  const abbr = String(a?.groupPrefix || "").trim().toUpperCase();
  if(!abbr) return "";
  return `authentik-${abbr}-AgencyAdmin`;
}

// ---- Admin modal behavior (copy of Groups -> View Members) ----
let activeAdmins = [];
let activeAdminsGroupId = "";
let activeAdminsGroupName = "";

function showAdminsModal(on){
  if(!adminsOverlay) return;
  adminsOverlay.style.display = on ? "flex" : "none";
  document.body.style.overflow = on ? "hidden" : "";
}

function escAttr(s){
  return String(s ?? "")
    .replaceAll("&","&amp;")
    .replaceAll("<","&lt;")
    .replaceAll(">","&gt;")
    .replaceAll('"',"&quot;")
    .replaceAll("'","&#39;");
}

function memberRow(u){
  const username = String(u?.username || "");
  const name = String(u?.name || u?.displayName || "");
  const email = String(u?.email || "");
  const pk = String(u?.pk || u?.id || "");
  const canRemove = !!(activeAdminsGroupId && pk);
  return `
    <tr>
      <td>${escAttr(username)}</td>
      <td>${escAttr(name)}</td>
      <td>${escAttr(email)}</td>
      <td style="text-align:right;">
        ${canRemove ? `<button class="btn danger" type="button" onclick="removeUserFromAdminsGroup('${escAttr(pk)}')">Remove</button>` : ``}
      </td>
    </tr>
  `;
}

function renderAdminsList(){
  const needle = String(adminsFilter?.value || "").trim().toLowerCase();
  const filtered = needle
    ? (activeAdmins || []).filter(u => {
        const u1 = String(u?.username || "").toLowerCase();
        const u2 = String(u?.name || u?.displayName || "").toLowerCase();
        const u3 = String(u?.email || "").toLowerCase();
        return u1.includes(needle) || u2.includes(needle) || u3.includes(needle);
      })
    : (activeAdmins || []);

  const rowsHtml = filtered.map(memberRow).join("");
  adminsList.innerHTML = `
    <table class="table" style="margin:0;">
      <thead>
        <tr>
          <th>Username</th>
          <th>Name</th>
          <th>Email</th>
          <th style="text-align:right;">Actions</th>
        </tr>
      </thead>
      <tbody>
        ${rowsHtml || `<tr><td colspan="4" class="muted">No users found.</td></tr>`}
      </tbody>
    </table>
  `;
}

if (adminsCloseBtn) adminsCloseBtn.onclick = () => showAdminsModal(false);
if (adminsOverlay) adminsOverlay.addEventListener("click", (e) => {
  if (e.target === adminsOverlay) showAdminsModal(false);
});
if (adminsFilter) adminsFilter.oninput = renderAdminsList;

function renderAgencies(){
  // apply sort (copy to avoid mutating original order if you later want it)
  const rows = [...agencies];

  if (sortState.key){
    const key = sortState.key;
    const dir = sortState.dir;
    const th = agencyTable.querySelector(`thead th[data-sort="${CSS.escape(key)}"]`);
    const type = th?.dataset.type || "text";

    rows.sort((a,b) => {
      if (type === "number"){
        const av = Number(a[key] ?? 0);
        const bv = Number(b[key] ?? 0);
        return (av - bv) * dir;
      } else {
        const av = normalizeVal(a[key]);
        const bv = normalizeVal(b[key]);
        return av.localeCompare(bv) * dir;
      }
    });
  }

  // update header indicators
  agencyTable.querySelectorAll("thead th[data-sort]").forEach(th => {
    th.classList.remove("sorted-asc","sorted-desc");
    if (th.dataset.sort === sortState.key){
      th.classList.add(sortState.dir === 1 ? "sorted-asc" : "sorted-desc");
    }
  });

  tbody.innerHTML = rows.map((a)=>`
    <tr>
      <td>${esc(a.name)}</td>
      <td>${esc(a.groupPrefix)}</td>
      <td>${esc(a.suffix)}</td>
      <td>${esc(a.county)}</td>
      <td>${esc(a.type)}</td>
      <td>${esc(a.color || "")}</td>
      <td>${esc(adminGroupNameForAgency(a))}</td>
      <td>
        <button class="btn" type="button" onclick="openAgencyAdmins('${esc(a._id ?? a.id ?? "")}')">View Admins</button>
        <button class="btn danger" type="button" onclick="delAgency('${esc(a._id ?? a.id ?? "")}')">Delete</button>
      </td>
    </tr>
  `).join("");
}

// Open admins modal for the agency's computed admin group.
window.openAgencyAdmins = async (agencyId) => {
  const a = (agencies || []).find(x => String(x._id ?? x.id) === String(agencyId));
  if(!a){
    setMsg("Could not find agency.", false);
    return;
  }

  const groupName = adminGroupNameForAgency(a);
  if(!groupName){
    setMsg("Agency abbreviation is missing; cannot determine admin group.", false);
    return;
  }

  activeAdminsGroupName = groupName;
  activeAdminsGroupId = "";
  activeAdmins = [];

  adminsSummary.textContent = `Loading admins for "${groupName}"...`;
  adminsSummary.className = "msg";
  adminsList.innerHTML = "";
  adminsHint.textContent = "";
  if (adminsFilter) adminsFilter.value = "";

  showAdminsModal(true);

  try {
    // Find the group (same strategy as Groups page, but by name)
    const gRes = await fetch("/api/groups");
    const gOut = await gRes.json();
    if(!gRes.ok) throw new Error(gOut.error || "Failed to load groups");

    const allGroups = Array.isArray(gOut) ? gOut : [];
    const g = allGroups.find(x => String(x?.name || "").trim().toLowerCase() === groupName.toLowerCase());
    if(!g || !g.pk){
      adminsSummary.textContent = `Admin group "${groupName}" was not found in Authentik.`;
      adminsSummary.className = "msg bad";
      adminsHint.textContent = "If this agency was created before the new auto-create behavior, create this group in Authentik or re-save the agency.";
      return;
    }

    activeAdminsGroupId = String(g.pk);

    const res = await fetch(`/api/groups/${encodeURIComponent(activeAdminsGroupId)}/members`);
    const out = await res.json();
    if(!res.ok) throw new Error(out.error || "Failed to load admins");

    activeAdmins = Array.isArray(out.users) ? out.users : [];
    const memberCount = typeof out.memberCount === "number" ? out.memberCount : activeAdmins.length;

    adminsSummary.textContent = `${memberCount} admin${memberCount === 1 ? "" : "s"} in group "${groupName}".`;
    adminsSummary.className = "msg ok";
    adminsHint.textContent = memberCount
      ? "Showing current admins for this agency. Use Remove to strip admin access from individual users."
      : "No users are currently assigned to this agency admin group.";

    renderAdminsList();
  } catch (e) {
    adminsSummary.textContent = "Failed to load admins.";
    adminsSummary.className = "msg bad";
    adminsList.innerHTML = "";
    adminsHint.textContent = "";
    activeAdmins = [];
  }
};

window.removeUserFromAdminsGroup = async (userPk) => {
  if(!activeAdminsGroupId) return;

  if(!confirm(`Remove this user from "${activeAdminsGroupName || activeAdminsGroupId}"?`)) return;

  try {
    const res = await fetch("/api/groups/mass-unassign", {
      method: "POST",
      headers: {"Content-Type":"application/json"},
      body: JSON.stringify({
        groupId: activeAdminsGroupId,
        userIds: [String(userPk)]
      })
    });
    const out = await res.json();
    if(!res.ok){
      alert(out.error || "Failed to remove user from admin group.");
      return;
    }

    // Optimistically update local list
    activeAdmins = (activeAdmins || []).filter(u => String(u?.pk || u?.id) !== String(userPk));
    adminsSummary.textContent = `${activeAdmins.length} admin${activeAdmins.length === 1 ? "" : "s"} in group "${activeAdminsGroupName || activeAdminsGroupId}".`;
    adminsSummary.className = "msg ok";
    renderAdminsList();
  } catch (e) {
    alert("Failed to remove user from admin group.");
  }
};

async function loadAgenciesWithCounts(){
  const res = await fetch("/api/agencies/with-counts");
  const data = await res.json();

  if(!res.ok){
    setMsg(data.error || "Failed to load agencies", false);
    return;
  }

  // Expecting each agency to include an id (recommended). We'll still render even if missing.
  agencies = Array.isArray(data) ? data : [];
  renderAgencies();
}

// Prefer deleting by real id.
// If your API currently deletes by index, update the backend route to delete by id.
window.delAgency = async (id) => {
  if(!confirm("Delete this agency?")) return;

  if(!id){
    setMsg("Missing agency id (API should return _id/id).", false);
    return;
  }

  const res = await fetch("/api/agencies/" + encodeURIComponent(id), { method:"DELETE" });
  const out = await res.json();

  if(!res.ok){
    setMsg(out.error || "Delete failed", false);
    return;
  }

  setMsg("Agency deleted", true);
  loadAgenciesWithCounts();
};

// === County normalization helpers ===
function toTitleCaseWords(str) {
  return String(str || "")
    .toLowerCase()
    .trim()
    .split(/\s+/)
    .filter(Boolean)
    .map(w => w.charAt(0).toUpperCase() + w.slice(1))
    .join(" ");
}

// Handler for fixing county names
function normalizeCountyName(raw) {
  let v = String(raw || "").trim().replace(/\s+/g, " ");
  if (!v) return "";

  const lower = v.toLowerCase();
  if (lower.endsWith(" county")) {
    // strip " county" and title-case the base name
    const base = v.slice(0, lower.lastIndexOf(" county"));
    return toTitleCaseWords(base);
  } else {
    // just title-case whatever they typed
    return toTitleCaseWords(v);
  }
}

// === Remember last-used county between form submissions ===
const COUNTY_KEY = "lastCountyUsed";

function loadLastCounty() {
  try {
    const stored = localStorage.getItem(COUNTY_KEY);
    if (stored) {
      addForm.elements.county.value = stored;
    }
  } catch (e) {
    // localStorage might be unavailable in some environments; fail silently
  }
}

function saveLastCounty(county) {
  try {
    localStorage.setItem(COUNTY_KEY, county);
  } catch (e) {
    // ignore storage errors
  }
}

addForm.onsubmit = async (e) => {
  e.preventDefault();
  setMsg("");

  // Normalize county before sending to backend
  const countyInput = addForm.elements.county;
  countyInput.value = normalizeCountyName(countyInput.value);

  // Save last-used county AFTER normalization
  if (countyInput.value) {
    saveLastCounty(countyInput.value);
  }

  const body = Object.fromEntries(new FormData(addForm));

  const res = await fetch("/api/agencies", {
    method:"POST",
    headers: {"Content-Type":"application/json"},
    body: JSON.stringify(body)
  });

  const out = await res.json();
  if(!res.ok){
    setMsg(out.error || "Add failed", false);
    return;
  }

  addForm.reset();

  // Restore last-used county
  loadLastCounty();

  setMsg("Agency added", true);
  loadAgenciesWithCounts();
};

if (refreshBtn) refreshBtn.onclick = () => loadAgenciesWithCounts();

// click-to-sort + keyboard support (Enter/Space)
agencyTable.querySelectorAll("thead th[data-sort]").forEach(th => {
  th.addEventListener("click", () => {
    const key = th.dataset.sort;
    if (sortState.key === key){
      sortState.dir *= -1; // toggle direction
    } else {
      sortState.key = key;
      sortState.dir = 1;
    }
    renderAgencies();
  });

  th.addEventListener("keydown", (e) => {
    if (e.key === "Enter" || e.key === " "){
      e.preventDefault();
      th.click();
    }
  });
});

// Initialize last county + data on page load
loadLastCounty();
loadAgenciesWithCounts();
</script>

<style>
/* Hide columns on small screens */
@media (max-width: 640px){
  .table th:nth-child(4),
  .table td:nth-child(4),
  .table th:nth-child(5),
  .table td:nth-child(5),
  .table th:nth-child(7),
  .table td:nth-child(7){
    display: none;
  }
}
@media (max-width: 835px){
  .table th:nth-child(6),
  .table td:nth-child(6){
    display: none;
  }
}

/* Make sortable headers look clickable */
.table thead th[data-sort]{
  cursor: pointer;
  user-select: none;
  position: relative;
  padding-right: 1.25rem;
}

/* Sort indicator */
.table thead th[data-sort].sorted-asc::after{
  content: "▲";
  position: absolute;
  right: 0.5rem;
  opacity: 0.7;
}
.table thead th[data-sort].sorted-desc::after{
  content: "▼";
  position: absolute;
  right: 0.5rem;
  opacity: 0.7;
}
</style>

</div></body></html>
