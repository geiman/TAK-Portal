<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1" />
    <title>TAK Portal</title>
    <link rel="stylesheet" href="/styles.css" />

    <% if (brandLogoUrl) { %>
      <link rel="icon" href="<%= brandLogoUrl %>" type="image/png" />
      <link rel="shortcut icon" href="<%= brandLogoUrl %>" type="image/png" />
    <% } %>
  </head>
  <body class="theme-<%= brandTheme || 'dark-blue' %>">

<div class="app">

<main class="main" style="max-width: 980px; margin: 0 auto;">
  <h1>Request TAK Portal Access</h1>

  <div class="card">
    <p>
      Please use this form to request access to TAK Portal. Once submitted, an administrator will review your request. After it has been approved, you will receive an email with instructions on how to access your account.
    </p>

    <% if (typeof error !== "undefined" && error) { %>
      <div class="msg bad" style="margin-bottom: 12px;"><%= error %></div>
    <% } %>

    <form method="POST" action="/request-access" class="grid2" autocomplete="off">

      <label>First Name
        <input name="firstName" required value="<%= (form && form.firstName) ? form.firstName : '' %>" />
      </label>

      <label>Last Name
        <input name="lastName" required value="<%= (form && form.lastName) ? form.lastName : '' %>" />
      </label>

      <label>Email Address
        <input name="email" type="email" required value="<%= (form && form.email) ? form.email : '' %>" />
      </label>

      <label>Badge Number
        <input name="badgeNumber" required value="<%= (form && form.badgeNumber) ? form.badgeNumber : '' %>" />
      </label>

      <label style="grid-column: 1 / -1;">Agency
        <select name="agencySuffix" id="agencySelect" required>
          <% 
            const list = Array.isArray(agencies) ? agencies.slice() : [];
            list.sort((a,b) => String(a?.name||'').localeCompare(String(b?.name||'')));
            const selected = (form && form.agencySuffix) ? String(form.agencySuffix) : '';
          %>
          <% list.forEach(a => { %>
            <option value="<%= a.suffix %>" <%= (selected && selected === a.suffix) ? 'selected' : '' %>>
              <%= a.name %> (<%= a.suffix %>)
            </option>
          <% }) %>
          <option value="__other__" <%= selected === '__other__' ? 'selected' : '' %>>Other / My Agency Isn't Listed</option>
        </select>
      </label>

      <div id="otherWrap" style="grid-column: 1 / -1; display:none;">
        <label>Agency Name
          <input name="otherAgency" id="otherAgency"
            value="<%= (form && form.otherAgency) ? form.otherAgency : '' %>" />
        </label>

        <label>Reason for requesting access
          <textarea name="otherReason" id="otherReason"
            rows="4" style="width: 100%; box-sizing: border-box;"><%= (form && form.otherReason) ? form.otherReason : '' %></textarea>
        </label>
      </div>

      <% if (hcaptchaEnabled && hcaptchaSiteKey) { %>
      <div style="grid-column: 1 / -1; margin-top: 10px;">
        <div id="hcaptchaWidget"></div>
        <div class="msg bad" id="hcaptchaError"
             style="margin-top: 8px; display:none;">
          Please complete the captcha before submitting.
        </div>
      </div>
      <% } %>

      <div style="grid-column: 1 / -1; display:flex; align-items:center; gap:10px; flex-wrap: wrap;">
        <button class="btn" id="submitRequestBtn" type="submit">
          Submit Request
        </button>
      </div>

    </form>
  </div>
</main>

<script>
(function(){
  const sel = document.getElementById('agencySelect');
  const wrap = document.getElementById('otherWrap');
  const otherAgency = document.getElementById('otherAgency');
  const otherReason = document.getElementById('otherReason');

  function update() {
    const isOther = sel && sel.value === '__other__';
    if (wrap) wrap.style.display = isOther ? 'block' : 'none';
    if (otherAgency) otherAgency.required = !!isOther;
    if (otherReason) otherReason.required = !!isOther;
  }

  if (sel) sel.addEventListener('change', update);
  update();
})();
</script>

<% if (hcaptchaEnabled && hcaptchaSiteKey) { %>
<script>
(function(){
  var form = document.querySelector('form[action="/request-access"]');
  var errorBox = document.getElementById('hcaptchaError');
  var captchaCompleted = false;

  if (!form) return;

  window.hcaptchaOnLoad = function() {
    try {
      hcaptcha.render('hcaptchaWidget', {
        sitekey: "<%= hcaptchaSiteKey %>",
        callback: function() {
          captchaCompleted = true;
          if (errorBox) errorBox.style.display = 'none';
        },
        'expired-callback': function() {
          captchaCompleted = false;
        },
        'error-callback': function() {
          captchaCompleted = false;
        }
      });
    } catch (e) {
      captchaCompleted = false;
    }
  };

  form.addEventListener('submit', function(e) {
    if (!captchaCompleted) {
      e.preventDefault();
      e.stopPropagation();

      if (errorBox) {
        errorBox.style.display = 'block';
        errorBox.scrollIntoView({ behavior: 'smooth', block: 'center' });
      }

      return false;
    }
  });
})();
</script>

<script src="https://js.hcaptcha.com/1/api.js?onload=hcaptchaOnLoad&render=explicit" async defer></script>
<% } %>

</div>
</body>
</html>