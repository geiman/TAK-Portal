<%- include("partials/header") %>
<%- include("partials/sidebar") %>

<main class="main">
  <h1>Dashboard</h1>

  <% if (mutualAid && (mutualAid.activeIncidents > 0 || mutualAid.activeEvents > 0)) { %>
    <div style="margin: 6px 0 10px 0;">
      <% if (mutualAid.activeIncidents > 0) { %>
        <div class="maBanner maBannerIncident">
          <%= mutualAid.activeIncidents %> Mutual Aid Incident<%= mutualAid.activeIncidents === 1 ? "" : "s" %> <%= mutualAid.activeIncidents === 1 ? "Is" : "Are" %> Active
        </div>
      <% } %>
      <% if (mutualAid.activeEvents > 0) { %>
        <div class="maBanner maBannerEvent">
          <%= mutualAid.activeEvents %> Mutual Aid Event<%= mutualAid.activeEvents === 1 ? "" : "s" %> <%= mutualAid.activeEvents === 1 ? "is" : "Are" %> Active
        </div>
      <% } %>
    </div>
  <% } %>

  <% if (typeof error !== "undefined" && error) { %>
    <div class="card">
      <div class="msg bad"><%= typeof error === "string" ? error : JSON.stringify(error) %></div>
    </div>
  <% } %>

  <!-- Top stats -->
  <div class="grid3">
    <div class="card stat">
      <div class="statLabel">Total Users</div>
      <div class="statValue"><%= stats.totalUsers %></div>
    </div>

    <div class="card stat">
      <div class="statLabel">Total Agencies</div>
      <div class="statValue"><%= stats.totalAgencies %></div>
    </div>

    <div class="card stat">
      <div class="statLabel">Total Groups</div>
      <div class="statValue"><%= stats.totalGroups %></div>
    </div>
  </div>

  <!-- TAK stats -->
  <div class="grid3 gridTight">
    <div class="card stat">
      <div class="statLabel">Connected Users / Clients</div>
      <div class="statValue" id="takClients">--</div>
    </div>

    <div class="card stat">
      <div class="statLabel">TAK Server Uptime</div>
      <div class="statValue" id="takUptime">--</div>
    </div>

    <div class="card stat">
      <div class="statLabel">Disk Usage %</div>
      <div class="statValue" id="takDisk">--</div>
    </div>
  </div>

  <!-- Charts -->
  <div class="grid2 gridTight">
    <div class="card">
      <h2 class="cardTitle">Users by Agency</h2>
      <div class="chartWrap"><canvas id="agencyChart"></canvas></div>
    </div>

    <div class="card">
      <h2 class="cardTitle">Users by Type</h2>
      <div class="chartWrap"><canvas id="typeChart"></canvas></div>
    </div>
  </div>

  <% if (isGlobalAdmin) { %>
    <div class="card gridTight">
      <h2>Bookmarks</h2>
      <div class="row" style="flex-wrap:wrap; gap:8px;">
        <% (bookmarks || []).forEach(function(bm) { %>
          <a class="btn" href="<%= bm.url %>" target="_blank"><%= bm.title %></a>
        <% }); %>
      </div>
    </div>
  <% } %>

</main>

<style>
  .grid3{ display:grid; grid-template-columns:repeat(3,1fr); gap:6px; }
  .grid2{ display:grid; grid-template-columns:repeat(2,1fr); gap:6px; }

  @media (max-width:1100px){
    .grid3,.grid2{ grid-template-columns:1fr; }
  }

  .gridTight{ margin-top:6px; }

  .card{
    border:1px solid rgba(255,255,255,0.06);
    border-radius:14px;
    box-shadow:0 6px 16px rgba(0,0,0,.25);
  }

  .stat{ padding:10px; }

  .statLabel{
    font-size:16px;
    color:var(--muted);
    margin-bottom:4px;
  }

  .statValue{
    font-size:44px;
    font-weight:800;
    line-height:.95;
  }

  .cardTitle{
    font-size:16px;
    margin:0 0 6px 0;
    font-weight:800;
  }

  .chartWrap{ max-width:300px; margin:0 auto; }

  .maBanner{ padding:10px 12px; border-radius:10px; font-weight:800; }
  .maBannerIncident{ background:#992525; }
  .maBannerEvent{ background:#995725; }
</style>
