<%- include("partials/header") %>
<%- include("partials/sidebar") %>

<main class="main">
  <h1>Dashboard</h1>

  <% if (mutualAid && (mutualAid.activeIncidents > 0 || mutualAid.activeEvents > 0)) { %>
    <div style="margin: 10px 0 14px 0;">
      <% if (mutualAid.activeIncidents > 0) { %>
        <div class="maBanner maBannerIncident">
          <%= mutualAid.activeIncidents %> Mutual Aid Incident<%= mutualAid.activeIncidents === 1 ? "" : "s" %> <%= mutualAid.activeIncidents === 1 ? "Is" : "Are" %> Active
        </div>
      <% } %>
      <% if (mutualAid.activeEvents > 0) { %>
        <div class="maBanner maBannerEvent">
          <%= mutualAid.activeEvents %> Mutual Aid Event<%= mutualAid.activeEvents === 1 ? "" : "s" %> <%= mutualAid.activeEvents === 1 ? "is" : "Are" %> Active
        </div>
      <% } %>
    </div>
  <% } %>

  <% if (typeof error !== "undefined" && error) { %>
    <div class="card">
      <div class="msg bad"><%= typeof error === "string" ? error : JSON.stringify(error) %></div>
    </div>
  <% } %>

  <!-- Top stats (unchanged) -->
  <div class="grid3">
    <div class="card stat">
      <div class="statLabel">Total Users</div>
      <div class="statValue"><%= stats.totalUsers %></div>
      <div class="statHint"></div>
    </div>

    <div class="card stat">
      <div class="statLabel">Total Agencies</div>
      <div class="statValue"><%= stats.totalAgencies %></div>
      <div class="statHint"></div>
    </div>

    <div class="card stat">
      <div class="statLabel">Total Groups</div>
      <div class="statValue"><%= stats.totalGroups %></div>
      <div class="statHint"></div>
    </div>
  </div>

  <!-- TAK stats row (same style as top row) -->
  <div class="grid3" style="margin-top:14px;">
    <div class="card stat">
      <div style="display:flex; align-items:center; justify-content:space-between; gap:12px;">
        <div class="statLabel">Connected Clients</div>
        <span
          id="takStatusPill"
          style="padding:6px 10px; border-radius:999px; font-weight:800; font-size:12px; background: rgba(255,255,255,0.08);"
        >
          <%= takMetrics && takMetrics.configured ? "CONNECTED" : "NOT CONFIGURED" %>
        </span>
      </div>
      <div class="statValue" id="takClients">--</div>
      <div class="statHint"></div>
    </div>

    <div class="card stat">
      <div class="statLabel">Uptime</div>
      <div class="statValue" id="takUptime">--</div>
      <div class="statHint" id="takUptimeHint"></div>
    </div>

    <div class="card stat">
      <div class="statLabel">Disk %</div>
      <div class="statValue" id="takDisk">--</div>
      <div class="statHint"></div>
    </div>
  </div>

  <!-- Two pies side by side -->
  <div class="grid2" style="margin-top:14px;">
    <div class="card">
      <h2 class="cardTitle">Users by Agency</h2>
      <div class="chartWrap">
        <canvas id="agencyChart"></canvas>
      </div>
    </div>

    <div class="card">
      <h2 class="cardTitle">Users by Type</h2>
      <div class="chartWrap">
        <canvas id="typeChart"></canvas>
      </div>
    </div>
  </div>

  <% if (isGlobalAdmin) { %>
    <div class="card" style="margin-top:14px;">
      <h2>Bookmarks</h2>
      <div class="row" style="flex-wrap:wrap; gap:10px;">
        <% (bookmarks || []).forEach(function(bm) { %>
          <a class="btn" href="<%= bm.url %>" target="_blank" rel="noopener noreferrer">
            <%= bm.title %>
          </a>
        <% }); %>
      </div>
    </div>
  <% } %>

  <script>
    (function() {
      function initCharts() {
        const usersByAgency = <%- JSON.stringify((charts && charts.usersByAgency) || {}) %>;
        const unknownAgency = <%- JSON.stringify((charts && charts.unknownAgency) || 0) %>;

        const agencyLabels = Object.keys(usersByAgency);
        const agencyData = Object.values(usersByAgency);
        if (unknownAgency > 0) { agencyLabels.push("Unknown"); agencyData.push(unknownAgency); }

        new Chart(document.getElementById("agencyChart"), {
          type: "pie",
          data: { labels: agencyLabels, datasets: [{ data: agencyData }] },
          options: { responsive: true, plugins: { legend: { position: "bottom" } } }
        });

        const usersByType = <%- JSON.stringify((charts && charts.usersByType) || {}) %>;
        const unknownType = <%- JSON.stringify((charts && charts.unknownType) || 0) %>;

        const typeLabels = Object.keys(usersByType);
        const typeData = Object.values(usersByType);
        if (unknownType > 0) { typeLabels.push("Unknown"); typeData.push(unknownType); }

        new Chart(document.getElementById("typeChart"), {
          type: "pie",
          data: { labels: typeLabels, datasets: [{ data: typeData }] },
          options: { responsive: true, plugins: { legend: { position: "bottom" } } }
        });
      }

      function loadChartJsAndInit() {
        if (window.Chart) return initCharts();
        var cdnScript = document.createElement("script");
        cdnScript.src = "https://cdn.jsdelivr.net/npm/chart.js";
        cdnScript.onload = initCharts;
        document.head.appendChild(cdnScript);
      }

      if (document.readyState === "loading") {
        document.addEventListener("DOMContentLoaded", loadChartJsAndInit);
      } else {
        loadChartJsAndInit();
      }
    })();
  </script>

  <script>
    (function(){
      const $ = (id) => document.getElementById(id);

      function setPill(text, ok){
        const pill = $("takStatusPill");
        if (!pill) return;
        pill.textContent = text;
        pill.style.background = ok ? "rgba(56, 166, 91, 0.25)" : "rgba(199, 82, 82, 0.25)";
      }

      // Disk formatting:
      // < 10 => 1 decimal (trim trailing .0), >= 10 => integer
      function fmtPct(n){
        if (typeof n !== "number" || !isFinite(n)) return "--";
        if (n < 10) return n.toFixed(1).replace(/\.0$/, "");
        return String(Math.round(n));
      }

      function fmtUptime(seconds){
        if (typeof seconds !== "number" || !isFinite(seconds)) return "--";
        const s = Math.max(0, Math.floor(seconds));
        const d = Math.floor(s / 86400);
        const h = Math.floor((s % 86400) / 3600);
        const m = Math.floor((s % 3600) / 60);
        const parts = [];
        if (d) parts.push(d + "d");
        if (h || d) parts.push(h + "h");
        parts.push(m + "m");
        return parts.join(" ");
      }

      function apply(data){
        if (!data || data.configured === false) setPill("NOT CONFIGURED", false);
        else setPill("CONNECTED", true);

        $("takDisk").textContent = fmtPct(data.diskUsagePercent);

        $("takClients").textContent =
          typeof data.connectedClients === "number" ? String(data.connectedClients) : "--";

        $("takUptime").textContent = fmtUptime(data.uptimeSeconds);
        $("takUptimeHint").textContent = "";
      }

      async function refresh(){
        try{
          const res = await fetch("/api/tak/metrics", { headers: { "Accept": "application/json" } });
          if (!res.ok) throw new Error("HTTP " + res.status);
          const data = await res.json();
          apply(data);
        }catch(e){
          setPill("UNAVAILABLE", false);
        }
      }

      // Initial render from server-side snapshot
      const initial = <%- JSON.stringify(takMetrics || null) %>;
      if (initial) apply(initial);

      // Delay the first health check until after full page load, then +5s.
      // Then poll every 25s.
      function startTakPolling() {
        setTimeout(async () => {
          await refresh();
          setInterval(refresh, 25000);
        }, 5000);
      }

      if (document.readyState === "complete") {
        startTakPolling();
      } else {
        window.addEventListener("load", startTakPolling, { once: true });
      }
    })();
  </script>
</main>

<style>
  .grid3{
    display:grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 14px;
  }
  @media (max-width: 1100px){
    .grid3{ grid-template-columns: 1fr; }
  }

  .grid2{
    display:grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 14px;
  }
  @media (max-width: 1100px){
    .grid2{ grid-template-columns: 1fr; }
  }

  /* Slightly refreshed card feel */
  .card{
    border: 1px solid rgba(255,255,255,0.06);
    box-shadow: 0 10px 25px rgba(0,0,0,0.18);
    border-radius: 16px;
  }

  .stat{ padding: 18px; }

  .statLabel{
    font-size: 22px;
    color: var(--muted);
    margin-bottom: 10px;
  }
  .statValue{
    font-size: 64px;
    font-weight: 800;
    line-height: 1;
    letter-spacing: -0.02em;
  }
  .statHint{
    margin-top: 10px;
    color: var(--muted);
    font-size: 12px;
  }

  /* Chart titles */
  .cardTitle{
    font-size:18px;
    margin: 0 0 10px 0;
    font-weight: 900;
    letter-spacing: -0.01em;
  }

  /* Makes both charts smaller + centered */
  .chartWrap{
    max-width: 320px;
    margin: 0 auto;
  }

  .maBanner{
    padding: 12px 14px;
    border-radius: 12px;
    font-weight: 800;
    color: #ffffff;
    margin-bottom: 10px;
  }
  .maBannerIncident{ background: #992525; }
  .maBannerEvent{ background: #995725; }
</style>
