<%- include("partials/header") %>
<%- include("partials/sidebar") %>

<main class="main">
  <h1>Dashboard</h1>

  <% 
    const hasMutualAid = isGlobalAdmin && mutualAid && (mutualAid.activeIncidents > 0 || mutualAid.activeEvents > 0);
    const hasUserRequests = typeof pendingUserRequestsCount !== "undefined" && pendingUserRequestsCount > 0;
  %>

  <% if (hasMutualAid || hasUserRequests) { %>
    <div style="margin: 10px 0 14px 0;">

      <!-- Mutual Aid Incident -->
      <% if (isGlobalAdmin && mutualAid && mutualAid.activeIncidents > 0) { %>
        <% if (isGlobalAdmin) { %>
          <a href="/mutual-aid" style="text-decoration:none;">
        <% } %>

        <div class="maBanner maBannerIncident">
          <%= mutualAid.activeIncidents %> Mutual Aid Incident<%= mutualAid.activeIncidents === 1 ? "" : "s" %> 
          <%= mutualAid.activeIncidents === 1 ? "Is" : "Are" %> Active
        </div>

        <% if (isGlobalAdmin || isAgencyAdmin) { %>
          </a>
        <% } %>
      <% } %>

      <!-- Mutual Aid Event -->
      <% if (isGlobalAdmin && mutualAid && mutualAid.activeEvents > 0) { %>
        <% if (isGlobalAdmin) { %>
          <a href="/mutual-aid" style="text-decoration:none;">
        <% } %>

        <div class="maBanner maBannerEvent">
          <%= mutualAid.activeEvents %> Mutual Aid Event<%= mutualAid.activeEvents === 1 ? "" : "s" %> 
          <%= mutualAid.activeEvents === 1 ? "Is" : "Are" %> Active
        </div>

        <% if (isGlobalAdmin || isAgencyAdmin) { %>
          </a>
        <% } %>
      <% } %>

      <!-- Pending User Requests -->
      <% if (hasUserRequests) { %>
        <% if (isGlobalAdmin || isAgencyAdmin) { %>
          <a href="/pending-user-requests" style="text-decoration:none;">
        <% } %>

        <div class="userReqBanner">
          <%= pendingUserRequestsCount %> Pending User Request<%= pendingUserRequestsCount === 1 ? "" : "s" %>
        </div>

        <% if (isGlobalAdmin || isAgencyAdmin) { %>
          </a>
        <% } %>
      <% } %>

    </div>
  <% } %>

  <% if (typeof error !== "undefined" && error) { %>
    <div class="card">
      <div class="msg bad"><%= typeof error === "string" ? error : JSON.stringify(error) %></div>
    </div>
  <% } %>

  <!-- Top stats -->
  <div class="grid3">
    <a href="/users/manage" class="statCardLink">
      <div class="card stat">
        <div class="statLabel">Total Users</div>
        <div class="statValue"><%= stats.totalUsers %></div>
        <div class="statHint"></div>
      </div>
    </a>

    <% if (isGlobalAdmin) { %>
    <a href="/agencies" class="statCardLink">
    <% } %>
    <div class="card stat">
      <div class="statLabel">Total Agencies</div>
      <div class="statValue"><%= stats.totalAgencies %></div>
      <div class="statHint"></div>
    </div>
    <% if (isGlobalAdmin) { %>
    </a>
    <% } %>

    <a href="/groups" class="statCardLink">
      <div class="card stat">
        <div class="statLabel">Total Groups</div>
        <div class="statValue"><%= stats.totalGroups %></div>
        <div class="statHint"></div>
      </div>
    </a>
  </div>

  <!-- TAK stats row: 4-wide; when expanded, Connected Clients uses half -->
  <div class="gridTakStats gridTight" id="takStatsRow" style="margin-top:8px;" <%= (isGlobalAdmin || isAgencyAdmin) ? 'data-can-expand-clients="true"' : '' %>>
    <div class="card stat" id="connectedClientsStatCard" role="<%= (isGlobalAdmin || isAgencyAdmin) ? 'button' : '' %>" tabindex="<%= (isGlobalAdmin || isAgencyAdmin) ? '0' : '-1' %>">
      <div class="statLabel">Connected Users</div>
      <div class="statValue" id="takClients">--</div>
      <div class="statHint"></div>
    </div>

    <% if (isGlobalAdmin) { %>
    <a href="/integrations" class="statCardLink">
    <% } %>
    <div class="card stat">
      <div class="statLabel">Connected Integrations</div>
      <div class="statValue" id="takConnectedIntegrations">--</div>
      <div class="statHint"></div>
    </div>
    <% if (isGlobalAdmin) { %>
    </a>
    <% } %>

    <div class="card stat">
      <div class="statLabel">TAK Server Uptime</div>
      <div class="statValue" id="takUptime">--</div>
      <div class="statHint" id="takUptimeHint"></div>
    </div>

    <div class="card stat">
      <div class="statLabel">Disk Usage %</div>
      <div class="statValue" id="takDisk">--</div>
      <div class="statHint"></div>
    </div>
  </div>

  <!-- Two pies side by side -->
  <div class="grid2 gridTight" style="margin-top:8px;">
    <div class="card">
      <h2 class="cardTitle">Users by Agency</h2>
      <div class="chartWrap">
        <canvas id="agencyChart"></canvas>
      </div>
    </div>

    <div class="card">
      <h2 class="cardTitle">Users by Type</h2>
      <div class="chartWrap">
        <canvas id="typeChart"></canvas>
      </div>
    </div>
  </div>

  <% if (isGlobalAdmin) { %>
    <div class="card" style="margin-top:8px;">
      <h2>Bookmarks</h2>
      <div class="row" style="flex-wrap:wrap; gap:10px;">
        <% (bookmarks || []).forEach(function(bm) { %>
          <a class="btn" href="<%= bm.url %>" target="_blank" rel="noopener noreferrer">
            <%= bm.title %>
          </a>
        <% }); %>
      </div>
    </div>
  <% } %>

  <script>
    (function() {
      function initCharts() {
        const usersByAgency = <%- JSON.stringify((charts && charts.usersByAgency) || {}) %>;
        const unknownAgency = <%- JSON.stringify((charts && charts.unknownAgency) || 0) %>;
        const agencyColors = <%- JSON.stringify(typeof agencyColors !== "undefined" ? agencyColors : {}) %>;
        const defaultAgencyColor = "#9ca3af";
        var agencyColorNameToHex = {
          "Blue": "#3b82f6",
          "Dark Blue": "#1e3a8a",
          "Brown": "#8B4513",
          "Cyan": "#06b6d4",
          "Green": "#22c55e",
          "Dark Green": "#166534",
          "Magenta": "#d946ef",
          "Maroon": "#881337",
          "Orange": "#f97316",
          "Purple": "#a855f7",
          "Red": "#dc2626",
          "Teal": "#0d9488",
          "White": "#f8fafc",
          "Yellow": "#eab308"
        };

        const agencyLabels = Object.keys(usersByAgency);
        const agencyData = Object.values(usersByAgency);
        if (unknownAgency > 0) { agencyLabels.push("Unknown"); agencyData.push(unknownAgency); }

        const agencyBackgroundColors = agencyLabels.map(function(label) {
          const c = agencyColors[label];
          if (!c || typeof c !== "string") return defaultAgencyColor;
          const raw = c.trim();
          if (!raw) return defaultAgencyColor;
          if (raw.charAt(0) === "#") return raw;
          return agencyColorNameToHex[raw] || agencyColorNameToHex[raw.toLowerCase()] || raw;
        });

        new Chart(document.getElementById("agencyChart"), {
          type: "pie",
          data: {
            labels: agencyLabels,
            datasets: [{
              data: agencyData,
              backgroundColor: agencyBackgroundColors,
              borderColor: "#ffffff",
              borderWidth: 2
            }]
          },
          options: { responsive: true, plugins: { legend: { position: "bottom" } } }
        });

        const usersByType = <%- JSON.stringify((charts && charts.usersByType) || {}) %>;
        const unknownType = <%- JSON.stringify((charts && charts.unknownType) || 0) %>;

        const typeLabels = Object.keys(usersByType);
        const typeData = Object.values(usersByType);
        if (unknownType > 0) { typeLabels.push("Unknown"); typeData.push(unknownType); }

        var typePalette = ["#3b82f6", "#f59e0b", "#10b981", "#ef4444", "#8b5cf6", "#ec4899", "#06b6d4", "#84cc16"];
        var typeBackgroundColors = typeLabels.map(function(_, i) { return typePalette[i % typePalette.length]; });

        new Chart(document.getElementById("typeChart"), {
          type: "pie",
          data: {
            labels: typeLabels,
            datasets: [{
              data: typeData,
              backgroundColor: typeBackgroundColors,
              borderColor: "#ffffff",
              borderWidth: 2
            }]
          },
          options: { responsive: true, plugins: { legend: { position: "bottom" } } }
        });
      }

      function loadChartJsAndInit() {
        if (window.Chart) return initCharts();
        var cdnScript = document.createElement("script");
        cdnScript.src = "https://cdn.jsdelivr.net/npm/chart.js";
        cdnScript.onload = initCharts;
        document.head.appendChild(cdnScript);
      }

      if (document.readyState === "loading") {
        document.addEventListener("DOMContentLoaded", loadChartJsAndInit);
      } else {
        loadChartJsAndInit();
      }
    })();
  </script>

  <script>
    (function(){
      const $ = (id) => document.getElementById(id);
      window.__latestConnectedClients = window.__latestConnectedClients || null;
      window.__latestConnectedIntegrations = window.__latestConnectedIntegrations || null;

      // Disk formatting:
      // < 10 => 1 decimal (trim trailing .0), >= 10 => integer
      function fmtPct(n){
        if (typeof n !== "number" || !isFinite(n)) return "--";
        if (n < 10) return n.toFixed(1).replace(/\.0$/, "");
        return String(Math.round(n));
      }

      function fmtUptime(seconds){
        if (typeof seconds !== "number" || !isFinite(seconds)) return "--";
        const s = Math.max(0, Math.floor(seconds));
        const d = Math.floor(s / 86400);
        const h = Math.floor((s % 86400) / 3600);
        const m = Math.floor((s % 3600) / 60);
        const parts = [];
        if (d) parts.push(d + "d");
        if (h || d) parts.push(h + "h");
        if (s < 86400) parts.push(m + "m");
        return parts.join(" ");
      }

      function apply(data){
        // Preserve previous values when new data is briefly missing or zero,
        // to avoid flickering 60 → 0 → 60 during sampling gaps.
        var prevCcStr = typeof window.__latestConnectedClients === "string" ? window.__latestConnectedClients : null;
        var prevCiStr = typeof window.__latestConnectedIntegrations === "string" ? window.__latestConnectedIntegrations : null;

        var nextDisk = data && typeof data.diskUsagePercent === "number" ? data.diskUsagePercent : null;
        $("takDisk").textContent = fmtPct(nextDisk);

        var rawCc = data && typeof data.connectedClients === "number" ? data.connectedClients : null;
        var rawCi = data && typeof data.connectedIntegrations === "number" ? data.connectedIntegrations : null;

        var ccStr;
        if (rawCc === null || !isFinite(rawCc)) {
          ccStr = prevCcStr || "--";
        } else if (rawCc === 0 && prevCcStr && isFinite(Number(prevCcStr)) && Number(prevCcStr) > 0) {
          ccStr = prevCcStr;
        } else {
          ccStr = String(rawCc);
        }

        var ciStr;
        if (rawCi === null || !isFinite(rawCi)) {
          ciStr = prevCiStr || "--";
        } else if (rawCi === 0 && prevCiStr && isFinite(Number(prevCiStr)) && Number(prevCiStr) > 0) {
          ciStr = prevCiStr;
        } else {
          ciStr = String(rawCi);
        }

        $("takClients").textContent = ccStr;
        window.__latestConnectedClients = ccStr;

        var ciEl = document.getElementById("takConnectedIntegrations");
        if (ciEl) ciEl.textContent = ciStr;
        window.__latestConnectedIntegrations = ciStr;

        $("takUptime").textContent = fmtUptime(data && data.uptimeSeconds);
        $("takUptimeHint").textContent = "";
      }

      async function refresh(){
        try{
          const res = await fetch("/api/tak/metrics", { headers: { "Accept": "application/json" } });
          if (!res.ok) throw new Error("HTTP " + res.status);
          const data = await res.json();
          apply(data);
        }catch(e){
          // no "Connected"/status pill on this page; just leave values as-is
        }
      }

      // Initial render from server-side snapshot
      const initial = <%- JSON.stringify(takMetrics || null) %>;
      if (initial) apply(initial);
      // Expose smoothing-aware updater for other scripts (manual refresh, etc.)
      window.__takApplyDashboardMetrics = apply;

      // Delay the first health check until after full page load, then +5s.
      // Then poll every 20s.
      function startTakPolling() {
        setTimeout(async () => {
          await refresh();
          setInterval(refresh, 20000);
        }, 5000);
      }

      if (document.readyState === "complete") {
        startTakPolling();
      } else {
        window.addEventListener("load", startTakPolling, { once: true });
      }
    })();
  </script>

  <script>
    (function () {
      var row = document.getElementById("takStatsRow");
      var card = document.getElementById("connectedClientsStatCard");
      if (!row || !card || !row.getAttribute("data-can-expand-clients")) return;

      var NODERED_PREFIX = "nodered-";
      var TEAM_COLORS = {
        "Blue": "#1e88e5", "Dark Blue": "#0d47a1", "Brown": "#6d4c41", "Cyan": "#00acc1",
        "Green": "#43a047", "Dark Green": "#1b5e20", "Magenta": "#d81b60", "Maroon": "#800000",
        "Orange": "#ff7b00", "Purple": "#8e24aa", "Red": "#e53935", "Teal": "#00897b",
        "White": "#ffffff", "Yellow": "#fdd835"
      };

      var originalCardHtml = card.innerHTML;
      var expandedRefreshTimer = null;
      var EXPANDED_REFRESH_MS = 20000;

      function esc(s) {
        if (s == null || s === "") return "";
        var div = document.createElement("div");
        div.textContent = s;
        return div.innerHTML;
      }

      function teamToBg(team) {
        if (!team) return "transparent";
        var hex = TEAM_COLORS[team];
        return hex ? hex + "33" : "transparent";
      }

      var latestSubscriptions = [];

      function fillExpandedTableBody(rows, rawItems) {
        latestSubscriptions = Array.isArray(rawItems) ? rawItems.slice() : [];
        var tbody = document.getElementById("connectedClientsTableBody");
        if (!tbody) return;
        tbody.innerHTML = "";
        (rows || []).forEach(function (r) {
          var tr = document.createElement("tr");
          if (r.subscriptionUid) {
            tr.setAttribute("data-subscription-uid", r.subscriptionUid);
          }
          var bg = teamToBg(r.team);
          if (bg !== "transparent") tr.style.backgroundColor = bg;
          tr.innerHTML = "<td>" + esc(r.callsign) + "</td><td>" + esc(r.username) + "</td><td>" + esc(r.takClient) + "</td><td>" + esc(r.role) + "</td>";
          tbody.appendChild(tr);
        });
      }

      function renderExpandedView(rows, rawItems) {
        var html = '<div class="connected-clients-expanded">' +
          '<div class="connected-clients-expanded-header">' +
          '<h2 class="cardTitle">Connected Users</h2>' +
          '<button type="button" class="btn" id="connectedClientsCloseBtn">Close</button>' +
          '</div>' +
          '<div class="connected-clients-table-wrap"><table class="connected-clients-table">' +
          '<thead><tr><th>Callsign</th><th>Username</th><th>TAK Client</th><th>Role</th></tr></thead>' +
          '<tbody id="connectedClientsTableBody"></tbody></table></div></div>' +
          '<div class="modalOverlay" id="clientGroupsOverlay" style="display:none;">' +
            '<div class="modal" role="dialog" aria-modal="true" aria-labelledby="clientGroupsTitle">' +
              '<div class="modalHeader">' +
                '<h2 id="clientGroupsTitle" style="margin:0;">Active Groups</h2>' +
                '<button class="btn" id="clientGroupsCloseBtn" type="button">Close</button>' +
              '</div>' +
              '<div class="modalBody">' +
                '<div id="clientGroupsSummary" class="msg" style="display:none;"></div>' +
                '<div id="clientGroupsList" style="margin-top:10px; max-height:320px; overflow:auto;"></div>' +
              '</div>' +
            '</div>' +
          '</div>';
        card.innerHTML = html;
        card.classList.add("connected-clients-expanded-card");
        row.classList.add("connected-clients-row-expanded");
        fillExpandedTableBody(rows, rawItems);
        document.getElementById("connectedClientsCloseBtn").addEventListener("click", function (e) {
          e.preventDefault();
          e.stopPropagation();
          collapse();
        });
        // Wire up modal behavior
        var overlay = document.getElementById("clientGroupsOverlay");
        var closeBtn = document.getElementById("clientGroupsCloseBtn");
        var listEl = document.getElementById("clientGroupsList");
        var summaryEl = document.getElementById("clientGroupsSummary");

        function closeClientGroupsModal(ev) {
          if (ev) {
            ev.preventDefault();
            ev.stopPropagation();
          }
          if (overlay) overlay.style.display = "none";
        }

        function openClientGroupsModal(sub) {
          if (!overlay || !listEl || !sub) return;

          // Build normalized group names from subscription groups
          var groups = Array.isArray(sub.groups) ? sub.groups.filter(function (g) { return g && g.active; }) : [];
          var byName = {};
          groups.forEach(function (g) {
            var name = (g.name != null ? String(g.name).trim() : "");
            if (!name) return;
            var dir = (g.direction != null ? String(g.direction).trim().toUpperCase() : "");
            if (!byName[name]) {
              byName[name] = { in: false, out: false };
            }
            if (dir === "IN") byName[name].in = true;
            if (dir === "OUT") byName[name].out = true;
          });

          var displayNames = Object.keys(byName).map(function (base) {
            var flags = byName[base];
            if (flags.in && flags.out) return base;
            if (flags.in) return base + "_WRITE";
            if (flags.out) return base + "_READ";
            return base;
          }).sort(function (a, b) {
            return a.localeCompare(b, undefined, { sensitivity: "base" });
          });

          listEl.innerHTML = "";
          if (displayNames.length === 0) {
            listEl.innerHTML = '<div class="muted">No active groups for this client.</div>';
          } else {
            var ul = document.createElement("ul");
            ul.style.paddingLeft = "20px";
            displayNames.forEach(function (name) {
              var li = document.createElement("li");
              li.textContent = name;
              ul.appendChild(li);
            });
            listEl.appendChild(ul);
          }

          if (summaryEl) {
            var label = (sub.callsign && String(sub.callsign).trim()) || (sub.username && String(sub.username).trim()) || "Client";
            summaryEl.textContent = "Groups currently active for " + label + ":";
            summaryEl.style.display = "block";
          }

          overlay.style.display = "flex";
        }

        if (closeBtn) {
          closeBtn.addEventListener("click", function (e) {
            closeClientGroupsModal(e);
          });
        }
        if (overlay) {
          overlay.addEventListener("click", function (e) {
            if (e.target === overlay) {
              closeClientGroupsModal(e);
            }
          });
          // Prevent any clicks inside the modal content from toggling the card
          var modalEl = overlay.querySelector(".modal");
          if (modalEl) {
            modalEl.addEventListener("click", function (e) {
              e.stopPropagation();
            });
          }
        }

        // Row click -> open modal with that subscription's groups
        var tbody = document.getElementById("connectedClientsTableBody");
        if (tbody) {
          tbody.addEventListener("click", function (e) {
            var tr = e.target.closest("tr");
            if (!tr) return;
            e.stopPropagation();
            var uid = tr.getAttribute("data-subscription-uid");
            if (!uid || !latestSubscriptions.length) return;
            var sub = latestSubscriptions.find(function (s) { return String(s.subscriptionUid) === uid; });
            if (!sub) return;
            openClientGroupsModal(sub);
          });
        }

        if (expandedRefreshTimer) clearInterval(expandedRefreshTimer);
        expandedRefreshTimer = setInterval(function () {
          if (!card.classList.contains("connected-clients-expanded-card")) return;
          fetch("/api/tak/subscriptions", { headers: { Accept: "application/json" } })
            .then(function (res) { return res.json(); })
            .then(function (data) {
              if (!data.configured || !Array.isArray(data.data)) return;
              var list = data.data.filter(function (item) {
                var u = (item.username != null ? String(item.username).trim() : "").toLowerCase();
                return u.indexOf(NODERED_PREFIX) !== 0;
              });
              var nextRows = list.map(function (item) {
                return {
                  callsign: item.callsign != null ? String(item.callsign).trim() : "",
                  username: item.username != null ? String(item.username).trim() : "",
                  takClient: item.takClient != null ? String(item.takClient).trim() || "—" : "—",
                  role: item.role != null ? String(item.role).trim() || "—" : "—",
                  team: item.team != null ? String(item.team).trim() : "",
                  subscriptionUid: item.subscriptionUid != null ? String(item.subscriptionUid).trim() : ""
                };
              });
              nextRows.sort(function (a, b) { return (a.callsign || "").localeCompare(b.callsign || "", undefined, { sensitivity: "base" }); });
              fillExpandedTableBody(nextRows, list);
            })
            .catch(function () {});
        }, EXPANDED_REFRESH_MS);
      }

      function collapse() {
        if (expandedRefreshTimer) {
          clearInterval(expandedRefreshTimer);
          expandedRefreshTimer = null;
        }
        card.innerHTML = originalCardHtml;
        card.classList.remove("connected-clients-expanded-card");
        row.classList.remove("connected-clients-row-expanded");
        // Reapply latest known metrics so the compact card shows the up-to-date value.
        var cc = typeof window.__latestConnectedClients === "string" ? window.__latestConnectedClients : null;
        var ciVal = typeof window.__latestConnectedIntegrations === "string" ? window.__latestConnectedIntegrations : null;
        var ccEl = document.getElementById("takClients");
        if (ccEl && cc != null) ccEl.textContent = cc;
        var ciEl = document.getElementById("takConnectedIntegrations");
        if (ciEl && ciVal != null) ciEl.textContent = ciVal;
      }

      card.style.cursor = "pointer";
      function tryExpand() {
        if (card.classList.contains("connected-clients-expanded-card")) return;
        card.querySelector(".statValue").textContent = "…";
        fetch("/api/tak/subscriptions", { headers: { Accept: "application/json" } })
          .then(function (res) { return res.json(); })
          .then(function (data) {
            if (!data.configured || !Array.isArray(data.data)) {
              collapse();
              return;
            }
            var list = data.data.filter(function (item) {
              var u = (item.username != null ? String(item.username).trim() : "").toLowerCase();
              return u.indexOf(NODERED_PREFIX) !== 0;
            });
            var rows = list.map(function (item) {
              return {
                callsign: item.callsign != null ? String(item.callsign).trim() : "",
                username: item.username != null ? String(item.username).trim() : "",
                takClient: item.takClient != null ? String(item.takClient).trim() || "—" : "—",
                role: item.role != null ? String(item.role).trim() || "—" : "—",
                team: item.team != null ? String(item.team).trim() : "",
                subscriptionUid: item.subscriptionUid != null ? String(item.subscriptionUid).trim() : ""
              };
            });
            rows.sort(function (a, b) { return (a.callsign || "").localeCompare(b.callsign || "", undefined, { sensitivity: "base" }); });
            renderExpandedView(rows, list);
          })
          .catch(function () { collapse(); });
      }
      card.addEventListener("click", function (e) {
        if (card.classList.contains("connected-clients-expanded-card")) {
          collapse();
          return;
        }
        tryExpand();
      });
      card.addEventListener("keydown", function (e) {
        if (card.classList.contains("connected-clients-expanded-card")) {
          if (e.key === "Enter" || e.key === " ") {
            e.preventDefault();
            collapse();
          }
          return;
        }
        if (e.key === "Enter" || e.key === " ") {
          e.preventDefault();
          tryExpand();
        }
      });

      window.__dashboardTakRefresh = function () {
        fetch("/api/tak/metrics", { headers: { Accept: "application/json" } })
          .then(function (res) { return res.json(); })
          .then(function (data) {
            // Reuse the same smoothing logic used by the polling script
            if (typeof window.__takApplyDashboardMetrics === "function") {
              window.__takApplyDashboardMetrics(data);
            } else {
              var el = document.getElementById("takClients");
              var cc = data && typeof data.connectedClients === "number" ? String(data.connectedClients) : "--";
              if (el) el.textContent = cc;
              window.__latestConnectedClients = cc;
              var ci = document.getElementById("takConnectedIntegrations");
              var ciVal = data && typeof data.connectedIntegrations === "number" ? String(data.connectedIntegrations) : "--";
              if (ci) ci.textContent = ciVal;
              window.__latestConnectedIntegrations = ciVal;
              var disk = document.getElementById("takDisk");
              if (disk) disk.textContent = data && typeof data.diskUsagePercent === "number" ? (data.diskUsagePercent < 10 ? data.diskUsagePercent.toFixed(1).replace(/\.0$/, "") : String(Math.round(data.diskUsagePercent))) : "--";
              var up = document.getElementById("takUptime");
              if (up && data && typeof data.uptimeSeconds === "number") {
                var s = Math.max(0, Math.floor(data.uptimeSeconds));
                var d = Math.floor(s / 86400), h = Math.floor((s % 86400) / 3600), m = Math.floor((s % 3600) / 60);
                var parts = [];
                if (d) parts.push(d + "d");
                if (h || d) parts.push(h + "h");
                if (s < 86400) parts.push(m + "m");
                up.textContent = parts.join(" ");
              }
            }
          }).catch(function () {});
      };
    })();
  </script>
</main>

