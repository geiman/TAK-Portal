<%- include("partials/header") %>
<%- include("partials/sidebar") %>

<main class="main">
  <h1>Dashboard</h1>

  <% if (mutualAid && (mutualAid.activeIncidents > 0 || mutualAid.activeEvents > 0)) { %>
    <div style="margin: 10px 0 14px 0;">
      <% if (mutualAid.activeIncidents > 0) { %>
        <div class="maBanner maBannerIncident">
          <%= mutualAid.activeIncidents %> Mutual Aid Incident<%= mutualAid.activeIncidents === 1 ? "" : "s" %> <%= mutualAid.activeIncidents === 1 ? "Is" : "Are" %> Active
        </div>
      <% } %>
      <% if (mutualAid.activeEvents > 0) { %>
        <div class="maBanner maBannerEvent">
          <%= mutualAid.activeEvents %> Mutual Aid Event<%= mutualAid.activeEvents === 1 ? "" : "s" %> <%= mutualAid.activeEvents === 1 ? "is" : "Are" %> Active
        </div>
      <% } %>
    </div>
  <% } %>

  <% if (typeof error !== "undefined" && error) { %>
    <div class="card">
      <div class="msg bad"><%= typeof error === "string" ? error : JSON.stringify(error) %></div>
    </div>
  <% } %>

  <!-- Top stats -->
  <div class="grid3">
    <div class="card stat">
      <div class="statLabel">Total Users</div>
      <div class="statValue"><%= stats.totalUsers %></div>
      <div class="statHint"></div>
    </div>

    <div class="card stat">
      <div class="statLabel">Total Agencies</div>
      <div class="statValue"><%= stats.totalAgencies %></div>
      <div class="statHint"></div>
    </div>

    <div class="card stat">
      <div class="statLabel">Total Groups</div>
      <div class="statValue"><%= stats.totalGroups %></div>
      <div class="statHint"></div>
    </div>
  </div>

  <!-- 3-across row: TAK Health + two pies -->
  <div class="grid3" style="margin-top:14px;">
    <!-- TAK Server Health -->
    <div class="card" style="padding: 18px;">
      <div style="display:flex; align-items:center; justify-content:space-between; gap: 12px;">
        <div style="font-size: 22px; font-weight: 800;">TAK Server Health</div>
        <div style="display:flex; align-items:center; gap:10px;">
          <span id="takStatusPill" style="padding:6px 10px; border-radius:999px; font-weight:800; font-size:12px; background: rgba(255,255,255,0.08);">
            <%= takMetrics && takMetrics.configured ? "CONNECTED" : "NOT CONFIGURED" %>
          </span>
          <button class="btn" type="button" id="takRefreshBtn" style="padding:8px 12px; border-radius: 10px;">Refresh</button>
        </div>
      </div>

      <div class="grid3 tak-grid" style="margin-top: 14px;">
        <div class="card stat" style="margin:0;">
          <div class="statLabel">CPU %</div>
          <div class="statValue" id="takCpu">
            <%= takMetrics && takMetrics.cpu && typeof takMetrics.cpu.cpuPercent === "number" ? takMetrics.cpu.cpuPercent.toFixed(1) : "--" %>
          </div>
          <div class="statHint" id="takCpuHint">
            <%= takMetrics && takMetrics.cpu && typeof takMetrics.cpu.cpuCount === "number" ? (takMetrics.cpu.cpuCount + " cores") : "" %>
          </div>
        </div>

        <div class="card stat" style="margin:0;">
          <div class="statLabel">Memory %</div>
          <div class="statValue" id="takMem">
            <%= takMetrics && typeof takMetrics.memoryUsagePercent === "number" ? takMetrics.memoryUsagePercent.toFixed(1) : "--" %>
          </div>
          <div class="statHint"></div>
        </div>

        <div class="card stat" style="margin:0;">
          <div class="statLabel">Disk %</div>
          <div class="statValue" id="takDisk">
            <%= takMetrics && typeof takMetrics.diskUsagePercent === "number" ? takMetrics.diskUsagePercent.toFixed(1) : "--" %>
          </div>
          <div class="statHint"></div>
        </div>

        <div class="card stat" style="margin:0;">
          <div class="statLabel">Clients</div>
          <div class="statValue" id="takClients">
            <%= takMetrics && typeof takMetrics.connectedClients === "number" ? takMetrics.connectedClients : "--" %>
          </div>
          <div class="statHint"></div>
        </div>

        <div class="card stat tak-uptime-wide" style="margin:0;">
          <div class="statLabel">Uptime</div>
          <!-- ONLY show human string here -->
          <div class="statValue" id="takUptime">
            <%= takMetrics && typeof takMetrics.uptimeSeconds === "number" ? "" : "--" %>
          </div>
          <div class="statHint" id="takUptimeHint"></div>
        </div>
      </div>

      <div style="margin-top:10px; font-size: 12px; color: var(--muted);">
        Last update: <span id="takLastUpdate"><%= takMetrics && takMetrics.fetchedAt ? takMetrics.fetchedAt : "—" %></span>
      </div>
    </div>

    <!-- Pie 1 -->
    <div class="card">
      <h2>Users by Agency</h2>
      <div class="chartWrap">
        <canvas id="agencyChart"></canvas>
      </div>
      <small style="color: var(--muted);">
        <% if (charts && charts.unknownAgency && charts.unknownAgency > 0) { %>
          Unknown suffix: <%= charts.unknownAgency %>
        <% } %>
      </small>
    </div>

    <!-- Pie 2 -->
    <div class="card">
      <h2>Users by Type</h2>
      <div class="chartWrap">
        <canvas id="typeChart"></canvas>
      </div>
      <small style="color: var(--muted);">
        <% if (charts && charts.unknownType && charts.unknownType > 0) { %>
          Unknown: <%= charts.unknownType %>
        <% } %>
      </small>
    </div>
  </div>

  <% if (isGlobalAdmin) { %>
    <div class="card" style="margin-top:14px;">
      <h2>Bookmarks</h2>
      <div class="row" style="flex-wrap:wrap; gap:10px;">
        <% (bookmarks || []).forEach(function(bm) { %>
          <a
            class="btn"
            href="<%= bm.url %>"
            target="_blank"
            rel="noopener noreferrer"
          >
            <%= bm.title %>
          </a>
        <% }); %>
      </div>
    </div>
  <% } %>

  <script>
    (function() {
      function initCharts() {
        // ---- Left chart: Users by Agency ----
        const usersByAgency = <%- JSON.stringify((charts && charts.usersByAgency) || {}) %>;
        const unknownAgency = <%- JSON.stringify((charts && charts.unknownAgency) || 0) %>;

        const agencyLabels = Object.keys(usersByAgency);
        const agencyData = Object.values(usersByAgency);

        if (unknownAgency > 0) {
          agencyLabels.push("Unknown");
          agencyData.push(unknownAgency);
        }

        new Chart(document.getElementById("agencyChart"), {
          type: "pie",
          data: { labels: agencyLabels, datasets: [{ data: agencyData }] },
          options: { responsive: true, plugins: { legend: { position: "bottom" } } }
        });

        // ---- Right chart: Users by Agency Type ----
        const usersByType = <%- JSON.stringify((charts && charts.usersByType) || {}) %>;
        const unknownType = <%- JSON.stringify((charts && charts.unknownType) || 0) %>;

        const typeLabels = Object.keys(usersByType);
        const typeData = Object.values(usersByType);

        if (unknownType > 0) {
          typeLabels.push("Unknown");
          typeData.push(unknownType);
        }

        new Chart(document.getElementById("typeChart"), {
          type: "pie",
          data: { labels: typeLabels, datasets: [{ data: typeData }] },
          options: { responsive: true, plugins: { legend: { position: "bottom" } } }
        });
      }

      function loadChartJsAndInit() {
        if (window.Chart) {
          initCharts();
          return;
        }
        // CDN only (avoid /chart.js MIME issue)
        var cdnScript = document.createElement("script");
        cdnScript.src = "https://cdn.jsdelivr.net/npm/chart.js";
        cdnScript.onload = initCharts;
        document.head.appendChild(cdnScript);
      }

      if (document.readyState === "loading") {
        document.addEventListener("DOMContentLoaded", loadChartJsAndInit);
      } else {
        loadChartJsAndInit();
      }
    })();
  </script>

  <script>
    (function(){
      const $ = (id) => document.getElementById(id);

      function setPill(text, ok){
        const pill = $("takStatusPill");
        if (!pill) return;
        pill.textContent = text;
        pill.style.background = ok ? "rgba(56, 166, 91, 0.25)" : "rgba(199, 82, 82, 0.25)";
      }

      function fmtUptime(seconds){
        if (typeof seconds !== "number" || !isFinite(seconds)) return "--";
        const s = Math.max(0, Math.floor(seconds));
        const d = Math.floor(s / 86400);
        const h = Math.floor((s % 86400) / 3600);
        const m = Math.floor((s % 3600) / 60);
        const parts = [];
        if (d) parts.push(d + "d");
        if (h || d) parts.push(h + "h");
        parts.push(m + "m");
        return parts.join(" ");
      }

      function fmtPct(n){
        if (typeof n !== "number" || !isFinite(n)) return "--";

        // show at most 1 decimal, but never trailing .0
        if (n < 10) return n.toFixed(1).replace(/\.0$/, "");
        return Math.round(n).toString();
      }


      async function refresh(){
        try{
          const res = await fetch("/api/tak/metrics", { headers: { "Accept": "application/json" } });
          if (!res.ok) throw new Error("HTTP " + res.status);
          const data = await res.json();

          if (!data || data.configured === false){
            setPill("NOT CONFIGURED", false);
          } else {
            setPill("CONNECTED", true);
          }

          $("takLastUpdate").textContent = data && data.fetchedAt ? data.fetchedAt : "—";

          const cpu = data && data.cpu ? data.cpu : null;
          $("takCpu").textContent = cpu ? fmtPct(cpu.cpuPercent) : "--";
          $("takCpuHint").textContent = cpu && typeof cpu.cpuCount === "number" ? (cpu.cpuCount + " cores") : "";

          $("takMem").textContent = fmtPct(data.memoryUsagePercent);
          $("takDisk").textContent = fmtPct(data.diskUsagePercent);
          $("takClients").textContent = typeof data.connectedClients === "number" ? String(data.connectedClients) : "--";

          // ONLY show human uptime string (no raw seconds)
          $("takUptime").textContent = fmtUptime(data.uptimeSeconds);
          $("takUptimeHint").textContent = "";
        }catch(e){
          setPill("UNAVAILABLE", false);
        }
      }

      const btn = $("takRefreshBtn");
      if (btn) btn.addEventListener("click", refresh);

      // initial render from server-side value if present
      const initialSeconds = <%- JSON.stringify(takMetrics && typeof takMetrics.uptimeSeconds === "number" ? takMetrics.uptimeSeconds : null) %>;
      if (initialSeconds != null) {
        $("takUptime").textContent = fmtUptime(initialSeconds);
        $("takUptimeHint").textContent = "";
      }

      // auto-refresh every 15s
      setInterval(refresh, 15000);
    })();
  </script>
</main>

<style>
  .grid3{
    display:grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 14px;
  }
  .grid2{
    display:grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 14px;
  }
  @media (max-width: 1100px){
    .grid3{ grid-template-columns: 1fr; }
    .grid2{ grid-template-columns: 1fr; }
  }
  .stat{ padding: 18px; }
  .statLabel{
    font-size: 18px;
    color: var(--muted);
    margin-bottom: 6px;
  }
  .statValue{
    font-size: 46px;
    font-weight: 800;
    line-height: 1;
  }
  .statHint{
    margin-top: 10px;
    color: var(--muted);
    font-size: 12px;
  }
  .tak-uptime-wide {
  grid-column: span 2;
}


  /* Makes both charts smaller + centered */
  .chartWrap{
    max-width: 320px;
    margin: 0 auto;
  }

  .maBanner{
    padding: 12px 14px;
    border-radius: 12px;
    font-weight: 800;
    color: #ffffff;
    margin-bottom: 10px;
  }
  .maBannerIncident{
    background: #992525;
  }
  .maBannerEvent{
    background: #995725;
  }
</style>
