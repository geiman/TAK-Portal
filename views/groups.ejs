<%- include("partials/header") %>
<%- include("partials/sidebar") %>

<main class="main">
  <h1>Groups</h1>

  <div class="card">
  <h2>Create Group</h2>

  <div class="row">
    <label>Group Type
      <select id="createType">
        <option value="agency" selected>Agency-Specific Group</option>
        <% if (isGlobalAdmin) { %>
        <option value="county">County-Specific Group</option>
        <option value="generic">Global Group</option>
        <% } %>
      </select>
    </label>

    <label id="agencyPrefixWrap" style="display:none;">Select Agency
      <select id="agencyPrefixSelect">
        <option value="">Select Agency</option>
      </select>
    </label>

    <label id="countyWrap" style="display:none;">Select County
      <select id="countySelect">
        <option value="">Select County</option>
      </select>
    </label>

    <label style="flex: 1; min-width: 160px;">Group Name
      <input
        id="groupName"
        placeholder="Group name"
        style="width: 100%;"
      />
    </label>

    <label style="min-width: 220px;">Channel Behavior
      <select id="behaviorSelect" style="min-width: 120px;">
        <option value="both" selected>BOTH - Send and Recieve (default)</option>
        <option value="read">READ - Recieve Only</option>
        <option value="write">WRITE - Send Only</option>
      </select>
    </label>

    <% if (isGlobalAdmin) { %>
    <label style="min-width: 140px;">Private
      <select id="privateSelect" style="min-width: 120px;">
        <option value="no" selected>No</option>
        <option value="yes">Yes</option>
      </select>
    </label>
    <% } %>

    <!-- optional: keep button aligned with labeled fields -->
    <label>&nbsp;
      <button class="btn" id="createBtn" type="button">Create New Group</button>
    </label>
  </div>

  <div class="row" style="margin-top:8px;">
    <label style="flex: 1; min-width: 0;">Group Description
      <input
        id="groupDescription"
        placeholder="One-line description for this group (optional)"
        style="width: 100%;"
      />
    </label>
  </div>

  <div id="createMsg" class="msg"></div>
</div>


  <div class="card">
    <div class="row" style="justify-content: space-between; align-items:center;">
      <h2 style="margin:0;">Existing Groups</h2>
    </div>

    <input
      id="filter"
      placeholder="Filter groups..."
      style="margin: 10px 0; width: 100%; box-sizing: border-box;"
    />

    <div id="listMsg" class="msg"></div>

    <table class="table">
      <thead>
        <tr>
          <th class="sortable" data-key="name">
            Group Name <span class="sortIndicator" aria-hidden="true"></span>
          </th>
          <% if (isGlobalAdmin) { %>
          <th class="sortable" data-key="private">
            Private <span class="sortIndicator" aria-hidden="true"></span>
          </th>
          <% } %>
          <th>Actions</th>
        </tr>
      </thead>
      <tbody id="tbody"></tbody>
    </table>
  </div>
</main>

<!-- Edit Group Modal -->
<div class="modalOverlay" id="editGroupOverlay" style="display:none;">
  <div class="modal" role="dialog" aria-modal="true" aria-labelledby="editGroupTitle">
    <div class="modalHeader">
      <h2 id="editGroupTitle" style="margin:0;">Edit Group</h2>
      <button class="btn" id="editGroupCloseBtn" type="button">Close</button>
    </div>
    <div class="modalBody">
      <div class="card" style="margin:0;">
        <h2 style="margin-top:0;">Edit Group</h2>

        <!-- Row that mirrors Create Group -->
        <div class="row">
          <label>Group Type
            <select id="editType">
              <option value="agency">Agency-Specific Group</option>
              <% if (isGlobalAdmin) { %>
              <option value="county">County-Specific Group</option>
              <option value="generic">Global Group</option>
              <% } %>
            </select>
          </label>

          <label id="editAgencyPrefixWrap" style="display:none;">Select Agency
            <select id="editAgencyPrefixSelect">
              <option value="">Select Agency</option>
            </select>
          </label>

          <label id="editCountyWrap" style="display:none;">Select County
            <select id="editCountySelect">
              <option value="">Select County</option>
            </select>
          </label>

          <label style="flex: 1; min-width: 160px;">Group Name
            <input
              id="editGroupName"
              placeholder="Group name"
              style="width: 100%;"
            />
          </label>

          <label style="min-width: 220px;">Channel Behavior
            <select id="editBehaviorSelect" style="min-width: 120px;">
              <option value="both">BOTH - Send and Recieve (default)</option>
              <option value="read">READ - Recieve Only</option>
              <option value="write">WRITE - Send Only</option>
            </select>
          </label>

          <% if (isGlobalAdmin) { %>
          <label style="min-width: 140px;">Private
            <select id="editPrivateSelect" style="min-width: 120px;">
              <option value="no">No</option>
              <option value="yes">Yes</option>
            </select>
          </label>
          <% } %>
        </div>

        <div class="row" style="margin-top:8px;">
          <label style="flex: 1; min-width: 0;">Group Description
            <input
              id="editGroupDescription"
              placeholder="One-line description for this group (optional)"
              style="width: 100%;"
            />
          </label>
        </div>

        <div class="row" style="margin-top:16px; align-items:center;">
          <button class="btn success" id="editGroupSaveBtn" type="button">Save Changes</button>
          <span id="editGroupMsg" class="msg"></span>
        </div>
      </div>
    </div>
  </div>
</div>

<!-- Mass Assign Modal -->
<div class="modalOverlay" id="massOverlay" style="display:none;">
  <div class="modal" role="dialog" aria-modal="true" aria-labelledby="massTitle">
    <div class="modalHeader">
      <h2 id="massTitle" style="margin:0;">Mass Assign</h2>
      <button class="btn" id="massCloseBtn" type="button">Close</button>
    </div>

    <div class="modalBody">
      <div class="segmented" style="margin-top:4px;">
        <button class="segBtn active" type="button" data-mode="agency">Entire agencies (suffix)</button>
        <button class="segBtn" type="button" data-mode="group">Users with existing group(s)</button>
        <button class="segBtn" type="button" data-mode="users">Specific users</button>
      </div>

      <!-- Agency mode -->
      <div id="massAgencyPane" style="margin-top:14px;">
        <div class="row" style="justify-content:space-between; align-items:center;">
          <input
