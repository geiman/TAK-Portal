const editGroupOverlay = document.getElementById("editGroupOverlay");
const editGroupCloseBtn = document.getElementById("editGroupCloseBtn");
const editGroupNameInput = document.getElementById("editGroupName");
const editGroupDescriptionInput = document.getElementById("editGroupDescription");
const editGroupSaveBtn = document.getElementById("editGroupSaveBtn");
const editGroupMsg = document.getElementById("editGroupMsg");

