      <!-- Users mode -->
      <div id="massUsersPane" style="display:none; margin-top:14px;">
        <div class="row" style="justify-content:space-between; align-items:center;">
          <input
            id="userSearch"
            placeholder="Search username, name, or email..."
            style="flex: 1; min-width: 0;"
            autocomplete="off"
          />
          <div class="row" style="gap:10px;">
            <button class="btn" id="userSelectAll" type="button">Select All (shown)</button>
            <button class="btn" id="userClearAll" type="button">Clear</button>
          </div>
        </div>
        <div id="userList" class="groupsBox" style="margin-top:10px;"></div>
        <small>Search and pick specific users to add the target group to.</small>
      </div>

