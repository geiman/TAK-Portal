  const mode = selectedMassMode();
  let payload = { groupId: activeMassGroupId };

  if (mode === "agency") {
    const suffixes = Array.from(agencyList.querySelectorAll('input.agencyChk:checked'))
      .map(x => String(x.value).trim().toLowerCase())
      .filter(Boolean);
    if (!suffixes.length) return setMsg(massMsg, "Select one or more agencies.", false);
    const actionVerb = massAction === "unassign" ? "unassign" : "assign";
    if (!confirm(`Mass ${actionVerb} "${activeMassGroupName}" ${actionVerb === "assign" ? "to" : "from"} all users in ${suffixes.length} agency suffix(es)?`)) return;
    payload.suffixes = suffixes;
  }

  if (mode === "group") {
    const srcIds = Array.from(selectedSourceGroupIds);
    if (!srcIds.length) return setMsg(massMsg, "Select one or more source groups.", false);
    const actionVerb = massAction === "unassign" ? "unassign" : "assign";
    if (!confirm(`Mass ${actionVerb} "${activeMassGroupName}" ${actionVerb === "assign" ? "to" : "from"} users already in ${srcIds.length} selected group(s)?`)) return;
    payload.sourceGroupIds = srcIds;
  }

  if (mode === "users") {
    const userIds = Array.from(selectedUserIds);
    if (!userIds.length) return setMsg(massMsg, "Select one or more users.", false);
    const actionVerb = massAction === "unassign" ? "unassign" : "assign";
    if (!confirm(`Mass ${actionVerb} "${activeMassGroupName}" ${actionVerb === "assign" ? "to" : "from"} ${userIds.length} user(s)?`)) return;
    payload.userIds = userIds;
  }

  const endpoint = massAction === "unassign" ? "/api/groups/mass-unassign" : "/api/groups/mass-assign";

  try {
    const res = await fetch(endpoint, {
      method: "POST",
      headers: {"Content-Type":"application/json"},
      body: JSON.stringify(payload)
    });
    const out = await res.json();
    if(!res.ok) return setMsg(massMsg, out.error || `Mass ${massAction} failed`, false);
    setMsg(massMsg, `Matched ${out.matched} user(s). Updated ${out.updated}.`, true);
  } catch (e) {
    setMsg(massMsg, `Mass ${massAction} failed`, false);
  }
};

if (reloadBtn) reloadBtn.onclick = loadGroups;

(async () => {
  createType.onchange();
  if (editType) editType.onchange();
  initGroupSort();
  await loadAgencies();
  await loadGroups();
})();
</script>

</div></body></html>
