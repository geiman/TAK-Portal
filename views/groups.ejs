let editGroupCurrentName = "";
let editGroupCurrentDescription = "";
let editGroupCurrentPrivate = "no";
let editGroupOriginalType = null; // used to prevent agency->global for non-global admins

// Rename (Edit Name)
window.editGroupName = async (groupId) => {
  setMsg(listMsg, "");

  const g = (groupsCache || []).find(x => String(x.pk) === String(groupId));
  const currentName = String(g?.name || "").trim();
  const currentDescription = String(g?.attributes?.description || "").trim();
  const currentPrivate = String(g?.attributes?.private || "no").trim().toLowerCase();

  if (groupActionsLocked(currentName)) {
    setMsg(listMsg, `Actions are locked for group ${currentName || groupId}`, false);
    return;
  }

  editGroupCurrentId = groupId;
  editGroupCurrentName = currentName;
  editGroupCurrentDescription = currentDescription;
  editGroupCurrentPrivate = currentPrivate;

  // Break apart the current name into structured fields
  const parsed = parseGroupName(currentName);
  editGroupOriginalType = parsed.type || "generic";

  // Type
  if (editType) {
    // If not global admin and this is an agency group, force type=agency
    if (!IS_GLOBAL_ADMIN && editGroupOriginalType === "agency") {
      editType.value = "agency";
    } else {
      editType.value = parsed.type || "generic";
    }
    if (editType.onchange) editType.onchange();
  }

  // Agency / county
  if (editAgencyPrefixSelect) {
    editAgencyPrefixSelect.value = parsed.agencyPrefix || "";
  }
  if (editCountySelect) {
    editCountySelect.value = parsed.county || "";
  }

  // Base name (no prefix, no behavior suffix)
  editGroupNameInput.value = parsed.baseName || "";

  // Behavior dropdown
  if (editBehaviorSelect) {
    editBehaviorSelect.value = parsed.behavior || "both";
  }

  // Description
  editGroupDescriptionInput.value = currentDescription;

  // Private dropdown (Global Admins only)
  if (editPrivateSelect) {
    editPrivateSelect.value = currentPrivate === "yes" ? "yes" : "no";
  }

  setMsg(editGroupMsg, "");
  showEditGroupModal(true);
};

// Delete w/ impact
window.deleteGroup = async (groupId) => {
  // Give immediate feedback so the user sees something while impact is computed
  setMsg(listMsg, "Calculating delete impact...", true);

  const g = (groupsCache || []).find(x => String(x.pk) === String(groupId));
  const name = String(g?.name || "").trim();
  if (name && groupActionsLocked(name)) {
    setMsg(listMsg, `Actions are locked for group ${name}`, false);
    return;
  }

  const impactRes = await fetch(`/api/groups/${encodeURIComponent(groupId)}/impact`);
  const impact = await impactRes.json();

  if(!impactRes.ok){
    setMsg(listMsg, impact.error || "Failed to fetch delete impact", false);
    return;
  }

  const tmplCount = Number(impact.templatesAffectedCount || 0);
  const userCount = Number(impact.usersAffected || 0);

  let tmplPreview = "";
  if (tmplCount > 0) {
    const names = (impact.templatesAffected || [])
      .slice(0, 6)
      .map(t => t.name)
      .filter(Boolean);
    tmplPreview = names.length ? `\n\nTemplates (first ${names.length}):\n- ${names.join("\n- ")}` : "";
    if ((impact.templatesAffected || []).length > 6) tmplPreview += `\n- ...and more`;
  }

  const ok = confirm(
    `DELETE GROUP: "${impact.groupName}"?\n\n` +
    `This will:\n` +
    `• Remove this group from ${userCount} user(s)\n` +
    `• Remove this group from ${tmplCount} template(s)\n\n` +
    `Then delete the group in Authentik.` +
    tmplPreview
  );

  if(!ok) return;

  const delRes = await fetch("/api/groups/" +
    encodeURIComponent(groupId), { method:"DELETE" });
  const out = await delRes.json();

  if(!delRes.ok){
    setMsg(listMsg, out.error || "Delete failed", false);
    return;
  }

  setMsg(
    listMsg,
    `Deleted "${out.groupName}". Removed from ${out.usersUpdated} user(s), updated ${out.templatesUpdated} template(s).`,
    true
  );

  await loadGroups();
};

