createBtn.onclick = async () => {
  setMsg(createMsg, "");

  let baseName = groupName.value.trim();
  if (!baseName) return setMsg(createMsg, "Group name is required", false);

  // Apply behavior suffix to the base name
  const behavior = String(behaviorSelect.value || "both").toLowerCase();
  let behaviorSuffix = "";
  if (behavior === "read") behaviorSuffix = "_READ";
  if (behavior === "write") behaviorSuffix = "_WRITE";

  let name = baseName + behaviorSuffix;

  const type = createType.value;

  if (type === "agency") {
    const prefix = String(agencyPrefixSelect.value || "").trim().toUpperCase();
    if (!prefix) return setMsg(createMsg, "Select an agency prefix.", false);
    name = `${prefix} ${name}`;
  } else if (type === "county") {
    const county = String(countySelect.value || "").trim();
    if (!county) return setMsg(createMsg, "Select a county.", false);
    name = `${county} Co ${name}`;
  }
  // type === "generic" just uses the base name + behavior suffix

  // Enforce tak_ prefix
  name = ensureTakPrefix(name);

  if (!confirm(`Create group "${name}"?`)) return;

  // Derive group type metadata for auditing
  let groupType = "Global";
  let groupTypeDetail = null;

  if (type === "agency") {
    groupType = "Agency";
    const prefix = String(agencyPrefixSelect.value || "").trim().toUpperCase();
    const agencyObj = (agenciesCache || []).find(a => {
      const p = String(a.groupPrefix || "").trim().toUpperCase();
      return p === prefix;
    });
    if (agencyObj && agencyObj.name) {
      groupTypeDetail = String(agencyObj.name);
    } else if (prefix) {
      groupTypeDetail = prefix;
    }
  } else if (type === "county") {
    groupType = "County";
    const county = String(countySelect.value || "").trim();
    if (county) {
      groupTypeDetail = county;
    }
  }

  const res = await fetch("/api/groups", {
    method: "POST",
    headers: {"Content-Type":"application/json"},
    body: JSON.stringify({
      name,
      description: String(groupDescription.value || "").trim() || null,
      private: (IS_GLOBAL_ADMIN && privateSelect)
        ? String(privateSelect.value || "no").trim().toLowerCase()
        : undefined,
      groupType,
      groupTypeDetail,
    })
  });

  const out = await res.json();
  if(!res.ok){
    setMsg(createMsg, out.error || "Create failed", false);
    return;
  }

  setMsg(createMsg, `Created "${name}"`, true);
  groupName.value = "";
  groupDescription.value = "";
  behaviorSelect.value = "both";
  if (privateSelect) privateSelect.value = "no";
  await loadGroups();
};

