<script>
const membersOverlay = document.getElementById("membersOverlay");
const membersCloseBtn = document.getElementById("membersCloseBtn");
const membersSummary = document.getElementById("membersSummary");
const membersFilter = document.getElementById("membersFilter");
const membersList = document.getElementById("membersList");
const membersHint = document.getElementById("membersHint");

const createType = document.getElementById("createType");
const agencyPrefixSelect = document.getElementById("agencyPrefixSelect");
const countySelect = document.getElementById("countySelect");
const groupName = document.getElementById("groupName");
const groupDescription = document.getElementById("groupDescription");
const agencyPrefixWrap = document.getElementById("agencyPrefixWrap");
const countyWrap = document.getElementById("countyWrap");
const editAgencyPrefixWrap = document.getElementById("editAgencyPrefixWrap");
const editCountyWrap = document.getElementById("editCountyWrap");

// Private dropdown (Global Admins only)
const privateSelect = document.getElementById("privateSelect");

// Behavior dropdown
const behaviorSelect = document.getElementById("behaviorSelect");

const createBtn = document.getElementById("createBtn");
const createMsg = document.getElementById("createMsg");

const filter = document.getElementById("filter");
const tbody = document.getElementById("tbody");
const listMsg = document.getElementById("listMsg");

// Sorting (similar behavior to users-manage.ejs)
let sortKey = "name";
let sortDir = 1; // 1 = ascending, -1 = descending

function normalizeSortValue(v){
  return String(v || "").trim().toLowerCase();
}

function getSortValue(group, key){
  if (!group) return "";
  if (key === "name") return normalizeSortValue(group.name);
  if (key === "private") {
    const isPriv = normalizeSortValue(group?.attributes?.private) === "yes";
    // Sort as 0/1 so non-private comes first in ascending order
    return isPriv ? "1" : "0";
  }
  return "";
}

function stableSortedCopy(arr, key, dir){
  const indexed = arr.map((item, idx) => ({ item, idx }));
  indexed.sort((a, b) => {
    const av = getSortValue(a.item, key);
    const bv = getSortValue(b.item, key);

    if (av < bv) return -1 * dir;
    if (av > bv) return  1 * dir;
    return a.idx - b.idx;
  });
  return indexed.map(x => x.item);
}

function updateSortIndicators(){
  const headers = document.querySelectorAll("th.sortable");
  headers.forEach(th => {
    const key = th.getAttribute("data-key");
    const indicator = th.querySelector(".sortIndicator");
    if (!indicator) return;

    if (key === sortKey) indicator.textContent = (sortDir === 1 ? "▲" : "▼");
    else indicator.textContent = "";
  });
}

function initGroupSort(){
  const headers = document.querySelectorAll("th.sortable");
  headers.forEach(th => {
    th.style.cursor = "pointer";
    th.addEventListener("click", () => {
      const key = th.getAttribute("data-key");
      if (!key) return;

      if (key === sortKey) sortDir *= -1;
      else {
        sortKey = key;
        sortDir = 1;
      }
      updateSortIndicators();
      renderGroups();
    });
  });

  updateSortIndicators();
}
const reloadBtn = document.getElementById("reloadBtn");

// Mass assign modal
const massOverlay = document.getElementById("massOverlay");
const massCloseBtn = document.getElementById("massCloseBtn");
const massTitle = document.getElementById("massTitle");
const massMsg = document.getElementById("massMsg");
const massApplyBtn = document.getElementById("massApplyBtn");

const massAgencyPane = document.getElementById("massAgencyPane");
const massGroupPane = document.getElementById("massGroupPane");
const massUsersPane = document.getElementById("massUsersPane");

const agencySearch = document.getElementById("agencySearch");
const agencyList = document.getElementById("agencyList");
const agencySelectAll = document.getElementById("agencySelectAll");
const agencyClearAll = document.getElementById("agencyClearAll");

const sourceGroupSearch = document.getElementById("sourceGroupSearch");
const sourceGroupList = document.getElementById("sourceGroupList");
const groupSelectAll = document.getElementById("groupSelectAll");
const groupClearAll = document.getElementById("groupClearAll");

const userSearch = document.getElementById("userSearch");
const userList = document.getElementById("userList");
const userSelectAll = document.getElementById("userSelectAll");
const userClearAll = document.getElementById("userClearAll");

// Edit Group controls (mirror Create Group controls)
const editType = document.getElementById("editType");
const editAgencyPrefixSelect = document.getElementById("editAgencyPrefixSelect");
const editCountySelect = document.getElementById("editCountySelect");
const editBehaviorSelect = document.getElementById("editBehaviorSelect");

// Private dropdown (Global Admins only)
const editPrivateSelect = document.getElementById("editPrivateSelect");

// Global admin flag for JS logic
const IS_GLOBAL_ADMIN = <%= isGlobalAdmin ? 'true' : 'false' %>;

let groupsCache = [];
let agenciesCache = [];

// Action-lock prefixes (case-insensitive, comma-separated)
const GROUPS_ACTIONS_HIDDEN_PREFIXES_RAW = "<%= (process.env.GROUPS_ACTIONS_HIDDEN_PREFIXES) %>";
const GROUPS_ACTIONS_HIDDEN_PREFIXES = GROUPS_ACTIONS_HIDDEN_PREFIXES_RAW
  .split(",")
  .map(p => String(p || "").trim().toLowerCase())
  .filter(Boolean);

function groupActionsLocked(name){
  const n = String(name || "").trim().toLowerCase();
  if (!n) return false;
  return GROUPS_ACTIONS_HIDDEN_PREFIXES.some(p => n.startsWith(p));
}

let massAction = "assign";
let activeMassGroupId = "";
let activeMassGroupName = "";
let usersSearchCache = [];
let massMode = "agency";

const selectedSourceGroupIds = new Set();
const selectedUserIds = new Set();

function setMsg(el, text, ok=true){
  el.textContent = text || "";
  el.className = "msg " + (ok ? "ok" : "bad");
}

function esc(s){
  return String(s ?? "")
    .replaceAll("&","&amp;")
    .replaceAll("<","&lt;")
    .replaceAll(">","&gt;")
    .replaceAll('"',"&quot;")
    .replaceAll("'","&#39;");

function ensureTakPrefix(name){
  const n = String(name || "").trim();
  if(!n) return "";
  return n.toLowerCase().startsWith("tak_") ? n : `tak_${n}`;
}

function stripTakPrefix(name){
  const n = String(name || "").trim();
  return n.toLowerCase().startsWith("tak_") ? n.slice(4) : n;
}

}

async function loadAgencies(){
  const res = await fetch("/api/agencies");
  const out = await res.json();
  if(!res.ok){
    agenciesCache = [];
    agencyPrefixSelect.innerHTML = `<option value="">No agencies loaded</option>`;
    countySelect.innerHTML = `<option value="">No counties loaded</option>`;
    // Mirror into edit selects even in error case
    if (editAgencyPrefixSelect) {
      editAgencyPrefixSelect.innerHTML = agencyPrefixSelect.innerHTML;
    }
    if (editCountySelect) {
      editCountySelect.innerHTML = countySelect.innerHTML;
    }
    return;
  }

  agenciesCache = Array.isArray(out) ? out : [];

  // --- Agency prefix dropdown (groupPrefix) ---
  const prefixList = agenciesCache
    .filter(a => String(a.groupPrefix || "").trim())
    .slice()
    .sort((a,b)=>String(a.name||"").localeCompare(String(b.name||"")));

  agencyPrefixSelect.innerHTML =
    `<option value="">Select Agency</option>` +
    prefixList.map(a => {
      const prefix = String(a.groupPrefix || "").trim().toUpperCase();
      const label = `${a.name} (${prefix})`;
      return `<option value="${esc(prefix)}">${esc(label)}</option>`;
    }).join("");

  // --- County dropdown (unique counties from agencies) ---
  const countySet = new Set(
    agenciesCache
      .map(a => String(a.county || "").trim())
      .filter(c => c)
  );
  const countyList = Array.from(countySet).sort((a, b) => a.localeCompare(b));

  countySelect.innerHTML =
    `<option value="">Select County</option>` +
    countyList.map(c => `<option value="${esc(c)}">${esc(c)}</option>`).join("");

  // Mirror options into Edit modal dropdowns
  if (editAgencyPrefixSelect) {
    editAgencyPrefixSelect.innerHTML = agencyPrefixSelect.innerHTML;
  }
  if (editCountySelect) {
    editCountySelect.innerHTML = countySelect.innerHTML;
  }

  renderAgencyList();
}

function agencyItems(){
  return agenciesCache
    .filter(a => String(a.suffix || "").trim())
    .slice()
    .sort((a,b)=>String(a.name||"").localeCompare(String(b.name||"")))
    .map(a => {
      const sfx = String(a.suffix || "").trim().toLowerCase();
      return { name: String(a.name || ""), suffix: sfx };
    });
}

// Parse a full group name into type/prefix/county/baseName/behavior
function parseGroupName(fullName) {
  let name = String(fullName || "").trim();
  // Remove mandatory tak_ prefix before parsing
  name = stripTakPrefix(name);
  let behavior = "both";

  // Strip behavior suffix first
  if (name.endsWith("_READ")) {
    behavior = "read";
    name = name.slice(0, -5);
  } else if (name.endsWith("_WRITE")) {
    behavior = "write";
    name = name.slice(0, -6);
  }

  let type = "generic";
  let agencyPrefix = "";
  let county = "";
  let baseName = name;

  // Try to split on " - "
  const dashIdx = name.indexOf(" - ");
  if (dashIdx > 0) {
    const left = name.slice(0, dashIdx).trim();
    const right = name.slice(dashIdx + 3).trim();
    // County groups are formatted like "<County> Co - <Title>".
    // Normalize the left side so we can correctly detect/edit them.
    const leftNoCo = left.replace(/\s+co\s*$/i, "").trim();
    const leftUpper = left.toUpperCase();
    const leftNoCoUpper = leftNoCo.toUpperCase();

    // Check for agency prefix
    const agencyMatch = (agenciesCache || []).find(a =>
      String(a.groupPrefix || "").trim().toUpperCase() === leftUpper
    );

    if (agencyMatch) {
      type = "agency";
      agencyPrefix = leftUpper;
      baseName = right || "";
    } else {
      // Try County (compare uppercase)
      const countySet = new Set(
        (agenciesCache || [])
          .map(a => String(a.county || "").trim())
          .filter(Boolean)
          .map(c => c.toUpperCase())
      );
      if (countySet.has(leftNoCoUpper) || countySet.has(leftUpper)) {
        type = "county";
        // Use canonical casing from agenciesCache so the dropdown value matches.
        const canonical = (agenciesCache || [])
          .map(a => String(a.county || "").trim())
          .filter(Boolean)
          .find(c => c.toUpperCase() === leftNoCoUpper);
        county = canonical || leftNoCo || left; // keep original case for the dropdown
        baseName = right || "";
      } else {
        // Fallback: treat everything as base name
        baseName = name;
      }
    }
  } else {
    baseName = name;
  }


  // Fallback parse for new format without " - "
  // Agency: "<PREFIX> <Title>"
  if (type === "generic") {
    const upperName = name.toUpperCase();
    const agencyPrefixes = (agenciesCache || [])
      .map(a => String(a.groupPrefix || "").trim().toUpperCase())
      .filter(Boolean)
      .sort((a,b)=>b.length - a.length); // longest first, just in case
    const hit = agencyPrefixes.find(pfx => upperName.startsWith(pfx + " "));
    if (hit) {
      type = "agency";
      agencyPrefix = hit;
      baseName = name.slice(hit.length + 1).trim(); // drop "<PREFIX> "
    }
  }

  // County: "<County> Co <Title>"
  if (type === "generic") {
    const counties = Array.from(new Set(
      (agenciesCache || [])
        .map(a => String(a.county || "").trim())
        .filter(Boolean)
    )).sort((a,b)=>b.length - a.length); // longest first
    const hitCounty = counties.find(cn => name.toLowerCase().startsWith((cn + " Co ").toLowerCase()));
    if (hitCounty) {
      type = "county";
      county = hitCounty;
      baseName = name.slice((hitCounty + " Co ").length).trim();
    }
  }

  return { type, agencyPrefix, county, baseName, behavior };
}

// Build a full group name from broken-out fields
function buildGroupNameFromParts({ type, baseName, behavior, prefix, county }) {
  let name = String(baseName || "").trim();
  if (!name) return "";

  const b = String(behavior || "both").toLowerCase();
  if (b === "read") name += "_READ";
  else if (b === "write") name += "_WRITE";

  if (type === "agency") {
    const p = String(prefix || "").trim().toUpperCase();
    if (!p) return "";
    name = `${p} ${name}`;
  } else if (type === "county") {
    const c = String(county || "").trim();
    if (!c) return "";
    name = `${c} Co ${name}`;
  }

  return ensureTakPrefix(name);
}

function isGroupEditable(name){
  <% if (isGlobalAdmin) { %>
  // Global admins can always rename/delete groups (subject to action locks).
  return true;
  <% } %>

  const n = String(name || "").trim();
  // Agency-specific groups are formatted like "<PREFIX> <Title>"
  const spIdx = n.indexOf(" ");
  if (spIdx <= 0) return false;

  // trim, so "CPD " becomes "CPD"
  const prefix = n.slice(0, spIdx).trim().toUpperCase();

  // Agency-specific groups: editable only if the prefix matches one of the
  // current user's agency groupPrefixes (from agenciesCache).
  return agenciesCache.some(a =>
    String(a.groupPrefix || "").trim().toUpperCase() === prefix
  );
}

function renderAgencyList(){
  const needle = String(agencySearch.value || "").trim().toLowerCase();
  const items = agencyItems().filter(x => {
    if (!needle) return true;
    return (
      x.name.toLowerCase().includes(needle) ||
      x.suffix.toLowerCase().includes(needle)
    );
  });

  agencyList.innerHTML = items.map(x => {
    const label = `${x.name} (${x.suffix})`;
    return `
      <label class="groupItem">
        <input type="checkbox" class="agencyChk" value="${esc(x.suffix)}" />
        <span>${esc(label)}</span>
      </label>
    `;
  }).join("") || `<div style="padding:10px; color: var(--muted);">No agencies found.</div>`;
}

// Show/hide agency / county selects based on type
createType.onchange = () => {
  const v = createType.value;
  const isAgency = v === "agency";
  const isCounty = v === "county";

  if (agencyPrefixWrap) agencyPrefixWrap.style.display = isAgency ? "flex" : "none";
  if (countyWrap) countyWrap.style.display = isCounty ? "flex" : "none";
};

// Show/hide edit agency / county selects based on type
if (editType) {
  editType.onchange = () => {
    const v = editType.value;
    const isAgency = v === "agency";
    const isCounty = v === "county";

    if (editAgencyPrefixWrap) editAgencyPrefixWrap.style.display = isAgency ? "flex" : "none";
    if (editCountyWrap) editCountyWrap.style.display = isCounty ? "flex" : "none";
  };
}


function renderGroups(){
  const needle = String(filter.value || "").trim().toLowerCase();
  const filteredRaw = needle
    ? groupsCache.filter(g => {
        const name = String(g.name || "").toLowerCase();
        const desc = String(g?.attributes?.description || "").toLowerCase();
        return name.includes(needle) || desc.includes(needle);
      })
    : groupsCache;

  const filtered = stableSortedCopy(filteredRaw, sortKey, sortDir);

  tbody.innerHTML = filtered.map(g => {
    const locked = groupActionsLocked(g.name);
    const editable = !locked && isGroupEditable(g.name);
    const desc = String(g?.attributes?.description || "").trim();
    const isPrivate = String(g?.attributes?.private || "").trim().toLowerCase() === "yes";

    return `
    <tr>
      <td style="max-width:320px; white-space:nowrap; overflow:hidden; text-overflow:ellipsis;">
        ${esc(g.name)}
