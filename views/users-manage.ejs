// Load templates & default groups for a specific agency suffix
let agencyTemplatesCache = [];

async function loadTemplatesForAgency(agencySuffix){
  agencyTemplatesCache = [];
  if (!templateApplySelect) return;

  templateApplySelect.innerHTML = '<option value="">Loading templates...</option>';
  if (applyTemplateBtn) applyTemplateBtn.disabled = true;

  const sfx = String(agencySuffix || "").trim();
  if (!sfx) {
    templateApplySelect.innerHTML = '<option value="">No agency info for this user</option>';
    return;
  }

  try {
    const res = await fetch('/api/users/meta?agencySuffix=' + encodeURIComponent(sfx));
    const meta = await res.json();
    if (!res.ok) throw new Error(meta.error || 'Failed to load templates');

    const all = Array.isArray(meta.templates) ? meta.templates : [];
    const rest = all.slice(1);
    const manual = all[0];

    const options = [];
    if (manual) {
      options.push(`<option value="${escapeHtml(manual.key)}">${escapeHtml(manual.label)}</option>`);
    }
    rest.forEach(t => {
      options.push(`<option value="${escapeHtml(t.key)}">${escapeHtml(t.label)}</option>`);
    });

    templateApplySelect.innerHTML = options.join("");
    agencyTemplatesCache = all;
    if (applyTemplateBtn) applyTemplateBtn.disabled = false;
  } catch (err) {
    templateApplySelect.innerHTML = '<option value="">Failed to load templates</option>';
    console.error(err);
  }
}

// Groups list
let groupIndex = new Map();
let pickedGroupIds = new Set();

// Group IDs that are "known" to this portal UI (i.e. returned from /api/users/meta.groups).
// Templates should only add/remove these. Anything outside this set is preserved.
let visibleGroupIds = new Set();

// Name->id cache for groups that may be hidden from the UI list
// (e.g. groups starting with "authentik-").
const groupNameToIdCache = new Map();

function getUserAgencyAbbreviation(user){
  const attrs = user && user.attributes ? user.attributes : {};
  const raw =
    attrs.agency_abbreviation ||
    attrs.agencyAbbreviation ||
    attrs.agencyAbbr ||
    attrs.agencyabbr ||
    "";
  return String(raw || "").trim();
}

function getAgencyAdminGroupNameForUser(user){
  const abbr = getUserAgencyAbbreviation(user);
  if (!abbr) return null;
  return `authentik-${String(abbr).trim().toUpperCase()}-AgencyAdmin`;
}

// Cache agency admin group ids per abbreviation so we can show a Role column in the results table
const agencyAdminGroupIdByAbbr = new Map();

async function ensureAgencyAdminIdsForUsers(users){
  const uniq = new Set();
  (users || []).forEach(u => {
    const abbr = String(getUserAgencyAbbreviation(u) || '').trim().toUpperCase();
    if (abbr) uniq.add(abbr);
  });

  for (const abbr of uniq){
    if (agencyAdminGroupIdByAbbr.has(abbr)) continue;
    const groupName = `authentik-${abbr}-AgencyAdmin`;
    const id = await resolveGroupIdByName(groupName);
    agencyAdminGroupIdByAbbr.set(abbr, id || null);
  }
}

function roleForUser(user){
  const abbr = String(getUserAgencyAbbreviation(user) || '').trim().toUpperCase();
  const adminId = abbr ? agencyAdminGroupIdByAbbr.get(abbr) : null;
  const groups = Array.isArray(user && user.groups) ? user.groups.map(x => String(x)) : [];
  return (adminId && groups.includes(String(adminId))) ? 'Admin' : 'User';
}

async function loadGroups(){
  const res = await fetch("/api/users/meta");
  const meta = await res.json();

  if(!res.ok){
    throw new Error(meta.error || "Failed to load groups");
  }

  const groups = Array.isArray(meta.groups) ? meta.groups : [];
  visibleGroupIds = new Set(groups.map(g => String(g.pk)));
  groupIndex = new Map(groups.map(g => [String(g.pk), g.name || ("Group " + g.pk)]));

  renderGroupsBox();
}

async function applyGroupChange(groupId, shouldBeMember){
  if (!selectedUser) return;

  const url = shouldBeMember
    ? `/api/users/${selectedUser.pk}/groups/add`
    : `/api/users/${selectedUser.pk}/groups/remove`;

  setMsgEl(actionMsg, "Updating groups...", true);

  let res;
  try {
    res = await fetch(url, {
      method: "POST",
      headers: { "Content-Type": "application/json" },
      body: JSON.stringify({ groupIds: [String(groupId)] }),
    });
  } catch (err) {
    setMsgEl(actionMsg, "Network error while updating groups", false);
    return;
  }

  const out = await res.json();
  if (!res.ok) {
    setMsgEl(actionMsg, out.error || "Update groups failed", false);
    pickedGroupIds = new Set((selectedUser.groups || []).map(x => String(x)));
    renderGroupsBox();
    return;
  }

  const newGroups = Array.isArray(out.groups) ? out.groups : Array.from(pickedGroupIds);
  selectedUser.groups = newGroups;
  pickedGroupIds = new Set((newGroups || []).map(x => String(x)));

  // Update role label (User/Admin) based on groups
  selectedUser.__role = roleForUser(selectedUser);
  renderGroupChips(selectedUser);

  const patch = (u) => String(u.pk) === String(selectedUser.pk)
    ? { ...u, groups: selectedUser.groups, __role: selectedUser.__role }
    : u;

  allUsers = (allUsers || []).map(patch);
  const updatedVisible = (window.__lastUsers || []).map(patch);
  applySortAndRender(updatedVisible);

  setMsgEl(actionMsg, "Groups updated.", true);
}

function renderGroupsBox(){
  // Only show "known/portal-visible" groups in the checkbox grid.
  // We may inject hidden/internal groups into groupIndex so we can render their names
  // in the "Current Groups" chips, but we don't want admins toggling them here.
  const allGroupsArray = Array.from(groupIndex.entries())
    .map(([id,name]) => ({id: String(id), name}))
    .filter(g => visibleGroupIds.has(String(g.id)));

  const filterText = groupFilter.value.trim().toLowerCase();
  const filteredGroups = filterText
    ? allGroupsArray.filter(g => {
        const raw = String(g.name || "").toLowerCase();
        const display = stripTakPrefix(g.name).toLowerCase();
        return raw.includes(filterText) || display.includes(filterText);
      })
    : allGroupsArray;

  groupsInner.innerHTML = filteredGroups.map(g => {
    const id = String(g.id);
    const checked = pickedGroupIds.has(id) ? "checked" : "";
    return `
      <label class="groupItem">
        <input type="checkbox" value="${escapeHtml(id)}" ${checked} />
        <span>${escapeHtml(stripTakPrefix(g.name))}</span>
      </label>
    `;
  }).join("");

  Array.from(groupsBox.querySelectorAll("input[type=checkbox]")).forEach(cb => {
    cb.addEventListener("change", () => {
      const id = String(cb.value);
      if (cb.checked) {
        pickedGroupIds.add(id);
      } else {
        pickedGroupIds.delete(id);
      }
      applyGroupChange(id, cb.checked);
    });
  });
}

groupFilter.addEventListener("input", ()=>renderGroupsBox());

if (selectAllBtn) selectAllBtn.addEventListener("click", function() {
  pickedGroupIds = new Set(Array.from(visibleGroupIds));
  renderGroupsBox();
});

if (clearAllBtn) clearAllBtn.addEventListener("click", function() {
  pickedGroupIds = new Set();
  renderGroupsBox();
});

// Selected user in the modal
let selectedUser = null;

function getGroupIdByName(name){
  const target = String(name || "").trim().toLowerCase();
  if (!target) return null;
  for (const [id, groupName] of groupIndex.entries()) {
    if (String(groupName || "").trim().toLowerCase() === target) return String(id);
  }
  return null;
}

// Resolve a group id by name, even if the group is hidden by GROUPS_HIDDEN_PREFIXES.
// Falls back to /api/users/group-lookup (global admins only) and caches the result.
async function resolveGroupIdByName(name){
  const key = String(name || "").trim().toLowerCase();
  if (!key) return null;

  // 1) Try visible groups first
  const direct = getGroupIdByName(name);
  if (direct) return direct;

  // 2) Try cache
  if (groupNameToIdCache.has(key)) return groupNameToIdCache.get(key);

  // 3) Ask server (includes hidden groups)
  try {
    const res = await fetch(`/api/users/group-lookup?name=${encodeURIComponent(name)}`);
    const out = await res.json().catch(()=> ({}));
    if (!res.ok) return null;
    const id = String(out.pk || "");
    const nm = String(out.name || "").trim();
    if (!id || !nm) return null;

    // Cache and also inject into groupIndex so chips can render the proper name
    groupNameToIdCache.set(key, id);
    groupIndex.set(id, nm);
    return id;
  } catch (e) {
    return null;
  }
}

window.editUser = async (userPk) => {
  const pkStr = String(userPk);
  const sourceLists = [
    window.__lastUsers || [],
    currentPageUsers || [],
    allUsers || [],
  ].filter(Array.isArray);

  let u = null;
  for (const list of sourceLists) {
    u = list.find(x => String(x.pk) === pkStr);
    if (u) break;
  }
  if (!u) {
    console.warn("editUser: user not found for pk", userPk, {
      sourceLengths: sourceLists.map(l => l.length),
    });
    return;
  }

  selectedUser = { ...u };

  // Resolve hidden/internal group names we know how to derive (e.g. the agency admin group)
  // BEFORE rendering chips so users never see raw UUIDs.
  const adminGroupName = getAgencyAdminGroupNameForUser(selectedUser);
  const adminGroupId = adminGroupName
    ? await resolveGroupIdByName(adminGroupName)
    : null;

  if (userTitle) userTitle.textContent = `User ${selectedUser.username}`;

  if (usernameSpan) {
    usernameSpan.textContent = `${selectedUser.username} — ${selectedUser.name || ""}`;
  }

  if (emailInput) emailInput.value = selectedUser.email || "";

  const { first, last } = splitName(selectedUser.name || "");
  if (firstNameInput) firstNameInput.value = first;
  if (lastNameInput) lastNameInput.value = last;

  setMsgEl(nameMsg, "");
  setMsgEl(actionMsg, "");

  renderGroupChips(selectedUser);

  pickedGroupIds = new Set((selectedUser.groups || []).map(x => String(x)));
  renderGroupsBox();

  // Default permissions = User; if user is in their agency admin group, reflect that.
  if (permissionsSelect) {
    if (adminGroupName) {
      const hasAdmin = adminGroupId
        ? (selectedUser.groups || []).some(gid => String(gid) === String(adminGroupId))
        : false;
      permissionsSelect.value = hasAdmin ? "agency_admin" : "user";
      permissionsSelect.disabled = false;
      if (applyPermissionsBtn) applyPermissionsBtn.disabled = false;
    } else {
      permissionsSelect.value = "user";
      permissionsSelect.disabled = true;
      if (applyPermissionsBtn) applyPermissionsBtn.disabled = true;
    }
  }

  // modal-only action buttons are not present; guard if you ever add them back
  if (toggleBtn) {
    toggleBtn.textContent = selectedUser.is_active ? "Disable User" : "Enable User";
  }

  await loadTemplatesForAgency(
    (selectedUser && selectedUser.attributes && selectedUser.attributes.agency) || ""
  );

  openModal();
};

// ---------- Permissions apply ----------
if (applyPermissionsBtn) applyPermissionsBtn.addEventListener("click", async () => {
  if (!selectedUser) return;

  setMsgEl(actionMsg, "");

  const desired = (permissionsSelect && permissionsSelect.value) || "user";
  const isAgencyAdmin = desired === "agency_admin";
  const isGlobalAdmin = desired === "global_admin";
  const adminGroupName = getAgencyAdminGroupNameForUser(selectedUser);

  if (!adminGroupName) {
    setMsgEl(actionMsg, "Cannot set permissions: user has no agency abbreviation.", false);
    return;
  }

  const adminGroupId = await resolveGroupIdByName(adminGroupName);
  if (!adminGroupId) {
    setMsgEl(actionMsg, `Cannot find group: ${adminGroupName}.`, false);
    return;
  }

  const currentlyHasAdmin = (selectedUser.groups || []).some(gid => String(gid) === String(adminGroupId));

  // Keep behavior simple and predictable:
  // - Selecting Agency Admin adds the group
  // - Selecting User removes the group (if present)
  const shouldHaveAdmin = isAgencyAdmin;

  if (shouldHaveAdmin === currentlyHasAdmin) {
    setMsgEl(actionMsg, shouldHaveAdmin ? "Already an Agency Admin." : "Already a User.", true);
    return;
  }

  const url = shouldHaveAdmin
    ? `/api/users/${selectedUser.pk}/groups/add`
    : `/api/users/${selectedUser.pk}/groups/remove`;

  setMsgEl(actionMsg, "Updating permissions...", true);

  let res;
  try {
    res = await fetch(url, {
      method: "POST",
      headers: { "Content-Type": "application/json" },
      body: JSON.stringify({ groupIds: [String(adminGroupId)] }),
    });
  } catch (err) {
    setMsgEl(actionMsg, "Network error while updating permissions.", false);
    return;
  }

  const out = await res.json();
  if (!res.ok) {
    setMsgEl(actionMsg, out.error || "Failed to update permissions.", false);
    return;
  }

  const newGroups = Array.isArray(out.groups) ? out.groups : (selectedUser.groups || []);
  selectedUser.groups = newGroups;
  pickedGroupIds = new Set((newGroups || []).map(x => String(x)));

  selectedUser.__role = roleForUser(selectedUser);
  renderGroupChips(selectedUser);
  renderGroupsBox();

  const patch = (u) =>
    String(u.pk) === String(selectedUser.pk) ? { ...u, groups: selectedUser.groups, __role: selectedUser.__role } : u;
  allUsers = (allUsers || []).map(patch);
  const updatedVisible = (window.__lastUsers || []).map(patch);
  applySortAndRender(updatedVisible);

  setMsgEl(actionMsg, isGlobalAdmin ? "Permissions updated: Global Admin." : (shouldHaveAdmin ? "Permissions updated: Agency Admin." : "Permissions updated: User."), true);
});

window.toggleUserFromTable = async (userPk) => {
  const u = (window.__lastUsers || []).find(x => String(x.pk) === String(userPk));
  if (!u) return;

  if (userActionsLocked(u.username)) {
    setMsgEl(msg, `Actions are locked for user ${u.username}.`, false);
    return;
  }

  const action = u.is_active ? "DISABLE" : "ENABLE";
  if (!confirm(`${action} ${u.username}?`)) return;

  const newState = !u.is_active;

  let res;
  try {
    res = await fetch(`/api/users/${u.pk}/active`, {
      method: "PUT",
      headers: { "Content-Type": "application/json" },
      body: JSON.stringify({ is_active: newState }),
    });
  } catch (err) {
    return setMsgEl(msg, "Network error while updating user.", false);
  }

  const raw = await res.text();
  let out = {};
  try { out = JSON.parse(raw); } catch { out = {}; }

  if (!res.ok) return setMsgEl(msg, out.error || "Toggle failed", false);

  const flip = (row) =>
    (String(row.pk) === String(u.pk) ? { ...row, is_active: newState } : row);

  allUsers = (allUsers || []).map(flip);
  const updatedVisible = (window.__lastUsers || []).map(flip);

  if (selectedUser && String(selectedUser.pk) === String(u.pk)) {
    selectedUser.is_active = newState;
    if (toggleBtn) toggleBtn.textContent = selectedUser.is_active ? "Disable User" : "Enable User";
    setMsgEl(actionMsg, `User is now ${selectedUser.is_active ? "ENABLED" : "DISABLED"}.`, true);
  }

  applySortAndRender(updatedVisible);
  setMsgEl(msg, `User ${u.username} is now ${newState ? "ENABLED" : "DISABLED"}.`, true);
};

window.deleteUserFromTable = async (userPk) => {
  const u = (window.__lastUsers || []).find(x => String(x.pk) === String(userPk));
  if(!u) return;

  if (userActionsLocked(u.username)) {
    setMsgEl(msg, `Actions are locked for user ${u.username}.`, false);
    return;
  }

  if(!confirm(`DELETE ${u.username}? This cannot be undone.`)) return;

  const res = await fetch(`/api/users/${u.pk}`, { method:"DELETE" });
  const out = await res.json();
  if(!res.ok) return setMsgEl(msg, out.error || "Delete failed", false);

  if (selectedUser && String(selectedUser.pk) === String(u.pk)) {
    selectedUser = null;
    closeModal();
  }

  allUsers = (allUsers || []).filter(row => String(row.pk) !== String(u.pk));
  const remainingVisible = (window.__lastUsers || []).filter(row => String(row.pk) !== String(u.pk));

  applySortAndRender(remainingVisible);
  setMsgEl(msg, `User ${u.username} deleted.`, true);
};

// ---------- LIVE filter ----------
function applyFilterSortRender(){
  currentSearch = String(q.value || "").trim();
  currentPage = 1;
  loadAllUsers();
}

function scheduleFilter(){
  clearTimeout(filterTimer);
  filterTimer = setTimeout(applyFilterSortRender, 120);
}

q.addEventListener("input", scheduleFilter);

q.addEventListener("keydown", (e) => {
  if (e.key === "Escape") {
    q.value = "";
    applyFilterSortRender();
  }
});

function renderCurrentPage() {
  const sorted = stableSortedCopy(currentPageUsers.slice(), sortState.key, sortState.dir);
  window.__lastUsers = sorted;
  renderResults(sorted);
  updatePaginationControls();
}

function updatePaginationControls() {
  const haveTop = !!paginationTop;
  const haveBottom = !!paginationBottom;

  if (!haveTop && !haveBottom) return;

  const total = totalUsers || 0;
  if (!total) {
    if (haveTop) paginationTop.style.display = "none";
    if (haveBottom) paginationBottom.style.display = "none";
    return;
  }

  const totalPages = Math.max(1, Math.ceil(total / PAGE_SIZE));

  if (haveTop) paginationTop.style.display = "flex";
  if (haveBottom) paginationBottom.style.display = "flex";

  const shown = currentPageUsers.length;
  const infoText = `Page ${currentPage} of ${totalPages} — showing ${shown} of ${total} users`;

  if (pageInfoTop) pageInfoTop.textContent = infoText;
  if (pageInfoBottom) pageInfoBottom.textContent = infoText;

  const disablePrev = !hasPrevPage && currentPage <= 1;
  const disableNext = !hasNextPage;

  [prevPageBtnTop, prevPageBtnBottom].forEach(btn => {
    if (btn) btn.disabled = disablePrev;
  });
  [nextPageBtnTop, nextPageBtnBottom].forEach(btn => {
    if (btn) btn.disabled = disableNext;
  });
}

[prevPageBtnTop, prevPageBtnBottom].forEach(btn => {
  if (!btn) return;
  btn.addEventListener("click", () => {
    if (currentPage > 1) {
      currentPage--;
      loadAllUsers();
    }
  });
});

[nextPageBtnTop, nextPageBtnBottom].forEach(btn => {
  if (!btn) return;
  btn.addEventListener("click", () => {
    if (hasNextPage) {
      currentPage++;
      loadAllUsers();
    }
  });
});

function applySortAndRender(users){
  const base = Array.isArray(users) ? users.slice() : currentPageUsers.slice();
  const sorted = stableSortedCopy(base, sortState.key, sortState.dir);

  window.__lastUsers = sorted;
  currentPageUsers = sorted;
  allUsers = sorted;

  renderCurrentPage();
  updateSortIndicators();
}

thead.addEventListener("click", (e) => {
  const th = e.target && e.target.closest ? e.target.closest("th.sortable") : null;
  if (!th) return;

  const key = th.dataset.key;
  if (!key) return;

  if (sortState.key === key) {
    sortState.dir = (sortState.dir === "asc") ? "desc" : "asc";
  } else {
    sortState.key = key;
    sortState.dir = "asc";
  }

  applySortAndRender(window.__lastUsers || currentPageUsers || []);
});

// ---------- Update name ----------
saveNameBtn.onclick = async () => {
  if (!selectedUser) return;

  setMsgEl(nameMsg, "");
  setMsgEl(actionMsg, "");

  const first = String(firstNameInput.value || "").trim();
  const last  = String(lastNameInput.value || "").trim();
  if (!first && !last) {
    return setMsgEl(nameMsg, "Enter a name or cancel.", false);
  }

  const newName = last ? `${last}, ${first}` : first;

  let res;
  try {
    res = await fetch(`/api/users/${selectedUser.pk}/name`, {
      method: "PUT",
      headers: { "Content-Type": "application/json" },
      body: JSON.stringify({ name: newName })
    });
  } catch {
    return setMsgEl(nameMsg, "Network error.", false);
  }

  const { json } = await readJsonSafe(res);

  if (!res.ok) {
    return setMsgEl(
      nameMsg,
      (json && json.error) || `Update failed (HTTP ${res.status})`,
      false
    );
  }

  selectedUser.name = newName;

  const patch = u =>
    String(u.pk) === String(selectedUser.pk) ? { ...u, name: newName } : u;

  allUsers = (allUsers || []).map(patch);
  const updatedVisible = (window.__lastUsers || []).map(patch);
  applySortAndRender(updatedVisible);

  setMsgEl(nameMsg, "Name updated.", true);
};


// ---------- Update email ----------
saveEmailBtn.onclick = async () => {
  if (!selectedUser) return;

  setMsgEl(actionMsg, "");

  const email = String(emailInput.value || "").trim();

// If provided, must be valid format
if (email && !emailInput.checkValidity()) {
  return setMsgEl(actionMsg, "Invalid email format.", false);
}


  let res;
  try {
    res = await fetch(`/api/users/${selectedUser.pk}/email`, {
      method: "PUT",
      headers: { "Content-Type": "application/json" },
      body: JSON.stringify({ email })
    });
  } catch {
    return setMsgEl(actionMsg, "Network error.", false);
  }

  const { json } = await readJsonSafe(res);

  if (!res.ok) {
    return setMsgEl(
      actionMsg,
      (json && json.error) || `Update failed (HTTP ${res.status})`,
      false
    );
  }

  selectedUser.email = email;

  const patch = u =>
    String(u.pk) === String(selectedUser.pk) ? { ...u, email } : u;

  allUsers = (allUsers || []).map(patch);
  const updatedVisible = (window.__lastUsers || []).map(patch);
  applySortAndRender(updatedVisible);

  setMsgEl(actionMsg, "Email updated.", true);
};


// ---------- Reset password ----------
resetPwBtn.onclick = async () => {
  if(!selectedUser) return;
  setMsgEl(actionMsg,"");

  if(pw1.value !== pw2.value) return setMsgEl(actionMsg,"Passwords must match.", false);
  const pw = String(pw1.value || "");
  if (!pw) return setMsgEl(actionMsg,"Password cannot be empty.", false);

  const res = await fetch(`/api/users/${selectedUser.pk}/reset-password`,{
    method:"POST",
    headers:{ "Content-Type":"application/json" },
    body:JSON.stringify({ password: pw })
  });
  const out = await res.json();
  if(!res.ok) return setMsgEl(actionMsg, out.error || "Reset failed", false);

  pw1.value = ""; pw2.value = "";
  setMsgEl(actionMsg, "Password reset.", true);
};

// ---------- Template apply ----------
if (applyTemplateBtn) applyTemplateBtn.addEventListener("click", async () => {
  if (!selectedUser) return;

  setMsgEl(actionMsg, "");

  const selectedKey = (templateApplySelect && templateApplySelect.value) || "";
  if (!selectedKey) {
    setMsgEl(actionMsg, "Select a template first.", false);
    return;
  }

  const template = Array.isArray(agencyTemplatesCache)
    ? agencyTemplatesCache.find(t => String(t.key) === String(selectedKey))
    : null;

  if (!template) {
    setMsgEl(actionMsg, "Selected template not found.", false);
    return;
  }

  if (selectedKey === "manual") {
    setMsgEl(actionMsg, "Manual selection does not apply a template.", false);
    return;
  }

  const nameToId = {};
  for (const [id, name] of groupIndex.entries()) {
    const n = String(name || "").trim().toLowerCase();
    if (!n) continue;
    nameToId[n] = id;
  }

  const templateGroupNames = Array.isArray(template.groups) ? template.groups : [];
  if (!templateGroupNames.length) {
    setMsgEl(actionMsg, "This template has no groups configured.", false);
    return;
  }

  const newGroupIds = templateGroupNames
    .map(gName => {
      const key = String(gName || "").trim().toLowerCase();
      return nameToId[key] || null;
    })
    .filter(Boolean);

  if (!newGroupIds.length) {
    setMsgEl(actionMsg, "Template groups could not be matched to available Authentik groups.", false);
    return;
  }

  // Preserve any groups the portal does NOT know about (e.g. internal authentik-* groups).
  // Templates should only overwrite "known" portal groups.
  const currentIds = Array.isArray(selectedUser.groups) ? selectedUser.groups.map(x => String(x)) : [];
  const preservedUnknownIds = currentIds.filter(id => !visibleGroupIds.has(String(id)));
  const finalGroupIds = Array.from(new Set([...preservedUnknownIds, ...newGroupIds]));

  setMsgEl(actionMsg, "Applying template...", true);

  let res;
  try {
    res = await fetch(`/api/users/${selectedUser.pk}/groups`, {
      method: "POST",
      headers: { "Content-Type": "application/json" },
      body: JSON.stringify({ groupIds: finalGroupIds }),
    });
  } catch (err) {
    setMsgEl(actionMsg, "Network error while applying template.", false);
    return;
  }

  const out = await res.json();
  if (!res.ok) {
    setMsgEl(actionMsg, out.error || "Failed to apply template.", false);
    return;
  }

  const applied = Array.isArray(out.groups) ? out.groups : finalGroupIds;

  selectedUser.groups = applied;
  pickedGroupIds = new Set(applied.map(x => String(x)));

  selectedUser.__role = roleForUser(selectedUser);
  renderGroupChips(selectedUser);
  renderGroupsBox();

  const patch = (u) =>
    String(u.pk) === String(selectedUser.pk)
      ? { ...u, groups: selectedUser.groups, __role: selectedUser.__role }
      : u;

  allUsers = (allUsers || []).map(patch);
  const updatedVisible = (window.__lastUsers || []).map(patch);
  applySortAndRender(updatedVisible);

  setMsgEl(actionMsg, "Template applied. Groups overwritten.", true);
});

async function loadAllUsers(){
  setMsgEl(msg, "Loading users...", true);

  const params = new URLSearchParams({
    page: String(currentPage),
    pageSize: String(PAGE_SIZE),
  });

  const qVal = String(currentSearch || "").trim();
  if (qVal) params.set("q", qVal);

  const res = await fetch(`/api/users/search?${params.toString()}`);
  const out = await res.json();

  if (!res.ok) {
    setMsgEl(msg, out.error || "Failed to load users", false);
    return;
  }

  const users = Array.isArray(out.users) ? out.users : [];
  currentPage = Number(out.page || currentPage || 1);
  totalUsers = Number(out.total || users.length);
  hasNextPage = !!out.hasNext;
  hasPrevPage = !!out.hasPrev;
  currentPageUsers = users.slice();
  allUsers = users.slice();

  // Compute per-row role (User/Admin) for the results table
  await ensureAgencyAdminIdsForUsers(users);
  currentPageUsers = currentPageUsers.map(u => ({ ...u, __role: roleForUser(u) }));
  allUsers = allUsers.map(u => ({ ...u, __role: roleForUser(u) }));

  renderCurrentPage();

  if (totalUsers) {
    if (qVal) {
      setMsgEl(msg, `Showing ${users.length} of ${totalUsers} user(s) for "${qVal}".`, true);
    } else {
      setMsgEl(msg, `Showing ${users.length} of ${totalUsers} user(s).`, true);
    }
  } else {
    setMsgEl(msg, "No users found.", true);
  }
}

// Allow other parts of the page (Create User + CSV import) to request a refresh
window.addEventListener("users:refresh", () => {
  loadAllUsers().catch((err) => {
    setMsgEl(msg, err?.message || "Failed to refresh users", false);
  });
});

searchForm.onsubmit = (e) => {
  e.preventDefault();
  applyFilterSortRender();
};

(async () => {
  try {
    await loadGroups();
    updateSortIndicators();
    await loadAllUsers();
  } catch (err) {
    setMsgEl(msg, err.message || "Failed to load page", false);
  }
})();
</script>


