// Selected user in the modal
let selectedUser = null;

function getGroupIdByName(name){
  const target = String(name || "").trim().toLowerCase();
  if (!target) return null;
  for (const [id, groupName] of groupIndex.entries()) {
    if (String(groupName || "").trim().toLowerCase() === target) return String(id);
  }
  return null;
}

// Resolve a group id by name, even if the group is hidden by GROUPS_HIDDEN_PREFIXES.
// Falls back to /api/users/group-lookup (global admins only) and caches the result.
async function resolveGroupIdByName(name){
  const key = String(name || "").trim().toLowerCase();
  if (!key) return null;

  // 1) Try visible groups first
  const direct = getGroupIdByName(name);
  if (direct) return direct;

  // 2) Try cache
  if (groupNameToIdCache.has(key)) return groupNameToIdCache.get(key);

  // 3) Ask server (includes hidden groups)
  try {
    const res = await fetch(`/api/users/group-lookup?name=${encodeURIComponent(name)}`);
    const out = await res.json().catch(()=> ({}));
    if (!res.ok) return null;
    const id = String(out.pk || "");
    const nm = String(out.name || "").trim();
    if (!id || !nm) return null;

    // Cache and also inject into groupIndex so chips can render the proper name
    groupNameToIdCache.set(key, id);
    groupIndex.set(id, nm);
    return id;
  } catch (e) {
    return null;
  }
}

// Resolve configured global-admin group IDs (AuthentiK group names from PORTAL_AUTH_REQUIRED_GROUP).
// Only meaningful for viewers who are already global admins (they can access /api/users/group-lookup).
let globalAdminGroupIdsCache = null;
async function getGlobalAdminGroupIds(){
  if (!IS_GLOBAL_ADMIN) return [];
  if (globalAdminGroupIdsCache) return globalAdminGroupIdsCache.slice();
  const names = PORTAL_GLOBAL_ADMIN_GROUP_NAMES.slice();
  if (!names.length) {
    globalAdminGroupIdsCache = [];
    return [];
  }
  const ids = [];
  for (const nm of names) {
    const id = await resolveGroupIdByName(nm);
    if (id) ids.push(String(id));
  }
  globalAdminGroupIdsCache = ids;
  return ids.slice();
}

function userHasAnyGroupId(user, ids){
  const gs = Array.isArray(user && user.groups) ? user.groups.map(x => String(x)) : [];
  return (ids || []).some(id => gs.includes(String(id)));
}

window.editUser = async (userPk) => {
  const pkStr = String(userPk);
  const sourceLists = [
    window.__lastUsers || [],
    currentPageUsers || [],
    allUsers || [],
  ].filter(Array.isArray);

  let u = null;
  for (const list of sourceLists) {
    u = list.find(x => String(x.pk) === pkStr);
    if (u) break;
  }
  if (!u) {
    console.warn("editUser: user not found for pk", userPk, {
      sourceLengths: sourceLists.map(l => l.length),
    });
    return;
  }

  selectedUser = { ...u };

  // Resolve agency-admin group id from our cached mapping (suffix-only lookup),
  // so it works for both legacy and county-prefixed group names.
  const abbrForSelected = String(getUserAgencyAbbreviation(selectedUser) || "").trim().toUpperCase();
  const adminGroupId = abbrForSelected ? agencyAdminGroupIdByAbbr.get(abbrForSelected) : null;

    // Also resolve configured Global Admin group names so chips display correctly
  if (IS_GLOBAL_ADMIN && PORTAL_GLOBAL_ADMIN_GROUP_NAMES.length) {
    for (const gName of PORTAL_GLOBAL_ADMIN_GROUP_NAMES) {
      await resolveGroupIdByName(gName);
    }
  }
  if (userTitle) userTitle.textContent = `User ${selectedUser.username}`;

  if (usernameSpan) {
    usernameSpan.textContent = `${selectedUser.username} — ${selectedUser.name || ""}`;
  }

  if (emailInput) emailInput.value = selectedUser.email || "";

  const { first, last } = splitName(selectedUser.name || "");
  if (firstNameInput) firstNameInput.value = first;
  if (lastNameInput) lastNameInput.value = last;

  setMsgEl(nameMsg, "");
  setMsgEl(actionMsg, "");

  renderGroupChips(selectedUser);

  pickedGroupIds = new Set((selectedUser.groups || []).map(x => String(x)));
  renderGroupsBox();

  // Default permissions = User; if user is in their agency admin group, reflect that.
  if (permissionsSelect) {
    // If the viewer is a global admin and the dropdown includes it, reflect global-admin status.
    // (Global admin groups are configured by PORTAL_AUTH_REQUIRED_GROUP in the server.)
    const globalOptionExists = !!permissionsSelect.querySelector('option[value="global_admin"]');
    if (IS_GLOBAL_ADMIN && globalOptionExists) {
      const globalIds = await getGlobalAdminGroupIds();
      const hasGlobal = userHasAnyGroupId(selectedUser, globalIds);
      if (hasGlobal) {
        permissionsSelect.value = "global_admin";
        permissionsSelect.disabled = false;
        if (applyPermissionsBtn) applyPermissionsBtn.disabled = false;
      }
    }

    if (abbrForSelected) {
      const adminIds = adminGroupId;
      const hasAdmin = Array.isArray(adminIds)
        ? adminIds.some(id => (selectedUser.groups || []).some(gid => String(gid) === String(id)))
        : (adminIds
            ? (selectedUser.groups || []).some(gid => String(gid) === String(adminIds))
            : false);
      // Only overwrite selection if not already set to global_admin above.
      if (permissionsSelect.value !== "global_admin") {
        permissionsSelect.value = hasAdmin ? "agency_admin" : "user";
      }
      permissionsSelect.disabled = false;
      if (applyPermissionsBtn) applyPermissionsBtn.disabled = false;
    } else {
      // If no agency abbreviation, only global admins can still manage global-admin status.
      if (permissionsSelect.value !== "global_admin") {
        permissionsSelect.value = "user";
      }
      const canUse = IS_GLOBAL_ADMIN && !!permissionsSelect.querySelector('option[value="global_admin"]');
      permissionsSelect.disabled = !canUse;
      if (applyPermissionsBtn) applyPermissionsBtn.disabled = !canUse;
    }
  }

  // modal-only action buttons are not present; guard if you ever add them back
  if (toggleBtn) {
    toggleBtn.textContent = selectedUser.is_active ? "Disable User" : "Enable User";
  }

  await loadTemplatesForAgency(
    (selectedUser && selectedUser.attributes && selectedUser.attributes.agency) || ""
  );

  openModal();
};

// ---------- Permissions apply ----------
if (applyPermissionsBtn) applyPermissionsBtn.addEventListener("click", async () => {
  if (!selectedUser) return;

  setMsgEl(actionMsg, "");

  const desired = (permissionsSelect && permissionsSelect.value) || "user";

  // Safety: never allow a non-global-admin viewer to attempt global-admin changes.
  if (desired === "global_admin" && !IS_GLOBAL_ADMIN) {
    setMsgEl(actionMsg, "You do not have permission to grant Global Admin.", false);
    return;
  }

  const currentIds = new Set((selectedUser.groups || []).map(x => String(x)));

  // Agency Admin group (per-user, derived from agency abbreviation, using cached ids)
  const abbr = String(getUserAgencyAbbreviation(selectedUser) || "").trim().toUpperCase();
  let adminGroupId = abbr ? agencyAdminGroupIdByAbbr.get(abbr) : null;
  const adminGroupIdsEmpty = Array.isArray(adminGroupId) ? !adminGroupId.length : !adminGroupId;
  if (adminGroupIdsEmpty && abbr) {
    // Try to resolve once more from Authentik if cache is empty
    await ensureAgencyAdminIdsForUsers([selectedUser]);
    adminGroupId = agencyAdminGroupIdByAbbr.get(abbr) || null;
  }

  // Global Admin group(s) (portal-wide)
  const globalIds = await getGlobalAdminGroupIds();

  // Build desired add/remove set
  const toAdd = new Set();
  const toRemove = new Set();

  if (desired === "agency_admin" || desired === "user") {
    // Agency-admin changes require a resolvable agency admin group.
    const hasAdminGroup = Array.isArray(adminGroupId) ? adminGroupId.length > 0 : !!adminGroupId;
    if (!abbr || !hasAdminGroup) {
      setMsgEl(actionMsg, "Cannot set Agency Admin/User: user has no agency abbreviation (or group missing).", false);
      return;
    }
  }

  if (desired === "user") {
    if (Array.isArray(adminGroupId)) {
      adminGroupId.forEach(id => toRemove.add(String(id)));
    } else if (adminGroupId) {
      toRemove.add(String(adminGroupId));
    }
    globalIds.forEach(id => toRemove.add(String(id)));
  } else if (desired === "agency_admin") {
    if (Array.isArray(adminGroupId)) {
      adminGroupId.forEach(id => toAdd.add(String(id)));
    } else if (adminGroupId) {
      toAdd.add(String(adminGroupId));
    }
    globalIds.forEach(id => toRemove.add(String(id)));
  } else if (desired === "global_admin") {
    if (!globalIds.length) {
      setMsgEl(actionMsg, "Global admin groups are not configured on the server.", false);
      return;
    }

    // Add global admin group(s)
    globalIds.forEach(id => toAdd.add(String(id)));

    // If user is currently an agency admin, remove that group
    if (Array.isArray(adminGroupId)) {
      adminGroupId.forEach(id => toRemove.add(String(id)));
    } else if (adminGroupId) {
      toRemove.add(String(adminGroupId));
    }
  }

  // Remove anything already satisfied
  for (const id of Array.from(toAdd)) {
    if (currentIds.has(String(id))) toAdd.delete(id);
  }
  for (const id of Array.from(toRemove)) {
    if (!currentIds.has(String(id))) toRemove.delete(id);
  }

  if (!toAdd.size && !toRemove.size) {
    const label = desired === "global_admin" ? "Already a Global Admin." : desired === "agency_admin" ? "Already an Agency Admin." : "Already a User.";
    setMsgEl(actionMsg, label, true);
    return;
  }

  setMsgEl(actionMsg, "Updating permissions...", true);

  // Apply adds first, then removes (so you don't accidentally lock yourself out mid-change).
  const applyDelta = async (kind, idsArr) => {
    const url = kind === "add"
      ? `/api/users/${selectedUser.pk}/groups/add`
      : `/api/users/${selectedUser.pk}/groups/remove`;

    const res = await fetch(url, {
      method: "POST",
      headers: { "Content-Type": "application/json" },
      body: JSON.stringify({ groupIds: idsArr.map(String) }),
    });

    const out = await res.json().catch(() => ({}));
    if (!res.ok) throw new Error(out.error || "Failed to update permissions.");
    return Array.isArray(out.groups) ? out.groups : null;
  };

  try {
    let latestGroups = null;
    if (toAdd.size) {
      latestGroups = await applyDelta("add", Array.from(toAdd));
    }
    if (toRemove.size) {
      latestGroups = await applyDelta("remove", Array.from(toRemove));
    }

    if (latestGroups) {
      selectedUser.groups = latestGroups;
    } else {
      // Fallback (shouldn't happen): patch local set
      Array.from(toAdd).forEach(id => currentIds.add(String(id)));
      Array.from(toRemove).forEach(id => currentIds.delete(String(id)));
      selectedUser.groups = Array.from(currentIds);
    }
  } catch (err) {
    setMsgEl(actionMsg, err?.message || "Failed to update permissions.", false);
    return;
  }

  pickedGroupIds = new Set((selectedUser.groups || []).map(x => String(x)));

  selectedUser.__role = roleForUser(selectedUser);
  renderGroupChips(selectedUser);
  renderGroupsBox();

  const patch = (u) =>
    String(u.pk) === String(selectedUser.pk) ? { ...u, groups: selectedUser.groups, __role: selectedUser.__role } : u;
  allUsers = (allUsers || []).map(patch);
  const updatedVisible = (window.__lastUsers || []).map(patch);
  window.__lastUsers = updatedVisible.slice();
  renderResults(updatedVisible);

  const doneLabel = desired === "global_admin" ? "Permissions updated: Global Admin." : desired === "agency_admin" ? "Permissions updated: Agency Admin." : "Permissions updated: User.";
  setMsgEl(actionMsg, doneLabel, true);
});

window.toggleUserFromTable = async (userPk) => {
  const u = (window.__lastUsers || []).find(x => String(x.pk) === String(userPk));
  if (!u) return;

  if (userActionsLocked(u.username)) {
    setMsgEl(msg, `Actions are locked for user ${u.username}.`, false);
    return;
  }

  const action = u.is_active ? "DISABLE" : "ENABLE";
  if (!confirm(`${action} ${u.username}?`)) return;

  const newState = !u.is_active;

  let res;
  try {
    res = await fetch(`/api/users/${u.pk}/active`, {
      method: "PUT",
      headers: { "Content-Type": "application/json" },
      body: JSON.stringify({ is_active: newState }),
    });
  } catch (err) {
    return setMsgEl(msg, "Network error while updating user.", false);
  }

  const raw = await res.text();
  let out = {};
  try { out = JSON.parse(raw); } catch { out = {}; }

  if (!res.ok) return setMsgEl(msg, out.error || "Toggle failed", false);

  const flip = (row) =>
    (String(row.pk) === String(u.pk) ? { ...row, is_active: newState } : row);

  allUsers = (allUsers || []).map(flip);
  const updatedVisible = (window.__lastUsers || []).map(flip);

  if (selectedUser && String(selectedUser.pk) === String(u.pk)) {
    selectedUser.is_active = newState;
    if (toggleBtn) toggleBtn.textContent = selectedUser.is_active ? "Disable User" : "Enable User";
    setMsgEl(actionMsg, `User is now ${selectedUser.is_active ? "ENABLED" : "DISABLED"}.`, true);
  }

  window.__lastUsers = updatedVisible.slice();
  renderResults(updatedVisible);
  setMsgEl(msg, `User ${u.username} is now ${newState ? "ENABLED" : "DISABLED"}.`, true);
};

window.deleteUserFromTable = async (userPk) => {
  const u = (window.__lastUsers || []).find(x => String(x.pk) === String(userPk));
  if(!u) return;

  if (userActionsLocked(u.username)) {
    setMsgEl(msg, `Actions are locked for user ${u.username}.`, false);
    return;
  }

  if(!confirm(`DELETE ${u.username}? This cannot be undone.`)) return;

  const res = await fetch(`/api/users/${u.pk}`, { method:"DELETE" });
  const out = await res.json();
  if(!res.ok) return setMsgEl(msg, out.error || "Delete failed", false);

  if (selectedUser && String(selectedUser.pk) === String(u.pk)) {
    selectedUser = null;
    closeModal();
  }

  allUsers = (allUsers || []).filter(row => String(row.pk) !== String(u.pk));
  const remainingVisible = (window.__lastUsers || []).filter(row => String(row.pk) !== String(u.pk));

  window.__lastUsers = remainingVisible.slice();
  renderResults(remainingVisible);
  setMsgEl(msg, `User ${u.username} deleted.`, true);
};

