async function fetchAllGroupsIncludingHidden(){
  if (allGroupsIncludingHiddenCache) return allGroupsIncludingHiddenCache;
  const res = await fetch("/api/users/all-groups-hidden");
  const out = await res.json();
  if (!res.ok) {
    console.error("Failed to load all groups (including hidden):", out.error || out);
    allGroupsIncludingHiddenCache = [];
    return allGroupsIncludingHiddenCache;
  }
  allGroupsIncludingHiddenCache = Array.isArray(out) ? out : [];
  return allGroupsIncludingHiddenCache;
}

function getUserAgencyAbbreviation(user){
  const attrs = user && user.attributes ? user.attributes : {};
  const raw =
    attrs.agency_abbreviation ||
    attrs.agencyAbbreviation ||
    attrs.agencyAbbr ||
    attrs.agencyabbr ||
    "";
  return String(raw || "").trim();
}

function getAgencyAdminGroupNameForUser(user){
  const abbr = getUserAgencyAbbreviation(user);
  if (!abbr) return null;
  // We do not know the county abbreviation from user attributes,
  // so accept any county prefix and match on the tail "-<ABBR>-AgencyAdmin".
  return `-` + String(abbr).trim().toUpperCase() + `-AgencyAdmin`;
}

// Cache agency admin group ids per abbreviation so we can show a Role column in the results table
const agencyAdminGroupIdByAbbr = new Map();
let agencyAdminGroupIdIndexByAbbr = null;

// Build an index from <AGENCY_ABBR> -> <group pk>
// by scanning ALL groups including hidden exactly once.
// This avoids O(uniqueAgencies * allGroups) repeated scans.
async function ensureAgencyAdminGroupIdIndex(){
  if (agencyAdminGroupIdIndexByAbbr) return agencyAdminGroupIdIndexByAbbr;

  const allGroups = await fetchAllGroupsIncludingHidden();
  const index = new Map();

  for (const g of allGroups){
    const pk = g?.pk ?? g?.id ?? null;
    const rawName = String(g?.name || "").trim();
    const nameLower = rawName.toLowerCase();

    if (!rawName) continue;
    // Match patterns like:
    // - authentik-<COUNTY>-<ABBR>-AgencyAdmin
    // - authentik-<ABBR>-AgencyAdmin
    if (!nameLower.startsWith("authentik-")) continue;
    if (!nameLower.endsWith("-agencyadmin")) continue;

    // Strip prefix + suffix, then take the last '-' segment as the abbr.
    // Example after stripping: "<COUNTY>-<ABBR>" or "<ABBR>"
    const inner = nameLower
      .slice("authentik-".length, nameLower.length - "-agencyadmin".length)
      .trim();
    const parts = inner.split("-").map(s => String(s || "").trim()).filter(Boolean);
    const abbrLower = parts[parts.length - 1] || "";
    const abbrUpper = abbrLower.toUpperCase();

    if (abbrUpper && pk != null && !index.has(abbrUpper)) {
      index.set(abbrUpper, pk);
    }
  }

  agencyAdminGroupIdIndexByAbbr = index;
  return agencyAdminGroupIdIndexByAbbr;
}

async function ensureAgencyAdminIdsForUsers(users){
  const uniq = new Set();
  (users || []).forEach(u => {
    const abbr = String(getUserAgencyAbbreviation(u) || '').trim().toUpperCase();
    if (abbr) uniq.add(abbr);
  });

  for (const abbr of uniq){
    if (agencyAdminGroupIdByAbbr.has(abbr)) continue;
    // Only global admins can access the full "all-groups-hidden" list.
    // For agency admins, resolve via a safe endpoint that filters to the
    // viewer's allowed agencies.
    if (IS_GLOBAL_ADMIN) {
      const index = await ensureAgencyAdminGroupIdIndex();
      const id = index.has(abbr) ? index.get(abbr) : null;
      agencyAdminGroupIdByAbbr.set(abbr, id ? [id] : []);
      continue;
    }

    // Lazy-load a map for agency admins (covers all abbreviations on this page).
    if (!agencyAdminGroupIdIndexByAbbr) {
      try {
        const res = await fetch(
          "/api/users/agency-admin-group-ids?abbreviations=" +
            encodeURIComponent(Array.from(uniq).join(","))
        );
        const out = await res.json();
        const map = new Map();
        if (res.ok && out && typeof out === "object") {
          for (const [k, v] of Object.entries(out)) {
            const key = String(k || "").trim().toUpperCase();
            const arr = Array.isArray(v) ? v.map(String) : [];
            map.set(key, arr);
          }
        }
        agencyAdminGroupIdIndexByAbbr = map;
      } catch (e) {
        // If this lookup fails, role labeling may degrade but the page
        // remains functional.
        agencyAdminGroupIdIndexByAbbr = new Map();
      }
    }

    const arr = agencyAdminGroupIdIndexByAbbr.has(abbr)
      ? agencyAdminGroupIdIndexByAbbr.get(abbr)
      : [];
    agencyAdminGroupIdByAbbr.set(abbr, Array.isArray(arr) ? arr : []);
  }
}

function roleForUser(user){
  const groups = Array.isArray(user && user.groups)
    ? user.groups.map(x => String(x))
    : [];

  // 1 Global Admin takes precedence
  if (globalAdminGroupIdsCache && globalAdminGroupIdsCache.length) {
    if (globalAdminGroupIdsCache.some(id => groups.includes(String(id)))) {
      return "Global Admin";
    }
  }

  // 2 Agency Admin
  const abbr = String(getUserAgencyAbbreviation(user) || '').trim().toUpperCase();
  const adminIds = abbr ? agencyAdminGroupIdByAbbr.get(abbr) : null;
  const hasAgencyAdmin = Array.isArray(adminIds)
    ? adminIds.some(id => groups.includes(String(id)))
    : (adminIds ? groups.includes(String(adminIds)) : false);

  if (hasAgencyAdmin) {
    return "Agency Admin";
  }

  // 3 Default
  return "User";
}

async function loadGroups(){
  const res = await fetch("/api/users/meta");
  const meta = await res.json();

  if(!res.ok){
    throw new Error(meta.error || "Failed to load groups");
  }

  const groups = Array.isArray(meta.groups) ? meta.groups : [];
  visibleGroupIds = new Set(groups.map(g => String(g.pk)));
  groupIndex = new Map(groups.map(g => [String(g.pk), g.name || ("Group " + g.pk)]));

  renderGroupsBox();
}

async function applyGroupChange(groupId, shouldBeMember){
  if (!selectedUser) return;

  const url = shouldBeMember
    ? `/api/users/${selectedUser.pk}/groups/add`
    : `/api/users/${selectedUser.pk}/groups/remove`;

  setMsgEl(actionMsg, "Updating groups...", true);

  let res;
  try {
    res = await fetch(url, {
      method: "POST",
      headers: { "Content-Type": "application/json" },
      body: JSON.stringify({ groupIds: [String(groupId)] }),
    });
  } catch (err) {
    setMsgEl(actionMsg, "Network error while updating groups", false);
    return;
  }

  const out = await res.json();
  if (!res.ok) {
    setMsgEl(actionMsg, out.error || "Update groups failed", false);
    pickedGroupIds = new Set((selectedUser.groups || []).map(x => String(x)));
    renderGroupsBox();
    return;
  }

  const newGroups = Array.isArray(out.groups) ? out.groups : Array.from(pickedGroupIds);
  selectedUser.groups = newGroups;
  pickedGroupIds = new Set((newGroups || []).map(x => String(x)));

  // Update role label (User/Admin) based on groups
  selectedUser.__role = roleForUser(selectedUser);
  renderGroupChips(selectedUser);

  const patch = (u) => String(u.pk) === String(selectedUser.pk)
    ? { ...u, groups: selectedUser.groups, __role: selectedUser.__role }
    : u;

  allUsers = (allUsers || []).map(patch);
  const updatedVisible = (window.__lastUsers || []).map(patch);
  window.__lastUsers = updatedVisible.slice();
  renderResults(updatedVisible);

  setMsgEl(actionMsg, "Groups updated.", true);
}

function renderGroupsBox(){
  // Only show "known/portal-visible" groups in the checkbox grid.
  // We may inject hidden/internal groups into groupIndex so we can render their names
  // in the "Current Groups" chips, but we don't want admins toggling them here.
  const allGroupsArray = Array.from(groupIndex.entries())
    .map(([id,name]) => ({id: String(id), name}))
    .filter(g => visibleGroupIds.has(String(g.id)));

  const filterText = groupFilter.value.trim().toLowerCase();
  const filteredGroups = filterText
    ? allGroupsArray.filter(g => {
        const raw = String(g.name || "").toLowerCase();
        const display = stripTakPrefix(g.name).toLowerCase();
        return raw.includes(filterText) || display.includes(filterText);
      })
    : allGroupsArray;

  groupsInner.innerHTML = filteredGroups.map(g => {
    const id = String(g.id);
    const checked = pickedGroupIds.has(id) ? "checked" : "";
    return `
      <label class="groupItem">
        <input type="checkbox" value="${escapeHtml(id)}" ${checked} />
        <span>${escapeHtml(stripTakPrefix(g.name))}</span>
      </label>
    `;
  }).join("");

  Array.from(groupsBox.querySelectorAll("input[type=checkbox]")).forEach(cb => {
    cb.addEventListener("change", () => {
      const id = String(cb.value);
      if (cb.checked) {
        pickedGroupIds.add(id);
      } else {
        pickedGroupIds.delete(id);
      }
      applyGroupChange(id, cb.checked);
    });
  });
}

