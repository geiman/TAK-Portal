      }

      // Otherwise hide it completely
      return null;
    })
    .filter(Boolean)
    .sort((a,b)=>String(a).localeCompare(String(b)));

  groupChips.innerHTML = names.length
    ? names.map(n =>
        `<span class="chip">${escapeHtml(stripTakPrefix(n))}</span>`
      ).join("")
    : `<span class="muted">None</span>`;
}

