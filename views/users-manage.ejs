<%- include("partials/header") %>
<%- include("partials/sidebar") %>

<main class="main">
  <h1>Manage Users</h1>

  <div class="card">
    <h2>Search</h2>
    <form id="searchForm" class="row">
      <input
        id="q"
        placeholder="Search username, email, or name..."
        style="min-width: 360px;"
        autocomplete="off"
      />
    </form>

    <div id="msg" class="msg"></div>
  </div>

  <div class="card">
    <h2>Results</h2>

    <!-- Pagination controls (top) -->
    <div class="pagination" id="paginationTop">
      <button class="btn" id="prevPageBtnTop" type="button">Previous</button>
      <span id="pageInfoTop"></span>
      <button class="btn" id="nextPageBtnTop" type="button">Next</button>
    </div>

    <table class="table">
      <thead id="thead">
        <tr>
          <th class="sortable" data-key="username">
            Username <span class="sortIndicator" aria-hidden="true"></span>
          </th>
          <th class="sortable" data-key="name">
            Name <span class="sortIndicator" aria-hidden="true"></span>
          </th>
          <th class="sortable" data-key="email">
            Email <span class="sortIndicator" aria-hidden="true"></span>
          </th>
          <th class="sortable" data-key="status">
            Status <span class="sortIndicator" aria-hidden="true"></span>
          </th>
          <th>Actions</th>
        </tr>
      </thead>
      <tbody id="tbody"></tbody>
    </table>

    <!-- Pagination controls (bottom) -->
    <div class="pagination" id="paginationBottom">
      <button class="btn" id="prevPageBtnBottom" type="button">Previous</button>
      <span id="pageInfoBottom"></span>
      <button class="btn" id="nextPageBtnBottom" type="button">Next</button>
    </div>
  </div>
</main>

<!-- Modal -->
<div class="modalOverlay" id="modalOverlay" style="display:none;">
  <div class="modal" role="dialog" aria-modal="true" aria-labelledby="userTitle">
    <div class="modalHeader">
      <h2 id="userTitle" style="margin:0;">User</h2>
      <button class="btn" id="closeBtn" type="button">Close</button>
    </div>

    <div class="modalBody">
      <div class="grid2">

        <!-- First/Last Name -->
        <label>First Name
          <input id="firstNameInput" />
        </label>

        <label>Last Name
          <input id="lastNameInput" />
        </label>

        <div style="grid-column:1/-1;" class="row">
          <button class="btn" id="saveNameBtn" type="button">Update Name</button>
          <span class="msg" id="nameMsg"></span>
        </div>

        <label>Email
          <input id="emailInput" />
          <button class="btn" id="saveEmailBtn" type="button">Update Email</button>
        </label>

        <label>Reset Password
          <input id="pw1" type="password" placeholder="New password" />
          <input id="pw2" type="password" placeholder="Confirm password" />
          <button class="btn" id="resetPwBtn" type="button">Reset Password</button>
        </label>

        <div style="grid-column:1/-1;">
          <h3>Current Groups</h3>
          <div id="groupChips" class="chips"></div>
          <small>These are the user’s current group memberships.</small>
        </div>

        <div style="grid-column:1/-1;">
          <h3>Modify Groups</h3>

          <!-- Templates-style groups picker (simple checked = member) -->
          <label style="display:block;">
            Groups
            <input id="groupFilter" placeholder="Search groups..." />

            <div class="row" style="gap:10px; margin-top:8px;">
              <button class="btn" id="selectAllBtn" type="button">Select All</button>
              <button class="btn" id="clearAllBtn" type="button">Clear</button>
              <small style="align-self:center; color: var(--muted);">
                Checking adds; unchecking removes. Changes save automatically.
              </small>
            </div>

            <!-- OUTER SCROLL BOX + INNER MULTICOL WRAPPER -->
            <div class="groupsBox" id="groupsBox">
              <div class="groupsInner" id="groupsInner"></div>
            </div>

            <div class="row" style="gap:10px; margin-top:10px; align-items:flex-end;">
              <label style="flex:1; max-width:320px;">
                Apply Template (overwrite)
                <select id="templateApplySelect">
                  <option value="">Select a template...</option>
                </select>
              </label>
              <button class="btn" id="applyTemplateBtn" type="button">Apply Template</button>
            </div>
            <small style="display:block; margin-top:4px; color: var(--muted);">
              Applying a template will overwrite this user's groups to match the template.
            </small>
          </label>
        </div>

        <div style="grid-column:1/-1;" class="row">
          <button class="btn" id="toggleBtn" type="button"></button>
          <button class="btn danger" id="deleteBtn" type="button">Delete User</button>
          <span id="actionMsg" class="msg"></span>
        </div>

      </div>
    </div>
  </div>
</div>


<!-- User Enrollment QR Modal -->
<div class="modalOverlay" id="userQrOverlay" style="display:none;">
  <div class="modal" role="dialog" aria-modal="true" aria-labelledby="userQrTitle">
    <div class="modalHeader">
      <h2 id="userQrTitle" style="margin:0;">Enrollment QR Code</h2>
      <button class="btn" id="userQrCloseBtn" type="button">Close</button>
    </div>
    <div class="modalBody">
      <div class="row" style="gap: 24px; align-items: flex-start; flex-wrap: wrap;">
        <div style="text-align:center; min-width: 260px;">
          <img id="userQrImg" alt="Enrollment QR Code" style="max-width: 280px; width: 100%; height: auto; border-radius: 14px;" />
          <div class="row" style="gap: 10px; margin-top: 14px; justify-content: center;">
            <button class="btn" type="button" id="userQrCopyBtn" disabled>Copy URL</button>
            <button class="btn" type="button" id="userQrSaveBtn" disabled>Save Image</button>
          </div>
        </div>
        <div style="min-width: 320px;">
          <h3 style="margin-top:0;">Details</h3>
          <div class="chips" id="userQrDetails"></div>
          <div id="userQrCountdown" class="msg" style="margin-top: 10px;"></div>
          <div id="userQrMsg" class="msg"></div>
        </div>
      </div>
    </div>
  </div>
</div>


<script>
const msg = document.getElementById("msg");
const actionMsg = document.getElementById("actionMsg");
const tbody = document.getElementById("tbody");
const thead = document.getElementById("thead");
const searchForm = document.getElementById("searchForm");
const q = document.getElementById("q");

// Pagination DOM
const paginationTop = document.getElementById("paginationTop");
const paginationBottom = document.getElementById("paginationBottom");
const prevPageBtnTop = document.getElementById("prevPageBtnTop");
const nextPageBtnTop = document.getElementById("nextPageBtnTop");
const pageInfoTop = document.getElementById("pageInfoTop");
const prevPageBtnBottom = document.getElementById("prevPageBtnBottom");
const nextPageBtnBottom = document.getElementById("nextPageBtnBottom");
const pageInfoBottom = document.getElementById("pageInfoBottom");

// Modal elements
const modalOverlay = document.getElementById("modalOverlay");
const closeBtn = document.getElementById("closeBtn");
const userTitle = document.getElementById("userTitle");
const usernameSpan = document.getElementById("usernameSpan");
const emailInput = document.getElementById("emailInput");
const saveEmailBtn = document.getElementById("saveEmailBtn");
const pw1 = document.getElementById("pw1");
const pw2 = document.getElementById("pw2");
const resetPwBtn = document.getElementById("resetPwBtn");
const toggleBtn = document.getElementById("toggleBtn");
const deleteBtn = document.getElementById("deleteBtn");
const groupChips = document.getElementById("groupChips");
const groupFilter = document.getElementById("groupFilter");
const groupsBox = document.getElementById("groupsBox");
const groupsInner = document.getElementById("groupsInner"); // NEW: inner multicol wrapper

// Name edit
const firstNameInput = document.getElementById("firstNameInput");
const lastNameInput = document.getElementById("lastNameInput");
const saveNameBtn = document.getElementById("saveNameBtn");
const nameMsg = document.getElementById("nameMsg");

// Template apply controls
const selectAllBtn = document.getElementById("selectAllBtn");
const clearAllBtn = document.getElementById("clearAllBtn");
const templateApplySelect = document.getElementById("templateApplySelect");
const applyTemplateBtn = document.getElementById("applyTemplateBtn");

// Action-lock prefixes (case-insensitive, comma-separated)
// Users whose username starts with one of these prefixes will have ALL action buttons hidden.
// NOTE: This value comes from the server environment (.env).
const USERS_ACTIONS_HIDDEN_PREFIXES_RAW = "<%= (process.env.USERS_ACTIONS_HIDDEN_PREFIXES) %>";
const USERS_ACTIONS_HIDDEN_PREFIXES = USERS_ACTIONS_HIDDEN_PREFIXES_RAW
  .split(",")
  .map(p => String(p || "").trim().toLowerCase())
  .filter(Boolean);

function userActionsLocked(username) {
  const u = String(username || "").trim().toLowerCase();
  if (!u) return false;
  return USERS_ACTIONS_HIDDEN_PREFIXES.some(prefix => u.startsWith(prefix));
}

// ------- Sorting state -------
let sortState = {
  key: "name",   // default sort
  dir: "asc"     // "asc" | "desc"
};

// ------- Users state (server-side pagination) -------
// allUsers now holds only the current page of users; all searching/filtering is done on the server.
let allUsers = [];
let filterTimer = null;

const PAGE_SIZE = 25;      // must match backend default unless pageSize is passed explicitly
let currentPage = 1;       // 1-based
let totalUsers = 0;        // total number of matches across all pages
let currentPageUsers = []; // users for the currently loaded page
let currentSearch = "";    // current search string

// track next/prev from backend
let hasNextPage = false;
let hasPrevPage = false;

function setMsgEl(el, text, ok=true){
  el.textContent = text || "";
  el.className = "msg " + (ok ? "ok" : "bad");
}

function escapeHtml(s){
  s = (s === null || s === undefined) ? "" : String(s);
  return s
    .replace(/&/g,"&amp;")
    .replace(/</g,"&lt;")
    .replace(/>/g,"&gt;")
    .replace(/"/g,"&quot;")
    .replace(/'/g,"&#39;");
}


// -------------------- Enrollment QR (per-user) --------------------
const userQrOverlay = document.getElementById("userQrOverlay");
const userQrCloseBtn = document.getElementById("userQrCloseBtn");
const userQrImg = document.getElementById("userQrImg");
const userQrCopyBtn = document.getElementById("userQrCopyBtn");
const userQrSaveBtn = document.getElementById("userQrSaveBtn");
const userQrDetails = document.getElementById("userQrDetails");
const userQrCountdown = document.getElementById("userQrCountdown");
const userQrMsg = document.getElementById("userQrMsg");

let userQrCountdownTimer = null;
let userQrCurrent = null;

function openUserQrModal(){
  userQrOverlay.style.display = "flex";
  document.body.classList.add("noScroll");
}

function closeUserQrModal(){
  userQrOverlay.style.display = "none";
  document.body.classList.remove("noScroll");
  if (userQrCountdownTimer) {
    clearInterval(userQrCountdownTimer);
    userQrCountdownTimer = null;
  }
}

function fmtRemain(ms){
  const s = Math.max(0, Math.floor(ms / 1000));
  const m = Math.floor(s / 60);
  const r = s % 60;
  return `${m}:${String(r).padStart(2,"0")}`;
}

function startUserQrCountdown(expiresAt){
  if (userQrCountdownTimer) {
    clearInterval(userQrCountdownTimer);
    userQrCountdownTimer = null;
  }

  const exp = expiresAt ? new Date(expiresAt).getTime() : NaN;
  if (!Number.isFinite(exp)) {
    userQrCountdown.textContent = "";
    return;
  }

  const tick = () => {
    const remain = exp - Date.now();
    if (remain <= 0) {
      userQrCountdown.textContent = "QR Code Expired";
      userQrCopyBtn.disabled = true;
      userQrSaveBtn.disabled = true;
      setMsgEl(userQrMsg, "This enrollment QR has expired. Click QR again to generate a new one.", false);
      if (userQrCountdownTimer) {
        clearInterval(userQrCountdownTimer);
        userQrCountdownTimer = null;
      }
      return;
    }
    userQrCountdown.textContent = "QR Code Expires In: " + fmtRemain(remain);
  };

  tick();
  userQrCountdownTimer = setInterval(tick, 1000);
}

async function copyToClipboard(text) {
  try {
    await navigator.clipboard.writeText(text);
    setMsgEl(userQrMsg, "Copied!", true);
  } catch (e) {
    const ta = document.createElement("textarea");
    ta.value = text;
    ta.style.position = "fixed";
    ta.style.opacity = "0";
    document.body.appendChild(ta);
    ta.select();
    document.execCommand("copy");
    document.body.removeChild(ta);
    setMsgEl(userQrMsg, "Copied!", true);
  }
}

function renderUserQr(obj){
  userQrCurrent = obj;

  userQrImg.src = obj.qrCode || "";
  const chips = [];
  if (obj.username) chips.push(`<span class="chip">User: ${escapeHtml(obj.username)}</span>`);
  if (obj.tokenIdentifier) chips.push(`<span class="chip">Token: ${escapeHtml(obj.tokenIdentifier)}</span>`);
  userQrDetails.innerHTML = chips.join(" ");

  userQrCopyBtn.disabled = !obj.enrollUrl;
  userQrSaveBtn.disabled = !(obj.username && obj.token);

  setMsgEl(userQrMsg, "QR ready.", true);
  startUserQrCountdown(obj.expiresAt);
  openUserQrModal();
}

async function fetchUserEnrollQr(userId, username){
  // UI reset
  userQrImg.src = "";
  userQrDetails.innerHTML = "";
  userQrCopyBtn.disabled = true;
  userQrSaveBtn.disabled = true;
  userQrCountdown.textContent = "";
  setMsgEl(userQrMsg, "Generating enrollment QR...", true);
  openUserQrModal();

  const res = await fetch("/api/users/enroll-qr", {
    method: "POST",
    headers: { "Content-Type": "application/json" },
    body: JSON.stringify({ userId, username })
  });

  const rawText = await res.text();
  let data = {};
  try { data = JSON.parse(rawText); } catch { data = {}; }

  if (!res.ok || !data || !data.ok) {
    throw new Error((data && (data.error || data.message)) || "Failed to generate enrollment QR");
  }

  return {
    username: data.username,
    tokenIdentifier: data.tokenIdentifier,
    token: data.token,
    expiresAt: data.expiresAt,
    enrollUrl: data.enrollUrl,
    qrCode: data.qrCode
  };
}

// Event delegation for QR buttons in table
tbody.addEventListener("click", async (e) => {
  const btn = e.target && e.target.closest ? e.target.closest(".userQrBtn") : null;
  if (!btn) return;

  const userId = btn.dataset.pk || btn.dataset.userId || "";
  const username = btn.dataset.username || "";

  try {
    const obj = await fetchUserEnrollQr(userId, username);
    renderUserQr(obj);
  } catch (err) {
    setMsgEl(userQrMsg, err?.message || String(err), false);
    openUserQrModal();
  }
});

userQrCloseBtn.addEventListener("click", closeUserQrModal);
userQrOverlay.addEventListener("click", (e) => { if (e.target === userQrOverlay) closeUserQrModal(); });
document.addEventListener("keydown", (e) => { if (e.key === "Escape" && userQrOverlay.style.display !== "none") closeUserQrModal(); });

userQrCopyBtn.addEventListener("click", () => {
  if (userQrCurrent && userQrCurrent.enrollUrl) copyToClipboard(userQrCurrent.enrollUrl);
});

userQrSaveBtn.addEventListener("click", () => {
  if (!userQrCurrent || !userQrCurrent.username || !userQrCurrent.token) {
    setMsgEl(userQrMsg, "Generate a QR first.", false);
    return;
  }

  const url =
    `/api/qr/download?username=${encodeURIComponent(userQrCurrent.username)}` +
    `&token=${encodeURIComponent(userQrCurrent.token)}`;

  const a = document.createElement("a");
  a.href = url;
  a.download = "";
  document.body.appendChild(a);
  a.click();
  document.body.removeChild(a);

  setMsgEl(userQrMsg, "Downloading high-res QR...", true);
});
// ------------------ end Enrollment QR ------------------


/**
 * Parses either:
 * - "Last, First"
 * - "First Last"
 * into {first,last}
 */
function splitName(full){
  const t = String(full || "").trim();
  if (!t) return { first: "", last: "" };

  // Stored format: "Last, First"
  if (t.includes(",")) {
    const [last, first] = t.split(",").map(x => String(x || "").trim());
    return { first, last };
  }

  // Fallback: assume "First Last"
  const parts = t.split(/\s+/);
  if (parts.length === 1) return { first: parts[0], last: "" };
  const last = parts.pop();
  const first = parts.join(" ");
  return { first, last };
}

// For sorting names by LAST name then FIRST
function lastNameForSort(full){
  const { first, last } = splitName(full);
  return `${last} ${first}`.trim();
}

function normalizeSortValue(v) {
  return String(v || "").trim().toLowerCase();
}

function getSortValue(user, key){
  if (!user) return "";

  if (key === "username") return normalizeSortValue(user.username);
  if (key === "email") return normalizeSortValue(user.email);
  if (key === "name") return normalizeSortValue(lastNameForSort(user.name));
  if (key === "status") return user.is_active ? "enabled" : "disabled";

  return "";
}

function stableSortedCopy(arr, key, dir){
  const sign = dir === "desc" ? -1 : 1;

  return arr
    .map((item, idx) => ({ item, idx }))
    .sort((a, b) => {
      const av = getSortValue(a.item, key);
      const bv = getSortValue(b.item, key);

      // Put blanks at the end for asc, at the start for desc
      const aBlank = !String(av || "").trim();
      const bBlank = !String(bv || "").trim();
      if (aBlank && !bBlank) return 1 * sign;
      if (!aBlank && bBlank) return -1 * sign;

      const cmp = String(av).localeCompare(String(bv), undefined, { numeric: true, sensitivity: "base" });
      if (cmp !== 0) return cmp * sign;

      // Stable tie-breaker
      return (a.idx - b.idx);
    })
    .map(x => x.item);
}

function updateSortIndicators(){
  const ths = Array.from(
    thead ? thead.querySelectorAll("th.sortable") : []
  );

  ths.forEach(th => {
    const key = th.dataset.key;
    const indicator = th.querySelector(".sortIndicator");
    if (!indicator) return;

    if (key === sortState.key) {
      indicator.textContent = sortState.dir === "asc" ? "▲" : "▼";
    } else {
      indicator.textContent = "";
    }
  });
}

function renderResults(users){
  tbody.innerHTML = users.map(u=>{
    const pk = escapeHtml(u.pk);
    const toggleLabel = u.is_active ? "Disable" : "Enable";
    const locked = userActionsLocked(u.username);
    return `
      <tr class="${u.is_active ? "" : "row-disabled"}">
        <td>${escapeHtml(u.username)}</td>
        <td>${escapeHtml(u.name || "")}</td>
        <td>${escapeHtml(u.email || "")}</td>
        <td>${u.is_active ? "Enabled" : "Disabled"}</td>
        <td>
          ${locked ? `<span class="muted">Actions Hidden</span>` : `
            <div class="row" style="gap:8px; flex-wrap:wrap;">
              <button class="btn" onclick="editUser('${pk}')">Edit</button>
              <button class="btn qr userQrBtn" type="button" data-pk="${pk}" data-username="${escapeHtml(u.username)}">QR</button>
              <button class="btn" onclick="toggleUserFromTable('${pk}')">${toggleLabel}</button>
              <button class="btn danger" onclick="deleteUserFromTable('${pk}')">Delete</button>
            </div>
          `}
        </td>
      </tr>
    `;
  }).join("");
}

function renderGroupChips(user){
  const ids = Array.isArray(user.groups) ? user.groups.map(x => String(x)) : [];
  const names = ids
    .map(id => groupIndex.get(id) || ("Group " + id))
    .sort((a,b)=>String(a).localeCompare(String(b)));

  groupChips.innerHTML = names.length
    ? names.map(n => `<span class="chip">${escapeHtml(n)}</span>`).join("")
    : `<span class="muted">None</span>`;
}

function openModal(){
  modalOverlay.style.display = "flex";
  document.body.classList.add("noScroll");
}

function closeModal(){
  modalOverlay.style.display = "none";
  document.body.classList.remove("noScroll");
  setMsgEl(actionMsg, "");
  setMsgEl(nameMsg, "");
  pw1.value = ""; pw2.value = "";
  groupFilter.value = "";
