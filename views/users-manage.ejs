// Load templates & default groups for a specific agency suffix
let agencyTemplatesCache = [];

async function loadTemplatesForAgency(agencySuffix){
  agencyTemplatesCache = [];
  if (!templateApplySelect) return;

  templateApplySelect.innerHTML = '<option value="">Loading templates...</option>';
  if (applyTemplateBtn) applyTemplateBtn.disabled = true;

  const sfx = String(agencySuffix || "").trim();
  if (!sfx) {
    templateApplySelect.innerHTML = '<option value="">No agency info for this user</option>';
    return;
  }

  try {
    const res = await fetch('/api/users/meta?agencySuffix=' + encodeURIComponent(sfx));
    const meta = await res.json();
    if (!res.ok) throw new Error(meta.error || 'Failed to load templates');

    const all = Array.isArray(meta.templates) ? meta.templates : [];
    const rest = all.slice(1);
    const manual = all[0];

    const options = [];
    if (manual) {
      options.push(`<option value="${escapeHtml(manual.key)}">${escapeHtml(manual.label)}</option>`);
    }
    rest.forEach(t => {
      options.push(`<option value="${escapeHtml(t.key)}">${escapeHtml(t.label)}</option>`);
    });

    templateApplySelect.innerHTML = options.join("");
    agencyTemplatesCache = all;
    if (applyTemplateBtn) applyTemplateBtn.disabled = false;
  } catch (err) {
    templateApplySelect.innerHTML = '<option value="">Failed to load templates</option>';
    console.error(err);
  }
}

// Groups list
let groupIndex = new Map();
let pickedGroupIds = new Set();

// Group IDs that are "known" to this portal UI (i.e. returned from /api/users/meta.groups).
// Templates should only add/remove these. Anything outside this set is preserved.
let visibleGroupIds = new Set();

// Name->id cache for groups that may be hidden from the UI list
// (e.g. groups starting with "authentik-").
const groupNameToIdCache = new Map();

// Cache of all Authentik groups including those hidden from the normal /api/users/groups list.
// Only global admins can load this (enforced server-side).
let allGroupsIncludingHiddenCache = null;

function wirePasswordToggle(inputEl, toggleEl) {
  if (!inputEl || !toggleEl) return;
  toggleEl.textContent = "👁";
  toggleEl.setAttribute("aria-label", "Show password");
  toggleEl.title = "Show password";
  toggleEl.addEventListener("click", () => {
    const isHidden = inputEl.type === "password";
    inputEl.type = isHidden ? "text" : "password";
    toggleEl.setAttribute("aria-label", isHidden ? "Hide password" : "Show password");
    toggleEl.title = isHidden ? "Hide password" : "Show password";
  });
}

