      </details>
    </div>

  </form>

  <!-- Action row (outside the main form to avoid nested forms) -->
  <div style="margin-top:1rem;display:flex;gap:.75rem;flex-wrap:wrap;align-items:center;">
    <button type="submit" class="btn" form="settingsForm">Save Settings</button>
    <a href="/settings/export-data" class="btn">Export Configuration</a>

    <!-- Separate form: Import Configuration -->
    <form id="importConfigForm" action="/settings/import-data" method="post" enctype="multipart/form-data" style="display:inline-block; margin:0;">
      <input
        id="configZipInput"
        type="file"
        name="CONFIG_ZIP_UPLOAD"
        accept=".zip,application/zip"
        style="position:absolute; left:-9999px; width:1px; height:1px; opacity:0;"
      />

      <!-- Label opens the file picker reliably on Windows -->
      <label for="configZipInput" class="btn btn-warning" style="cursor:pointer;">
        Import Configuration
      </label>
    </form>
  </div>

  <script>
    (function () {
      var root = document.querySelector(".email-templates-section") || document;

      // Email template reset buttons: load default into textarea, set reset flag, update badge
      var resetButtons = root.querySelectorAll("[data-reset-template]");
      var defaults = window.EMAIL_TEMPLATE_DEFAULTS || {};
      resetButtons.forEach(function (btn) {
        btn.addEventListener("click", function () {
          var key = btn.getAttribute("data-reset-template");
          if (!key) return;

          var textarea = document.getElementById("email-template-" + key);
          if (textarea && defaults[key] !== undefined) {
            textarea.value = defaults[key];
          }

          var flag = root.querySelector('[data-reset-flag="' + key + '"]');
          if (flag) flag.value = "1";

          var note = root.querySelector('[data-reset-note="' + key + '"]');
          if (note) note.style.display = "inline";

          var badge = root.querySelector('.email-template-badge[data-badge="' + key + '"]');
          if (badge) {
            badge.textContent = "Default";
            badge.style.background = "#e5e7eb";
            badge.style.color = "#374151";
          }
        });
      });

      // Import Configuration (restore data from zip)
      var importInput = document.getElementById("configZipInput");
      var importForm = document.getElementById("importConfigForm");

      if (importInput && importForm) {
        importInput.addEventListener("change", function () {
          if (!importInput.files || !importInput.files.length) return;

          var fileName = importInput.files[0].name || "selected file";

          // Confirm destructive action
          var ok = window.confirm(
            "Importing a configuration will OVERWRITE files in the data folder with the contents of the zip.\n\nContinue?"
          );
          if (!ok) {
            importInput.value = "";
            return;
          }

          var ok2 = window.confirm("Import '" + fileName + "' and overwrite existing configuration files?");
          if (!ok2) {
            importInput.value = "";
            return;
          }

          importForm.submit();
        });
      }
    })();
  </script>

  <script>
  function wirePasswordToggle(inputId, toggleId) {
    const input = document.getElementById(inputId);
    const toggle = document.getElementById(toggleId);
    if (!input || !toggle) return;

    toggle.addEventListener("click", () => {
      const hidden = input.type === "password";
      input.type = hidden ? "text" : "password";
      toggle.setAttribute("aria-label", hidden ? "Hide value" : "Show value");
      toggle.title = hidden ? "Hide value" : "Show value";
    });
  }

  document.addEventListener("DOMContentLoaded", () => {
    wirePasswordToggle("authentikTokenInput", "authentikTokenToggle");
    wirePasswordToggle("p12PassphraseInput", "p12PassphraseToggle");
  });
  </script>


