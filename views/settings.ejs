      />

      <!-- Label opens the file picker reliably on Windows -->
      <label for="configZipInput" class="btn btn-warning" style="cursor:pointer;">
        Import Configuration
      </label>
    </form>
  </div>

  <script>
    (function () {
      var root = document.querySelector(".email-templates-section") || document;

      // Email template reset buttons: load default into textarea, set reset flag, update badge
      var resetButtons = root.querySelectorAll("[data-reset-template]");
      var defaults = window.EMAIL_TEMPLATE_DEFAULTS || {};
      resetButtons.forEach(function (btn) {
        btn.addEventListener("click", function () {
          var key = btn.getAttribute("data-reset-template");
          if (!key) return;

          var textarea = document.getElementById("email-template-" + key);
          if (textarea && defaults[key] !== undefined) {
            textarea.value = defaults[key];
          }

          var flag = root.querySelector('[data-reset-flag="' + key + '"]');
          if (flag) flag.value = "1";

          var note = root.querySelector('[data-reset-note="' + key + '"]');
          if (note) note.style.display = "inline";

          var badge = root.querySelector('.email-template-badge[data-badge="' + key + '"]');
          if (badge) {
            badge.textContent = "Default";
            badge.style.background = "#e5e7eb";
            badge.style.color = "#374151";
          }
        });
      });

      // Import Configuration (restore data from zip)
      var importInput = document.getElementById("configZipInput");
      var importForm = document.getElementById("importConfigForm");

      if (importInput && importForm) {
        importInput.addEventListener("change", function () {
          if (!importInput.files || !importInput.files.length) return;

          var fileName = importInput.files[0].name || "selected file";

          // Confirm destructive action
          var ok = window.confirm(
            "Importing a configuration will OVERWRITE files in the data folder with the contents of the zip.\n\nContinue?"
          );
          if (!ok) {
            importInput.value = "";
            return;
          }

          var ok2 = window.confirm("Import '" + fileName + "' and overwrite existing configuration files?");
          if (!ok2) {
            importInput.value = "";
            return;
          }

          importForm.submit();
        });
      }
    })();
  </script>

  <script>
  function wirePasswordToggle(inputId, toggleId) {
    const input = document.getElementById(inputId);
    const toggle = document.getElementById(toggleId);
    if (!input || !toggle) return;

    toggle.addEventListener("click", () => {
      const hidden = input.type === "password";
      input.type = hidden ? "text" : "password";
      toggle.setAttribute("aria-label", hidden ? "Hide value" : "Show value");
      toggle.title = hidden ? "Hide value" : "Show value";
    });
  }

  document.addEventListener("DOMContentLoaded", () => {
    wirePasswordToggle("authentikTokenInput", "authentikTokenToggle");
    wirePasswordToggle("p12PassphraseInput", "p12PassphraseToggle");
    wirePasswordToggle("sshPasswordInput", "sshPasswordToggle");

    const statusBox = document.getElementById("sshStatusBox");
    const hostInput = document.getElementById("sshHostInput");
    const portInput = document.getElementById("sshPortInput");
    const userInput = document.getElementById("sshUserInput");
    const passInput = document.getElementById("sshPasswordInput");
    const btnHandshake = document.getElementById("sshHandshakeBtn");
    const btnTestConnection = document.getElementById("sshTestConnectionBtn");

    function setStatus(msg, isError) {
      if (!statusBox) return;
      statusBox.textContent = msg || "";
      statusBox.style.color = isError ? "#dc2626" : "";
    }

    async function getStatus() {
      const res = await fetch("/api/ssh/status");
      const data = await res.json();
      if (!res.ok || !data.ok) throw new Error(data.error || "Failed to load SSH status.");
      const s = data.status || {};
      setStatus(
        "Host: " + (s.host || "(not set)") +
        " | User: " + (s.username || "(not set)") +
        " | Port: " + (s.port || "22") +
        " | Keypair: " + (s.hasKeyPair ? "present" : "missing") +
        " | Handshake: " + (s.onboarded ? "complete" : "pending") +
        (s.lastHandshakeAt ? " | Last: " + s.lastHandshakeAt : ""),
        false
      );
    }

    async function postJson(url, body) {
      const res = await fetch(url, {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify(body || {}),
      });
      const data = await res.json();
      if (!res.ok || data.ok === false) {
        throw new Error(data.error || data.message || "Request failed.");
      }
      return data;
    }

    if (btnHandshake) {
      btnHandshake.addEventListener("click", async function () {
        const host = (hostInput && hostInput.value || "").trim();
        const port = (portInput && portInput.value || "22").trim();
        const username = (userInput && userInput.value || "").trim();
        const password = (passInput && passInput.value || "");
        if (!host || !username || !password) {
          setStatus("Host, username, and one-time password are required.", true);
          return;
        }
        try {
          btnHandshake.disabled = true;
          setStatus("Generating SSH key...", false);
          await postJson("/api/ssh/generate-key", {});
          setStatus("Running one-time handshake...", false);
          await postJson("/api/ssh/handshake", { host, port, username, password });
          if (passInput) passInput.value = "";
          await getStatus();
        } catch (err) {
          setStatus(err.message || String(err), true);
        } finally {
          btnHandshake.disabled = false;
        }
      });
    }

    if (btnTestConnection) {
      btnTestConnection.addEventListener("click", async function () {
        try {
          btnTestConnection.disabled = true;
          setStatus("Testing SSH connection...", false);
          const data = await postJson("/api/ssh/test-connection", {});
          const remoteUser = String(data.remoteUser || "").trim();
          setStatus(
            "SSH connection successful" + (remoteUser ? " (whoami: " + remoteUser + ")" : "."),
            false
          );
        } catch (err) {
          setStatus("SSH test failed: " + (err.message || String(err)), true);
        } finally {
          btnTestConnection.disabled = false;
        }
      });
    }

    getStatus().catch(function () {});
  });
  </script>

  <script>
    (function () {
      var form = document.getElementById("settingsForm");
      if (!form) return;

      var statusEl = document.getElementById("settingsAutoSaveStatus");
      var debounceMs = 1400;
      var timer = null;
      var pendingAutoSave = false;
      var saveInFlight = false;

      form.addEventListener("submit", function (e) {
        if (pendingAutoSave) {
          e.preventDefault();
          pendingAutoSave = false;
          if (saveInFlight) return;
          saveInFlight = true;
          if (statusEl) {
            statusEl.textContent = "Saving…";
            statusEl.style.color = "";
          }
          var action = form.getAttribute("action") || "/settings";
          fetch(action, {
            method: "POST",
            body: new FormData(form),
            headers: {
              Accept: "application/json",
              "X-Requested-With": "XMLHttpRequest",
            },
            credentials: "same-origin",
          })
            .then(function (res) {
              return res.text().then(function (text) {
                var j = null;
                try {
                  j = text ? JSON.parse(text) : null;
                } catch (_) {}
                if (!res.ok || !j || j.ok !== true) {
                  throw new Error((j && j.error) || text.slice(0, 200) || res.statusText || "Save failed");
                }
              });
            })
            .then(function () {
              if (statusEl) {
                statusEl.textContent = "Saved";
                statusEl.style.color = "";
              }
            })
            .catch(function (err) {
              if (statusEl) {
                statusEl.textContent = "Auto-save failed: " + (err.message || String(err));
                statusEl.style.color = "#dc2626";
              }
            })
            .finally(function () {
              saveInFlight = false;
            });
          return;
        }
        if (timer) {
          clearTimeout(timer);
          timer = null;
        }
      });

      function scheduleAutoSave() {
        if (timer) clearTimeout(timer);
        timer = setTimeout(function () {
          timer = null;
          pendingAutoSave = true;
          if (typeof form.requestSubmit === "function") {
            form.requestSubmit();
          } else {
            var sub = document.createElement("button");
            sub.type = "submit";
            sub.setAttribute("formnovalidate", "");
            sub.style.cssText = "position:absolute;left:-9999px;width:1px;height:1px;opacity:0;";
            form.appendChild(sub);
            sub.click();
            form.removeChild(sub);
          }
        }, debounceMs);
      }

      form.addEventListener(
        "input",
        function (e) {
          var t = e.target;
          if (!t || !t.name) return;
          if (t.type === "file") return;
          scheduleAutoSave();
        },
        true
      );

      form.addEventListener(
        "change",
        function (e) {
          var t = e.target;
          if (!t || !t.name) return;
          scheduleAutoSave();
        },
        true
      );
    })();
  </script>

