<%- include("partials/header") %>
<%- include("partials/sidebar") %>

<main class="main">
  <h1>Settings</h1>
  <small>Adjust settings as needed and then hit "Save Settings" for the changes to take effect.</small>

<% if (importStatus) { %>
  <div class="alert success" style="margin-top: 12px;">
    Configuration imported successfully. Your data folder has been restored from the uploaded zip.
  </div>
<% } %>
<% if (importError) { %>
  <div class="alert error" style="margin-top: 12px;">
    Import failed: <%= importError %>
  </div>
<% } %>

  <form id="settingsForm" method="post" action="/settings" autocomplete="off" enctype="multipart/form-data">
    <%
      const BOOL_KEYS = new Set([
        "TAK_REVOKE_ON_DISABLE",
        "TAK_DEBUG",
        "TAK_BYPASS_ENABLED",
        "EMAIL_ENABLED",
        "SMTP_SECURE",
        "EMAIL_FAIL_HARD",
        "PORTAL_AUTH_ENABLED"
      ]);

      function renderField(key, label, helpText, defaultValue) {
    %>
      <label class="settings-field">
        <span class="settings-label"><%= label || key %></span>

        <% if (BOOL_KEYS.has(key)) { %>
          <%
            const rawVal = (settings && typeof settings[key] === "string")
              ? settings[key].toLowerCase()
              : "";
            const currentVal =
              rawVal === "true" ? "true" :
              rawVal === "false" ? "false" :
              "";
          %>
          <select name="settings[<%= key %>]">
            <option value="true" <%= currentVal === "true" ? "selected" : "" %>>true</option>
            <option value="false" <%= currentVal === "false" ? "selected" : "" %>>false</option>
          </select>
        <% } else { %>
          <%
            const resolvedVal = (typeof settings[key] === 'string')
              ? settings[key]
              : (typeof defaultValue === 'string' ? defaultValue : '');
          %>
          <input
            type="text"
            name="settings[<%= key %>]"
            value="<%= resolvedVal %>"
          />
        <% } %>

        <% if (helpText) { %>
          <small class="settings-help"><%= helpText %></small>
        <% } %>
      </label>
    <% } %>

    <%
      // Build known keys list so bookmarks can scale without changing
      // the underlying settings.json format (flat BOOKMARKn_TITLE/URL keys).
      const bookmarkKeys = [];
      for (let i = 1; i <= 20; i++) {
        bookmarkKeys.push(`BOOKMARK${i}_TITLE`, `BOOKMARK${i}_URL`);
      }

      const knownKeys = new Set([
        "AUTHENTIK_URL",
        "AUTHENTIK_TOKEN",
        "USERS_HIDDEN_PREFIXES",
        "GROUPS_HIDDEN_PREFIXES",
        "USERS_ACTIONS_HIDDEN_PREFIXES",
        "GROUPS_ACTIONS_HIDDEN_PREFIXES",
        "DASHBOARD_AUTHENTIK_STATS_REFRESH_SECONDS",

        "TAK_URL",
        "TAK_API_P12_PATH",
        "TAK_API_P12_PASSPHRASE",
        "TAK_CA_PATH",
        "TAK_REVOKE_ON_DISABLE",
        "TAK_DEBUG",
        "TAK_BYPASS_ENABLED",
        "CLOUDTAK_URL",

        "PORTAL_AUTH_ENABLED",
        "PORTAL_AUTH_REQUIRED_GROUP",
        "AUTHENTIK_PUBLIC_URL",
        "TAK_PORTAL_PUBLIC_URL",

        "EMAIL_ENABLED",
        "EMAIL_PROVIDER",
        "SMTP_HOST",
        "SMTP_PORT",
        "SMTP_SECURE",
        "SMTP_USER",
        "SMTP_PASS",
        "SMTP_FROM",
        "EMAIL_ALWAYS_CC",
        "EMAIL_SEND_COPY_TO",
        "EMAIL_FAIL_HARD",

        ...bookmarkKeys,

        "BRAND_THEME",
        "BRAND_LOGO_URL",

        "CALLSIGN_FORMAT_EXPRESSION"
      ]);

      const otherKeys = keys.filter(k => !knownKeys.has(k));
    %>

    <!-- Authentik -->
    <div class="card">
      <details class="settings-section">
        <summary class="settings-summary">Authentik</summary>

        <div class="settings-body">
          <div class="grid2">
            <% renderField("AUTHENTIK_URL","Authentik Internal URL","Base URL of your Authentik instance (e.g. http://authentik:9000)"); %>
            <label class="settings-field">
              <span class="settings-label">Authentik API Token</span>

              <div class="passwordWrap">
                <input
                  id="authentikTokenInput"
                  type="password"
                  name="settings[AUTHENTIK_TOKEN]"
                  value="<%= settings.AUTHENTIK_TOKEN || '' %>"
                  autocomplete="new-password"
                />

                <button
                  type="button"
                  id="authentikTokenToggle"
                  class="passwordToggle"
                  aria-label="Show token"
                  title="Show token"
                >
                  👁
                </button>
              </div>

              <small class="settings-help">
                API token with permission to manage users and groups.
              </small>
            </label>
            <% renderField("USERS_HIDDEN_PREFIXES","Hidden User Prefixes","Comma-separated prefixes of usernames to hide from the UI."); %>
            <% renderField("GROUPS_HIDDEN_PREFIXES","Hidden Group Prefixes","Comma-separated prefixes of groups to hide from the UI."); %>
            <% renderField("USERS_ACTIONS_HIDDEN_PREFIXES","User Action-Lock Prefixes","Users whose name starts with these prefixes cannot be modified from the portal."); %>
            <% renderField("GROUPS_ACTIONS_HIDDEN_PREFIXES","Group Action-Lock Prefixes","Groups whose name starts with these prefixes cannot be modified from the portal."); %>
            <% renderField("DASHBOARD_AUTHENTIK_STATS_REFRESH_SECONDS","Dashboard Authentik Stats Refresh (seconds)","How often the server refreshes cached Authentik dashboard stats in the background. Server restart required for changes to take effect."); %>
          </div>
        </div>
      </details>
    </div>

    <!-- TAK Server -->
    <div class="card">
      <details class="settings-section">
        <summary class="settings-summary">TAK Server</summary>

        <div class="settings-body">
          <div class="grid2">
            <% renderField("TAK_URL","TAK URL","Full Marti URL, e.g. https://tak.example.gov:8443/Marti."); %>

        <label class="settings-field">
          <span class="settings-label">
            Client P12 Certificate
            <% if (p12Exists) { %>
              <span class="cert-status installed">Installed</span>
            <% } else { %>
              <span class="cert-status missing">Not Installed</span>
            <% } %>
          </span>

          <input type="file" name="TAK_API_P12_UPLOAD" accept=".p12,.pfx,application/x-pkcs12" />
          <small class="settings-help">
            Upload a new file to replace the existing certificate.
          </small>
        </label>

        <label class="settings-field">
        <span class="settings-label">Client P12 Password</span>

        <div class="passwordWrap">
          <input
            id="p12PassphraseInput"
            type="password"
            name="settings[TAK_API_P12_PASSPHRASE]"
            value="<%= settings.TAK_API_P12_PASSPHRASE || '' %>"
            autocomplete="new-password"
          />

          <button
            type="button"
            id="p12PassphraseToggle"
            class="passwordToggle"
            aria-label="Show passphrase"
            title="Show passphrase"
          >
            👁
          </button>
        </div>

        <small class="settings-help">
          Passphrase for the client .p12 file (may be empty).
        </small>
      </label>

        <label class="settings-field">
          <span class="settings-label">
            TAK Server PEM Certificate
            <% if (caExists) { %>
              <span class="cert-status installed">Installed</span>
            <% } else { %>
              <span class="cert-status missing">Not Installed</span>
            <% } %>
          </span>

          <input type="file" name="TAK_CA_UPLOAD" accept=".pem,.crt,.cer,.der" />
          <small class="settings-help">
            Upload a new file to replace the existing CA certificate. Notepad should show three distinct blocks of text starting with -----BEGIN CERTIFICATE-----
          </small>
        </label>

            <% renderField("TAK_REVOKE_ON_DISABLE","Revoke on Disable","If true, revokes TAK certs when a user is disabled."); %>
            <% renderField("TAK_DEBUG","TAK Debug","If true, enables verbose TAK debug logging."); %>
            <% renderField("TAK_BYPASS_ENABLED","Bypass TAK","If true, disables all outbound TAK calls (for testing)."); %>
            <% renderField("CLOUDTAK_URL","CloudTAK URL","Optional. Base URL for CloudTAK web (e.g. https://cloudtak.example.gov)."); %>
          </div>
        </div>
      </details>
    </div>

    <!-- Email -->
    <div class="card">
      <details class="settings-section">
        <summary class="settings-summary">Email</summary>

        <div class="settings-body">
          <div class="grid2">
            <% renderField("EMAIL_ENABLED","Email Enabled","true/false – whether email notifications are enabled."); %>
            <% renderField("EMAIL_PROVIDER","Email Provider","Currently only 'smtp' is supported."); %>
            <% renderField("SMTP_HOST","SMTP Host","SMTP server hostname."); %>
            <% renderField("SMTP_PORT","SMTP Port","SMTP port, e.g. 587."); %>
            <% renderField("SMTP_SECURE","SMTP Secure","true for SMTPS/465, false for STARTTLS/587."); %>
            <% renderField("SMTP_USER","SMTP Username","Username for SMTP authentication."); %>
            <% renderField("SMTP_PASS","SMTP Password","Password for SMTP authentication."); %>
            <% renderField("SMTP_FROM","From Address",'e.g. TAK Admin <admin@example.com>'); %>
            <% renderField("EMAIL_ALWAYS_CC","Always CC","Optional comma-separated list."); %>
            <% renderField("EMAIL_SEND_COPY_TO","Always BCC","Optional comma-separated list."); %>
            <% renderField("EMAIL_FAIL_HARD","Fail Hard on Email Error","If true, user actions fail when email fails."); %>
          </div>

          <!-- Send Test Email button (uses the main form, but overrides action) -->
          <div style="margin-top:1rem;">
            <button
              type="submit"
              class="btn"
              formaction="/settings/test-email"
              formmethod="post"
              name="_testEmail"
              value="1">
              Send Test Email
            </button>
            <small class="settings-help">
              Sends “TAK Portal - Email SMTP Test” to the configured Always CC and Always BCC addresses. (Email Enabled must be true.)
            </small>
          </div>
        </div>
      </details>
    </div>

    <%
      const emailTemplatesList = Array.isArray(
        typeof emailTemplates !== "undefined" ? emailTemplates : []
      )
        ? emailTemplates
        : [];

      // Desired order
      const templateOrder = [
        "user_created_password_set.html",
        "user_created_no_password.html",
        "groups_updated.html",
        "password_changed.html",
        "mutual_aid_created.html"
      ];

      const friendlyNames = {
        "user_created_password_set.html": "User Created (with Password)",
        "user_created_no_password.html": "User Created (without Password)",
        "groups_updated.html": "Groups Updated",
        "password_changed.html": "Password Changed by Admin",
        "mutual_aid_created.html": "Mutual Aid"
      };

      function templateSortIndex(filename) {
        const idx = templateOrder.indexOf(filename);
        return idx === -1 ? templateOrder.length : idx;
      }

      const orderedEmailTemplates = emailTemplatesList
        .slice()
        .sort(function (a, b) {
          return templateSortIndex(a.filename) - templateSortIndex(b.filename);
        });
    %>
    <% if (orderedEmailTemplates.length) { %>
      <div class="card">
        <details class="settings-section email-templates-section">
          <summary class="settings-summary">Email Templates</summary>

          <div class="settings-body">
            <p class="settings-help">
              Edit the HTML bodies used for system notification emails. Changes
              here are stored separately from the built-in files in
              <code>/email_templates</code>, so your customizations will not be
              overwritten by upgrades.
            </p>

            <script>
              window.EMAIL_TEMPLATE_DEFAULTS = {};
              <% orderedEmailTemplates.forEach(function (tpl) { %>
              window.EMAIL_TEMPLATE_DEFAULTS["<%= tpl.idSafe %>"] = <%- JSON.stringify((tpl.defaultHtml != null && tpl.defaultHtml !== undefined) ? tpl.defaultHtml : "") %>;
              <% }); %>
            </script>

            <% orderedEmailTemplates.forEach(function (tpl) { %>
              <details
                class="email-template-item"
                data-template-id="<%= tpl.idSafe %>"
                style="margin-top:1rem;border:1px solid #e5e7eb;border-radius:0.5rem;padding:0.5rem 0.75rem;"
              >
                <summary
                  style="display:flex;align-items:center;justify-content:space-between;cursor:pointer;list-style:none;"
                >
                  <span class="settings-label">
                    <%= friendlyNames[tpl.filename] || tpl.filename %>
                  </span>

                  <span
                    class="email-template-badge"
                    data-badge="<%= tpl.idSafe %>"
                    style="<%= tpl.overridden ? 'background:#2563eb;color:#fff;' : 'background:#e5e7eb;color:#374151;' %>padding:0.1rem 0.4rem;border-radius:999px;font-size:0.75rem;"
                  >
                    <%= tpl.overridden ? "Custom" : "Default" %>
                  </span>
                </summary>

                <div style="margin-top:0.75rem;">
                  <textarea
                    id="email-template-<%= tpl.idSafe %>"
                    name="settings[EMAIL_TEMPLATES_OVERRIDES][<%= tpl.filename %>]"
                    class="email-template-editor"
                    rows="30"
                    style="width:100%;min-height:450px;font-family:monospace;font-size:.85rem;white-space:pre;overflow:auto;"
                  ><%- tpl.html || "" %></textarea>

                  <input
                    type="hidden"
                    name="settings[EMAIL_TEMPLATES_OVERRIDES_RESET][<%= tpl.filename %>]"
                    value="0"
                    data-reset-flag="<%= tpl.idSafe %>"
                  />

                  <small
                    class="settings-help"
                    data-reset-note="<%= tpl.idSafe %>"
                    style="display:none;"
                  >
                    This template will be reset to the built-in default when you save using the button at the bottom of the page.
                  </small>

                  <div style="margin-top:.75rem;display:flex;gap:.5rem;flex-wrap:wrap;">
                    <button
                      type="submit"
                      class="btn"
                      name="_saveTemplate"
                      value="<%= tpl.filename %>"
                    >
                      Save Custom Template
                    </button>

                    <button
                      type="button"
                      class="btn"
                      data-reset-template="<%= tpl.idSafe %>"
                    >
                      Reset to Default
                    </button>
                  </div>
                </div>
              </details>
            <% }); %>
          </div>
        </details>
      </div>
    <% } %>

    <!-- Callsign Format -->
    <div class="card">
      <details class="settings-section">
        <summary class="settings-summary">Callsign Format</summary>

        <div class="settings-body">
          <p class="settings-help">
            Configure how callsigns are displayed. Use field blocks and text blocks to build the final callsign string.
          </p>

          <div id="callsignBuilder" style="margin-top:.5rem;">
            <div style="display:flex;gap:.5rem;flex-wrap:wrap;align-items:center;margin-bottom:.5rem;">
              <button type="button" class="btn" id="addCallsignFieldBtn">Add Field</button>
              <button type="button" class="btn" id="addCallsignTextBtn">Add Text</button>
              <small class="settings-help">Drag chips by the handle to change order.</small>
            </div>

            <ul
              id="callsignList"
              style="list-style:none;padding:0;margin:0;display:flex;flex-direction:row;flex-wrap:wrap;gap:0.35rem;align-items:flex-start;"
            ></ul>

            <input
              type="hidden"
              id="callsignFormatInput"
              name="settings[CALLSIGN_FORMAT_EXPRESSION]"
              value="<%- (settings.CALLSIGN_FORMAT_EXPRESSION || '{{agencyAbbreviation}}-{{lastNameUpper}}-{{badgeNumber}}') %>"
            />


            <div style="margin-top:.5rem;">
              <strong>Preview:</strong>
              <span id="callsignPreview" style="font-family:monospace;margin-left:.25rem;"></span>
            </div>
          </div>

          <script>
            (function () {
              var root = document.getElementById("callsignBuilder");
              if (!root) return;

              var list = document.getElementById("callsignList");
              var input = document.getElementById("callsignFormatInput");
              var preview = document.getElementById("callsignPreview");
              var addFieldBtn = document.getElementById("addCallsignFieldBtn");
              var addTextBtn = document.getElementById("addCallsignTextBtn");

              if (!list || !input || !preview || !addFieldBtn || !addTextBtn) return;

              var FIELD_OPTIONS = [
                { value: "stateAbbreviation", label: "State" },
                { value: "county", label: "County" },
                { value: "countyAbbreviation", label: "County Abbrev" },
                { value: "agencyAbbreviation", label: "Agency" },
                { value: "agencyTypeCode", label: "Agency Type" },
                { value: "firstName", label: "First" },
                { value: "lastNameUpper", label: "Last (UPPER)" },
                { value: "lastName", label: "Last" },
                { value: "badgeNumber", label: "Badge" },
                { value: "_dash", label: "— (dash)" }
              ];

              function getDragAfterElement(container, x) {
                var els = [].slice.call(
                  container.querySelectorAll("li[data-callsign-row]:not(.dragging)")
                );
                return els.reduce(function (closest, child) {
                  var box = child.getBoundingClientRect();
                  var offset = x - box.left - box.width / 2;
                  if (offset < 0 && offset > closest.offset) {
                    return { offset: offset, element: child };
                  }
                  return closest;
                }, { offset: Number.NEGATIVE_INFINITY, element: null }).element;
              }

              function serialize() {
                var parts = [];
                var rows = [].slice.call(list.querySelectorAll("li[data-callsign-row]"));
                rows.forEach(function (row) {
                  var type = row.getAttribute("data-type");
                  if (type === "field") {
                    var sel = row.querySelector("select[data-field-name]");
                    var v = (sel && sel.value) || "";
                    if (v === "_dash") {
                      parts.push("-");
                    } else if (v) {
                      parts.push("{{" + v + "}}");
                    }
                  } else if (type === "text") {
                    var inp = row.querySelector("input[data-text-val]");
                    if (inp && inp.value) parts.push(inp.value);
                  }
                });

                if (!parts.length) {
                  parts = ["{{agencyAbbreviation}}", "-", "{{lastNameUpper}}", "-", "{{badgeNumber}}"];
                }

                input.value = parts.join("");
                updatePreview();
              }

              function updatePreview() {
                var expr = String(input.value || "").trim();
                if (!expr) {
                  preview.textContent = "AGENCY-LASTNAME-BADGE";
                  return;
                }

                var exampleCtx = {
                  agencyAbbreviation: "AGENCY",
                  stateAbbreviation: "STATE",
                  county: "COUNTY",
                  countyAbbreviation: "CNTY",
                  agencyTypeCode: "LE",
                  firstName: "FIRST",
                  lastName: "Last",
                  lastNameUpper: "LAST",
                  badgeNumber: "1234"
                };

                var rendered = expr.replace(/\{\{\s*([a-zA-Z0-9_]+)\s*\}\}/g, function (_, key) {
                  if (Object.prototype.hasOwnProperty.call(exampleCtx, key)) {
                    return exampleCtx[key];
                  }
                  return "";
                });

                preview.textContent = rendered || "AGENCY-LASTNAME-BADGE";
              }

              function makeDeleteButton(onClick) {
                var btn = document.createElement("button");
                btn.type = "button";
                btn.textContent = "✕";
                btn.title = "Remove";
                btn.className = "btn btn-warning callsign-block-delete";
                btn.addEventListener("click", function () {
                  onClick();
                  serialize();
                });
                return btn;
              }

              function createRow(opts) {
                var type = opts && opts.type === "text" ? "text" : "field";
                var field = opts && opts.field;
                var text = opts && opts.text;

                var li = document.createElement("li");
                li.setAttribute("data-callsign-row", "1");
                li.setAttribute("data-type", type);
                li.className = "callsign-block";
                li.draggable = true;
                li.style.border = "1px solid #e5e7eb";
                li.style.background = "#fff0";

                var wrap = document.createElement("div");
                wrap.className = "callsign-block-inner";

                var handle = document.createElement("div");
                handle.className = "callsign-block-handle";
                handle.title = "Drag to reorder";
                handle.textContent = "⋮⋮";

                var main;
                if (type === "field") {
                  var select = document.createElement("select");
                  select.setAttribute("data-field-name", "1");
                  FIELD_OPTIONS.forEach(function (opt) {
                    var o = document.createElement("option");
                    o.value = opt.value;
                    o.textContent = opt.label;
                    select.appendChild(o);
                  });
                  select.value = field && FIELD_OPTIONS.some(function (o) { return o.value === field; })
                    ? field
                    : "agencyAbbreviation";
                  select.addEventListener("change", serialize);
                  main = select;
                } else {
                  var inp = document.createElement("input");
                  inp.type = "text";
                  inp.setAttribute("data-text-val", "1");
                  inp.placeholder = "Text (e.g. -, TN-)";
                  inp.value = text || "";
                  inp.addEventListener("input", serialize);
                  main = inp;
                }

                var del = makeDeleteButton(function () {
                  li.remove();
                });

                wrap.appendChild(handle);
                wrap.appendChild(main);
                wrap.appendChild(del);
                li.appendChild(wrap);

                li.addEventListener("dragstart", function (e) {
                  li.classList.add("dragging");
                  if (e.dataTransfer) {
                    e.dataTransfer.effectAllowed = "move";
                  }
                });
                li.addEventListener("dragend", function () {
                  li.classList.remove("dragging");
                  serialize();
                });

                return li;
              }

              function initFromExpression() {
                var expr = String(input.value || "").trim();
                if (!expr) {
                  expr = "{{agencyAbbreviation}}-{{lastNameUpper}}-{{badgeNumber}}";
                }

                var re = /\{\{\s*([a-zA-Z0-9_]+)\s*\}\}/g;
                var lastIndex = 0;
                var m;
                while ((m = re.exec(expr)) !== null) {
                  var textPart = expr.slice(lastIndex, m.index);
                  if (textPart) {
                    list.appendChild(textPart === "-"
                      ? createRow({ type: "field", field: "_dash" })
                      : createRow({ type: "text", text: textPart }));
                  }
                  list.appendChild(createRow({ type: "field", field: m[1] }));
                  lastIndex = re.lastIndex;
                }
                var tail = expr.slice(lastIndex);
                if (tail) {
                  list.appendChild(tail === "-"
                    ? createRow({ type: "field", field: "_dash" })
                    : createRow({ type: "text", text: tail }));
                }

                if (!list.querySelector("li[data-callsign-row]")) {
                  list.appendChild(createRow({ type: "field", field: "agencyAbbreviation" }));
                  list.appendChild(createRow({ type: "field", field: "_dash" }));
                  list.appendChild(createRow({ type: "field", field: "lastNameUpper" }));
                  list.appendChild(createRow({ type: "field", field: "_dash" }));
                  list.appendChild(createRow({ type: "field", field: "badgeNumber" }));
                }

                serialize();
              }

              addFieldBtn.addEventListener("click", function () {
                list.appendChild(createRow({ type: "field", field: "badgeNumber" }));
                serialize();
              });

              addTextBtn.addEventListener("click", function () {
                list.appendChild(createRow({ type: "text", text: "-" }));
                serialize();
              });

              list.addEventListener("dragover", function (e) {
                e.preventDefault();
                var dragging = list.querySelector(".dragging");
                if (!dragging) return;
                var after = getDragAfterElement(list, e.clientX);
                if (after == null) {
                  list.appendChild(dragging);
                } else {
                  list.insertBefore(dragging, after);
                }
              });

              initFromExpression();
            })();
          </script>
        </div>
      </details>
    </div>

    <!-- Appearance -->
    <div class="card">
      <details class="settings-section">
        <summary class="settings-summary">Appearance</summary>

        <div class="settings-body">
          <div class="grid2">
            <label class="settings-field">
              <span class="settings-label">Portal Logo</span>
              <input type="file" name="BRAND_LOGO_UPLOAD" accept="image/*" />
              <% if (settings.BRAND_LOGO_URL) { %>
                <small class="settings-help">Current: <code><%= settings.BRAND_LOGO_URL %></code></small>
              <% } else { %>
                <small class="settings-help">Shown in sidebar and QR codes.</small>
              <% } %>
            </label>

            <label class="settings-field">
              <span class="settings-label">Color Theme</span>
              <% const currentTheme = settings.BRAND_THEME || "dark"; %>
              <select name="settings[BRAND_THEME]">
                <option value="dark" <%= currentTheme === "dark" ? "selected" : "" %>>Dark Mode</option>
                <option value="dark-blue" <%= currentTheme === "dark-blue" ? "selected" : "" %>>Dark Blue</option>
                <option value="light" <%= currentTheme === "light" ? "selected" : "" %>>Light Mode</option>
              </select>
            </label>
          </div>
        </div>
      </details>
    </div>

    <!-- Dashboard Bookmarks -->
    <div class="card">
      <details class="settings-section">
        <summary class="settings-summary">Dashboard Bookmarks (Visible Only To Global Admins)</summary>

        <div class="settings-body">
          <% 
            const initialBookmarks = [];
            for (let i = 1; i <= 20; i++) {
              const t = (settings[`BOOKMARK${i}_TITLE`] || "").trim();
              const u = (settings[`BOOKMARK${i}_URL`] || "").trim();
              if (!t && !u) continue;
              initialBookmarks.push({ title: t, url: u });
            }
          %>

          <div id="bookmarkEditor" style="margin-top:.5rem;">
            <div style="display:flex;gap:.5rem;flex-wrap:wrap;align-items:center;margin-bottom:.5rem;">
              <button type="button" class="btn" id="addBookmarkBtn">Add Bookmark</button>
              <small class="settings-help" id="bookmarkCountNote"></small>
            </div>

            <ul id="bookmarkList" style="list-style:none;padding:0;margin:0;display:flex;flex-direction:column;gap:.5rem;"></ul>

            <!-- Hidden fields will be generated on submit to keep settings.json format unchanged -->
            <div id="bookmarkHiddenFields"></div>
          </div>

          <script>
            (function () {
              var MAX = 20;
              var form = document.getElementById('settingsForm');
              var list = document.getElementById('bookmarkList');
              var addBtn = document.getElementById('addBookmarkBtn');
              var note = document.getElementById('bookmarkCountNote');
              var hiddenHost = document.getElementById('bookmarkHiddenFields');

              if (!form || !list || !addBtn || !hiddenHost) return;

              var initial = <%- JSON.stringify(initialBookmarks) %>;

              function updateCount() {
                var n = list.querySelectorAll('li[data-bookmark-row]').length;
                if (note) note.textContent = n + ' / ' + MAX + ' bookmarks';
                addBtn.disabled = n >= MAX;
              }

              function makeInput(placeholder, value) {
                var inp = document.createElement('input');
                inp.type = 'text';
                inp.placeholder = placeholder;
                inp.value = value || '';
                inp.style.width = '100%';
                return inp;
              }

              function createRow(bm) {
                var li = document.createElement('li');
                li.setAttribute('data-bookmark-row', '1');
                li.draggable = true;
                li.style.border = '1px solid #e5e7eb';
                li.style.borderRadius = '0.5rem';
                li.style.padding = '0.5rem';
                li.style.background = '#fff0';

                var wrap = document.createElement('div');
                wrap.style.display = 'grid';
                wrap.style.gridTemplateColumns = '32px 1fr 1fr 80px';
                wrap.style.gap = '0.5rem';
                wrap.style.alignItems = 'center';

                var handle = document.createElement('div');
                handle.title = 'Drag to reorder';
                handle.textContent = '⋮⋮';
                handle.style.cursor = 'grab';
                handle.style.userSelect = 'none';
                handle.style.fontSize = '1.2rem';
                handle.style.textAlign = 'center';

                var title = makeInput('Title', bm && bm.title);
                title.setAttribute('data-bm-title', '1');
                var url = makeInput('URL (https://...)', bm && bm.url);
                url.setAttribute('data-bm-url', '1');

                var del = document.createElement('button');
                del.type = 'button';
                del.className = 'btn btn-warning';
                del.textContent = 'Delete';
                del.addEventListener('click', function () {
                  li.remove();
                  updateCount();
                });

                wrap.appendChild(handle);
                wrap.appendChild(title);
                wrap.appendChild(url);
                wrap.appendChild(del);
                li.appendChild(wrap);

                // Drag/drop
                li.addEventListener('dragstart', function (e) {
                  li.classList.add('dragging');
                  e.dataTransfer.effectAllowed = 'move';
                });
                li.addEventListener('dragend', function () {
                  li.classList.remove('dragging');
                });

                return li;
              }

              function getDragAfterElement(container, y) {
                var els = [].slice.call(container.querySelectorAll('li[data-bookmark-row]:not(.dragging)'));
                return els.reduce(function (closest, child) {
                  var box = child.getBoundingClientRect();
                  var offset = y - box.top - box.height / 2;
                  if (offset < 0 && offset > closest.offset) {
                    return { offset: offset, element: child };
                  }
                  return closest;
                }, { offset: Number.NEGATIVE_INFINITY, element: null }).element;
              }

              list.addEventListener('dragover', function (e) {
                e.preventDefault();
                var dragging = list.querySelector('.dragging');
                if (!dragging) return;
                var after = getDragAfterElement(list, e.clientY);
                if (after == null) {
                  list.appendChild(dragging);
                } else {
                  list.insertBefore(dragging, after);
                }
              });

              addBtn.addEventListener('click', function () {
                var n = list.querySelectorAll('li[data-bookmark-row]').length;
                if (n >= MAX) return;
                list.appendChild(createRow({ title: '', url: '' }));
                updateCount();
              });

              // Seed
              if (Array.isArray(initial) && initial.length) {
                initial.forEach(function (bm) {
                  list.appendChild(createRow(bm));
                });
              }
              updateCount();

              // On submit, serialize into flat settings[BOOKMARKn_*] fields.
              form.addEventListener('submit', function () {
                // Clear any previous hidden fields
                hiddenHost.innerHTML = '';

                var rows = [].slice.call(list.querySelectorAll('li[data-bookmark-row]'));
                var normalized = rows
                  .map(function (li) {
                    var t = (li.querySelector('[data-bm-title]') || {}).value || '';
                    var u = (li.querySelector('[data-bm-url]') || {}).value || '';
                    return { title: String(t).trim(), url: String(u).trim() };
                  })
                  .filter(function (bm) {
                    return bm.title || bm.url;
                  });

                for (var i = 1; i <= MAX; i++) {
                  var bm = normalized[i - 1] || { title: '', url: '' };

                  var t = document.createElement('input');
                  t.type = 'hidden';
                  t.name = 'settings[BOOKMARK' + i + '_TITLE]';
                  t.value = bm.title;

                  var u = document.createElement('input');
                  u.type = 'hidden';
                  u.name = 'settings[BOOKMARK' + i + '_URL]';
                  u.value = bm.url;

                  hiddenHost.appendChild(t);
                  hiddenHost.appendChild(u);
                }
              });
            })();
          </script>
        </div>
      </details>
    </div>



    <!-- Deployment Packet Settings -->
    <div class="card">
      <details class="settings-section">
        <summary class="settings-summary">Deployment Packet Settings</summary>

        <div class="settings-body">
          <h3 style="margin:0 0 .5rem 0;">Color / Team</h3>
          <div class="grid2">
            <% renderField("DP_COLOR_BLUE","Blue",null,"Aircraft"); %>
            <% renderField("DP_COLOR_DARK_BLUE","Dark Blue",null,"Law Enforcement"); %>
            <% renderField("DP_COLOR_BROWN","Brown",null,"State Defense Forces"); %>
            <% renderField("DP_COLOR_CYAN","Cyan",null,"SWAT / Sniper / Overwatch"); %>
            <% renderField("DP_COLOR_GREEN","Green",null,"Military"); %>
            <% renderField("DP_COLOR_DARK_GREEN","Dark Green",null,"TWRA / NPS / Forestry"); %>
            <% renderField("DP_COLOR_MAGENTA","Magenta",null,"CBRNE / HAZMAT"); %>
            <% renderField("DP_COLOR_MAROON","Maroon",null,"EMS"); %>
            <% renderField("DP_COLOR_ORANGE","Orange",null,"SAR / Technical"); %>
            <% renderField("DP_COLOR_PURPLE","Purple",null,"Volunteers"); %>
            <% renderField("DP_COLOR_RED","Red",null,"Fire"); %>
