<%
  const _isGlobalAdmin = typeof isGlobalAdmin !== "undefined" ? !!isGlobalAdmin : false;
  const _isAgencyAdmin = typeof isAgencyAdmin !== "undefined" ? !!isAgencyAdmin : false;

  const isAdmin = _isGlobalAdmin || _isAgencyAdmin;

  const _displayName =
    typeof authUser !== "undefined" &&
    authUser &&
    (authUser.displayName || authUser.username)
      ? (authUser.displayName || authUser.username)
      : "";

  const canSeeSettings = _isGlobalAdmin;

  const _settings = typeof settings !== "undefined" && settings ? settings : {};
  const betaModeEnabled =
    typeof _settings.BETA_MODE === "string"
      ? _settings.BETA_MODE.toLowerCase() === "true"
      : false;

  const _path = (typeof currentPath !== "undefined" && currentPath) ? String(currentPath).replace(/\/+$/, "") || "/" : "/";
  function isActive(href) {
    const h = (href || "/").replace(/\/+$/, "") || "/";
    if (h === "/") return _path === "/" || _path === "/dashboard";
    return _path === h || _path.startsWith(h + "/");
  }
%>

<aside class="sidebar" id="sidebar">
  <div class="brand <%= brandLogoUrl ? 'has-logo' : 'no-logo' %>">
    <% if (brandLogoUrl) { %>
      <img src="<%= brandLogoUrl %>" alt="Portal logo" class="brand-logo" />
    <% } %>
    <span class="brand-title">TAK Portal</span>
  </div>

  <nav class="sidebar-nav">
    <div class="nav-top">
      <% if (!isAdmin) { %>
        <div class="nav-section" data-section="onboarding">
          <button type="button" class="nav-section-toggle" aria-expanded="true" aria-controls="nav-onboarding" id="nav-toggle-onboarding">
            <span class="nav-section-label">Onboarding</span>
            <span class="nav-section-chevron" aria-hidden="true">▾</span>
          </button>
          <div class="nav-section-links" id="nav-onboarding">
            <a href="/setup-my-device" class="<%= isActive('/setup-my-device') ? 'active' : '' %>">Setup My Device</a>
            <% if (betaModeEnabled) { %>
              <a href="/getting-started" class="<%= isActive('/getting-started') ? 'active' : '' %>">Getting Started</a>
            <% } %>
            <a href="/plugins" class="<%= isActive('/plugins') ? 'active' : '' %>">ATAK Plugins</a>
          </div>
        </div>
      <% } else { %>
        <a href="/" class="<%= isActive('/') ? 'active' : '' %>">Dashboard</a>

        <!-- Users & Groups -->
        <div class="nav-section" data-section="users-groups">
          <button type="button" class="nav-section-toggle" aria-expanded="true" aria-controls="nav-users-groups" id="nav-toggle-users-groups">
            <span class="nav-section-label">Users &amp; Groups</span>
            <span class="nav-section-chevron" aria-hidden="true">▾</span>
          </button>
          <div class="nav-section-links" id="nav-users-groups">
            <a href="/users/manage" class="<%= isActive('/users/manage') ? 'active' : '' %>">Users</a>
            <a href="/groups" class="<%= isActive('/groups') ? 'active' : '' %>">Groups</a>
            <a href="/templates" class="<%= isActive('/templates') ? 'active' : '' %>">Templates</a>
          </div>
        </div>

        <!-- Administration -->
        <div class="nav-section" data-section="administration">
          <button type="button" class="nav-section-toggle" aria-expanded="true" aria-controls="nav-administration" id="nav-toggle-administration">
            <span class="nav-section-label">Administration</span>
            <span class="nav-section-chevron" aria-hidden="true">▾</span>
          </button>
          <div class="nav-section-links" id="nav-administration">
            <% if (_isGlobalAdmin) { %>
              <a href="/mutual-aid" class="<%= isActive('/mutual-aid') ? 'active' : '' %>">Mutual Aid</a>
            <% } %>
            <a href="/email" class="<%= isActive('/email') ? 'active' : '' %>">Email Users</a>
            <% if (_isGlobalAdmin && betaModeEnabled) { %>
              <a href="/locate" class="<%= isActive('/locate') ? 'active' : '' %>">Locate Persons</a>
              <a href="/data-sync" class="<%= isActive('/data-sync') ? 'active' : '' %>">Data Sync</a>
            <% } %>
            <% if (_isGlobalAdmin) { %>
              <a href="/audit-log" class="<%= isActive('/audit-log') ? 'active' : '' %>">Audit Log</a>
            <% } %>
          </div>
        </div>

        <% if (canSeeSettings) { %>
        <!-- Configuration -->
        <div class="nav-section" data-section="configuration">
          <button type="button" class="nav-section-toggle" aria-expanded="true" aria-controls="nav-configuration" id="nav-toggle-configuration">
            <span class="nav-section-label">Configuration</span>
            <span class="nav-section-chevron" aria-hidden="true">▾</span>
          </button>
          <div class="nav-section-links" id="nav-configuration">
            <a href="/agencies" class="<%= isActive('/agencies') ? 'active' : '' %>">Agencies</a>
            <a href="/integrations" class="<%= isActive('/integrations') ? 'active' : '' %>">Integrations</a>
            <a href="/plugin-manager" class="<%= isActive('/plugin-manager') ? 'active' : '' %>">Plugin Manager</a>
            <a href="/settings" class="<%= isActive('/settings') ? 'active' : '' %>">Server Settings</a>
          </div>
        </div>
        <% } %>

        <!-- Onboarding -->
        <div class="nav-section" data-section="onboarding">
          <button type="button" class="nav-section-toggle" aria-expanded="true" aria-controls="nav-onboarding" id="nav-toggle-onboarding">
            <span class="nav-section-label">Onboarding</span>
            <span class="nav-section-chevron" aria-hidden="true">▾</span>
          </button>
          <div class="nav-section-links" id="nav-onboarding">
            <a href="/setup-my-device" class="<%= isActive('/setup-my-device') ? 'active' : '' %>">Setup My Device</a>
            <% if (betaModeEnabled) { %>
              <a href="/getting-started" class="<%= isActive('/getting-started') ? 'active' : '' %>">Getting Started</a>
            <% } %>
            <a href="/plugins" class="<%= isActive('/plugins') ? 'active' : '' %>">ATAK Plugins</a>
          </div>
        </div>
      <% } %>
    </div>

    <div class="nav-bottom">
      <a href="/logout" class="logout-link">Log Out</a>

      <small class="version-text">
        <%= _displayName %>
        <% if (_isGlobalAdmin) { %>
          - Global Admin
        <% } else if (_isAgencyAdmin) { %>
          - Agency Admin
        <% } %>
        <br>
        <a
          href="https://github.com/AdventureSeeker423/TAK-Portal/blob/main/CHANGELOG.md"
          target="_blank"
          rel="noopener noreferrer"
        >
          TAK Portal Version <%= APP_VERSION %>
        </a>
      </small>

      <% if (isAdmin && typeof APP_UPDATE_AVAILABLE !== "undefined" && APP_UPDATE_AVAILABLE) { %>
        <div class="update-available-form">
          <button
            type="button"
            class="update-available-pill"
            id="update-pill"
            <% if (!_isGlobalAdmin) { %> disabled style="opacity:.6; cursor:not-allowed;" <% } %>
          >
            Update Available
            <% if (typeof APP_LATEST_VERSION !== "undefined" && APP_LATEST_VERSION) { %>
              &nbsp;(v<%= APP_LATEST_VERSION %>)
            <% } %>
          </button>
        </div>
      <% } %>
    </div>
  </nav>
</aside>

<script>
(function () {
  var storageKey = "tak-portal-sidebar-sections";
  function getStored() {
    try {
      var raw = localStorage.getItem(storageKey);
      return raw ? JSON.parse(raw) : {};
    } catch (e) { return {}; }
  }
  function setStored(obj) {
    try { localStorage.setItem(storageKey, JSON.stringify(obj)); } catch (e) {}
  }
  function initSections() {
    var sections = document.querySelectorAll(".sidebar .nav-section");
    var stored = getStored();
    sections.forEach(function (section) {
      var id = section.getAttribute("data-section");
      var toggle = section.querySelector(".nav-section-toggle");
      var links = section.querySelector(".nav-section-links");
      if (!toggle || !links) return;
      var hasActive = section.querySelector("a.active");
      var openByStorage = stored[id] === true;
      var defaultOpen = hasActive || openByStorage;
      if (defaultOpen) {
        section.classList.remove("collapsed");
        toggle.setAttribute("aria-expanded", "true");
        links.style.maxHeight = links.scrollHeight + "px";
        if (hasActive && !openByStorage) {
          var next = getStored();
          next[id] = true;
          setStored(next);
        }
      } else {
        section.classList.add("collapsed");
        toggle.setAttribute("aria-expanded", "false");
      }
      toggle.addEventListener("click", function () {
        var collapsed = section.classList.toggle("collapsed");
        toggle.setAttribute("aria-expanded", collapsed ? "false" : "true");
        if (!collapsed) links.style.maxHeight = links.scrollHeight + "px";
        var next = getStored();
        next[id] = !collapsed;
        setStored(next);
      });
    });
  }
  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", initSections);
  } else {
    initSections();
  }
})();
</script>

<% /* Modal OUTSIDE sidebar so layout never interferes */ %>
<% if (_isGlobalAdmin && typeof APP_UPDATE_AVAILABLE !== "undefined" && APP_UPDATE_AVAILABLE) { %>
  <div id="update-modal" class="modalOverlay" style="display:none;">
    <div class="modal" role="dialog" aria-modal="true" aria-labelledby="updateTitle">
      <div class="modalHeader">
        <h2 id="updateTitle" style="margin:0;">Update Available</h2>
        <button class="btn" id="updateCloseBtn" type="button">Close</button>
      </div>

      <div class="modalBody">
        <p>
          To update TAK Portal please run updates via your Infra-TAK interface.
          If you are not using Infra-TAK, log into the server CLI and run:
        </p>

        <pre><code>cd ~/TAK-Portal && ./takportal update</code></pre>

        <p>
          To see what changed, view the
          <a
            href="https://github.com/AdventureSeeker423/TAK-Portal/blob/main/CHANGELOG.md"
            target="_blank"
            rel="noopener noreferrer"
          >
            changelog
          </a>.
        </p>
      </div>
    </div>
  </div>

  <script>
    (function () {
      var pill = document.getElementById('update-pill');
      var modal = document.getElementById('update-modal');
      var closeBtn = document.getElementById('updateCloseBtn');

      if (!pill || !modal || !closeBtn) return;

      function closeModal() {
        modal.style.display = 'none';
        document.body.style.overflow = '';
      }

      pill.addEventListener('click', function () {
        modal.style.display = 'flex';
        document.body.style.overflow = 'hidden';
      });

      closeBtn.addEventListener('click', closeModal);

      modal.addEventListener('click', function (e) {
        if (e.target === modal) {
          closeModal();
        }
      });
    })();
  </script>
<% } %>