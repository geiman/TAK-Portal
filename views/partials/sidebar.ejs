<%
  const _isGlobalAdmin = typeof isGlobalAdmin !== "undefined" ? !!isGlobalAdmin : false;
  const _isAgencyAdmin = typeof isAgencyAdmin !== "undefined" ? !!isAgencyAdmin : false;

  const isAdmin = _isGlobalAdmin || _isAgencyAdmin;

  // Current user's display name from Authentik (via res.locals.authUser)
  const _displayName =
    typeof authUser !== "undefined" &&
    authUser &&
    authUser.displayName
      ? authUser.displayName
      : "";

  // Only Global Admins can see these
  const canSeeSettings = _isGlobalAdmin;
%>

<aside class="sidebar" id="sidebar">
  <div class="brand <%= brandLogoUrl ? 'has-logo' : 'no-logo' %>">
    <% if (brandLogoUrl) { %>
      <img src="<%= brandLogoUrl %>" alt="Portal logo" class="brand-logo" />
    <% } %>

    <span class="brand-title">TAK Portal</span>
  </div>

  <nav class="sidebar-nav">
    <div class="nav-top">
      <% if (!isAdmin) { %>
        <a href="/setup-my-device">Setup My Device</a>
      <% } else { %>
        <a href="/">Dashboard</a>
        <a href="/users/manage">Users</a>
        <a href="/groups">Groups</a>
        <a href="/templates">Templates</a>
        <a href="/audit-log">Audit Log</a>

        <% if (canSeeSettings) { %>
          <a href="/agencies">Agencies</a>
          <a href="/mutual-aid">Mutual Aid</a>
          <!-- Pending User Requests moved to banner -->
        <% } %>

        <!--<a href="/qr-generator">QR Code Generator</a>-->
        <a href="/setup-my-device">Setup My Device</a>
      <% } %>
    </div>

    <div class="nav-bottom">
      <a href="/logout" class="logout-link">Log Out</a>

      <% if (canSeeSettings) { %>
        <a href="/settings">Server Settings</a>
      <% } %>

      <small class="version-text">
        <%= _displayName %>
        <% if (_isGlobalAdmin) { %>
          - Global Admin
        <% } else if (_isAgencyAdmin) { %>
          - Agency Admin
        <% } %>
        <br>
        <a
          href="https://github.com/AdventureSeeker423/TAK-Portal/blob/main/CHANGELOG.md"
          target="_blank"
          rel="noopener noreferrer"
        >
          TAK Portal Version <%= APP_VERSION %>
        </a>
      </small>

      <% /* Only admins see the update pill */ %>
      <% if (isAdmin && typeof APP_UPDATE_AVAILABLE !== "undefined" && APP_UPDATE_AVAILABLE) { %>
        <div class="update-available-form">
          <button type="button" class="update-available-pill" id="update-pill">
            Update Available
            <% if (typeof APP_LATEST_VERSION !== "undefined" && APP_LATEST_VERSION) { %>
              &nbsp;(v<%= APP_LATEST_VERSION %>)
            <% } %>
          </button>
        </div>
      <% } %>
    </div>
  </nav>

  <% /* Only admins get the update modal + script */ %>
  <% if (isAdmin && typeof APP_UPDATE_AVAILABLE !== "undefined" && APP_UPDATE_AVAILABLE) { %>
    <!-- Update Modal (uses the same modal system as the rest of the app) -->
    <div class="modalOverlay updateOverlay" id="updateOverlay" style="display:none;">
      <div class="modal updateModal" role="dialog" aria-modal="true" aria-labelledby="updateTitle">
        <div class="modalHeader">
          <div class="modalHeaderLeft">
            <h2 id="updateTitle" style="margin:0;">Update Available</h2>
            <span class="msg modalStatus" id="update-status">Idle</span>
          </div>
          <button class="btn update-modal-close" type="button" id="updateCloseBtn">Close</button>
        </div>

        <div class="modalBody">
          <p class="update-meta" style="margin-top:0;">
            Current: <strong>v<%= APP_VERSION %></strong>
            <% if (typeof APP_LATEST_VERSION !== "undefined" && APP_LATEST_VERSION) { %>
              &nbsp;•&nbsp;Latest: <strong>v<%= APP_LATEST_VERSION %></strong>
            <% } %>
          </p>

          <% if (_isGlobalAdmin) { %>
            <p>
              Using the Update Now button will pull the latest code,
              install dependencies, then restart.
            </p>

            <div class="row" style="gap:10px; align-items:center; margin: 10px 0 12px;">
              <button type="button" class="btn" id="update-start-btn">Update Now</button>
              <span class="update-inline-help" id="update-inline-help"></span>
            </div>

            <div class="update-log-wrap">
              <div class="update-log" id="update-log"></div>
            </div>
          <% } else { %>
            <p>Please contact your Global Administrator to update TAK Portal.</p>
          <% } %>

          <p style="margin-bottom:0;">
            <a
              href="https://github.com/AdventureSeeker423/TAK-Portal/blob/main/CHANGELOG.md"
              target="_blank"
              rel="noopener noreferrer"
              class="btn btnPrimary"
              style="display:inline-block; text-decoration:none;"
            >
              To See What Changed Click Here To View The Changelog
            </a>
          </p>
        </div>
      </div>

      <!-- Click backdrop to close -->
      <div class="updateOverlayBackdrop update-modal-close" aria-hidden="true"></div>
    </div>

    <script>
      (function () {
        var pill = document.getElementById('update-pill');
        var overlay = document.getElementById('updateOverlay');
        var startBtn = document.getElementById('update-start-btn');
        var statusEl = document.getElementById('update-status');
        var logEl = document.getElementById('update-log');
        var helpEl = document.getElementById('update-inline-help');

        var es = null;
        var isRunning = false;
        var waitingForRestart = false;
        var lastFinishedAt = null;

        if (!pill || !overlay) return;

        var closers = overlay.querySelectorAll('.update-modal-close');

        function setStatus(text) {
          if (!statusEl) return;
          statusEl.textContent = text;
        }

        function setHelp(text) {
          if (!helpEl) return;
          helpEl.textContent = text || '';
        }

        function appendLog(line) {
          if (!logEl) return;
          var div = document.createElement('div');
          div.className = 'update-log-line';
          div.textContent = line;
          logEl.appendChild(div);
          logEl.scrollTop = logEl.scrollHeight;
        }

        function connectStream() {
          if (es || !logEl) return;
          es = new EventSource('/api/update/stream');

          es.addEventListener('status', function (ev) {
            try {
              var s = JSON.parse(ev.data || '{}');
              isRunning = !!s.running;
              if (startBtn) startBtn.disabled = isRunning;
              if (isRunning) {
                setStatus('Updating…');
                setHelp('');
              } else if (s.exitCode === 0 && s.finishedAt) {
                setStatus('Update complete.');
                setHelp('Server restarted. Reloading page in 15 seconds…');

                // Start reload flow once per finishedAt
                if (!waitingForRestart || lastFinishedAt !== s.finishedAt) {
                  waitingForRestart = true;
                  lastFinishedAt = s.finishedAt;
                  waitForServerThenReload();
                }
              } else if (s.exitCode && s.exitCode !== 0) {
                setStatus('Update failed');
                setHelp('');
              } else {
                setStatus('Idle');
                setHelp('');
              }
            } catch (e) {}
          });

          es.addEventListener('log', function (ev) {
            try {
              var entry = JSON.parse(ev.data || '{}');
              var line = entry && entry.line ? entry.line : '';
              if (line) appendLog(line);
            } catch (e) {}
          });

          es.onerror = function () {
            // Connection may drop during restart; that's expected.
            // Keep UI friendly.
            if (waitingForRestart) {
              setStatus('Restarting…');
              setHelp('Waiting for server to come back online…');
            } else if (isRunning) {
              setStatus('Updating… (connection lost; server may be restarting)');
            }
          };
        }

        function waitForServerThenReload() {
          // Poll for the server to return after restart, then reload the page.
          // We avoid relying solely on SSE because the stream will drop during restart.
          var attempts = 0;
          var maxAttempts = 300; // ~10 minutes at 2s

          function tick() {
            attempts++;
            fetch('/api/update/status', { cache: 'no-store' })
              .then(function (r) {
                if (!r.ok) throw new Error('status not ok');
                return r.json();
              })
              .then(function (st) {
                var current = st && st.currentVersion;
                var latest = st && st.latestVersion;
                var running = !!(st && st.running);
                var updateAvailable = !!(st && st.updateAvailable);

                // If the server is responding again and the updater isn't running,
                // we can safely reload. Prefer to reload when current==latest, but
                // don't block forever if versions aren't reported.
              if (!running && (!updateAvailable || (current && latest && current === latest))) {
                setTimeout(function () {
                  window.location.reload();
                }, 15000);
                return;
              }
              if (!running) {
                setTimeout(function () {
                  window.location.reload();
                }, 15000);
                return;
              }
                setTimeout(tick, 2000);
              })
              .catch(function () {
                if (attempts < maxAttempts) return setTimeout(tick, 2000);
                setHelp('Server is taking longer than expected. Please refresh the page.');
              });
          }

          tick();
        }

        function openModal() {
          overlay.style.display = 'flex';
          document.body.classList.add('noScroll');
          if (logEl) logEl.innerHTML = '';
          setStatus('Idle');
          setHelp('');
          waitingForRestart = false;
          connectStream();
        }

        function closeModal() {
          overlay.style.display = 'none';
          document.body.classList.remove('noScroll');
          if (es) {
            es.close();
            es = null;
          }
          waitingForRestart = false;
          setHelp('');
        }

        pill.addEventListener('click', openModal);

        closers.forEach(function (el) {
          el.addEventListener('click', function () {
            closeModal();
          });
        });

        if (startBtn) {
          startBtn.addEventListener('click', function () {
            if (startBtn.disabled) return;
            startBtn.disabled = true;
            setStatus('Starting…');
            setHelp('');
            appendLog('Starting update…');

            fetch('/api/update/start', {
              method: 'POST',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({})
            })
              .then(function (r) { return r.json().catch(function () { return {}; }).then(function (j) { return { ok: r.ok, json: j }; }); })
              .then(function (payload) {
                if (!payload.ok) {
                  var msg = (payload.json && (payload.json.error || payload.json.code)) ? (payload.json.error || payload.json.code) : 'Update failed to start';
                  appendLog('ERROR: ' + msg);
                  setStatus('Update failed');
                  setHelp('');
                  startBtn.disabled = false;
                  return;
                }
                setStatus('Updating…');
                setHelp('');
              })
              .catch(function (err) {
                appendLog('ERROR: ' + (err && err.message ? err.message : String(err)));
                setStatus('Update failed');
                setHelp('');
                startBtn.disabled = false;
              });
          });
        }
      })();
    </script>
  <% } %>
</aside>
