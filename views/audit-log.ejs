<div class="page-header">
  <h1>Audit Log</h1>
</div>

<div class="card mb-3">
  <div class="card-body">
    <form method="GET" action="/audit-log" class="row g-2 align-items-end">

      <div class="col-md-3">
        <label class="form-label">Search</label>
        <input type="text" name="search" value="<%= filters.search || '' %>" class="form-control" placeholder="User, action, target..." />
      </div>

      <div class="col-md-2">
        <label class="form-label">Actor</label>
        <input type="text" name="actor" value="<%= filters.actor || '' %>" class="form-control" />
      </div>

      <div class="col-md-2">
        <label class="form-label">Agency</label>
        <input type="text" name="agency" value="<%= filters.agency || '' %>" class="form-control" />
      </div>

      <div class="col-md-2">
        <label class="form-label">Action</label>
        <input type="text" name="action" value="<%= filters.action || '' %>" class="form-control" />
      </div>

      <div class="col-md-2">
        <label class="form-label">Target Type</label>
        <input type="text" name="targetType" value="<%= filters.targetType || '' %>" class="form-control" />
      </div>

      <div class="col-md-2">
        <label class="form-label">From</label>
        <input type="date" name="from" value="<%= filters.from || '' %>" class="form-control" />
      </div>

      <div class="col-md-2">
        <label class="form-label">To</label>
        <input type="date" name="to" value="<%= filters.to || '' %>" class="form-control" />
      </div>

      <div class="col-md-1">
        <label class="form-label">Size</label>
        <input type="number" name="limit" value="<%= filters.limit || 50 %>" class="form-control" min="10" max="500" />
      </div>

      <div class="col-md-2">
        <button type="submit" class="btn btn-primary w-100">
          Apply Filters
        </button>
      </div>

    </form>
  </div>
</div>

<div class="card">
  <div class="card-body p-0">

    <div class="table-responsive">
      <table class="table table-striped table-hover mb-0">
        <thead>
          <tr>
            <th style="width: 180px;">Time</th>
            <th>Actor</th>
            <th>Agency</th>
            <th>Action</th>
            <th>Target</th>
            <th>Details</th>
          </tr>
        </thead>
        <tbody>
          <% if (!logs.length) { %>
            <tr>
              <td colspan="6" class="text-center p-4">
                No audit entries found.
              </td>
            </tr>
          <% } %>

          <% logs.forEach(log => { %>
            <tr>
              <td>
                <%= new Date(log.timestamp).toLocaleString() %>
              </td>

              <td>
                <strong><%= log.displayName || log.user %></strong>
                <div class="text-muted small"><%= log.user %></div>
              </td>

              <td>
                <%= log.agency || '-' %>
              </td>

              <td>
                <span class="badge bg-secondary">
                  <%= log.action %>
                </span>
              </td>

              <td>
                <strong><%= log.targetType %></strong><br/>
                <span class="text-muted small"><%= log.targetId %></span>
              </td>

              <td>
                <% if (log.details) { %>
                  <pre class="small mb-0"><%= JSON.stringify(log.details, null, 2) %></pre>
                <% } %>
              </td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>

  </div>
</div>