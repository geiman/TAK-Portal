<%
  const safeResult = typeof result !== "undefined" ? result : { items: [], page: 1, pageCount: 1 };
  const safeFilters = typeof filters !== "undefined" ? filters : {};
  const items = Array.isArray(safeResult.items) ? safeResult.items : [];
%>

<div class="page-header">
  <h1>Audit Log</h1>
</div>

<div class="card mb-3">
  <div class="card-body">
    <form method="GET" action="/audit-log" class="row g-2 align-items-end">

      <div class="col-md-3">
        <label class="form-label">Search</label>
        <input type="text" name="q"
               value="<%= safeFilters.q || '' %>"
               class="form-control"
               placeholder="User, action, target..." />
      </div>

      <div class="col-md-2">
        <label class="form-label">Actor</label>
        <input type="text" name="actor"
               value="<%= safeFilters.actor || '' %>"
               class="form-control" />
      </div>

      <div class="col-md-2">
        <label class="form-label">Action</label>
        <input type="text" name="action"
               value="<%= safeFilters.action || '' %>"
               class="form-control" />
      </div>

      <div class="col-md-2">
        <label class="form-label">Target Type</label>
        <input type="text" name="targetType"
               value="<%= safeFilters.targetType || '' %>"
               class="form-control" />
      </div>

      <div class="col-md-2">
        <label class="form-label">Agency</label>
        <input type="text" name="agencySuffix"
               value="<%= safeFilters.agencySuffix || '' %>"
               class="form-control" />
      </div>

      <div class="col-md-1">
        <label class="form-label">Size</label>
        <input type="number" name="pageSize"
               value="<%= safeFilters.pageSize || 50 %>"
               class="form-control"
               min="10" max="500" />
      </div>

      <div class="col-md-2">
        <button type="submit" class="btn btn-primary w-100">
          Apply
        </button>
      </div>

    </form>
  </div>
</div>

<div class="card">
  <div class="card-body p-0">
    <div class="table-responsive">
      <table class="table table-striped table-hover mb-0">
        <thead>
          <tr>
            <th style="width:180px;">Time</th>
            <th>Actor</th>
            <th>Agency</th>
            <th>Action</th>
            <th>Target</th>
            <th>Details</th>
          </tr>
        </thead>
        <tbody>

          <% if (!items.length) { %>
            <tr>
              <td colspan="6" class="text-center p-4">
                No audit entries found.
              </td>
            </tr>
          <% } %>

          <% items.forEach(log => { %>
            <tr>
              <td>
                <%= log.timestamp ? new Date(log.timestamp).toLocaleString() : '' %>
              </td>

              <td>
                <strong><%= log.actorDisplayName || log.actorUsername || '-' %></strong>
                <div class="text-muted small"><%= log.actorUsername || '' %></div>
              </td>

              <td>
                <%= log.agencySuffix || '-' %>
              </td>

              <td>
                <span class="badge bg-secondary">
                  <%= log.action || '-' %>
                </span>
              </td>

              <td>
                <strong><%= log.targetType || '-' %></strong><br/>
                <span class="text-muted small"><%= log.targetId || '' %></span>
              </td>

              <td>
                <% if (log.details) { %>
                  <pre class="small mb-0"><%= JSON.stringify(log.details, null, 2) %></pre>
                <% } %>
              </td>
            </tr>
          <% }) %>

        </tbody>
      </table>
    </div>
  </div>
</div>

<div class="d-flex justify-content-between mt-3">
  <% if (safeResult.page > 1) { %>
    <a class="btn btn-outline-secondary btn-sm" href="<%= pageLinks.prev %>">Previous</a>
  <% } else { %>
    <span></span>
  <% } %>

  <span class="text-muted small align-self-center">
    Page <%= safeResult.page %> of <%= safeResult.pageCount %>
  </span>

  <% if (safeResult.page < safeResult.pageCount) { %>
    <a class="btn btn-outline-secondary btn-sm" href="<%= pageLinks.next %>">Next</a>
  <% } %>
</div>