<%- include("partials/header") %>
<%- include("partials/sidebar") %>

<main class="main">

  <h1>Audit Log</h1>

  <div class="card">

    <div class="row" style="justify-content: space-between; align-items:center; gap:12px; flex-wrap:wrap;">
      <h2 style="margin:0;">Audit Events</h2>

      <form method="GET" action="/audit-log" class="row" style="gap:8px; flex-wrap:wrap; align-items:center;">
        <input type="text" name="q" value="<%= filters?.q || '' %>" class="input" placeholder="Search..." />
        <input type="text" name="actor" value="<%= filters?.actor || '' %>" class="input" placeholder="Actor" />
        <input type="text" name="action" value="<%= filters?.action || '' %>" class="input" placeholder="Action" />
        <input type="text" name="agencySuffix" value="<%= filters?.agencySuffix || '' %>" class="input" placeholder="Agency" />
        <button class="btn" type="submit">Filter</button>
      </form>
    </div>

    <table class="table">
      <thead>
        <tr>
          <th>Time</th>
          <th>Actor</th>
          <th>Action</th>
          <th>Target</th>
          <th>Agency</th>
          <th>Details</th>
        </tr>
      </thead>
      <tbody id="auditTbody">

        <% if (!result || !result.items || !result.items.length) { %>
          <tr>
            <td colspan="6" class="muted">No audit events found.</td>
          </tr>
        <% } %>

        <% (result?.items || []).forEach((log) => { %>
          <tr data-details='<%- JSON.stringify(log.details || {}) %>'
              data-action="<%= log.action || '' %>"
              data-target-type="<%= log.targetType || '' %>"
              data-target-id="<%= log.targetId || '' %>">

            <!-- Time -->
            <td>
              <span class="ts" data-ts="<%= log.timestamp || '' %>"></span>
            </td>

            <!-- Actor -->
            <td>
              <strong><%= log.actor?.displayName || log.actor?.username || '—' %></strong><br>
              <span class="muted"><%= log.actor?.username || '' %></span>
            </td>

            <!-- Action -->
            <td>
              <span class="badge"><%= log.action || '—' %></span>
            </td>

          <!-- Target (names from details or userMap/groupMap, fallback to ID) -->
          <td>
            <%
              const type = String(log.targetType || '').toLowerCase();
              const details = log.details || {};
              const targetId = String(log.targetId || '').trim();
              const uMap = typeof userMap !== 'undefined' ? userMap : {};
              const gMap = typeof groupMap !== 'undefined' ? groupMap : {};

              let display = log.targetDisplay || '';

              if (type === 'user' || type === 'authentik_user') {
                const username = details.username || details.userUsername || '';
                const name =
                  details.name ||
                  details.displayName ||
                  [details.firstName, details.lastName].filter(Boolean).join(' ');

                if (username && name) {
                  display = `${username} - ${name}`;
                } else if (username) {
                  display = username;
                } else if (name) {
                  display = name;
                }
                if (!display && targetId && uMap[targetId]) {
                  const u = uMap[targetId];
                  if (u && (u.username || u.name)) {
                    display = u.username && u.name ? `${u.username} - ${u.name}` : (u.username || u.name);
                  }
                }
                if (!display && targetId) display = targetId;
              }

              if (type === 'group' || type === 'authentik_group') {
                const groupName = details.name || details.groupName;
                if (groupName) display = groupName;
                else if (targetId && gMap[targetId]) display = gMap[targetId] || targetId;
                else if (targetId) display = targetId;
              }

              if (!display && targetId) display = targetId;
              if (!display) display = '—';
            %>
            <strong><%= log.targetType || '—' %></strong><br>
            <span class="muted"><%= display %></span>
          </td>

            <!-- Agency -->
            <td>
              <%
                const sfx = String(log.agencySuffix || '').toLowerCase();
                const agencyObj = agencyMap?.[sfx];
                const agencyLabel = agencyObj ? (agencyObj.name || agencyObj.groupPrefix || sfx) : (sfx || '—');
              %>
              <%= agencyLabel %>
            </td>

            <!-- Details -->
            <td>
              <% if (log.details && Object.keys(log.details).length) { %>
                <button class="btn viewDetailsBtn" type="button">View Details</button>
              <% } else { %>
                <span class="muted">—</span>
              <% } %>
            </td>

          </tr>
        <% }) %>

      </tbody>
    </table>

    <!-- Pagination -->
    <% if (result && result.pageCount > 1) { %>
      <div class="pagination">
        <a class="btn" href="<%= pageLinks.prev %>" <%= result.page <= 1 ? 'disabled' : '' %>>Prev</a>
        <span id="pageInfoTop">Page <%= result.page %> of <%= result.pageCount %></span>
        <a class="btn" href="<%= pageLinks.next %>" <%= result.page >= result.pageCount ? 'disabled' : '' %>>Next</a>
      </div>
    <% } %>

  </div>

  <!-- Inline Modal -->
  <template id="detailsTemplate">
    <div class="modalOverlay">
      <div class="modalCard card">
        <div class="row" style="justify-content: space-between; align-items:center;">
          <h2 style="margin:0;">Audit Details</h2>
          <button class="btn closeModalBtn">Close</button>
        </div>
        <div class="auditDetailsSummary"></div>
        <div class="auditDetailsFormatted"></div>
        <details class="auditDetailsRawWrap">
          <summary class="muted">Raw data</summary>
          <pre class="detailsPre"></pre>
        </details>
      </div>
    </div>
  </template>

</main>

<script>
  window.AUDIT_USER_MAP = <%- JSON.stringify(typeof userMap !== 'undefined' ? userMap : {}) %>;
  window.AUDIT_GROUP_MAP = <%- JSON.stringify(typeof groupMap !== 'undefined' ? groupMap : {}) %>;
</script>

<style>
.modalOverlay{
  position: fixed;
  inset: 0;
  background: rgba(0,0,0,.6);
  display:flex;
  align-items:center;
  justify-content:center;
  z-index:1000;
}

.modalCard{
  width: min(900px, 95%);
  max-height: 80vh;
  overflow:auto;
}

.detailsPre{
  background: rgba(255,255,255,.05);
  padding:12px;
  border-radius:8px;
  font-size:13px;
  white-space:pre-wrap;
  margin-top:8px;
}
.auditDetailsSummary{
  background: rgba(255,255,255,.06);
  padding:12px;
  border-radius:8px;
  margin-bottom:12px;
  font-size:14px;
}
.auditDetailsSummary .detailRow{ display:flex; gap:12px; margin-bottom:6px; }
.auditDetailsSummary .detailRow:last-child{ margin-bottom:0; }
.auditDetailsSummary .detailLabel{ color: var(--muted-color, #888); min-width:100px; }
.auditDetailsFormatted{ margin-bottom:12px; }
.auditDetailsFormatted .detailBlock{ margin-bottom:12px; }
.auditDetailsFormatted .detailBlock:last-child{ margin-bottom:0; }
.auditDetailsFormatted .detailItem{ display:flex; gap:12px; padding:6px 0; border-bottom:1px solid rgba(255,255,255,.06); font-size:14px; }
.auditDetailsFormatted .detailItem:last-child{ border-bottom:none; }
.auditDetailsFormatted .detailKey{ color: var(--muted-color, #888); min-width:140px; flex-shrink:0; }
.auditDetailsFormatted .detailVal{ word-break:break-word; }
.auditDetailsFormatted .detailVal.empty{ font-style:italic; color: var(--muted-color, #888); }
.auditDetailsFormatted ul.detailList{ margin:0; padding-left:20px; }
.auditDetailsFormatted .detailPre{ margin:0; padding:8px; background: rgba(0,0,0,.2); border-radius:4px; font-size:12px; white-space:pre-wrap; word-break:break-word; max-height:200px; overflow:auto; }
.auditDetailsRawWrap{ margin-top:12px; }
.auditDetailsRawWrap summary{ cursor:pointer; padding:4px 0; }
</style>

<script>
(function(){
  const tbody = document.getElementById('auditTbody');
  const tpl = document.getElementById('detailsTemplate');

  const USER_MAP = window.AUDIT_USER_MAP || {};
  const GROUP_MAP = window.AUDIT_GROUP_MAP || {};

  const FRIENDLY_LABELS = {
    username: 'Username',
    userUsername: 'Username',
    name: 'Name',
    displayName: 'Display name',
    email: 'Email',
    is_active: 'Active status',
    groups: 'Groups',
    groupIds: 'Group IDs',
    groupId: 'Group',
    GroupId: 'Group',
    userId: 'User',
    UserId: 'User',
    jobId: 'Job ID',
    created: 'Created count',
    skipped: 'Skipped count',
    durationMs: 'Duration (ms)',
    durationSeconds: 'Duration (s)',
    created_method: 'Creation method',
    tokenIdentifier: 'Token identifier',
    expiresAt: 'Expires at',
    error: 'Error',
    phase: 'Phase',
    total: 'Total',
    processed: 'Processed',
  };

  function isUuid(s) {
    if (typeof s !== 'string') return false;
    return /^[0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{12}$/i.test(s.trim());
  }

  function resolveUserName(id) {
    if (id == null || id === '') return null;
    var key = String(id);
    var u = USER_MAP[key];
    if (!u) return null;
    if (u.username && u.name) return u.username + ' - ' + u.name;
    return u.username || u.name || null;
  }

  function resolveGroupName(uuid) {
    if (uuid == null || uuid === '') return null;
    return GROUP_MAP[String(uuid)] || null;
  }

  function formatValue(val, key) {
    if (val == null && key !== 'username' && key !== 'name') return { text: '—', empty: true };
    if (typeof val === 'boolean') return { text: val ? 'Yes' : 'No', empty: false };
    if (typeof val === 'number' && (key === 'userId' || key === 'UserId')) {
      var name = resolveUserName(val);
      return { text: name || ('User ID: ' + val), empty: !name };
    }
    if (typeof val === 'number') return { text: String(val), empty: false };
    if (Array.isArray(val)) {
      if (val.length === 0) return { text: '—', empty: true };
      var list = val.map(function (x) {
        var id = String(x);
        if (isUuid(id)) {
          var gName = resolveGroupName(id);
          return gName ? gName + ' (' + id + ')' : id;
        }
        return id;
      });
      return { text: list.join(', '), list: list, empty: false };
    }
    if (typeof val === 'string' && (key === 'groupId' || key === 'GroupId') && isUuid(val)) {
      var gn = resolveGroupName(val);
      return { text: gn || val, empty: !gn };
    }
    if (typeof val === 'string' && (key === 'userId' || key === 'UserId') && !isUuid(val)) {
      var un = resolveUserName(val);
      return { text: un || val, empty: !un };
    }
    if (typeof val === 'object') {
      try { return { text: JSON.stringify(val, null, 2), empty: false, pre: true }; } catch (_) { return { text: '—', empty: true }; }
    }
    var s = String(val).trim();
    return { text: s || '—', empty: !s };
  }

  function labelForKey(key) {
    return FRIENDLY_LABELS[key] || key.replace(/_/g, ' ').replace(/\b\w/g, function(c) { return c.toUpperCase(); });
  }

  function buildFormattedHtml(details) {
    const keys = Object.keys(details).filter(function(k) { return details[k] !== undefined; }).sort();
    if (keys.length === 0) return '<p class="muted">No additional details recorded.</p>';
    var html = '';
    keys.forEach(function(key) {
      var v = formatValue(details[key], key);
      html += '<div class="detailItem">';
      html += '<span class="detailKey">' + escapeHtml(labelForKey(key)) + '</span>';
      html += '<span class="detailVal' + (v.empty ? ' empty' : '') + '">';
      if (v.list) {
        html += '<ul class="detailList">';
        v.list.forEach(function(item) { html += '<li>' + escapeHtml(item) + '</li>'; });
        html += '</ul>';
      } else if (v.pre) {
        html += '<pre class="detailPre">' + escapeHtml(v.text) + '</pre>';
      } else {
        html += escapeHtml(v.text);
      }
      html += '</span></div>';
    });
    return html;
  }

  function escapeHtml(s) {
    if (typeof s !== 'string') return '';
    var div = document.createElement('div');
    div.textContent = s;
    return div.innerHTML;
  }

  function closeModal(){
    const existing = document.querySelector('.modalOverlay');
    if (existing) existing.remove();
  }

  tbody.addEventListener('click', function(e){
    const btn = e.target.closest('.viewDetailsBtn');
    if (!btn) return;

    const tr = btn.closest('tr');
    const raw = tr.getAttribute('data-details');
    const action = tr.getAttribute('data-action') || '—';
    const targetType = tr.getAttribute('data-target-type') || '—';
    const targetId = tr.getAttribute('data-target-id') || '—';

    let details = {};
    try { details = JSON.parse(raw || '{}'); } catch {}

    var targetDisplay = targetId;
    if (targetType.toLowerCase() === 'user' && targetId && USER_MAP[targetId]) {
      var u = USER_MAP[targetId];
      targetDisplay = (u.username && u.name) ? (u.username + ' - ' + u.name) : (u.username || u.name || targetId);
    } else if (targetType.toLowerCase() === 'group' && targetId && GROUP_MAP[targetId]) {
      targetDisplay = GROUP_MAP[targetId];
    }

    const frag = tpl.content.cloneNode(true);
    const overlay = frag.querySelector('.modalOverlay');
    const summaryEl = frag.querySelector('.auditDetailsSummary');
    const formattedEl = frag.querySelector('.auditDetailsFormatted');
    const pre = frag.querySelector('.detailsPre');
    const closeBtn = frag.querySelector('.closeModalBtn');

    summaryEl.innerHTML =
      '<div class="detailRow"><span class="detailLabel">Action</span><span>' + escapeHtml(action) + '</span></div>' +
      '<div class="detailRow"><span class="detailLabel">Target type</span><span>' + escapeHtml(targetType) + '</span></div>' +
      '<div class="detailRow"><span class="detailLabel">Target</span><span>' + escapeHtml(targetDisplay) + '</span></div>';

    formattedEl.innerHTML = '<div class="detailBlock">' + buildFormattedHtml(details) + '</div>';
    pre.textContent = JSON.stringify(details, null, 2);

    closeBtn.addEventListener('click', closeModal);
    overlay.addEventListener('click', function(ev){
      if (ev.target === overlay) closeModal();
    });

    document.body.appendChild(overlay);
  });

})();
</script>
<script>
(function() {
  const tz = Intl.DateTimeFormat().resolvedOptions().timeZone;

  document.querySelectorAll(".ts").forEach(el => {
    const raw = el.getAttribute("data-ts");
    if (!raw) return;

    try {
      const d = new Date(raw);
      el.textContent = d.toLocaleString(undefined, { timeZone: tz });
    } catch (e) {
      el.textContent = raw;
    }
  });
})();
</script>