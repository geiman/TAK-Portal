<%- include("partials/header") %>
<%- include("partials/sidebar") %>

<main class="main">

  <h1>Audit Log</h1>

  <div class="card">

    <div class="row" style="justify-content: space-between; align-items:center; gap:12px; flex-wrap:wrap;">
      <h2 style="margin:0;">Audit Events</h2>

      <form method="GET" action="/audit-log" class="row" style="gap:8px; flex-wrap:wrap; align-items:center;">
        <input type="text" name="q" value="<%= filters?.q || '' %>" class="input" placeholder="Search..." />
        <input type="text" name="actor" value="<%= filters?.actor || '' %>" class="input" placeholder="Actor" />
        <input type="text" name="action" value="<%= filters?.action || '' %>" class="input" placeholder="Action" />
        <input type="text" name="agencySuffix" value="<%= filters?.agencySuffix || '' %>" class="input" placeholder="Agency" />
        <button class="btn" type="submit">Filter</button>
      </form>
    </div>

    <table class="table">
      <thead>
        <tr>
          <th>Time</th>
          <th>Actor</th>
          <th>Action</th>
          <th>Target</th>
          <th>Agency</th>
          <th>Details</th>
        </tr>
      </thead>
      <tbody id="auditTbody">

        <% if (!result || !result.items || !result.items.length) { %>
          <tr>
            <td colspan="6" class="muted">No audit events found.</td>
          </tr>
        <% } %>

        <% (result?.items || []).forEach((log) => { %>
          <tr data-details='<%- JSON.stringify(log.details || {}) %>'>

            <!-- Time -->           
            <td>
              <%
                let formatted = '';
                try {
                  const tz =
                    typeof serverTimeZone !== 'undefined' && serverTimeZone
                      ? serverTimeZone
                      : Intl.DateTimeFormat().resolvedOptions().timeZone;

                  if (log.timestamp) {
                    formatted = new Date(log.timestamp).toLocaleString(undefined, {
                      timeZone: tz
                    });
                  }
                } catch (err) {
                  if (log.timestamp) {
                    formatted = new Date(log.timestamp).toLocaleString();
                  }
                }
              %>
              <%= formatted %>
            </td>

            <!-- Actor -->
            <td>
              <strong><%= log.actor?.displayName || log.actor?.username || '-' %></strong><br>
              <span class="muted"><%= log.actor?.username || '' %></span>
            </td>

            <!-- Action -->
            <td>
              <span class="badge"><%= log.action || '-' %></span>
            </td>

          <!-- Target (Parsed from details) -->
          <td>
            <%
              const type = String(log.targetType || '').toLowerCase();
              const details = log.details || {};

              let display = log.targetDisplay || '-';

              if (type === 'user') {
                const username = details.username || details.userUsername || '';
                const name =
                  details.name ||
                  details.displayName ||
                  [details.firstName, details.lastName].filter(Boolean).join(' ');

                if (username && name) {
                  display = `${username} - ${name}`;
                } else if (username) {
                  display = username;
                } else if (name) {
                  display = name;
                }
              }

              if (type === 'group') {
                const groupName = details.name || details.groupName;
                if (groupName) {
                  display = groupName;
                }
              }
            %>

            <strong><%= log.targetType || '-' %></strong><br>
            <span class="muted"><%= display %></span>
          </td>

            <!-- Agency (Now PREFIX, not suffix) -->
            <td>
              <%
                const sfx = String(log.agencySuffix || '').toLowerCase();
                const agencyObj = agencyMap?.[sfx];
                const prefix = agencyObj?.groupPrefix || '-';
              %>
              <%= prefix %>
            </td>

            <!-- Details -->
            <td>
              <% if (log.details && Object.keys(log.details).length) { %>
                <button class="btn viewDetailsBtn" type="button">View Details</button>
              <% } else { %>
                <span class="muted">—</span>
              <% } %>
            </td>

          </tr>
        <% }) %>

      </tbody>
    </table>

    <!-- Pagination -->
    <% if (result && result.pageCount > 1) { %>
      <div class="pagination">
        <a class="btn" href="<%= pageLinks.prev %>" <%= result.page <= 1 ? 'disabled' : '' %>>Prev</a>
        <span id="pageInfoTop">Page <%= result.page %> of <%= result.pageCount %></span>
        <a class="btn" href="<%= pageLinks.next %>" <%= result.page >= result.pageCount ? 'disabled' : '' %>>Next</a>
      </div>
    <% } %>

  </div>

  <!-- Inline Modal -->
  <template id="detailsTemplate">
    <div class="modalOverlay">
      <div class="modalCard card">
        <div class="row" style="justify-content: space-between; align-items:center;">
          <h2 style="margin:0;">Audit Details</h2>
          <button class="btn closeModalBtn">Close</button>
        </div>
        <pre class="detailsPre"></pre>
      </div>
    </div>
  </template>

</main>

<style>
.modalOverlay{
  position: fixed;
  inset: 0;
  background: rgba(0,0,0,.6);
  display:flex;
  align-items:center;
  justify-content:center;
  z-index:1000;
}

.modalCard{
  width: min(900px, 95%);
  max-height: 80vh;
  overflow:auto;
}

.detailsPre{
  background: rgba(255,255,255,.05);
  padding:12px;
  border-radius:8px;
  font-size:13px;
  white-space:pre-wrap;
}
</style>

<script>
(function(){
  const tbody = document.getElementById('auditTbody');
  const tpl = document.getElementById('detailsTemplate');

  function closeModal(){
    const existing = document.querySelector('.modalOverlay');
    if (existing) existing.remove();
  }

  tbody.addEventListener('click', function(e){
    const btn = e.target.closest('.viewDetailsBtn');
    if (!btn) return;

    const tr = btn.closest('tr');
    const raw = tr.getAttribute('data-details');
    let details = {};
    try { details = JSON.parse(raw || '{}'); } catch {}

    const frag = tpl.content.cloneNode(true);
    const overlay = frag.querySelector('.modalOverlay');
    const pre = frag.querySelector('.detailsPre');
    const closeBtn = frag.querySelector('.closeModalBtn');

    pre.textContent = JSON.stringify(details, null, 2);

    closeBtn.addEventListener('click', closeModal);
    overlay.addEventListener('click', function(ev){
      if (ev.target === overlay) closeModal();
    });

    document.body.appendChild(overlay);
  });

})();
</script>