<script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf/2.5.1/jspdf.umd.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/qrcode-generator/1.4.4/qrcode.min.js"></script>
<script>
// ----- Shared helpers -----
function esc(s){
  return String(s ?? "")
    .replaceAll("&","&amp;")
    .replaceAll("<","&lt;")
    .replaceAll(">","&gt;")
    .replaceAll('"',"&quot;")
    .replaceAll("'","&#39;");
}

function setMsg(el, text, ok=true){
  el.textContent = text || "";
  el.className = "msg " + (ok ? "ok" : "bad");
}

async function copyToClipboard(text) {
  try {
    await navigator.clipboard.writeText(text);
  } catch (e) {
    const ta = document.createElement("textarea");
    ta.value = text;
    ta.style.position = "fixed";
    ta.style.opacity = "0";
    document.body.appendChild(ta);
    ta.select();
    document.execCommand("copy");
    document.body.removeChild(ta);
  }
}

// ----- Mutual aid members modal -----
const membersOverlay = document.getElementById("membersOverlay");
const membersCloseBtn = document.getElementById("membersCloseBtn");
const membersSummary = document.getElementById("membersSummary");
const membersFilter = document.getElementById("membersFilter");
const membersList = document.getElementById("membersList");
const membersHint = document.getElementById("membersHint");

let activeMembers = [];
let activeMembersGroupId = "";
let activeMembersGroupName = "";

function showMembersModal(show) {
  if (!membersOverlay) return;
  membersOverlay.style.display = show ? "flex" : "none";
  document.body.classList.toggle("noScroll", !!show);
}

function renderMembersList() {
  const needle = String(membersFilter?.value || "").trim().toLowerCase();
  const items = (activeMembers || []).filter((u) => {
    if (!needle) return true;
    const uname = String(u.username || "").toLowerCase();
    const name = String(u.name || "").toLowerCase();
    const em = String(u.email || "").toLowerCase();
    return uname.includes(needle) || name.includes(needle) || em.includes(needle);
  });

  if (!items.length) {
    membersList.innerHTML = '<div class="muted">No members match your filter.</div>';
    return;
  }

  const rows = items
    .map(
      (u) => `
    <tr>
      <td>${esc(u.username || "")}</td>
      <td>${esc(u.name || "")}</td>
      <td>${esc(u.email || "")}</td>
    </tr>
  `
    )
    .join("");

  membersList.innerHTML = `
    <table class="table">
      <thead>
        <tr>
          <th>Username</th>
          <th>Name</th>
          <th>Email</th>
        </tr>
      </thead>
      <tbody>
        ${rows}
      </tbody>
    </table>
  `;
}

async function openMutualAidMembers(groupId, groupName) {
  activeMembersGroupId = String(groupId || "");
  activeMembersGroupName = String(groupName || "");

  membersSummary.textContent = "Loading members...";
  membersSummary.className = "msg";
  membersList.innerHTML = "";
  membersHint.textContent = "";
  if (membersFilter) membersFilter.value = "";

  showMembersModal(true);

  try {
    const res = await fetch(`/api/groups/${encodeURIComponent(groupId)}/members`);
    const out = await res.json();

    if (!res.ok) {
      throw new Error(out.error || "Failed to load members");
    }

    activeMembers = Array.isArray(out.users) ? out.users : [];
    const memberCount =
      typeof out.memberCount === "number" ? out.memberCount : activeMembers.length;
    const label = activeMembersGroupName || out.group?.name || groupId;

    membersSummary.textContent = `${memberCount} member${
      memberCount === 1 ? "" : "s"
    } in group "${label}".`;
    membersSummary.className = "msg ok";
    membersHint.textContent = memberCount
      ? "Users currently assigned to this mutual aid group's Authentik group."
      : "No users are currently assigned to this mutual aid group.";

    renderMembersList();
  } catch (e) {
    membersSummary.textContent = "Failed to load members.";
    membersSummary.className = "msg bad";
    membersList.innerHTML = "";
    membersHint.textContent = "";
    activeMembers = [];
  }
}

if (membersCloseBtn && membersOverlay) {
  membersCloseBtn.onclick = () => showMembersModal(false);
  membersOverlay.addEventListener("click", (e) => {
    if (e.target === membersOverlay) showMembersModal(false);
  });
}
if (membersFilter) {
  membersFilter.oninput = renderMembersList;
}

// ----- Page state -----

const maType = document.getElementById("maType");
const maTitle = document.getElementById("maTitle");
const maCreateBtn = document.getElementById("maCreateBtn");
const maCreateMsg = document.getElementById("maCreateMsg");

const maExpireWrap = document.getElementById("maExpireWrap");
const maExpireEnabled = document.getElementById("maExpireEnabled");
const maExpireAt = document.getElementById("maExpireAt");

const maGroupMode = document.getElementById("maGroupMode");
const maExistingGroupWrap = document.getElementById("maExistingGroupWrap");
const maExistingGroup = document.getElementById("maExistingGroup");
const maCreateHelp = document.getElementById("maCreateHelp");

const maFilter = document.getElementById("maFilter");
const maTbody = document.getElementById("maTbody");
const maListMsg = document.getElementById("maListMsg");

let allItems = [];
let activeItem = null;

// ----- Create: expiration controls -----
function updateCreateExpireUi(){
  // Expiration is supported for both EVENT and INCIDENT.
  const enabled = String(maExpireEnabled.value || "").toLowerCase() === "yes";
  maExpireAt.style.display = enabled ? "block" : "none";
  if (!enabled) maExpireAt.value = "";
}
maType.onchange = updateCreateExpireUi;
maExpireEnabled.onchange = updateCreateExpireUi;
updateCreateExpireUi();

// ----- Create: group mode controls -----
function renderExistingGroupSelect() {
  if (!maExistingGroup) return;
  const current = String(maExistingGroup.value || "");
  const items = (groupsCache || [])
    .slice()
    .sort((a,b)=>String(a.name||"").localeCompare(String(b.name||"")));

  const opts = [`<option value="">-- Select A Group --</option>`]
    .concat(items.map(g => {
      const id = String(g.pk);
      const name = String(g.name || "");
      return `<option value="${esc(id)}">${esc(name)}</option>`;
    }));

  maExistingGroup.innerHTML = opts.join("");
  if (current) maExistingGroup.value = current;
}

function updateCreateGroupModeUi(){
  const mode = String(maGroupMode?.value || "new").toLowerCase();
  const isExisting = mode === "existing";
  // Use flex so the "Existing Group" label sits above the dropdown.
  if (maExistingGroupWrap) maExistingGroupWrap.style.display = isExisting ? "flex" : "none";

  if (maCreateHelp) {
    maCreateHelp.innerHTML = isExisting
      ? `This will create a matching user with an auto-generated 18-character password and add it to the selected group.`
      : `This will create a group named <strong>MA - TITLE</strong> and a matching user with an auto-generated 18-character password.`;
  }

  if (isExisting) {
    // Ensure groups are loaded and dropdown is populated.
    if (!groupsCache || !groupsCache.length) {
      loadGroups().catch(()=>{});
    } else {
      renderExistingGroupSelect();
    }
  } else {
    if (maExistingGroup) maExistingGroup.value = "";
  }
}

if (maGroupMode) maGroupMode.onchange = updateCreateGroupModeUi;
updateCreateGroupModeUi();

// ----- QR modal -----
const qrOverlay = document.getElementById("qrOverlay");
const qrCloseBtn = document.getElementById("qrCloseBtn");
const qrTitle = document.getElementById("qrTitle");
const qrImg = document.getElementById("qrImg");
const qrCopyBtn = document.getElementById("qrCopyBtn");
const qrSaveBtn = document.getElementById("qrSaveBtn");
const qrPacketBtn = document.getElementById("qrPacketBtn");
const qrDetails = document.getElementById("qrDetails");
const qrMsg = document.getElementById("qrMsg");

let qrEnrollUrl = "";
let qrActiveId = "";
let qrActiveItem = null;

function openQrModal(item){
  qrOverlay.style.display = "flex";
  document.body.classList.add("noScroll");
  qrTitle.textContent = `QR Code — ${item.type} — ${item.title}`;
  qrImg.src = "";
  qrCopyBtn.disabled = true;
  qrSaveBtn.disabled = true;
  if (qrPacketBtn) qrPacketBtn.disabled = true;
  qrEnrollUrl = "";
  qrActiveId = item.id;
  qrActiveItem = item;
  qrDetails.innerHTML = `
    <span class="chip">Group: ${esc(item.groupName || "")}</span>
    <span class="chip">Username: ${esc(item.username || "")}</span>
  `;
  setMsg(qrMsg, "Loading...", true);

  fetch(`/api/mutual-aid/${encodeURIComponent(item.id)}/qr`)
    .then(r => r.json().then(d => ({ ok: r.ok, d })))
    .then(({ok, d}) => {
      if(!ok) throw new Error(d.error || "Failed to generate QR");
      qrEnrollUrl = d.enrollUrl;
      qrImg.src = d.qrCode;
      qrCopyBtn.disabled = false;
      qrSaveBtn.disabled = false;
      if (qrPacketBtn) qrPacketBtn.disabled = false;
      setMsg(qrMsg, "QR ready.", true);
    })
    .catch(e => setMsg(qrMsg, e.message || String(e), false));
}

qrCloseBtn.onclick = () => { qrOverlay.style.display = "none"; document.body.classList.remove("noScroll"); };
qrCopyBtn.onclick = async () => {
  if (!qrEnrollUrl) return;
  await copyToClipboard(qrEnrollUrl);
  setMsg(qrMsg, "Copied!", true);
};
qrSaveBtn.onclick = () => {
  if (!qrActiveId) return;
  const url = `/api/mutual-aid/${encodeURIComponent(qrActiveId)}/qr/download`;
  const a = document.createElement("a");
  a.href = url;
  a.download = "";
  document.body.appendChild(a);
  a.click();
  document.body.removeChild(a);
  setMsg(qrMsg, "Downloading high-res QR...", true);
};

// ----- Download Packet (PDF) -----
// Pull guide definitions from settings.json (server-rendered into the page).
//
// Expected settings keys (see settings.example.json):
//   DP_COLOR_BLUE, DP_COLOR_DARK_BLUE, ... DP_COLOR_YELLOW
//   DP_ROLE_TEAM_MEMBER, DP_ROLE_TEAM_LEAD, ... DP_ROLE_K9
const SETTINGS = <%- JSON.stringify(settings || {}) %>;

function getSetting(key) {
  const v = SETTINGS ? SETTINGS[key] : "";
  return String(v ?? "").trim();
}

// If a color/role definition is blank, don't include it.
const TEAM_COLORS = [
  { name: "Blue", key: "DP_COLOR_BLUE", hex: "#1e88e5" },
  { name: "Dark Blue", key: "DP_COLOR_DARK_BLUE", hex: "#0d47a1" },
  { name: "Brown", key: "DP_COLOR_BROWN", hex: "#6d4c41" },
  { name: "Cyan", key: "DP_COLOR_CYAN", hex: "#00acc1" },
  { name: "Green", key: "DP_COLOR_GREEN", hex: "#43a047" },
  { name: "Dark Green", key: "DP_COLOR_DARK_GREEN", hex: "#1b5e20" },
  { name: "Magenta", key: "DP_COLOR_MAGENTA", hex: "#d81b60" },
  { name: "Maroon", key: "DP_COLOR_MAROON", hex: "#800000" },
  { name: "Orange", key: "DP_COLOR_ORANGE", hex: "#fb8c00" },
  { name: "Purple", key: "DP_COLOR_PURPLE", hex: "#8e24aa" },
  { name: "Red", key: "DP_COLOR_RED", hex: "#e53935" },
  { name: "Teal", key: "DP_COLOR_TEAL", hex: "#00897b" },
  { name: "White", key: "DP_COLOR_WHITE", hex: "#ffffff" },
  { name: "Yellow", key: "DP_COLOR_YELLOW", hex: "#fdd835" },
]
  .map(c => ({ name: c.name, hex: c.hex, desc: getSetting(c.key) }))
  .filter(c => !!String(c.desc || "").trim());

const TEAM_ROLES = [
  { name: "Team Member", key: "DP_ROLE_TEAM_MEMBER" },
  { name: "Team Lead", key: "DP_ROLE_TEAM_LEAD" },
  { name: "HQ", key: "DP_ROLE_HQ" },
  { name: "Sniper", key: "DP_ROLE_SNIPER" },
  { name: "Medic", key: "DP_ROLE_MEDIC" },
  { name: "Forward Observer", key: "DP_ROLE_FORWARD_OBSERVER" },
  { name: "RTO", key: "DP_ROLE_RTO" },
  { name: "K9", key: "DP_ROLE_K9" },
]
  .map(r => ({ name: r.name, desc: getSetting(r.key) }))
  .filter(r => !!String(r.desc || "").trim());

function hexToRgb(hex) {
  const h = String(hex || "").replace(/^#/, "");
  if (h.length === 3) {
    const r = int(h[0] + h[0]);
    const g = int(h[1] + h[1]);
    const b = int(h[2] + h[2]);
    return [r, g, b];
  }
  if (h.length !== 6) return [0, 0, 0];
  const r = int(h.slice(0, 2));
  const g = int(h.slice(2, 4));
  const b = int(h.slice(4, 6));
  return [r, g, b];
  function int(s) {
    const n = parseInt(s, 16);
    return Number.isFinite(n) ? n : 0;
  }
}

function makeQrDataUrl(text, cellSize = 8, margin = 2) {
  // qrcode-generator (cdnjs) exposes global: qrcode
  const qr = qrcode(0, "M");
  qr.addData(String(text || ""));
  qr.make();
  return qr.createDataURL(cellSize, margin);
}

function fitOneLine(doc, text, maxWidthPt, startSizePt) {
  let size = startSizePt;
  doc.setFontSize(size);
  while (size > 10 && doc.getTextWidth(text) > maxWidthPt) {
    size -= 1;
    doc.setFontSize(size);
  }
  return size;
}

async function downloadDeploymentPacket() {
  try {
    if (!qrEnrollUrl || !qrImg?.src) {
      setMsg(qrMsg, "QR not ready yet.", false);
      return;
    }

    // jsPDF UMD bundle exposes window.jspdf.jsPDF
    const jsPDF = window.jspdf?.jsPDF;
    if (!jsPDF) {
      setMsg(qrMsg, "PDF library failed to load.", false);
      return;
    }
    if (typeof window.qrcode !== "function") {
      setMsg(qrMsg, "QR library failed to load.", false);
      return;
    }

    const doc = new jsPDF({ orientation: "portrait", unit: "pt", format: "letter" });
    const pageW = doc.internal.pageSize.getWidth();
    const pageH = doc.internal.pageSize.getHeight();

    // Slightly larger margins so content isn't so close to the page edges.
    const margin = 54;

    // --- Page 1: App QR codes ---
    doc.setFont("helvetica", "bold");
    doc.setFontSize(18);
    doc.text("TAK Aware (iOS)", pageW / 2, margin, { align: "center" });
    const takAwareUrl = "https://apps.apple.com/us/app/tak-aware/id6738631659";
    const atakUrl = "https://play.google.com/store/apps/details?id=com.atakmap.app.civ";
    const takAwareQr = makeQrDataUrl(takAwareUrl, 10, 2);
    const atakQr = makeQrDataUrl(atakUrl, 10, 2);

    const qrSize1 = 260;
    doc.addImage(takAwareQr, "PNG", (pageW - qrSize1) / 2, margin + 20, qrSize1, qrSize1);

    doc.setFont("helvetica", "bold");
    doc.setFontSize(18);
    doc.text("ATAK (Android)", pageW / 2, pageH - margin - qrSize1 - 20, { align: "center" });
    doc.addImage(atakQr, "PNG", (pageW - qrSize1) / 2, pageH - margin - qrSize1, qrSize1, qrSize1);

    // --- Page 2: User + Mutual Aid QR ---
    doc.addPage();
    // Per request: show a fixed placeholder above the QR section.
    const callsignText = "AGENCY-LASTNAME-CALLSIGN";
    doc.setFont("helvetica", "bold");
    fitOneLine(doc, callsignText, pageW - margin * 2, 36);
    doc.text(callsignText, pageW / 2, margin + 10, { align: "center" });

    const qrSize2 = min(pageW - margin * 2, pageH - (margin * 2 + 80));
    const qrY2 = margin + 50;
    doc.addImage(qrImg.src, "PNG", (pageW - qrSize2) / 2, qrY2, qrSize2, qrSize2);

    // Username label under the QR (e.g., MA-XYZ)
    const userLabel = String(qrActiveItem?.username || "").trim();
    if (userLabel) {
      const userY = Math.min(pageH - margin, qrY2 + qrSize2 + 28);
      doc.setFont("helvetica", "bold");
      doc.setFontSize(18);
      doc.setTextColor(0);
      doc.text(userLabel, pageW / 2, userY, { align: "center" });
    }

    // --- Page 3: Team Color Guide ---
    doc.addPage();
    doc.setFont("helvetica", "bold");
    doc.setFontSize(26);
    doc.text("Team Color Guide", pageW / 2, margin, { align: "center" });

    // Add a full row of whitespace under the title.
    let y = margin + 30 + 44;
    const lineH = 44;
    const swatch = 22;
    doc.setFont("helvetica", "bold");
    doc.setFontSize(20);
    for (const c of TEAM_COLORS) {
      if (y + lineH > pageH - margin) break;
      const [r, g, b] = hexToRgb(c.hex);
      doc.setFillColor(r, g, b);
      doc.setDrawColor(0);
      doc.rect(margin, y - swatch + 6, swatch, swatch, "FD");

      // For white swatches, add a border so it shows up.
      if (String(c.hex).toLowerCase() == "#ffffff") {
        doc.setDrawColor(120);
        doc.rect(margin, y - swatch + 6, swatch, swatch);
        doc.setDrawColor(0);
      }

      const label = c.desc ? `${c.name} — ${c.desc}` : c.name;
      doc.setTextColor(0);
      doc.text(label, margin + swatch + 12, y);
      y += lineH;
    }

    // --- Page 4: Team Role Guide ---
    doc.addPage();
    doc.setFont("helvetica", "bold");
    doc.setFontSize(26);
    doc.text("Team Role Guide", pageW / 2, margin, { align: "center" });

    // Add a full row of whitespace under the title.
    y = margin + 30 + 44;
    doc.setFont("helvetica", "bold");
    doc.setFontSize(20);
    for (const r of TEAM_ROLES) {
      if (y + lineH > pageH - margin) break;
      const label = r.desc ? `${r.name} — ${r.desc}` : r.name;
      doc.text(label, margin, y);
      y += lineH;
    }

    const filenameSafe = (String(qrActiveItem?.username || "deployment-packet")
      .trim()
      .replace(/[^a-z0-9_-]+/gi, "-")
      .replace(/-+/g, "-")
      .replace(/^[-_]+|[-_]+$/g, "")
      || "deployment-packet").toLowerCase();

    doc.save(`${filenameSafe}-packet.pdf`);
    setMsg(qrMsg, "Packet downloaded.", true);
  } catch (e) {
    setMsg(qrMsg, e?.message || String(e), false);
  }

  function min(a, b) { return a < b ? a : b; }
}

if (qrPacketBtn) {
  qrPacketBtn.onclick = downloadDeploymentPacket;
}

// ----- Edit modal -----
const editOverlay = document.getElementById("editOverlay");
const editCloseBtn = document.getElementById("editCloseBtn");
const editType = document.getElementById("editType");
const editName = document.getElementById("editName");
const editExpireEnabledWrap = document.getElementById("editExpireEnabledWrap");
const editExpireEnabled = document.getElementById("editExpireEnabled");
const editExpireAt = document.getElementById("editExpireAt");
const editSaveBtn = document.getElementById("editSaveBtn");
const editMsg = document.getElementById("editMsg");


function openEdit(item){
  activeItem = item;
  editOverlay.style.display = "flex";
  document.body.classList.add("noScroll");
  editType.value = item.type || "INCIDENT";
  editName.value = item.title || "";
  // Expiration fields (EVENT + INCIDENT)
  editExpireEnabled.value = item.expireEnabled ? "yes" : "no";
  if (item.expireAt) {
    const d = new Date(item.expireAt);
    if (!Number.isNaN(d.getTime())) {
      const pad = (n) => String(n).padStart(2, "0");
      const yyyy = d.getFullYear();
      const mm = pad(d.getMonth() + 1);
      const dd = pad(d.getDate());
      const hh = pad(d.getHours());
      const min = pad(d.getMinutes());
      editExpireAt.value = `${yyyy}-${mm}-${dd}T${hh}:${min}`;
    } else {
      editExpireAt.value = "";
    }
  } else {
    editExpireAt.value = "";
  }
  updateEditExpireUi();
  setMsg(editMsg, "", true);
}

function updateEditExpireUi(){
  // Expiration is supported for both EVENT and INCIDENT.
  editExpireEnabledWrap.style.display = "block";

  const enabled = String(editExpireEnabled.value || "").toLowerCase() === "yes";

  editExpireAt.disabled = !enabled;
  editExpireAt.style.display = enabled ? "block" : "none";

  if (!enabled) {
    editExpireAt.value = "";
  }
}

editType.onchange = updateEditExpireUi;
editExpireEnabled.onchange = updateEditExpireUi;
editCloseBtn.onclick = () => { editOverlay.style.display = "none"; document.body.classList.remove("noScroll"); };
editSaveBtn.onclick = async () => {
  if(!activeItem) return;
  const type = String(editType.value || "").trim().toUpperCase();
  const title = String(editName.value || "").trim();
  if(!title){ setMsg(editMsg, "Name is required.", false); return; }

  setMsg(editMsg, "Saving...", true);

  // Expiration payload (EVENT + INCIDENT)
  let expireEnabled = false;
  let expireAt = null;
  expireEnabled = String(editExpireEnabled.value || "").toLowerCase() === "yes";
  if (expireEnabled) {
    const raw = String(editExpireAt.value || "").trim();
    if (!raw) {
      setMsg(editMsg, "Expiration date/time is required.", false);
      return;
    }
    expireAt = new Date(raw).toISOString();
  }
  const res = await fetch(`/api/mutual-aid/${encodeURIComponent(activeItem.id)}`, {
    method: "PATCH",
    headers: { "Content-Type": "application/json" },
    body: JSON.stringify({ type, title, expireEnabled, expireAt })
  });
  const data = await res.json();
  if(!res.ok){ setMsg(editMsg, data.error || "Failed to save", false); return; }
  setMsg(editMsg, "Saved.", true);
  editOverlay.style.display = "none";
  document.body.classList.remove("noScroll");
  await loadList();
};

// Group assignment is handled via the "Assign" button on each row.

// ----- Mass assign modal (adapted from groups page) -----
const massOverlay = document.getElementById("massOverlay");
const massCloseBtn = document.getElementById("massCloseBtn");
const massTitle = document.getElementById("massTitle");
const massMsg = document.getElementById("massMsg");
const massApplyBtn = document.getElementById("massApplyBtn");
const massSkipBtn = document.getElementById("massSkipBtn");

const massAgencyPane = document.getElementById("massAgencyPane");
const massGroupPane = document.getElementById("massGroupPane");
const massUsersPane = document.getElementById("massUsersPane");

const agencySearch = document.getElementById("agencySearch");
const agencyList = document.getElementById("agencyList");
const agencySelectAll = document.getElementById("agencySelectAll");
const agencyClearAll = document.getElementById("agencyClearAll");

const sourceGroupSearch = document.getElementById("sourceGroupSearch");
const sourceGroupList = document.getElementById("sourceGroupList");
const groupSelectAll = document.getElementById("groupSelectAll");
const groupClearAll = document.getElementById("groupClearAll");

const userSearch = document.getElementById("userSearch");
const userList = document.getElementById("userList");
const userSelectAll = document.getElementById("userSelectAll");
const userClearAll = document.getElementById("userClearAll");

let agenciesCache = [];
// NOTE: groupsCache is used by both the Mutual Aid create form and the mass-assign modal.
// Use `var` so it's available before this point in the script (no TDZ issues).
var groupsCache = [];
let usersSearchCache = [];
let massMode = "agency";
let massAction = "assign";
let activeMassGroupId = "";
let activeMassGroupName = "";

const selectedSourceGroupIds = new Set();
const selectedUserIds = new Set();

function resetMassState() {
  selectedSourceGroupIds.clear();
  selectedUserIds.clear();
  agencySearch.value = "";
  sourceGroupSearch.value = "";
  userSearch.value = "";
  usersSearchCache = [];
}

function openMassAssign({ groupId, groupName }){
  activeMassGroupId = String(groupId || "");
  activeMassGroupName = String(groupName || "");
  massAction = "assign";
  massTitle.textContent = `Mass Assign — ${activeMassGroupName}`;
  massApplyBtn.textContent = "Mass Assign";
  setMsg(massMsg, "", true);
  resetMassState();
  massOverlay.style.display = "flex";
  document.body.classList.add("noScroll");

  // load caches if empty
  Promise.all([loadAgencies(), loadGroups()]).catch(()=>{});
}

function openMassUnassign({ groupId, groupName }){
  activeMassGroupId = String(groupId || "");
  activeMassGroupName = String(groupName || "");
  massAction = "unassign";
  massTitle.textContent = `Mass Unassign — ${activeMassGroupName}`;
  massApplyBtn.textContent = "Mass Unassign";
  setMsg(massMsg, "", true);
  resetMassState();
  massOverlay.style.display = "flex";
  document.body.classList.add("noScroll");

  // load caches if empty
  Promise.all([loadAgencies(), loadGroups()]).catch(()=>{});
}

function closeMassAssign(){
  massOverlay.style.display = "none";
  document.body.classList.remove("noScroll");
}

massCloseBtn.onclick = closeMassAssign;
massSkipBtn.onclick = closeMassAssign;

function setMassMode(mode){
  massMode = mode;
  document.querySelectorAll(".segBtn").forEach(b => {
    b.classList.toggle("active", b.dataset.mode === mode);
  });
  massAgencyPane.style.display = mode === "agency" ? "block" : "none";
  massGroupPane.style.display = mode === "group" ? "block" : "none";
  massUsersPane.style.display = mode === "users" ? "block" : "none";
  if(mode === "agency") renderAgencyList();
  if(mode === "group") renderSourceGroupList();
  if(mode === "users") renderUserList(usersSearchCache);
}

document.querySelectorAll(".segBtn").forEach(b => {
  b.onclick = () => setMassMode(b.dataset.mode);
});

async function loadAgencies(){
  const res = await fetch("/api/agencies");
  const out = await res.json();
  agenciesCache = res.ok && Array.isArray(out) ? out : [];
  renderAgencyList();
}

function agencyItems(){
  return agenciesCache
    .filter(a => String(a.suffix || "").trim())
    .slice()
    .sort((a,b)=>String(a.name||"").localeCompare(String(b.name||"")))
    .map(a => ({ name: String(a.name||""), suffix: String(a.suffix||"").trim().toLowerCase() }));
}

function renderAgencyList(){
  const needle = String(agencySearch.value||"").trim().toLowerCase();
  const items = agencyItems().filter(x => {
    if(!needle) return true;
    return x.name.toLowerCase().includes(needle) || x.suffix.includes(needle);
  });
  agencyList.innerHTML = items.map(x => {
    const label = `${x.name} (${x.suffix})`;
    return `
      <label class="groupItem">
        <input type="checkbox" class="agencyChk" value="${esc(x.suffix)}" />
        <span>${esc(label)}</span>
      </label>
    `;
  }).join("") || `<div style="padding:10px; color: var(--muted);">No agencies found.</div>`;
}

agencySearch.oninput = () => renderAgencyList();
agencySelectAll.onclick = () => {
  agencyList.querySelectorAll("input.agencyChk").forEach(ch => ch.checked = true);
};
agencyClearAll.onclick = () => {
  agencyList.querySelectorAll("input.agencyChk").forEach(ch => ch.checked = false);
};

async function loadGroups(){
  const res = await fetch("/api/groups");
  const out = await res.json();
  groupsCache = res.ok && Array.isArray(out) ? out : [];
  renderSourceGroupList();
  renderExistingGroupSelect();
}

function renderSourceGroupList(){
  const needle = String(sourceGroupSearch.value||"").trim().toLowerCase();
  const items = groupsCache
    .slice()
    .sort((a,b)=>String(a.name||"").localeCompare(String(b.name||"")))
    .filter(g => !needle || String(g.name||"").toLowerCase().includes(needle));

  sourceGroupList.innerHTML = items.map(g => {
    const id = String(g.pk);
    return `
      <label class="groupItem">
        <input type="checkbox" class="srcGroupChk" value="${esc(id)}" />
        <span>${esc(g.name||"")}</span>
      </label>
    `;
  }).join("") || `<div style="padding:10px; color: var(--muted);">No groups found.</div>`;

  // Restore selections
  sourceGroupList.querySelectorAll("input.srcGroupChk").forEach(ch => {
    if(selectedSourceGroupIds.has(String(ch.value))) ch.checked = true;
    ch.onchange = () => {
      if(ch.checked) selectedSourceGroupIds.add(String(ch.value));
      else selectedSourceGroupIds.delete(String(ch.value));
    };
  });
}

sourceGroupSearch.oninput = () => renderSourceGroupList();
groupSelectAll.onclick = () => {
  sourceGroupList.querySelectorAll("input.srcGroupChk").forEach(ch => { ch.checked = true; selectedSourceGroupIds.add(String(ch.value)); });
};
groupClearAll.onclick = () => {
  sourceGroupList.querySelectorAll("input.srcGroupChk").forEach(ch => { ch.checked = false; });
  selectedSourceGroupIds.clear();
};


function renderUserList(users){
  userList.innerHTML = (users || []).map(u => {
    const pk = String(u.pk);
    const username = String(u.username || "");
    const name = String(u.name || "");
    const email = String(u.email || "");
    const label = `${username} — ${name || "(no name)"} — ${email || "(no email)"}`;
    const checked = selectedUserIds.has(pk) ? "checked" : "";
    return `
      <label class="groupItem">
        <input type="checkbox" class="userChk" value="${esc(pk)}" ${checked} />
        <span>${esc(label)}</span>
      </label>
    `;
  }).join("") || `<div style="padding:10px; color: var(--muted);">No users loaded.</div>`;

  userList.querySelectorAll("input.userChk").forEach(ch => {
    ch.onchange = () => {
      const id = String(ch.value || "").trim();
      if (!id) return;
      if (ch.checked) selectedUserIds.add(id);
      else selectedUserIds.delete(id);
    };
  });
}

let userSearchT = null;
userSearch.oninput = () => {
  clearTimeout(userSearchT);
  userSearchT = setTimeout(async () => {
    const q = String(userSearch.value || "").trim();
    if (!q) {
      usersSearchCache = [];
      renderUserList([]);
      return;
    }
    try {
      const res = await fetch(`/api/users/search?q=${encodeURIComponent(q)}&page=1&pageSize=200`);
      const out = await res.json();
      if (!res.ok) throw new Error(out.error || "Search failed");
      const arr = Array.isArray(out.users) ? out.users : [];
      usersSearchCache = arr.slice(0, 200);
      renderUserList(usersSearchCache);
    } catch (e) {
      renderUserList([]);
    }
  }, 220);
};

userSelectAll.onclick = () => {
  // Add all shown users to the persistent selection set
  usersSearchCache.forEach(u => {
    const id = String(u.pk || "").trim();
    if (id) selectedUserIds.add(id);
  });
  renderUserList(usersSearchCache);
};
userClearAll.onclick = () => {
  selectedUserIds.clear();
  renderUserList(usersSearchCache);
};

massApplyBtn.onclick = async () => {
  if(!activeMassGroupId){ setMsg(massMsg, "Missing target group", false); return; }
  const actionVerb = massAction === "unassign" ? "unassign" : "assign";
  setMsg(massMsg, "Applying...", true);

  let payload = { groupId: activeMassGroupId };

  if(massMode === "agency"){
    const suffixes = Array.from(agencyList.querySelectorAll("input.agencyChk:checked")).map(ch => String(ch.value));
    if(suffixes.length) payload.suffixes = suffixes;
    else { setMsg(massMsg, "No selections — nothing to apply (you can just Close).", true); return; }
  }

  if(massMode === "group"){
    const sourceGroupIds = Array.from(selectedSourceGroupIds);
    if(sourceGroupIds.length) payload.sourceGroupIds = sourceGroupIds;
    else { setMsg(massMsg, "No selections — nothing to apply (you can just Close).", true); return; }
  }

  if(massMode === "users"){
    const userIds = Array.from(selectedUserIds);
    if(userIds.length) payload.userIds = userIds;
    else { setMsg(massMsg, "No selections — nothing to apply (you can just Close).", true); return; }
  }

  const endpoint = massAction === "unassign" ? "/api/groups/mass-unassign" : "/api/groups/mass-assign";

  const res = await fetch(endpoint, {
    method: "POST",
    headers: { "Content-Type": "application/json" },
    body: JSON.stringify(payload)
  });
  const data = await res.json();
  if(!res.ok){ setMsg(massMsg, data.error || `Mass ${actionVerb} failed`, false); return; }
  const label = actionVerb === "assign" ? "Assigned" : "Unassigned";
  setMsg(massMsg, `${label} ${data.updated}/${data.matched} users.`, true);
};

// ----- List rendering -----
function renderList(){
  const needle = String(maFilter.value||"").trim().toLowerCase();
  const items = allItems.filter(it => {
    if(!needle) return true;
    return (
      String(it.type||"").toLowerCase().includes(needle) ||
      String(it.title||"").toLowerCase().includes(needle) ||
      String(it.groupName||"").toLowerCase().includes(needle) ||
      String(it.username||"").toLowerCase().includes(needle)
    );
  });

  maTbody.innerHTML = items.map(it => {
    const isExistingGroup = String(it.groupMode || "new").toLowerCase() === "existing";
    return `
      <tr>
        <td>${esc(it.type||"")}</td>
        <td>
          <div style="font-weight:600;">${esc(it.title||"")}</div>
          <div style="color: var(--muted); font-size: 12px;">${esc(it.groupName||"")}</div>
          ${it.expireEnabled && it.expireAt ? `<div style="color: var(--muted); font-size: 12px;">Expires: ${esc(new Date(it.expireAt).toLocaleString())}</div>` : ""}
        </td>
        <td>
          <div class="row" style="gap:10px; flex-wrap: wrap;">
            <button class="btn" type="button" data-act="members" data-id="${esc(it.id)}">View Members</button>
            ${isExistingGroup ? "" : `<button class=\"btn success\" type=\"button\" data-act=\"assign\" data-id=\"${esc(it.id)}\">Assign</button>`}
            ${isExistingGroup ? "" : `<button class=\"btn\" type=\"button\" data-act=\"unassign\" data-id=\"${esc(it.id)}\">Unassign</button>`}
            <button class="btn" type="button" data-act="edit" data-id="${esc(it.id)}">Edit</button>
            <button class="btn qr" type="button" data-act="qr" data-id="${esc(it.id)}">Show QR</button>
            <button class="btn danger" type="button" data-act="del" data-id="${esc(it.id)}">Delete</button>
          </div>
        </td>
      </tr>
    `;
  }).join("") || `<tr><td colspan="3" style="color:var(--muted); padding: 10px;">No mutual aid items found.</td></tr>`;

  maTbody.querySelectorAll("button[data-act]").forEach(btn => {
    const id = String(btn.dataset.id);
    const act = String(btn.dataset.act);
    const it = allItems.find(x => String(x.id) === id);
    if(!it) return;
    btn.onclick = () => {
      if(act === "members") return openMutualAidMembers(it.groupId, it.groupName);
      if(act === "assign") return openMassAssign({ groupId: it.groupId, groupName: it.groupName });
      if(act === "unassign") return openMassUnassign({ groupId: it.groupId, groupName: it.groupName });
      if(act === "edit") return openEdit(it);
      if(act === "qr") return openQrModal(it);
      if(act === "del") return deleteItem(it);
    };
  });
}

async function loadList(){
  setMsg(maListMsg, "Loading...", true);
  const res = await fetch("/api/mutual-aid");
  const data = await res.json();
  if(!res.ok){
    allItems = [];
    renderList();
    setMsg(maListMsg, data.error || "Failed to load", false);
    return;
  }
  allItems = Array.isArray(data) ? data : [];
  renderList();
  setMsg(maListMsg, `Loaded ${allItems.length} item(s).`, true);
}

maFilter.oninput = () => renderList();

async function deleteItem(item){
  const willDeleteGroup = String(item.groupMode||"new").toLowerCase() !== "existing";
  const extra = willDeleteGroup
    ? "This will revoke TAK certs, delete the user, and delete the group."
    : "This will revoke TAK certs and delete the user. (The existing group will NOT be deleted.)";
  const ok = confirm(`Delete ${item.type} "${item.title}"?\n\n${extra}`);
  if(!ok) return;
  setMsg(maListMsg, "Deleting...", true);
  const res = await fetch(`/api/mutual-aid/${encodeURIComponent(item.id)}`, { method: "DELETE" });
  const data = await res.json().catch(()=>({}));
  if(!res.ok){ setMsg(maListMsg, data.error || "Delete failed", false); return; }
  setMsg(maListMsg, "Deleted.", true);
  await loadList();
}

// ----- Create flow -----
maCreateBtn.onclick = async () => {
  setMsg(maCreateMsg, "", true);
  const type = String(maType.value || "").trim().toUpperCase();
  const title = String(maTitle.value || "").trim();
  if(!title){ setMsg(maCreateMsg, "Name is required.", false); return; }

  maCreateBtn.disabled = true;
  setMsg(maCreateMsg, "Creating...", true);
  try {
    // Expiration payload (EVENT + INCIDENT)
    let expireEnabled = false;
    let expireAt = null;
    expireEnabled = String(maExpireEnabled.value || "").toLowerCase() === "yes";
    if (expireEnabled) {
      const raw = String(maExpireAt.value || "").trim();
      if (!raw) {
        setMsg(maCreateMsg, "Expiration date/time is required.", false);
        maCreateBtn.disabled = false;
        return;
      }
      expireAt = new Date(raw).toISOString();
    }
    // Group mode payload
    const groupMode = String(maGroupMode?.value || "new").toLowerCase() === "existing" ? "existing" : "new";
    const existingGroupId = groupMode === "existing" ? String(maExistingGroup?.value || "").trim() : "";
    if (groupMode === "existing" && !existingGroupId) {
      setMsg(maCreateMsg, "Please select an existing group.", false);
      maCreateBtn.disabled = false;
      return;
    }

    const res = await fetch("/api/mutual-aid", {
      method: "POST",
      headers: { "Content-Type": "application/json" },
      body: JSON.stringify({ type, title, expireEnabled, expireAt, groupMode, existingGroupId })
    });
    const data = await res.json();
    if(!res.ok) throw new Error(data.error || "Create failed");

    const item = data.item;
    setMsg(maCreateMsg, `Created ${item.groupName} (user: ${item.username}).`, true);
    maTitle.value = "";
    maExpireEnabled.value = "no";
    maExpireAt.value = "";
    if (maGroupMode) maGroupMode.value = "new";
    if (maExistingGroup) maExistingGroup.value = "";
    updateCreateGroupModeUi();
    updateCreateExpireUi();
    await loadList();

    // Immediately offer mass-assign (optional) ONLY when we created a new group.
    if (groupMode !== "existing") {
      openMassAssign({ groupId: item.groupId, groupName: item.groupName });
    }
  } catch (e){
    setMsg(maCreateMsg, e.message || String(e), false);
  } finally {
    maCreateBtn.disabled = false;
  }
};

// initial
loadList();
</script>

