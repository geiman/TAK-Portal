<%- include("partials/header") %>
<%- include("partials/sidebar") %>

<main class="main">
  <h1>Mutual Aid</h1>

  <div class="card">
    <h2>Create Mutual Aid</h2>
    <div class="row" style="flex-wrap: wrap;">
      <label> Type
        <select id="maType" style="min-width: 120px;">
        <option value="INCIDENT" selected>Incident</option>
        <option value="EVENT">Event</option>
        <option value="STANDBY">Standby</option>
      </select>
      </label>
      <label>Title
      <input id="maTitle" placeholder="Title (ex. County Fair, Search, etc...)" style="min-width: 240px;" /></label>

      <label id="maExpireWrap" style="display:flex; align-items:center; gap:8px;">
        <span>Expires</span>
        <select id="maExpireEnabled">
          <option value="no" selected>No</option>
          <option value="yes">Yes</option>
        </select>
      </label>

      <label id="maExpireAtWrap"><br>
        <input id="maExpireAt" type="datetime-local" style="min-width: 240px;" />
      </label>

      <label>
        Group
        <select id="maGroupMode" style="min-width: 220px;">
          <option value="new" selected>Create New Group</option>
          <option value="existing">Use Existing Group</option>
        </select>
      </label>

      <label id="maExistingGroupWrap" style="display:none; flex-direction:column;">
        <span>Existing Group</span>
        <select id="maExistingGroup" style="min-width: 220px;"></select>
      </label>

      
      <label><br>
      <button class="btn" id="maCreateBtn" type="button">Create New Mutual Aid</button></label>

      <div id="maCreateMsg" class="msg" style="margin-top:10px;"></div>

    </div>
  </div>

  <div class="card">
    <div class="row" style="justify-content: space-between; align-items:center;">
      <h2 style="margin:0;">Active Incidents & Events</h2>
    </div>

    <input id="maFilter" placeholder="Filter..." style="margin: 10px 0; min-width: 360px;" />

    <table class="table">
      <thead>
        <tr>
          <th style="width: 100px;">Type</th>
          <th style="width: 140px;">Title</th>
          <th style="width: 380px;">Actions</th>
        </tr>
      </thead>
      <tbody id="maTbody"></tbody>
    </table>

    <div id="maListMsg" class="msg"></div>
  </div>
</main>

<style>
  /* Make the calendar icon white on the expire date inputs */
  #maExpireAt::-webkit-calendar-picker-indicator,
  #editExpireAt::-webkit-calendar-picker-indicator {
    filter: invert(1);
  }

  /* Optional: ensure the text is white too, if you're on a dark background */
  #maExpireAt,
  #editExpireAt {
    color: #fff;
  }
</style>


