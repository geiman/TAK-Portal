<%- include("partials/header") %>
<%- include("partials/sidebar") %>

<main class="main">
  <h1>Setup My Device</h1>

  <!-- Device selector -->
  <div class="card" id="deviceSelectCard">
    <h2>Select Your Device Type</h2>

    <div class="<%= (settings && settings.CLOUDTAK_URL && settings.CLOUDTAK_URL.trim()) ? 'grid3' : 'grid2' %>">
      <button type="button" class="btn tile deviceTile deviceTile-ios" id="selectIOS">
        <span class="title">Apple (iPhone / iPad)</span>
        <span class="desc">Use TAK Aware on iOS devices.</span>
      </button>

      <button type="button" class="btn tile deviceTile deviceTile-android" id="selectAndroid">
        <span class="title">Android (Phone / Tablet)</span>
        <span class="desc">Use ATAK or Open TAK Tracker on Android devices.</span>
      </button>

      <% if (settings && typeof settings.CLOUDTAK_URL === "string" && settings.CLOUDTAK_URL.trim()) { %>
        <button type="button" class="btn tile deviceTile" id="selectWeb">
          <span class="title">Web Browser</span>
          <span class="desc">Use CloudTAK on web browsers.</span>
        </button>
      <% } %>
    </div>
  </div>

  <!-- iOS flow -->
  <div id="iosFlow" style="display:none;">
    <div class="card">
      <h2>Step 1: Download the TAK App</h2>
      <a
        href="https://apps.apple.com/us/app/tak-aware/id6738631659"
        target="_blank"
        rel="noopener noreferrer"
        class="btn tile"
      >
        <span class="title">iOS - TAK Aware</span>
        <span class="desc">Download TAK Aware for iPhone or iPad.</span>
      </a>
    </div>

    <div class="card">
      <h2>Step 2: Enroll Your Device</h2>
      <div class="grid2">
        <button type="button" class="btn tile" id="scanQrBtnTakAware">
          <span class="title">Scan QR Code (Recommended)</span>
          <span class="desc">Scan an enrollment QR code to automatically configure TAK Aware.</span>
        </button>
        <button type="button" class="btn tile" id="manualLoginBtnTakAware">
          <span class="title">Manual Login</span>
          <span class="desc">Manually configure TAK Aware with step-by-step instructions.</span>
        </button>
      </div>
    </div>
  </div>

  <!-- Android flow -->
  <div id="androidFlow" style="display:none;">
    <div class="card">
      <h2>Step 1: Download the TAK App</h2>
      <div class="grid2">
        <a
          href="https://play.google.com/store/apps/details?id=com.atakmap.app.civ"
          target="_blank"
          rel="noopener noreferrer"
          class="btn tile"
        >
          <span class="title">Android - ATAK</span>
          <span class="desc">Download ATAK for Android devices.</span>
        </a>
        <a
          href="https://github.com/GoTAK-LLC/OpenTAKTracker/releases"
          target="_blank"
          rel="noopener noreferrer"
          class="btn tile"
        >
          <span class="title">Android - Open TAK Tracker</span>
          <span class="desc">Download Open TAK Tracker for Android devices. (Tracking Only, No Map)</span>
        </a>
      </div>
    </div>

    <div class="card">
      <h2>Step 2: Enroll Your Device</h2>
      <div class="grid2">
        <button type="button" class="btn tile" id="scanQrBtnAtak">
          <span class="title">Scan QR Code (Recommended)</span>
          <span class="desc">Scan an enrollment QR code to automatically configure ATAK.</span>
        </button>
        <button type="button" class="btn tile" id="manualLoginBtnAtak">
          <span class="title">Manual Login</span>
          <span class="desc">Manually configure ATAK with step-by-step instructions.</span>
        </button>
      </div>
    </div>

    <div class="card">
      <h2>Step 3: Configure Callsign, Team, and Role</h2>
      <div class="grid2">
        <button type="button" class="btn tile" id="preferenceScanQrBtn">
          <span class="title">Scan QR Code (Recommended)</span>
          <span class="desc">Scan a QR code to set your callsign and team (color) on your device.</span>
        </button>
        <button type="button" class="btn tile" id="preferenceManualBtn">
          <span class="title">Manual Configuration</span>
          <span class="desc">Enter your callsign and team manually in ATAK preferences.</span>
        </button>
      </div>
    </div>
  </div>
</main>

<!-- QR Modal -->
<div class="modalOverlay" id="setupQrOverlay" style="display:none;">
  <div class="modal" role="dialog" aria-modal="true" aria-labelledby="setupQrTitle">
    <div class="modalHeader">
      <h2 id="setupQrTitle" style="margin:0;">Enrollment QR Code</h2>
      <button class="btn" id="setupQrCloseBtn" type="button">Close</button>
    </div>
    <div class="modalBody">
      <div class="row" style="gap: 24px; align-items: flex-start; flex-wrap: wrap;">
        <div style="text-align:center; min-width: 260px;">
          <img id="setupQrImg" alt="Enrollment QR Code" style="max-width: 280px; width: 100%; height: auto; border-radius: 14px;" />
          <div class="row" style="gap: 10px; margin-top: 14px; justify-content: center;">
            <span id="setupQrEnrollUrlHolder" data-enroll-url="" style="display:none;" aria-hidden="true"></span>
            <button class="btn" type="button" id="setupQrOpenBtn" disabled>Open URL</button>
            <button class="btn" type="button" id="setupQrCopyBtn" disabled>Copy URL</button>
            <button class="btn" type="button" id="setupQrSaveBtn" disabled>Save Image</button>
          </div>
        </div>
        <div style="min-width: 320px;">
          <h3 style="margin-top:0;" id="setupQrInstructionsTitle">How to Scan</h3>
          <ol id="setupQrInstructions" style="margin-top: 6px;"></ol>
          <h3 style="margin-top:0;">Details</h3>
          <div class="chips" id="setupQrDetails"></div>
          <div id="setupQrCountdown" class="msg" style="margin-top: 10px;"></div>
          <div id="setupQrMsg" class="msg"></div>
        </div>
      </div>
    </div>
  </div>
</div>

<!-- Manual Login Modal -->
<div class="modalOverlay" id="manualLoginOverlay" style="display:none;">
  <div class="modal" role="dialog" aria-modal="true" aria-labelledby="manualLoginTitle">
    <div class="modalHeader">
      <h2 id="manualLoginTitle" style="margin:0;">Manual Login Instructions</h2>
      <button class="btn" id="manualLoginCloseBtn" type="button">Close</button>
    </div>
    <div class="modalBody">
      <div style="max-width: 600px;">
        <h3 style="margin-top:0;" id="manualLoginInstructionsTitle">How to Manually Configure</h3>
        <ol id="manualLoginInstructions" style="margin-top: 6px;"></ol>
        <h3 style="margin-top:0;">Details</h3>
        <div class="chips" id="manualLoginDetails"></div>
      </div>
    </div>
  </div>
</div>

<!-- Preference QR Modal (Android Step 3) -->
<div class="modalOverlay" id="preferenceQrOverlay" style="display:none;">
  <div class="modal" role="dialog" aria-modal="true" aria-labelledby="preferenceQrTitle">
    <div class="modalHeader">
      <h2 id="preferenceQrTitle" style="margin:0;">Configure Device Preferences</h2>
      <button class="btn" id="preferenceQrCloseBtn" type="button">Close</button>
    </div>
    <div class="modalBody">
      <div class="row" style="gap: 24px; align-items: flex-start; flex-wrap: wrap;">
        <div style="text-align:center; min-width: 260px;">
          <img id="preferenceQrImg" alt="Preference QR Code" style="max-width: 280px; width: 100%; height: auto; border-radius: 14px;" />
        </div>
        <div style="min-width: 320px;">
          <h3 style="margin-top:0;">How to Scan</h3>
          <ol id="preferenceQrInstructions" style="margin-top: 6px;">
            <li>Open the camera on your Android device.</li>
            <li>Point your camera at the QR code and select the notification to open the link.</li>
            <li>Select Yes to apply the configuration inside ATAK.</li>
          </ol>
          <h3 style="margin-top:0;">Details</h3>
          <div class="chips" id="preferenceQrDetails"></div>
          <div id="preferenceQrMsg" class="msg"></div>
        </div>
      </div>
    </div>
  </div>
</div>

<!-- Manual Preference Modal (Android Step 3) -->
<div class="modalOverlay" id="preferenceManualOverlay" style="display:none;">
  <div class="modal" role="dialog" aria-modal="true" aria-labelledby="preferenceManualTitle">
    <div class="modalHeader">
      <h2 id="preferenceManualTitle" style="margin:0;">Manual Configuration</h2>
      <button class="btn" id="preferenceManualCloseBtn" type="button">Close</button>
    </div>
    <div class="modalBody">
      <div style="max-width: 600px;">
        <h3 style="margin-top:0;">Configure callsign and team in ATAK</h3>
        <ol id="preferenceManualInstructions" style="margin-top: 6px;"></ol>
      </div>
    </div>
  </div>
</div>

<script>
  // CloudTAK URL (from settings.json via server render)
  const cloudtakUrl = <%- JSON.stringify((settings && typeof settings.CLOUDTAK_URL === "string") ? settings.CLOUDTAK_URL.trim() : "") %>;

  // --- device selection UI (NO persistence; forgets on reload) ---
  const iosFlow = document.getElementById("iosFlow");
  const androidFlow = document.getElementById("androidFlow");
  const selectIOS = document.getElementById("selectIOS");
  const selectAndroid = document.getElementById("selectAndroid");
  const selectWeb = document.getElementById("selectWeb");

  function showIOS() {
    iosFlow.style.display = "block";
    androidFlow.style.display = "none";
    setScanInstructions("takaware");
    // optional: scroll to the revealed content
    iosFlow.scrollIntoView({ behavior: "smooth", block: "start" });
  }

  function showAndroid() {
    iosFlow.style.display = "none";
    androidFlow.style.display = "block";
    setScanInstructions("atak");
    androidFlow.scrollIntoView({ behavior: "smooth", block: "start" });
  }

  function openCloudTAK() {
    if (!cloudtakUrl) return;
    window.open(cloudtakUrl, "_blank", "noopener,noreferrer");
  }

  // On load: always start with chooser only
  (function resetOnLoad() {
    iosFlow.style.display = "none";
    androidFlow.style.display = "none";
  })();

  selectIOS.addEventListener("click", showIOS);
  selectAndroid.addEventListener("click", showAndroid);
  if (selectWeb) selectWeb.addEventListener("click", openCloudTAK);

  // --- QR modal + enrollment logic ---
  const scanQrBtnTakAware = document.getElementById("scanQrBtnTakAware");
  const scanQrBtnAtak = document.getElementById("scanQrBtnAtak");
  const overlay = document.getElementById("setupQrOverlay");
  const closeBtn = document.getElementById("setupQrCloseBtn");
  const qrImg = document.getElementById("setupQrImg");
  const enrollUrlHolder = document.getElementById("setupQrEnrollUrlHolder");
  const openUrlBtn = document.getElementById("setupQrOpenBtn");
  const copyBtn = document.getElementById("setupQrCopyBtn");
  const saveBtn = document.getElementById("setupQrSaveBtn");

  function getCurrentEnrollUrl() {
    if (!enrollUrlHolder || !enrollUrlHolder.dataset.enrollUrl) return "";
    return String(enrollUrlHolder.dataset.enrollUrl).trim();
  }
  const details = document.getElementById("setupQrDetails");
  const countdownEl = document.getElementById("setupQrCountdown");
  const msg = document.getElementById("setupQrMsg");
  const instructionsTitle = document.getElementById("setupQrInstructionsTitle");
  const instructionsList = document.getElementById("setupQrInstructions");

  // Manual Login modal elements
  const manualLoginBtnTakAware = document.getElementById("manualLoginBtnTakAware");
  const manualLoginBtnAtak = document.getElementById("manualLoginBtnAtak");
  const manualLoginOverlay = document.getElementById("manualLoginOverlay");
  const manualLoginCloseBtn = document.getElementById("manualLoginCloseBtn");
  const manualLoginInstructionsTitle = document.getElementById("manualLoginInstructionsTitle");
  const manualLoginInstructions = document.getElementById("manualLoginInstructions");
  const manualLoginDetails = document.getElementById("manualLoginDetails");

  // Which app the user is scanning with (controls modal instructions)
  let scanMode = "takaware"; // "takaware" | "atak"

  function setScanInstructions(mode) {
    scanMode = mode;

    const isTakAware = mode === "takaware";
    instructionsTitle.textContent = isTakAware ? "TAK Aware (iOS): How to Scan" : "ATAK (Android): How to Scan";

    const steps = isTakAware
      ? [
          "Open TAK Aware on your iOS device.",
          "When prompted, allow Location access and set it to 'Always Allow'.",
          "Enter your assigned Call Sign / Team / Role (per your welcome email).",
          "Tap 'Connect to a TAK Server', then choose 'Scan QR Code'.",
          "Allow camera access and scan the QR until you see 'Status: Succeeded'."
        ]
      : [
          "Open the camera on your Android device.",
          "Point your camera at the QR code and select the notification to open the link.",
          "Select Yes to perform quick enrollment inside ATAK."
        ];

    instructionsList.innerHTML = steps.map(s => `<li>${s}</li>`).join("");
  }

  function setManualLoginInstructions(mode) {
    const isTakAware = mode === "takaware";
    manualLoginInstructionsTitle.textContent = isTakAware ? "TAK Aware (iOS): How to Manually Configure" : "ATAK (Android): How to Manually Configure";

    const steps = isTakAware
      ? [
          "Open TAK Aware on your iOS device.",
          "When prompted, allow Location access and set it to 'Always Allow'.",
          "Enter your assigned Call Sign / Team / Role (per your welcome email).",
          "Tap 'Connect to a TAK Server', then choose 'Certificate Enrollment'.",
          "Enter the hostname: <strong><%= takHost || 'your TAK server hostname' %></strong>",
          `Enter your username and password: <strong>${CURRENT_USERNAME}</strong>`,
          "Tap 'Start Enrollment', if successful, you should see 'Status: Succeeded'.",
          "You can then tap 'Close'."
        ]
      : [
          "Open ATAK on your Android device.",
          "Tap the menu icon and navigate to 'Settings'.",
          "Select 'Network Preferences' and select 'TAK Servers'.",
          "Tap the three lines in the top right and select 'Add'.",
          "Enter the address: <strong><%= takHost || 'your TAK server hostname' %></strong>",
          `Select 'Use Authentication' and enter your username and password: <strong>${CURRENT_USERNAME}</strong>`,
          "Select 'Enroll for Client Certificate' and <strong>DESELECT</strong> 'Enroll with Preconfigured Trust'.",
          "Select 'Ok' and you should see 'TAK Server registration succeeded'."
        ];

    manualLoginInstructions.innerHTML = steps.map(s => `<li>${s}</li>`).join("");
  }

  // --- IMPORTANT: make cache user-specific to prevent cross-user QR reuse ---
  const CURRENT_USERNAME = "<%= (authUser && authUser.username) ? authUser.username : '' %>";
  const CACHE_KEY = CURRENT_USERNAME ? `takPortal.setupDevice.enrollQr.v1:${CURRENT_USERNAME}` : null;
  const LEGACY_CACHE_KEY = "takPortal.setupDevice.enrollQr.v1";

  let cached = null; // { username, token, expiresAt, enrollUrl, qrCode }
  let countdownTimer = null;

  function setMsg(el, text, ok = true) {
    el.textContent = text || "";
    el.className = "msg " + (ok ? "ok" : "bad");
  }

  function safeParseJson(s) {
    try { return JSON.parse(s); } catch { return null; }
  }

  function isValidCacheObject(obj) {
    if (!obj || !obj.expiresAt) return false;
    const exp = new Date(obj.expiresAt);
    if (Number.isNaN(exp.getTime())) return false;
    if (Date.now() >= exp.getTime()) return false;
    return true;
  }

  function loadCache() {
    // Clean up old global key if it exists (prevents surprises)
    try {
      const legacy = localStorage.getItem(LEGACY_CACHE_KEY);
      if (legacy) localStorage.removeItem(LEGACY_CACHE_KEY);
    } catch {}

    if (!CACHE_KEY) return null;

    const raw = localStorage.getItem(CACHE_KEY);
    const obj = raw ? safeParseJson(raw) : null;
    if (!isValidCacheObject(obj)) return null;

    // Hard safety: don't ever reuse another user's cached QR
    if (obj.username && CURRENT_USERNAME && obj.username !== CURRENT_USERNAME) {
      try { localStorage.removeItem(CACHE_KEY); } catch {}
      return null;
    }

    // If we couldn't determine current username, be conservative and do not reuse cache
    if (!CURRENT_USERNAME) return null;

    return obj;
  }

  function saveCache(obj) {
    if (!CACHE_KEY) return; // if username unknown, do not cache
    if (!obj || !obj.username || obj.username !== CURRENT_USERNAME) return;
    try { localStorage.setItem(CACHE_KEY, JSON.stringify(obj)); } catch {}
  }

  function clearCountdown() {
    if (countdownTimer) {
      clearInterval(countdownTimer);
      countdownTimer = null;
    }
  }

  function fmtRemain(ms) {
    const total = Math.max(0, Math.floor(ms / 1000));
    const m = Math.floor(total / 60);
    const s = total % 60;
    return String(m).padStart(2, "0") + ":" + String(s).padStart(2, "0");
  }

  function startCountdown(expiresAt) {
    clearCountdown();
    const exp = new Date(expiresAt);

    const tick = () => {
      const remain = exp.getTime() - Date.now();
      if (remain <= 0) {
        countdownEl.textContent = "QR Code Expired";
        if (enrollUrlHolder) enrollUrlHolder.dataset.enrollUrl = "";
        openUrlBtn.disabled = true;
        copyBtn.disabled = true;
        saveBtn.disabled = true;
        setMsg(msg, "This enrollment QR has expired. Click Scan QR Code to generate a new one.", false);
        clearCountdown();
        return;
      }
      countdownEl.textContent = "QR Code Expires In: " + fmtRemain(remain);
    };

    tick();
    countdownTimer = setInterval(tick, 1000);
  }

  async function copyToClipboard(text) {
    try {
      await navigator.clipboard.writeText(text);
      setMsg(msg, "Copied!", true);
    } catch (e) {
      const ta = document.createElement("textarea");
      ta.value = text;
      ta.style.position = "fixed";
      ta.style.opacity = "0";
      document.body.appendChild(ta);
      ta.select();
      document.execCommand("copy");
      document.body.removeChild(ta);
      setMsg(msg, "Copied!", true);
    }
  }

  function openModal() {
    overlay.style.display = "flex";
    document.body.classList.add("noScroll");
  }

  function closeModal() {
    overlay.style.display = "none";
    document.body.classList.remove("noScroll");
    clearCountdown();
  }

  function openManualLoginModal() {
    manualLoginOverlay.style.display = "flex";
    document.body.classList.add("noScroll");
  }

  function closeManualLoginModal() {
    manualLoginOverlay.style.display = "none";
    document.body.classList.remove("noScroll");
  }

  function renderFromCache(obj) {
    cached = obj;
    qrImg.src = obj.qrCode || "";
    var url = (obj.enrollUrl && String(obj.enrollUrl).trim()) || "";
    if (enrollUrlHolder) enrollUrlHolder.dataset.enrollUrl = url;

    const chips = [];
    if (obj.username) chips.push(`<span class="chip">User: ${obj.username}</span>`);
    details.innerHTML = chips.join(" ");

    openUrlBtn.disabled = !url;
    copyBtn.disabled = !url;
    saveBtn.disabled = !(obj.username && obj.token);
    setMsg(msg, "QR ready.", true);

    startCountdown(obj.expiresAt);
    openModal();
  }

  async function fetchAndShowQr() {
    // UI reset
    qrImg.src = "";
    details.innerHTML = "";
    if (enrollUrlHolder) enrollUrlHolder.dataset.enrollUrl = "";
    openUrlBtn.disabled = true;
    copyBtn.disabled = true;
    saveBtn.disabled = true;
    countdownEl.textContent = "";
    setMsg(msg, "Generating enrollment QR...", true);

    const res = await fetch("/api/setup-my-device/enroll-qr", {
      method: "POST",
      headers: { "Content-Type": "application/json" },
      body: JSON.stringify({})
    });

    const rawText = await res.text();
    let data = {};
    try { data = JSON.parse(rawText); } catch { data = {}; }
    if (!res.ok || !data || !data.ok) {
      throw new Error((data && data.error) || "Failed to generate enrollment QR");
    }

    const obj = {
      username: data.username,
      tokenIdentifier: data.tokenIdentifier,
      token: data.token,
      expiresAt: data.expiresAt,
      enrollUrl: data.enrollUrl,
      qrCode: data.qrCode
    };

    // If server returns username, enforce match (extra safety)
    if (CURRENT_USERNAME && obj.username && obj.username !== CURRENT_USERNAME) {
      throw new Error("User mismatch while generating QR. Please refresh and try again.");
    }

    saveCache(obj);
    renderFromCache(obj);
  }

  async function handleScanClick(mode) {
    setScanInstructions(mode);
    setMsg(msg, "", true);

    // If we can't determine current username, don't reuse cache
    if (!CURRENT_USERNAME) {
      try {
        await fetchAndShowQr();
      } catch (err) {
        setMsg(msg, err?.message || String(err), false);
        openModal();
      }
      return;
    }

    const existing = loadCache();
    if (existing && existing.qrCode && existing.enrollUrl && existing.token) {
      renderFromCache(existing);
      return;
    }

    try {
      await fetchAndShowQr();
    } catch (err) {
      setMsg(msg, err?.message || String(err), false);
      openModal();
    }
  }

  function handleManualLoginClick(mode) {
    setManualLoginInstructions(mode);
    
    // Display username in details
    const chips = [];
    if (CURRENT_USERNAME) chips.push(`<span class="chip">User: ${CURRENT_USERNAME}</span>`);
    manualLoginDetails.innerHTML = chips.join(" ");
    
    openManualLoginModal();
  }

  // --- Android Step 3: Configure Device Preferences ---
  const preferenceScanQrBtn = document.getElementById("preferenceScanQrBtn");
  const preferenceManualBtn = document.getElementById("preferenceManualBtn");
  const preferenceQrOverlay = document.getElementById("preferenceQrOverlay");
  const preferenceQrCloseBtn = document.getElementById("preferenceQrCloseBtn");
  const preferenceQrImg = document.getElementById("preferenceQrImg");
  const preferenceQrDetails = document.getElementById("preferenceQrDetails");
  const preferenceQrMsg = document.getElementById("preferenceQrMsg");
  const preferenceManualOverlay = document.getElementById("preferenceManualOverlay");
  const preferenceManualCloseBtn = document.getElementById("preferenceManualCloseBtn");
  const preferenceManualInstructions = document.getElementById("preferenceManualInstructions");

  function setPreferenceMsg(text, ok = true) {
    preferenceQrMsg.textContent = text || "";
    preferenceQrMsg.className = "msg " + (ok ? "ok" : "bad");
  }

  async function fetchPreferenceData() {
    const res = await fetch("/api/setup-my-device/preference-data");
    const rawText = await res.text();
    let data = {};
    try { data = JSON.parse(rawText); } catch { data = {}; }
    if (!res.ok || !data.ok) throw new Error((data && data.error) || "Failed to load preference data");
    return data;
  }

  function openPreferenceQrModal() {
    preferenceQrOverlay.style.display = "flex";
    document.body.classList.add("noScroll");
  }

  function closePreferenceQrModal() {
    preferenceQrOverlay.style.display = "none";
    document.body.classList.remove("noScroll");
  }

  function openPreferenceManualModal() {
    preferenceManualOverlay.style.display = "flex";
    document.body.classList.add("noScroll");
  }

  function closePreferenceManualModal() {
    preferenceManualOverlay.style.display = "none";
    document.body.classList.remove("noScroll");
  }

  async function handlePreferenceScanClick() {
    setPreferenceMsg("Loading...", true);
    preferenceQrImg.src = "";
    preferenceQrDetails.innerHTML = "";
    openPreferenceQrModal();
    try {
      const data = await fetchPreferenceData();
      if (data.qrCode) preferenceQrImg.src = data.qrCode;
      const chips = [];
      if (data.callsign) chips.push(`<span class="chip">Callsign: ${escapeHtml(data.callsign)}</span>`);
      if (data.teamLabel) chips.push(`<span class="chip">Team: ${escapeHtml(data.teamLabel)}</span>`);
      if (data.roleLabel) chips.push(`<span class="chip">Role: ${escapeHtml(data.roleLabel)}</span>`);
      preferenceQrDetails.innerHTML = chips.join(" ");
      setPreferenceMsg("", true);
    } catch (err) {
      setPreferenceMsg(err?.message || String(err), false);
    }
  }

  function escapeHtml(s) {
    const div = document.createElement("div");
    div.textContent = s;
    return div.innerHTML;
  }

  async function handlePreferenceManualClick() {
    preferenceManualInstructions.innerHTML = "";
    openPreferenceManualModal();
    try {
      const data = await fetchPreferenceData();
      const callsign = (data.callsign && escapeHtml(data.callsign)) || "";
      const team = (data.teamLabel && escapeHtml(data.teamLabel)) || "";
      preferenceManualInstructions.innerHTML = [
        "Open ATAK on your Android device.",
        "Tap the menu icon and navigate to 'Settings'.",
        "Select callsign and device preferences.",
        "Select Callsign Preferences.",
        "Select My Callsign and enter: <strong>" + callsign + "</strong>",
        "Select My Team and enter: <strong>" + team + "</strong>",
        "Exit out of the settings menu after entering these settings."
      ].map(function (s) { return "<li>" + s + "</li>"; }).join("");
    } catch (err) {
      preferenceManualInstructions.innerHTML = "<li class=\"msg bad\">" + escapeHtml(err?.message || "Failed to load preference data") + "</li>";
    }
  }

  preferenceScanQrBtn.addEventListener("click", handlePreferenceScanClick);
  preferenceManualBtn.addEventListener("click", handlePreferenceManualClick);
  preferenceQrCloseBtn.addEventListener("click", closePreferenceQrModal);
  preferenceManualCloseBtn.addEventListener("click", closePreferenceManualModal);
  preferenceQrOverlay.addEventListener("click", (e) => { if (e.target === preferenceQrOverlay) closePreferenceQrModal(); });
  preferenceManualOverlay.addEventListener("click", (e) => { if (e.target === preferenceManualOverlay) closePreferenceManualModal(); });

  // Attach handlers (buttons exist in DOM even when flows are hidden)
  scanQrBtnTakAware.addEventListener("click", () => handleScanClick("takaware"));
  scanQrBtnAtak.addEventListener("click", () => handleScanClick("atak"));
  manualLoginBtnTakAware.addEventListener("click", () => handleManualLoginClick("takaware"));
  manualLoginBtnAtak.addEventListener("click", () => handleManualLoginClick("atak"));

  closeBtn.addEventListener("click", closeModal);
  overlay.addEventListener("click", (e) => {
    if (e.target === overlay) closeModal();
  });
  
  manualLoginCloseBtn.addEventListener("click", closeManualLoginModal);
  manualLoginOverlay.addEventListener("click", (e) => {
    if (e.target === manualLoginOverlay) closeManualLoginModal();
  });
  
  document.addEventListener("keydown", (e) => {
    if (e.key === "Escape") {
      if (overlay.style.display !== "none") closeModal();
      if (manualLoginOverlay.style.display !== "none") closeManualLoginModal();
      if (preferenceQrOverlay.style.display !== "none") closePreferenceQrModal();
      if (preferenceManualOverlay.style.display !== "none") closePreferenceManualModal();
    }
  });

  openUrlBtn.addEventListener("click", () => {
    var url = getCurrentEnrollUrl();
    if (!url) return;
    var a = document.createElement("a");
    a.href = url;
    a.target = "_blank";
    a.rel = "noopener noreferrer";
    document.body.appendChild(a);
    a.click();
    document.body.removeChild(a);
  });

  copyBtn.addEventListener("click", () => {
    var url = getCurrentEnrollUrl();
    if (url) copyToClipboard(url);
  });

  saveBtn.addEventListener("click", () => {
    if (!cached || !cached.username || !cached.token) {
      setMsg(msg, "Generate a QR first.", false);
      return;
    }

    const url =
      `/api/qr/download?username=${encodeURIComponent(cached.username)}` +
      `&token=${encodeURIComponent(cached.token)}`;

    const a = document.createElement("a");
    a.href = url;
    a.download = "";
    document.body.appendChild(a);
    a.click();
    document.body.removeChild(a);

    setMsg(msg, "Downloading high-res QR...", true);
  });
</script>