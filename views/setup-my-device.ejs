<%- include("partials/header") %>
<%- include("partials/sidebar") %>

<main class="main">
  <h1>Setup My Device</h1>

  <div class="card">
    <h2>Step 1: Download the TAK App</h2>
    <div class="grid2">
      <a
        href="https://apps.apple.com/us/app/tak-aware/id6738631659"
        target="_blank"
        rel="noopener noreferrer"
        class="btn tile"
      >
        <span class="title">iOS - TAK Aware</span>
        <span class="desc">Download TAK Aware for iPhone or iPad.</span>
      </a>

      <a
        href="https://play.google.com/store/apps/details?id=com.atakmap.app.civ"
        target="_blank"
        rel="noopener noreferrer"
        class="btn tile"
      >
        <span class="title">Android - ATAK</span>
        <span class="desc">Download ATAK for Android devices.</span>
      </a>
    </div>
  </div>

  <div class="card">
    <h2>Step 2: Enroll Your Device (DEVELOPMENT IN PROGRESS)</h2>


    <div class="grid2">
      <button type="button" class="btn tile">
        <span class="title">Scan QR Code</span>
        <span class="desc">
          Scan an enrollment QR code to automatically configure your device.
        </span>
      </button>
    <!--
      <button type="button" class="btn tile">
        <span class="title">Manual Enrollment</span>
        <span class="desc">
          Enter your enrollment details manually if you don’t have a camera.
        </span>
      </button>
    </div>
  -->
  </div>
</main>
