<%- include("partials/header") %>
<%- include("partials/sidebar") %>

<main class="main data-packages-page">
  <div class="data-packages-hero">
    <h1>Data Packages Manager</h1>
  </div>

  <div id="statusBanner" class="card data-packages-status" style="display:none;" role="status"></div>

  <div class="card">
    <h2 style="margin-top:0;">Upload Data Package</h2>
    <div class="row data-packages-upload-row">
      <label class="data-packages-upload-field">
        Choose File
        <input type="file" id="uploadFile" />
      </label>
      <label class="data-packages-upload-field">
        Assign Groups
        <select id="uploadGroups" multiple size="6"></select>
      </label>
      <label class="data-packages-upload-btn-wrap">
        <span class="data-packages-upload-spacer" aria-hidden="true">&nbsp;</span>
        <button type="button" class="btn success data-packages-upload-btn" id="btnUploadPackage">Upload</button>
      </label>
    </div>
    <div class="settings-help" style="margin-top:8px;">Keyword is fixed to <code>missionpackage</code>. Tool is fixed to <code>public</code>.</div>
    <div id="uploadMsg" class="msg" style="margin-top:10px;"></div>
  </div>

  <div class="card" style="margin-top:1.25rem;">
    <h2 style="margin-top:0;">Existing Data Packages</h2>
    <div class="row" style="flex-wrap:wrap; align-items:flex-end; gap:12px;">
      <label style="min-width:220px;">
        Filter
        <input type="search" id="packageFilter" placeholder="Filter by filename/group/creator..." autocomplete="off" />
      </label>
      <button type="button" class="btn" id="btnRefreshPackages">Refresh</button>
    </div>
    <div id="packagesMsg" class="msg" style="margin:12px 0 0 0;"></div>
    <div class="data-packages-table-scroll">
      <table class="table data-packages-table">
        <thead>
          <tr>
            <th>Filename</th>
            <th>Size</th>
            <th>Creator</th>
            <th>Groups</th>
            <th>Expiration</th>
            <th>Tool</th>
            <th>Created</th>
            <th style="min-width:120px;">Actions</th>
          </tr>
        </thead>
        <tbody id="packagesTbody"></tbody>
      </table>
    </div>
  </div>

  <details class="card" style="margin-top:1.25rem;">
    <summary style="cursor:pointer;font-weight:600;user-select:none;">
      Archived Data Packages <span id="archivedCountWrap">(<span id="archivedCount">0</span>)</span>
    </summary>
    <div style="margin-top:12px;">
      <div id="archivedPackagesMsg" class="msg" style="margin-left:0;"></div>
      <div class="data-packages-table-scroll">
        <table class="table data-packages-table data-packages-table-archived">
          <thead>
            <tr>
              <th>Filename</th>
              <th>Size</th>
              <th>Creator</th>
              <th>Groups</th>
              <th>Expiration</th>
              <th>Tool</th>
              <th>Created</th>
              <th style="min-width:120px;">Actions</th>
            </tr>
          </thead>
          <tbody id="archivedPackagesTbody"></tbody>
        </table>
      </div>
    </div>
  </details>
</main>

<style>
  .data-packages-page.main {
    min-width: 0;
    max-width: 100%;
    box-sizing: border-box;
  }
  .data-packages-page .muted { color: var(--muted); }
  .data-packages-status.msg { margin-left: 0; padding: 12px 14px; border-radius: 10px; border: 1px solid var(--line); }
  .data-packages-status.bad { border-color: rgba(255,80,80,.45); background: rgba(255,80,80,.08); }
  .data-packages-page .card,
  .data-packages-page .data-packages-table-scroll {
    min-width: 0;
    max-width: 100%;
    box-sizing: border-box;
  }
  .data-packages-page .data-packages-upload-row {
    flex-wrap: wrap;
    align-items: flex-end;
    gap: 12px;
  }
  .data-packages-page .data-packages-upload-field {
    min-width: 0;
    flex: 1 1 260px;
  }
  .data-packages-page .data-packages-upload-field input,
  .data-packages-page .data-packages-upload-field select {
    width: 100%;
    max-width: 100%;
    box-sizing: border-box;
  }
  .data-packages-page .data-packages-upload-btn-wrap {
    flex: 1 1 100%;
    min-width: 0;
  }
  .data-packages-page .data-packages-upload-spacer {
    display: none;
  }
  .data-packages-page .data-packages-upload-btn {
    width: 100%;
    box-sizing: border-box;
  }
  @media (min-width: 640px) {
    .data-packages-page .data-packages-upload-btn-wrap {
      flex: 0 0 auto;
      width: auto;
    }
    .data-packages-page .data-packages-upload-spacer {
      display: inline;
    }
    .data-packages-page .data-packages-upload-btn {
      width: auto;
    }
  }
  .data-packages-page .data-packages-table-scroll {
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
    margin-top: 12px;
    width: 100%;
  }
  .data-packages-page .data-packages-table {
    width: 100%;
  }
  @media (min-width: 641px) {
    .data-packages-page .data-packages-table {
      min-width: 720px;
    }
  }
  .data-packages-page .data-packages-actions-cell {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
    align-items: center;
  }
  .data-packages-page .data-packages-actions-cell .btn {
    margin: 0 !important;
  }
</style>

<script>
(function () {
  var API = "/api/data-packages";
  var ACTIVE_KEYWORD = "missionpackage";
  var ARCHIVED_KEYWORD = "archived_mission";

  var statusBanner = document.getElementById("statusBanner");
  var uploadFile = document.getElementById("uploadFile");
  var uploadGroups = document.getElementById("uploadGroups");
  var btnUploadPackage = document.getElementById("btnUploadPackage");
  var uploadMsg = document.getElementById("uploadMsg");
  var packageFilter = document.getElementById("packageFilter");
  var btnRefreshPackages = document.getElementById("btnRefreshPackages");
  var packagesMsg = document.getElementById("packagesMsg");
  var archivedPackagesMsg = document.getElementById("archivedPackagesMsg");
  var packagesTbody = document.getElementById("packagesTbody");
  var archivedPackagesTbody = document.getElementById("archivedPackagesTbody");
  var archivedCount = document.getElementById("archivedCount");

  var packagesCache = [];

  function esc(s) {
    return String(s == null ? "" : s)
      .replace(/&/g, "&amp;")
      .replace(/</g, "&lt;")
      .replace(/>/g, "&gt;")
      .replace(/"/g, "&quot;");
  }

  function setMsg(el, text, ok) {
    if (!el) return;
    el.textContent = text || "";
    el.className = "msg " + (ok === true ? "ok" : ok === false ? "bad" : "");
  }

  function firstVal(obj, keys) {
    if (!obj || typeof obj !== "object") return "";
    for (var i = 0; i < keys.length; i++) {
      var k = keys[i];
      if (obj[k] != null && obj[k] !== "") return String(obj[k]);
    }
    return "";
  }

  function asNumber(v) {
    var n = Number(v);
    return Number.isFinite(n) ? n : null;
  }

  function fmtSize(v) {
    var n = asNumber(v);
    if (n == null || n < 0) return "";
    if (n < 1024) return n + " B";
    if (n < 1024 * 1024) return (n / 1024).toFixed(1) + " KB";
    return (n / (1024 * 1024)).toFixed(1) + " MB";
  }

  function normalizeList(payload) {
    if (!payload) return [];
    if (Array.isArray(payload.items)) return payload.items;
    if (Array.isArray(payload.data)) return payload.data;
    if (Array.isArray(payload)) return payload;
    return [];
  }

  function normalizeKeywords(pkg) {
    if (Array.isArray(pkg.keywords)) {
      return pkg.keywords
        .map(function (k) { return String(k || "").trim(); })
        .filter(Boolean);
    }
    var raw = firstVal(pkg, ["keywords", "Keywords", "keyword", "tags"]);
    if (!raw) return [];
    return String(raw)
      .split(",")
      .map(function (k) { return k.trim(); })
      .filter(Boolean);
  }

  function hasKeyword(pkg, keyword) {
    var target = String(keyword || "").trim().toLowerCase();
    if (!target) return false;
    var list = normalizeKeywords(pkg);
    for (var i = 0; i < list.length; i++) {
      if (String(list[i]).toLowerCase() === target) return true;
    }
    return false;
  }

  function stripTakPrefix(name) {
    var n = String(name || "").trim();
    return n.toLowerCase().indexOf("tak_") === 0 ? n.slice(4) : n;
  }

  async function loadGroups() {
    if (!uploadGroups) return;
    uploadGroups.innerHTML = "";
    try {
      var res = await fetch("/api/groups");
      var j = await res.json();
      if (!res.ok || !Array.isArray(j)) throw new Error((j && j.error) || "Failed to load groups.");

      var sorted = j
        .filter(function (g) {
          var raw = String(g && g.name || "").trim().toLowerCase();
          return raw.indexOf("tak_") === 0;
        })
        .sort(function (a, b) {
          return stripTakPrefix(String(a && a.name || "")).localeCompare(
            stripTakPrefix(String(b && b.name || ""))
          );
        });
      for (var i = 0; i < sorted.length; i++) {
        var g = sorted[i] || {};
        var name = String(g.name || "").trim();
        if (!name) continue;
        var opt = document.createElement("option");
        opt.value = name;
        opt.textContent = stripTakPrefix(name);
        uploadGroups.appendChild(opt);
      }
    } catch (e) {
      setMsg(uploadMsg, e.message || "Could not load groups.", false);
    }
  }

  async function loadStatus() {
    try {
      var res = await fetch(API + "/status");
      var j = await res.json();
      if (!res.ok) throw new Error((j && j.error) || "Status failed");
      if (!j.configured) {
        statusBanner.style.display = "block";
        statusBanner.className = "card data-packages-status msg bad";
        statusBanner.innerHTML =
          "<strong>TAK is not available from the portal.</strong> " +
          (j.bypassed
            ? "TAK_BYPASS_ENABLED is on, or TAK_URL / client certificates are not configured."
            : "Set TAK_URL and API client cert/key or P12 in Server Settings.");
        return false;
      }
      statusBanner.style.display = "none";
      statusBanner.innerHTML = "";
      return true;
    } catch (e) {
      statusBanner.style.display = "block";
      statusBanner.className = "card data-packages-status msg bad";
      statusBanner.textContent = e.message || "Could not load status.";
      return false;
    }
  }

  async function loadPackages() {
    setMsg(packagesMsg, "Loading packages…", undefined);
    setMsg(archivedPackagesMsg, "", undefined);
    try {
      var res = await fetch(API + "/packages");
      var text = await res.text();
      var j;
      try {
        j = JSON.parse(text);
      } catch (_) {
        throw new Error("Invalid server response");
      }
      if (!res.ok) throw new Error((j && j.error) || text.slice(0, 400));
      packagesCache = normalizeList(j);
      renderTables();

      var activeCount = packagesCache.filter(function (p) { return hasKeyword(p, ACTIVE_KEYWORD); }).length;
      if (!activeCount) setMsg(packagesMsg, "No active mission packages found.", true);
      else setMsg(packagesMsg, "", true);
    } catch (e) {
      setMsg(packagesMsg, e.message || "Failed to load packages", false);
      setMsg(archivedPackagesMsg, e.message || "Failed to load archived packages", false);
    }
  }

  function packageToRow(pkg, tbody, isArchived) {
    var filename = firstVal(pkg, ["filename", "name", "original_filename"]);
    var hash = firstVal(pkg, ["hash", "sha256", "uid", "id"]);
    var size = firstVal(pkg, ["size", "content_length", "contentLength"]);
    var creator = firstVal(pkg, ["creator_uid", "creatorUid", "creator", "owner"]);
    var groups = firstVal(pkg, ["groups", "Groups", "group", "Group"]);
    var expiration = firstVal(pkg, ["expiration", "Expiration", "expires", "expiresAt"]);
    var tool = firstVal(pkg, ["tool", "Tool"]);
    var created = firstVal(pkg, ["created_at", "createTime", "created", "timestamp"]);

    var tr = document.createElement("tr");
    tr.innerHTML =
      "<td style='max-width:240px;'>" + esc(filename || "(unnamed)") + "</td>" +
      "<td style='white-space:nowrap;'>" + esc(fmtSize(size)) + "</td>" +
      "<td>" + esc(creator) + "</td>" +
      "<td style='max-width:170px;font-size:12px;'>" + esc(groups) + "</td>" +
      "<td style='white-space:nowrap;font-size:12px;'>" + esc(expiration) + "</td>" +
      "<td style='font-size:12px;'>" + esc(tool) + "</td>" +
      "<td style='font-size:12px;white-space:nowrap;'>" + esc(created) + "</td>" +
      "<td></td>";

    var tdAct = tr.querySelector("td:last-child");
    tdAct.className = "data-packages-actions-cell";

    var bDl = document.createElement("button");
    bDl.type = "button";
    bDl.className = "btn";
    bDl.textContent = "Download";
    bDl.disabled = !hash;
    bDl.addEventListener("click", (function (h, fn) {
      return function () { downloadPackage(h, fn); };
    })(hash, filename));

    var bDel = document.createElement("button");
    bDel.type = "button";
    bDel.className = "btn danger";
    bDel.textContent = "Delete";
    bDel.disabled = !hash;
    bDel.addEventListener("click", (function (h, fn) {
      return function () { deletePackage(h, fn, isArchived); };
    })(hash, filename));

    tdAct.appendChild(bDl);
    tdAct.appendChild(bDel);
    tbody.appendChild(tr);
  }

  function renderTables() {
    var filt = ((packageFilter && packageFilter.value) || "").trim().toLowerCase();
    packagesTbody.innerHTML = "";
    archivedPackagesTbody.innerHTML = "";

    var activeCount = 0;
    var archivedCountValue = 0;
    for (var i = 0; i < packagesCache.length; i++) {
      var p = packagesCache[i] || {};
      var keywords = normalizeKeywords(p).join(" ");
      var hay = (
        firstVal(p, ["filename", "name", "original_filename"]) + " " +
        firstVal(p, ["creator_uid", "creatorUid", "creator", "owner"]) + " " +
        firstVal(p, ["groups", "Groups", "group", "Group"]) + " " +
        firstVal(p, ["tool", "Tool"]) + " " +
        keywords
      ).toLowerCase();
      if (filt && hay.indexOf(filt) === -1) continue;

      if (hasKeyword(p, ACTIVE_KEYWORD)) {
        activeCount += 1;
        packageToRow(p, packagesTbody, false);
        continue;
      }
      if (hasKeyword(p, ARCHIVED_KEYWORD)) {
        archivedCountValue += 1;
        packageToRow(p, archivedPackagesTbody, true);
      }
    }

    if (activeCount === 0) {
      var trA = document.createElement("tr");
      var tdA = document.createElement("td");
      tdA.colSpan = 8;
      tdA.textContent = "No active mission packages.";
      trA.appendChild(tdA);
      packagesTbody.appendChild(trA);
    }
    if (archivedCountValue === 0) {
      var trR = document.createElement("tr");
      var tdR = document.createElement("td");
      tdR.colSpan = 8;
      tdR.textContent = "No archived mission packages.";
      trR.appendChild(tdR);
      archivedPackagesTbody.appendChild(trR);
    }
    if (archivedCount) archivedCount.textContent = String(archivedCountValue);
  }

  async function uploadPackage() {
    setMsg(uploadMsg, "Uploading…", undefined);
    try {
      var file = uploadFile && uploadFile.files && uploadFile.files[0];
      if (!file) throw new Error("Choose a file to upload.");

      var selectedGroupNames = [];
      if (uploadGroups && uploadGroups.options) {
        for (var i = 0; i < uploadGroups.options.length; i++) {
          var opt = uploadGroups.options[i];
          if (opt.selected) selectedGroupNames.push(opt.value);
        }
      }

      var fd = new FormData();
      fd.append("file", file, file.name || "data-package.zip");
      fd.append("keywords", ACTIVE_KEYWORD);
      fd.append("tool", "public");
      if (selectedGroupNames.length) fd.append("groups", selectedGroupNames.join(","));

      var res = await fetch(API + "/packages/upload", {
        method: "POST",
        body: fd,
      });
      var text = await res.text();
      var j;
      try {
        j = JSON.parse(text);
      } catch (_) {
        j = {};
      }
      if (!res.ok) throw new Error((j && j.error) || text.slice(0, 500) || "Upload failed");
      setMsg(uploadMsg, "Data package uploaded.", true);
      uploadFile.value = "";
      await loadPackages();
    } catch (e) {
      setMsg(uploadMsg, e.message || "Upload failed", false);
    }
  }

  async function deletePackage(hash, filename, isArchived) {
    var ok = window.confirm("Delete data package \"" + (filename || hash) + "\"?");
    if (!ok) return;
    setMsg(isArchived ? archivedPackagesMsg : packagesMsg, "Deleting package…", undefined);
    try {
      var res = await fetch(API + "/packages/" + encodeURIComponent(hash), { method: "DELETE" });
      var text = await res.text();
      var j;
      try {
        j = JSON.parse(text);
      } catch (_) {
        j = {};
      }
      if (!res.ok) throw new Error((j && j.error) || "Delete failed");
      setMsg(isArchived ? archivedPackagesMsg : packagesMsg, "Package deleted.", true);
      await loadPackages();
    } catch (e) {
      setMsg(isArchived ? archivedPackagesMsg : packagesMsg, e.message || "Delete failed", false);
    }
  }

  async function downloadPackage(hash, filename) {
    setMsg(packagesMsg, "Downloading package…", undefined);
    try {
      var url = API + "/packages/download?hash=" + encodeURIComponent(hash);
      var res = await fetch(url);
      if (!res.ok) {
        var errText = await res.text().catch(function () { return ""; });
        var errMsg = "Download failed (HTTP " + res.status + ")";
        try {
          var j = JSON.parse(errText);
          if (j && j.error) errMsg = j.error;
        } catch (_) {}
        throw new Error(errMsg);
      }
      var blob = await res.blob();
      var name = filename || ("data-package-" + hash + ".zip");
      var a = document.createElement("a");
      a.href = URL.createObjectURL(blob);
      a.download = name;
      document.body.appendChild(a);
      a.click();
      a.remove();
      setTimeout(function () {
        try { URL.revokeObjectURL(a.href); } catch (_) {}
      }, 2500);
      setMsg(packagesMsg, "Download started.", true);
    } catch (e) {
      setMsg(packagesMsg, e.message || "Download failed", false);
    }
  }

  if (btnUploadPackage) btnUploadPackage.addEventListener("click", uploadPackage);
  if (btnRefreshPackages) btnRefreshPackages.addEventListener("click", loadPackages);
  if (packageFilter) packageFilter.addEventListener("input", renderTables);

  loadStatus().then(function (ok) {
    if (!ok) return;
    loadGroups();
    loadPackages();
  });
})();
</script>
<%- include("partials/header") %>
<%- include("partials/sidebar") %>

<main class="main data-packages-page">
  <div class="data-packages-hero">
    <h1>Data Packages Manager</h1>
  </div>

  <div id="statusBanner" class="card data-packages-status" style="display:none;" role="status"></div>

  <div class="card">
    <h2 style="margin-top:0;">Upload Data Package</h2>
    <div class="row" style="flex-wrap:wrap; align-items:flex-end; gap:12px;">
      <label style="min-width:260px;">
        File
        <input type="file" id="uploadFile" />
      </label>
      <label style="min-width:240px;">
        Keywords (optional)
        <input type="text" id="uploadKeywords" placeholder="comma,separated,keywords" />
      </label>
      <label style="min-width:180px;">
        Tool (optional)
        <input type="text" id="uploadTool" placeholder="e.g. Data Package" />
      </label>
      <label style="min-width:180px;">
        Creator UID (optional)
        <input type="text" id="uploadCreatorUid" placeholder="defaults to tak-portal" />
      </label>
      <label>
        &nbsp;
        <button type="button" class="btn success" id="btnUploadPackage">Upload</button>
      </label>
    </div>
    <div id="uploadMsg" class="msg" style="margin-top:10px;"></div>
  </div>

  <div class="card">
    <h2 style="margin-top:0;">Existing Data Packages</h2>
    <div class="row" style="flex-wrap:wrap; align-items:flex-end; gap:12px;">
      <label style="min-width:220px;">
        Filter
        <input type="search" id="packageFilter" placeholder="Filter by filename/hash..." autocomplete="off" />
      </label>
      <button type="button" class="btn" id="btnRefreshPackages">Refresh</button>
      <a class="btn" href="https://docs.opentakserver.io/data_packages.html" target="_blank" rel="noopener">Docs</a>
    </div>
    <div id="packagesMsg" class="msg" style="margin:12px 0 0 0;"></div>
    <div style="overflow-x:auto; margin-top:12px;">
      <table class="table data-packages-table">
        <thead>
          <tr>
            <th>Filename</th>
            <th>Hash</th>
            <th>Type</th>
            <th>Size</th>
            <th>Creator</th>
            <th>Groups</th>
            <th>Expiration</th>
            <th>Tool</th>
            <th>Keywords</th>
            <th>Created</th>
            <th style="min-width:190px;">Actions</th>
          </tr>
        </thead>
        <tbody id="packagesTbody"></tbody>
      </table>
    </div>
  </div>
</main>

<div class="modalOverlay" id="metadataModal" style="display:none;">
  <div class="modal" role="dialog" aria-modal="true" aria-labelledby="metadataTitle" style="width:min(620px, 95vw);">
    <div class="modalHeader">
      <h2 id="metadataTitle" style="margin:0;">Edit Package Metadata</h2>
      <button type="button" class="btn" id="metadataClose">Close</button>
    </div>
    <div class="modalBody">
      <div id="metadataMsg" class="msg" style="margin-bottom:10px;"></div>
      <label style="display:block;">
        Hash
        <input type="text" id="metaHash" readonly style="width:100%; box-sizing:border-box; opacity:0.8;" />
      </label>
      <label style="display:block; margin-top:10px;">
        Tool
        <input type="text" id="metaTool" placeholder="e.g. Data Package" style="width:100%; box-sizing:border-box;" />
      </label>
      <label style="display:block; margin-top:10px;">
        Keywords (comma-separated)
        <input type="text" id="metaKeywords" placeholder="ops,map,overlay" style="width:100%; box-sizing:border-box;" />
      </label>
      <div id="metaFlagsWrap" style="margin-top:12px; display:none;">
        <label class="chk-inline">
          <input type="checkbox" id="metaInstallEnroll" />
          Install on enrollment
        </label>
        <label class="chk-inline" style="margin-left:12px;">
          <input type="checkbox" id="metaInstallConnection" />
          Install on connection
        </label>
      </div>
      <div class="row" style="margin-top:14px; gap:10px;">
        <button type="button" class="btn success" id="metadataSave">Save Metadata</button>
      </div>
    </div>
  </div>
</div>

<style>
  .data-packages-page .muted { color: var(--muted); }
  .data-packages-status.msg { margin-left: 0; padding: 12px 14px; border-radius: 10px; border: 1px solid var(--line); }
  .data-packages-status.bad { border-color: rgba(255,80,80,.45); background: rgba(255,80,80,.08); }
  .data-packages-table code { font-size: 11px; word-break: break-all; }
  .chk-inline { display: inline-flex; align-items: center; gap: 6px; color: var(--muted); user-select:none; }
</style>

<script>
(function () {
  var API = "/api/data-packages";

  var statusBanner = document.getElementById("statusBanner");
  var uploadFile = document.getElementById("uploadFile");
  var uploadKeywords = document.getElementById("uploadKeywords");
  var uploadTool = document.getElementById("uploadTool");
  var uploadCreatorUid = document.getElementById("uploadCreatorUid");
  var btnUploadPackage = document.getElementById("btnUploadPackage");
  var uploadMsg = document.getElementById("uploadMsg");
  var packageFilter = document.getElementById("packageFilter");
  var btnRefreshPackages = document.getElementById("btnRefreshPackages");
  var packagesMsg = document.getElementById("packagesMsg");
  var packagesTbody = document.getElementById("packagesTbody");
  var metadataModal = document.getElementById("metadataModal");
  var metadataClose = document.getElementById("metadataClose");
  var metadataSave = document.getElementById("metadataSave");
  var metadataMsg = document.getElementById("metadataMsg");
  var metaHash = document.getElementById("metaHash");
  var metaTool = document.getElementById("metaTool");
  var metaKeywords = document.getElementById("metaKeywords");
  var metaFlagsWrap = document.getElementById("metaFlagsWrap");
  var metaInstallEnroll = document.getElementById("metaInstallEnroll");
  var metaInstallConnection = document.getElementById("metaInstallConnection");

  var packagesCache = [];
  var editingHash = "";

  function esc(s) {
    return String(s == null ? "" : s)
      .replace(/&/g, "&amp;")
      .replace(/</g, "&lt;")
      .replace(/>/g, "&gt;")
      .replace(/"/g, "&quot;");
  }

  function setMsg(el, text, ok) {
    if (!el) return;
    el.textContent = text || "";
    el.className = "msg " + (ok === true ? "ok" : ok === false ? "bad" : "");
  }

  function setMetadataMsg(text, ok) {
    setMsg(metadataMsg, text, ok);
  }

  function firstVal(obj, keys) {
    if (!obj || typeof obj !== "object") return "";
    for (var i = 0; i < keys.length; i++) {
      var k = keys[i];
      if (obj[k] != null && obj[k] !== "") return String(obj[k]);
    }
    return "";
  }

  function asNumber(v) {
    var n = Number(v);
    return Number.isFinite(n) ? n : null;
  }

  function fmtSize(v) {
    var n = asNumber(v);
    if (n == null || n < 0) return "";
    if (n < 1024) return n + " B";
    if (n < 1024 * 1024) return (n / 1024).toFixed(1) + " KB";
    return (n / (1024 * 1024)).toFixed(1) + " MB";
  }

  function shortHash(v) {
    var s = String(v || "").trim();
    if (!s) return "";
    if (s.length <= 18) return s;
    return s.slice(0, 10) + "…" + s.slice(-6);
  }

  async function loadStatus() {
    try {
      var res = await fetch(API + "/status");
      var j = await res.json();
      if (!res.ok) throw new Error((j && j.error) || "Status failed");
      if (!j.configured) {
        statusBanner.style.display = "block";
        statusBanner.className = "card data-packages-status msg bad";
        statusBanner.innerHTML =
          "<strong>TAK is not available from the portal.</strong> " +
          (j.bypassed
            ? "TAK_BYPASS_ENABLED is on, or TAK_URL / client certificates are not configured."
            : "Set TAK_URL and API client cert/key or P12 in Server Settings.");
        return false;
      }
      statusBanner.style.display = "none";
      statusBanner.innerHTML = "";
      return true;
    } catch (e) {
      statusBanner.style.display = "block";
      statusBanner.className = "card data-packages-status msg bad";
      statusBanner.textContent = e.message || "Could not load status.";
      return false;
    }
  }

  function normalizeList(payload) {
    if (!payload) return [];
    if (Array.isArray(payload.items)) return payload.items;
    if (Array.isArray(payload.data)) return payload.data;
    if (Array.isArray(payload)) return payload;
    return [];
  }

  async function loadPackages() {
    setMsg(packagesMsg, "Loading packages…", undefined);
    try {
      var res = await fetch(API + "/packages");
      var text = await res.text();
      var j;
      try {
        j = JSON.parse(text);
      } catch (_) {
        throw new Error("Invalid server response");
      }
      if (!res.ok) throw new Error((j && j.error) || text.slice(0, 400));
      packagesCache = normalizeList(j);
      renderTable();
      setMsg(packagesMsg, packagesCache.length ? "" : "No data packages found.", true);
    } catch (e) {
      setMsg(packagesMsg, e.message || "Failed to load packages", false);
    }
  }

  function renderTable() {
    var filt = ((packageFilter && packageFilter.value) || "").trim().toLowerCase();
    packagesTbody.innerHTML = "";

    for (var i = 0; i < packagesCache.length; i++) {
      var p = packagesCache[i] || {};
      var filename = firstVal(p, ["filename", "name", "original_filename"]);
      var hash = firstVal(p, ["hash", "sha256", "uid", "id"]);
      var mime = firstVal(p, ["mime_type", "mimetype", "contentType", "type"]);
      var size = firstVal(p, ["size", "content_length", "contentLength"]);
      var creator = firstVal(p, ["creator_uid", "creatorUid", "creator", "owner"]);
      var groups = firstVal(p, ["groups", "Groups", "group", "Group"]);
      var expiration = firstVal(p, ["expiration", "Expiration", "expires", "expiresAt"]);
      var tool = firstVal(p, ["tool", "Tool"]);
      var keywords = "";
      if (Array.isArray(p.keywords)) keywords = p.keywords.join(", ");
      else keywords = firstVal(p, ["keywords", "Keywords", "keyword", "tags"]);
      var created = firstVal(p, ["created_at", "createTime", "created", "timestamp"]);

      var hay = (filename + " " + hash + " " + creator + " " + mime + " " + groups + " " + expiration + " " + tool + " " + keywords).toLowerCase();
      if (filt && hay.indexOf(filt) === -1) continue;

      var tr = document.createElement("tr");
      tr.innerHTML =
        "<td style='max-width:220px;'>" + esc(filename || "(unnamed)") + "</td>" +
        "<td title='" + esc(hash) + "'><code>" + esc(shortHash(hash)) + "</code></td>" +
        "<td style='font-size:12px;'>" + esc(mime) + "</td>" +
        "<td style='white-space:nowrap;'>" + esc(fmtSize(size)) + "</td>" +
        "<td>" + esc(creator) + "</td>" +
        "<td style='max-width:170px;font-size:12px;'>" + esc(groups) + "</td>" +
        "<td style='white-space:nowrap;font-size:12px;'>" + esc(expiration) + "</td>" +
        "<td style='font-size:12px;'>" + esc(tool) + "</td>" +
        "<td style='max-width:220px;font-size:12px;'>" + esc(keywords) + "</td>" +
        "<td style='font-size:12px;white-space:nowrap;'>" + esc(created) + "</td>" +
        "<td></td>";

      var tdAct = tr.querySelector("td:last-child");

      var bDl = document.createElement("button");
      bDl.type = "button";
      bDl.className = "btn";
      bDl.textContent = "Download";
      bDl.disabled = !hash;
      bDl.addEventListener("click", (function (h, fn) {
        return function () { downloadPackage(h, fn); };
      })(hash, filename));

      var bDel = document.createElement("button");
      bDel.type = "button";
      bDel.className = "btn danger";
      bDel.textContent = "Delete";
      bDel.disabled = !hash;
      bDel.addEventListener("click", (function (h, fn) {
        return function () { deletePackage(h, fn); };
      })(hash, filename));

      var bMeta = document.createElement("button");
      bMeta.type = "button";
      bMeta.className = "btn";
      bMeta.textContent = "Metadata";
      bMeta.disabled = !hash;
      bMeta.addEventListener("click", (function (h, p) {
        return function () { openMetadataModal(h, p); };
      })(hash, p));

      tdAct.appendChild(bDl);
      tdAct.appendChild(document.createTextNode(" "));
      tdAct.appendChild(bMeta);
      tdAct.appendChild(document.createTextNode(" "));
      tdAct.appendChild(bDel);
      packagesTbody.appendChild(tr);
    }
  }

  function closeMetadataModal() {
    if (!metadataModal) return;
    metadataModal.style.display = "none";
    document.body.classList.remove("noScroll");
    editingHash = "";
    setMetadataMsg("", undefined);
  }

  async function openMetadataModal(hash, pkgRow) {
    if (!hash) return;
    editingHash = hash;
    metaHash.value = hash;
    metaTool.value = firstVal(pkgRow, ["tool"]);
    metaKeywords.value = firstVal(pkgRow, ["keywords"]);
    metaFlagsWrap.style.display = "none";
    metaInstallEnroll.checked = false;
    metaInstallConnection.checked = false;
    setMetadataMsg("Loading metadata…", undefined);
    metadataModal.style.display = "flex";
    document.body.classList.add("noScroll");

    try {
      var res = await fetch(API + "/packages/" + encodeURIComponent(hash) + "/metadata");
      var text = await res.text();
      var j = {};
      try { j = JSON.parse(text); } catch (_) {}
      if (!res.ok) throw new Error((j && j.error) || "Failed to load metadata");

      metaTool.value = j.tool != null ? String(j.tool) : metaTool.value;
      if (Array.isArray(j.keywords)) metaKeywords.value = j.keywords.join(", ");
      else if (j.keywords != null) metaKeywords.value = String(j.keywords);

      var hasInstallFlags = j.installOnEnrollment != null || j.installOnConnection != null;
      if (hasInstallFlags) {
        metaFlagsWrap.style.display = "block";
        metaInstallEnroll.checked = j.installOnEnrollment === true;
        metaInstallConnection.checked = j.installOnConnection === true;
      }

      setMetadataMsg("", true);
    } catch (e) {
      setMetadataMsg(e.message || "Failed to load metadata", false);
    }
  }

  async function saveMetadata() {
    if (!editingHash) return;
    setMetadataMsg("Saving metadata…", undefined);
    try {
      var payload = {
        tool: metaTool.value.trim(),
        keywords: metaKeywords.value
          .split(",")
          .map(function (x) { return x.trim(); })
          .filter(Boolean),
      };
      if (metaFlagsWrap.style.display !== "none") {
        payload.installOnEnrollment = metaInstallEnroll.checked;
        payload.installOnConnection = metaInstallConnection.checked;
      }

      var res = await fetch(API + "/packages/" + encodeURIComponent(editingHash) + "/metadata", {
        method: "PUT",
        headers: { "Content-Type": "application/json", Accept: "application/json" },
        body: JSON.stringify(payload),
      });
      var text = await res.text();
      var j = {};
      try { j = JSON.parse(text); } catch (_) {}
      if (!res.ok) throw new Error((j && j.error) || text.slice(0, 500) || "Save failed");

      if (j.flagsUnsupported) {
        setMetadataMsg("Saved tool/keywords. Install flags not supported by this TAK build.", true);
      } else {
        setMetadataMsg("Metadata saved.", true);
      }
      await loadPackages();
    } catch (e) {
      setMetadataMsg(e.message || "Save failed", false);
    }
  }

  async function uploadPackage() {
    setMsg(uploadMsg, "Uploading…", undefined);
    try {
      var file = uploadFile && uploadFile.files && uploadFile.files[0];
      if (!file) throw new Error("Choose a file to upload.");

      var fd = new FormData();
      fd.append("file", file, file.name || "data-package.zip");
      if (uploadKeywords && uploadKeywords.value) fd.append("keywords", uploadKeywords.value.trim());
      if (uploadTool && uploadTool.value) fd.append("tool", uploadTool.value.trim());
      if (uploadCreatorUid && uploadCreatorUid.value) fd.append("creator_uid", uploadCreatorUid.value.trim());

      var res = await fetch(API + "/packages/upload", {
        method: "POST",
        body: fd,
      });
      var text = await res.text();
      var j;
      try {
        j = JSON.parse(text);
      } catch (_) {
        j = {};
      }
      if (!res.ok) throw new Error((j && j.error) || text.slice(0, 500) || "Upload failed");
      setMsg(uploadMsg, "Data package uploaded.", true);
      uploadFile.value = "";
      await loadPackages();
    } catch (e) {
      setMsg(uploadMsg, e.message || "Upload failed", false);
    }
  }

  async function deletePackage(hash, filename) {
    var ok = window.confirm("Delete data package \"" + (filename || hash) + "\"?");
    if (!ok) return;
    setMsg(packagesMsg, "Deleting package…", undefined);
    try {
      var res = await fetch(API + "/packages/" + encodeURIComponent(hash), { method: "DELETE" });
      var text = await res.text();
      var j;
      try {
        j = JSON.parse(text);
      } catch (_) {
        j = {};
      }
      if (!res.ok) throw new Error((j && j.error) || "Delete failed");
      setMsg(packagesMsg, "Package deleted.", true);
      await loadPackages();
    } catch (e) {
      setMsg(packagesMsg, e.message || "Delete failed", false);
    }
  }

  async function downloadPackage(hash, filename) {
    setMsg(packagesMsg, "Downloading package…", undefined);
    try {
      var url = API + "/packages/download?hash=" + encodeURIComponent(hash);
      var res = await fetch(url);
      if (!res.ok) {
        var errText = await res.text().catch(function () { return ""; });
        var errMsg = "Download failed (HTTP " + res.status + ")";
        try {
          var j = JSON.parse(errText);
          if (j && j.error) errMsg = j.error;
        } catch (_) {
          // noop
        }
        throw new Error(errMsg);
      }
      var blob = await res.blob();
      var name = filename || ("data-package-" + hash + ".zip");
      var a = document.createElement("a");
      a.href = URL.createObjectURL(blob);
      a.download = name;
      document.body.appendChild(a);
      a.click();
      a.remove();
      setTimeout(function () {
        try {
          URL.revokeObjectURL(a.href);
        } catch (_) {
          // noop
        }
      }, 2500);
      setMsg(packagesMsg, "Download started.", true);
    } catch (e) {
      setMsg(packagesMsg, e.message || "Download failed", false);
    }
  }

  if (btnUploadPackage) btnUploadPackage.addEventListener("click", uploadPackage);
  if (btnRefreshPackages) btnRefreshPackages.addEventListener("click", loadPackages);
  if (packageFilter) packageFilter.addEventListener("input", renderTable);
  if (metadataClose) metadataClose.addEventListener("click", closeMetadataModal);
  if (metadataSave) metadataSave.addEventListener("click", saveMetadata);
  if (metadataModal) {
    metadataModal.addEventListener("click", function (e) {
      if (e.target === metadataModal) closeMetadataModal();
    });
  }

  loadStatus().then(function (ok) {
    if (ok) loadPackages();
  });
})();
</script>
