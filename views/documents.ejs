<%
  const _docAgencyOptions = Array.isArray(docAgencyOptions) ? docAgencyOptions : [];
%>
<%- include("partials/header") %>
<%- include("partials/sidebar") %>

<main class="main documents-page">
  <h1>Documents</h1>

  <div id="documentsBanner" class="msg" style="display: none; margin-bottom: 12px;"></div>

  <div class="card" style="margin-bottom: 14px;">
    <div class="row" style="justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 10px;">
      <div class="row" style="gap: 10px; flex-wrap: wrap; align-items: center;">
        <input type="search" id="docFilter" placeholder="Filter by title…" style="min-width: 220px; max-width: 360px;" autocomplete="off" />
        <% if (typeof isGlobalAdmin !== "undefined" && isGlobalAdmin) { %>
          <button type="button" class="btn success" id="btnNewDoc">New document</button>
        <% } %>
      </div>
      <button type="button" class="btn" id="btnRefreshDocs">Refresh</button>
    </div>
  </div>

  <div class="card" style="overflow-x: auto;">
    <table class="table documents-table" style="margin: 0;">
      <thead>
        <tr>
          <th>Title</th>
          <th style="width: 150px;">Category</th>
          <th style="width: 150px;">Status</th>
          <th style="min-width: 140px;">Agency admins</th>
          <th style="width: 160px;">Updated</th>
          <th style="min-width: 100px;">Actions</th>
        </tr>
      </thead>
      <tbody id="documentsTbody">
        <tr><td colspan="6" class="muted">Loading…</td></tr>
      </tbody>
    </table>
  </div>
</main>

<!-- New document -->
  <div class="modalOverlay" id="createModal" style="display: none;" aria-hidden="true">
  <div class="modal documents-modal" role="dialog" aria-modal="true" aria-labelledby="createModalTitle" style="width: min(560px, 96vw);">
    <div class="modalHeader">
      <h2 id="createModalTitle" style="margin: 0;">New document</h2>
      <button type="button" class="btn" data-close-create>Close</button>
    </div>
    <div class="modalBody">
      <div id="createMsg" class="msg" style="display: none;"></div>
      <form id="createForm">
        <label class="settings-field" style="display: block;">
          <span class="settings-label">Title</span>
          <input type="text" name="title" required placeholder="e.g. Regional MOU 2026" style="width: 100%; box-sizing: border-box;" />
        </label>
        <label class="settings-field" style="display: block; margin-top: 10px;">
          <span class="settings-label">Category</span>
          <select name="category" style="width: 100%; max-width: 320px;">
            <option value="MOU">MOU</option>
            <option value="Data Sharing Agreement">Data Sharing Agreement</option>
            <option value="SOP">SOP</option>
            <option value="Other">Other</option>
          </select>
        </label>
        <label class="settings-field" style="display: block; margin-top: 10px;">
          <span class="settings-label">Description</span>
          <textarea name="description" rows="3" placeholder="Optional" style="width: 100%; box-sizing: border-box; resize: vertical;"></textarea>
        </label>
        <label class="settings-field" style="display: block; margin-top: 10px;">
          <span class="settings-label">Draft file (optional)</span>
          <input type="file" name="file" accept=".pdf,.doc,.docx,.png,.jpg,.jpeg" />
        </label>

        <input type="hidden" id="createAgencyInput" name="agencySuffixes" value="" />

        <div style="margin-top: 12px;">
          <strong class="settings-label" style="display: block; margin-bottom: 6px;">Also share with agency admins</strong>
          <p class="muted" style="margin: 0 0 8px 0; font-size: 13px;">
            Global admins <strong>always</strong> have access. Use the list below only to allow specific agencies’ agency admins to view this document.
          </p>
          <div class="filter-multiselect" data-filter="agency-create">
            <button type="button" class="btn filter-toggle" id="createAgencyToggle">Select agencies ▾</button>
            <div class="filter-menu" role="listbox" aria-label="Agencies">
              <div class="filter-menu-inner">
                <% if (!_docAgencyOptions.length) { %>
                  <div class="filter-option" style="cursor: default;"><span class="muted">No agencies available.</span></div>
                <% } %>
                <% _docAgencyOptions.forEach(function (opt) { %>
                  <label class="filter-option">
                    <input type="checkbox" value="<%= opt.value %>" data-filter-value="<%= opt.value %>" />
                    <span><%= opt.label %></span>
                  </label>
                <% }); %>
              </div>
            </div>
          </div>
        </div>

        <div class="row" style="margin-top: 16px; gap: 8px;">
          <button type="submit" class="btn success">Create</button>
          <button type="button" class="btn" data-close-create>Cancel</button>
        </div>
      </form>
    </div>
  </div>
</div>

<!-- Detail -->
<div class="modalOverlay" id="detailModal" style="display: none;" aria-hidden="true">
  <div class="modal" role="dialog" aria-modal="true" aria-labelledby="detailModalTitle" style="width: min(860px, 98vw);">
    <div class="modalHeader">
      <h2 id="detailModalTitle" style="margin: 0;">Document</h2>
      <button type="button" class="btn" id="detailCloseBtn">Close</button>
    </div>
    <div class="modalBody">
      <div id="detailMsg" class="msg" style="display: none;"></div>
      <div id="detailBody"></div>
    </div>
  </div>
</div>

<!-- Upload draft -->
<div class="modalOverlay" id="draftUploadModal" style="display: none;" aria-hidden="true">
  <div class="modal" role="dialog" aria-modal="true" aria-labelledby="draftUploadTitle" style="width: min(480px, 96vw);">
    <div class="modalHeader">
      <h2 id="draftUploadTitle" style="margin: 0;">Upload draft / unsigned file</h2>
      <button type="button" class="btn" data-close-draft-upload>Close</button>
    </div>
    <div class="modalBody">
      <div id="draftUploadMsg" class="msg" style="display: none;"></div>
      <form id="draftUploadForm">
        <input type="hidden" id="draftUploadDocId" />
        <p class="muted" style="margin-top: 0;">This is the working or unsigned copy (for review or to email for signature).</p>
        <label class="settings-field" style="display: block;">
          <span class="settings-label">File</span>
          <input type="file" name="file" required accept=".pdf,.doc,.docx,.png,.jpg,.jpeg" />
        </label>
        <div class="row" style="margin-top: 14px; gap: 8px;">
          <button type="submit" class="btn success">Upload</button>
          <button type="button" class="btn" data-close-draft-upload>Cancel</button>
        </div>
      </form>
    </div>
  </div>
</div>

<!-- Upload signed -->
<div class="modalOverlay" id="signedUploadModal" style="display: none;" aria-hidden="true">
  <div class="modal" role="dialog" aria-modal="true" aria-labelledby="signedUploadTitle" style="width: min(480px, 96vw);">
    <div class="modalHeader">
      <h2 id="signedUploadTitle" style="margin: 0;">Upload signed / executed file</h2>
      <button type="button" class="btn" data-close-signed-upload>Close</button>
    </div>
    <div class="modalBody">
      <div id="signedUploadMsg" class="msg" style="display: none;"></div>
      <form id="signedUploadForm">
        <input type="hidden" id="signedUploadDocId" />
        <p class="muted" style="margin-top: 0;">Upload the fully executed agreement. The document will be marked <strong>Signed</strong> and replaces any previous signed file.</p>
        <label class="settings-field" style="display: block;">
          <span class="settings-label">File</span>
          <input type="file" name="file" required accept=".pdf,.doc,.docx,.png,.jpg,.jpeg" />
        </label>
        <div class="row" style="margin-top: 14px; gap: 8px;">
          <button type="submit" class="btn success">Upload</button>
          <button type="button" class="btn" data-close-signed-upload>Cancel</button>
        </div>
      </form>
    </div>
  </div>
</div>

<!-- Email -->
<div class="modalOverlay" id="emailModal" style="display: none;" aria-hidden="true">
  <div class="modal" role="dialog" aria-modal="true" aria-labelledby="emailModalTitle" style="width: min(480px, 96vw);">
    <div class="modalHeader">
      <h2 id="emailModalTitle" style="margin: 0;">Email draft for signature</h2>
      <button type="button" class="btn" data-close-email>Close</button>
    </div>
    <div class="modalBody">
      <div id="emailMsg" class="msg" style="display: none;"></div>
      <p class="muted" style="margin-top: 0;">Attaches the <strong>draft / unsigned</strong> file. After a successful send, status becomes <em>Pending signature</em>.</p>
      <form id="emailForm">
        <input type="hidden" id="emailDocId" />
        <label class="settings-field" style="display: block;">
          <span class="settings-label">To</span>
          <input type="email" id="emailTo" required placeholder="recipient@example.gov" style="width: 100%; box-sizing: border-box;" autocomplete="off" />
        </label>
        <label class="settings-field" style="display: block; margin-top: 10px;">
          <span class="settings-label">Note (optional)</span>
          <textarea id="emailNote" rows="3" style="width: 100%; box-sizing: border-box; resize: vertical;"></textarea>
        </label>
        <p class="muted" style="font-size: 12px; margin: 8px 0 0 0;">Requires SMTP configured in Server Settings.</p>
        <div class="row" style="margin-top: 14px; gap: 8px;">
          <button type="submit" class="btn success">Send</button>
          <button type="button" class="btn" data-close-email>Cancel</button>
        </div>
      </form>
    </div>
  </div>
</div>

<!-- Edit meta -->
  <div class="modalOverlay" id="editModal" style="display: none;" aria-hidden="true">
  <div class="modal documents-modal" role="dialog" aria-modal="true" aria-labelledby="editModalTitle" style="width: min(560px, 96vw);">
    <div class="modalHeader">
      <h2 id="editModalTitle" style="margin: 0;">Edit document</h2>
      <button type="button" class="btn" data-close-edit>Close</button>
    </div>
    <div class="modalBody">
      <div id="editMsg" class="msg" style="display: none;"></div>
      <form id="editForm">
        <input type="hidden" id="editDocId" />
        <label class="settings-field" style="display: block;">
          <span class="settings-label">Title</span>
          <input type="text" id="editTitle" required style="width: 100%; box-sizing: border-box;" />
        </label>
        <label class="settings-field" style="display: block; margin-top: 10px;">
          <span class="settings-label">Category</span>
          <select id="editCategory" style="width: 100%; max-width: 320px;">
            <option value="MOU">MOU</option>
            <option value="Data Sharing Agreement">Data Sharing Agreement</option>
            <option value="SOP">SOP</option>
            <option value="Other">Other</option>
          </select>
        </label>
        <label class="settings-field" style="display: block; margin-top: 10px;">
          <span class="settings-label">Status</span>
          <select id="editStatus" style="width: 100%; max-width: 320px;">
            <option value="draft">Draft</option>
            <option value="pending_signature">Pending signature</option>
            <option value="signed">Signed</option>
          </select>
        </label>
        <label class="settings-field" style="display: block; margin-top: 10px;">
          <span class="settings-label">Description</span>
          <textarea id="editDescription" rows="3" style="width: 100%; box-sizing: border-box; resize: vertical;"></textarea>
        </label>

        <input type="hidden" id="editAgencyInput" value="" />

        <div style="margin-top: 12px;">
          <strong class="settings-label" style="display: block; margin-bottom: 6px;">Also share with agency admins</strong>
          <p class="muted" style="margin: 0 0 8px 0; font-size: 13px;">
            Global admins <strong>always</strong> have access. Select agencies whose agency admins may also view this document.
          </p>
          <div class="filter-multiselect" data-filter="agency-edit">
            <button type="button" class="btn filter-toggle" id="editAgencyToggle">Select agencies ▾</button>
            <div class="filter-menu" role="listbox" aria-label="Agencies">
              <div class="filter-menu-inner">
                <% if (!_docAgencyOptions.length) { %>
                  <div class="filter-option" style="cursor: default;"><span class="muted">No agencies available.</span></div>
                <% } %>
                <% _docAgencyOptions.forEach(function (opt) { %>
                  <label class="filter-option">
                    <input type="checkbox" value="<%= opt.value %>" data-filter-value="<%= opt.value %>" />
                    <span><%= opt.label %></span>
                  </label>
                <% }); %>
              </div>
            </div>
          </div>
        </div>

        <div class="row" style="margin-top: 16px; gap: 8px;">
          <button type="submit" class="btn success">Save</button>
          <button type="button" class="btn" data-close-edit>Cancel</button>
        </div>
      </form>
    </div>
  </div>
</div>

<!-- Delete -->
<div class="modalOverlay" id="deleteModal" style="display: none;" aria-hidden="true">
  <div class="modal" role="dialog" aria-modal="true" aria-labelledby="deleteModalTitle" style="width: min(440px, 94vw);">
    <div class="modalHeader">
      <h2 id="deleteModalTitle" style="margin: 0;">Delete document</h2>
      <button type="button" class="btn" id="deleteModalClose">Cancel</button>
    </div>
    <div class="modalBody">
      <p id="deleteModalText" style="margin-top: 0;"></p>
      <div class="row" style="gap: 8px; margin-top: 12px;">
        <button type="button" class="btn danger" id="deleteConfirmBtn">Delete</button>
        <button type="button" class="btn" id="deleteCancelBtn">Cancel</button>
      </div>
    </div>
  </div>
</div>

<style>
  /* Let agency dropdown overlap modal edges (global .modal uses overflow:auto and clips menus). */
  .documents-page .modal.documents-modal {
    overflow: visible;
    max-height: 92vh;
  }
  .documents-page .modal.documents-modal .modalBody {
    overflow: visible;
  }

  .documents-page .filter-multiselect {
    position: relative;
  }
  .documents-page .filter-multiselect .filter-toggle {
    white-space: nowrap;
  }
  .documents-page .filter-multiselect .filter-menu {
    position: absolute;
    top: calc(100% + 4px);
    left: 0;
    z-index: 2000;
    min-width: 320px;
    max-height: 260px;
    overflow: auto;
    background: var(--card, #111827);
    border: 1px solid var(--line);
    border-radius: 8px;
    box-shadow: 0 12px 30px rgba(0, 0, 0, 0.45);
    padding: 6px 0;
    display: none;
  }
  .documents-page .filter-multiselect.open .filter-menu {
    display: block;
  }
  .documents-page .filter-multiselect .filter-menu-inner {
    padding: 0 8px 6px;
  }
  .documents-page .filter-multiselect .filter-option {
    display: flex;
    flex-direction: row;
    align-items: center;
    gap: 10px;
    padding: 6px 10px;
    font-size: 13px;
    cursor: pointer;
  }
  .documents-page .filter-multiselect .filter-option input[type="checkbox"] {
    margin: 0;
    flex-shrink: 0;
    width: 1.125em;
    height: 1.125em;
  }
  .documents-page .doc-status-pill {
    display: inline-block;
    font-size: 11px;
    padding: 3px 10px;
    border-radius: 999px;
    font-weight: 600;
  }
  .documents-page .doc-status-pill.draft {
    background: rgba(107, 114, 128, 0.35);
    color: var(--muted);
  }
  .documents-page .doc-status-pill.pending {
    background: rgba(234, 179, 8, 0.25);
    color: #eab308;
  }
  .documents-page .doc-status-pill.signed {
    background: rgba(34, 197, 94, 0.22);
    color: #22c55e;
  }
  .documents-page .badge-access {
    display: inline-block;
    font-size: 11px;
    padding: 2px 8px;
    border-radius: 999px;
    background: var(--line);
    color: var(--muted);
  }
  .documents-page .detail-section {
    margin-top: 14px;
    padding-top: 12px;
    border-top: 1px solid var(--line);
  }
  .documents-page .detail-section h3 {
    margin: 0 0 8px 0;
    font-size: 1rem;
  }
</style>

<script>
(function () {
  var API = "/api/documents";
  var IS_GLOBAL = <%= typeof isGlobalAdmin !== "undefined" && isGlobalAdmin ? "true" : "false" %>;

  var tbody = document.getElementById("documentsTbody");
  var filterEl = document.getElementById("docFilter");
  var banner = document.getElementById("documentsBanner");
  var currentDetailId = null;

  function showBanner(text, ok) {
    if (!banner) return;
    if (!text) {
      banner.style.display = "none";
      banner.textContent = "";
      banner.className = "msg";
      return;
    }
    banner.style.display = "block";
    banner.textContent = text;
    banner.className = "msg " + (ok === true ? "ok" : ok === false ? "bad" : "");
  }

  function esc(s) {
    return String(s == null ? "" : s)
      .replace(/&/g, "&amp;")
      .replace(/</g, "&lt;")
      .replace(/>/g, "&gt;")
      .replace(/"/g, "&quot;");
  }

  function formatBytes(n) {
    var x = Number(n) || 0;
    if (x < 1024) return x + " B";
    if (x < 1024 * 1024) return (x / 1024).toFixed(1) + " KB";
    return (x / 1024 / 1024).toFixed(1) + " MB";
  }

  function statusLabel(st) {
    if (st === "draft") return "Draft";
    if (st === "pending_signature") return "Pending signature";
    if (st === "signed") return "Signed";
    return st || "—";
  }

  function statusClass(st) {
    if (st === "signed") return "signed";
    if (st === "pending_signature") return "pending";
    return "draft";
  }

  function formatAccess(row) {
    var suf = row.agencySuffixes || [];
    if (!suf.length) {
      return '<span class="badge-access">None</span>';
    }
    return (
      '<span class="badge-access" title="' +
      esc(suf.join(", ")) +
      '">' +
      suf.length +
      " selected</span>"
    );
  }

  function formatWhen(iso) {
    if (!iso) return "—";
    try {
      return new Date(iso).toLocaleString();
    } catch (_) {
      return iso;
    }
  }

  var listRows = [];

  function renderTable(rows) {
    listRows = rows || [];
    applyFilter();
  }

  function applyFilter() {
    var q = (filterEl && filterEl.value || "").trim().toLowerCase();
    var rows = listRows.filter(function (r) {
      if (!q) return true;
      return String(r.title || "")
        .toLowerCase()
        .indexOf(q) >= 0;
    });
    if (!tbody) return;
    if (!rows.length) {
      tbody.innerHTML = '<tr><td colspan="6" class="muted">No documents match.</td></tr>';
      return;
    }
    var html = "";
    for (var i = 0; i < rows.length; i++) {
      var r = rows[i];
      var st = r.status || "draft";
      html +=
        "<tr data-id=\"" +
        esc(r.id) +
        "\">" +
        "<td><strong>" +
        esc(r.title) +
        "</strong></td>" +
        "<td>" +
        esc(r.category || "—") +
        "</td>" +
        "<td><span class=\"doc-status-pill " +
        esc(statusClass(st)) +
        "\">" +
        esc(statusLabel(st)) +
        "</span></td>" +
        "<td>" +
        formatAccess(r) +
        "</td>" +
        "<td style=\"font-size:12px;white-space:nowrap;\">" +
        esc(formatWhen(r.updatedAt)) +
        "</td>" +
        "<td><button type=\"button\" class=\"btn\" data-open-detail=\"" +
        esc(r.id) +
        "\">View</button></td>" +
        "</tr>";
    }
    tbody.innerHTML = html;
  }

  function loadList() {
    showBanner("Loading…", undefined);
    fetch(API, { credentials: "same-origin" })
      .then(function (res) {
        return res.json().then(function (j) {
          if (!res.ok) throw new Error((j && j.error) || "Failed to load");
          return j.data || [];
        });
      })
      .then(function (data) {
        showBanner("", undefined);
        renderTable(data);
      })
      .catch(function (e) {
        showBanner(e.message || "Failed to load documents", false);
        if (tbody) tbody.innerHTML = '<tr><td colspan="6" class="muted">Could not load.</td></tr>';
      });
  }

  function parseCsv(val) {
    return String(val || "")
      .split(",")
      .map(function (s) {
        return s.trim().toLowerCase();
      })
      .filter(Boolean);
  }

  function setupAgencyFilter(opts) {
    var container = document.querySelector(opts.containerSelector);
    var input = document.getElementById(opts.inputId);
    if (!container || !input) return;

    var menu = container.querySelector(".filter-menu");
    var toggle = container.querySelector(".filter-toggle");
    var checkboxes = Array.prototype.slice.call(
      container.querySelectorAll('input[type="checkbox"][data-filter-value]')
    );

    function syncFromInput() {
      var initial = parseCsv(input.value);
      checkboxes.forEach(function (cb) {
        var val = cb.getAttribute("data-filter-value");
        cb.checked = initial.includes(val);
      });
    }

    function syncInput() {
      var selected = checkboxes
        .filter(function (cb) {
          return cb.checked;
        })
        .map(function (cb) {
          return cb.getAttribute("data-filter-value");
        });
      input.value = selected.join(",");
    }

    checkboxes.forEach(function (cb) {
      cb.addEventListener("change", function () {
        syncInput();
      });
    });

    if (menu) {
      menu.addEventListener("mousedown", function (e) {
        e.stopPropagation();
      });
    }

    if (toggle && menu) {
      toggle.addEventListener("click", function (e) {
        e.preventDefault();
        e.stopPropagation();
        var isOpen = container.classList.contains("open");
        document.querySelectorAll(".documents-page .filter-multiselect.open").forEach(function (el) {
          if (el !== container) el.classList.remove("open");
        });
        if (!isOpen) container.classList.add("open");
        else container.classList.remove("open");
      });
    }

    return { syncFromInput: syncFromInput, syncInput: syncInput };
  }

  var createAgencyCtl = setupAgencyFilter({
    containerSelector: '.documents-page .filter-multiselect[data-filter="agency-create"]',
    inputId: "createAgencyInput",
  });

  var editAgencyCtl = setupAgencyFilter({
    containerSelector: '.documents-page .filter-multiselect[data-filter="agency-edit"]',
    inputId: "editAgencyInput",
  });

  document.addEventListener("click", function (e) {
    if (!e.target.closest(".documents-page .filter-multiselect")) {
      document.querySelectorAll(".documents-page .filter-multiselect.open").forEach(function (el) {
        el.classList.remove("open");
      });
    }
  });

  function openOverlay(el) {
    if (!el) return;
    el.style.display = "flex";
    el.setAttribute("aria-hidden", "false");
  }
  function closeOverlay(el) {
    if (!el) return;
    el.style.display = "none";
    el.setAttribute("aria-hidden", "true");
  }

  var createModal = document.getElementById("createModal");
  var detailModal = document.getElementById("detailModal");
  var draftUploadModal = document.getElementById("draftUploadModal");
  var signedUploadModal = document.getElementById("signedUploadModal");
  var emailModal = document.getElementById("emailModal");
  var editModal = document.getElementById("editModal");
  var deleteModal = document.getElementById("deleteModal");

  document.querySelectorAll("[data-close-create]").forEach(function (b) {
    b.addEventListener("click", function () {
      closeOverlay(createModal);
    });
  });
  document.getElementById("detailCloseBtn").addEventListener("click", function () {
    closeOverlay(detailModal);
  });
  document.querySelectorAll("[data-close-draft-upload]").forEach(function (b) {
    b.addEventListener("click", function () {
      closeOverlay(draftUploadModal);
    });
  });
  document.querySelectorAll("[data-close-signed-upload]").forEach(function (b) {
    b.addEventListener("click", function () {
      closeOverlay(signedUploadModal);
    });
  });
  document.querySelectorAll("[data-close-email]").forEach(function (b) {
    b.addEventListener("click", function () {
      closeOverlay(emailModal);
    });
  });
  document.querySelectorAll("[data-close-edit]").forEach(function (b) {
    b.addEventListener("click", function () {
      closeOverlay(editModal);
    });
  });

  var btnNew = document.getElementById("btnNewDoc");
  if (btnNew) {
    btnNew.addEventListener("click", function () {
      var form = document.getElementById("createForm");
      if (form) form.reset();
      var msg = document.getElementById("createMsg");
      if (msg) {
        msg.style.display = "none";
        msg.textContent = "";
      }
      document.getElementById("createAgencyInput").value = "";
      if (createAgencyCtl && createAgencyCtl.syncFromInput) createAgencyCtl.syncFromInput();
      openOverlay(createModal);
    });
  }

  document.getElementById("btnRefreshDocs").addEventListener("click", loadList);
  if (filterEl) filterEl.addEventListener("input", applyFilter);

  document.getElementById("createForm").addEventListener("submit", function (e) {
    e.preventDefault();
    var msg = document.getElementById("createMsg");
    if (createAgencyCtl && createAgencyCtl.syncInput) createAgencyCtl.syncInput();
    var fd = new FormData(e.target);
    msg.style.display = "block";
    msg.className = "msg";
    msg.textContent = "Saving…";
    fetch(API, { method: "POST", body: fd, credentials: "same-origin" })
      .then(function (res) {
        return res.json().then(function (j) {
          if (!res.ok) throw new Error((j && j.error) || "Failed");
          return j.data;
        });
      })
      .then(function () {
        msg.className = "msg ok";
        msg.textContent = "Created.";
        closeOverlay(createModal);
        loadList();
      })
      .catch(function (err) {
        msg.className = "msg bad";
        msg.textContent = err.message || "Failed";
      });
  });

  tbody.addEventListener("click", function (ev) {
    var t = ev.target;
    if (t && t.getAttribute && t.getAttribute("data-open-detail")) {
      openDetail(t.getAttribute("data-open-detail"));
    }
  });

  function fileDownloadUrl(docId, role) {
    return API + "/" + encodeURIComponent(docId) + "/file?role=" + role;
  }

  function openDetail(id) {
    currentDetailId = id;
    var body = document.getElementById("detailBody");
    var title = document.getElementById("detailModalTitle");
    body.innerHTML = '<p class="muted">Loading…</p>';
    openOverlay(detailModal);
    fetch(API + "/" + encodeURIComponent(id), { credentials: "same-origin" })
      .then(function (res) {
        return res.json().then(function (j) {
          if (!res.ok) throw new Error((j && j.error) || "Failed");
          return j.data;
        });
      })
      .then(function (d) {
        if (title) title.textContent = d.title || "Document";
        var st = d.status || "draft";
        var html = "";
        html +=
          '<p class="muted" style="margin-top:0;">' +
          esc(d.description || "") +
          "</p>";
        html += '<div class="row" style="flex-wrap:wrap;gap:10px;align-items:center;margin-bottom:12px;">';
        html +=
          '<span class="doc-status-pill ' +
          esc(statusClass(st)) +
          '">' +
          esc(statusLabel(st)) +
          "</span>";
        html += "<span class=\"muted\" style=\"font-size:13px;\">" + esc(d.category || "") + "</span>";
        if (d.emailedAt) {
          html +=
            '<span class="muted" style="font-size:12px;">Emailed: ' +
            esc(formatWhen(d.emailedAt)) +
            "</span>";
        }
        html += "</div>";
        html +=
          '<p class="muted" style="font-size:13px;margin:0 0 10px 0;">' +
          "<strong>Global admins</strong> always have access." +
          (d.agencySuffixes && d.agencySuffixes.length
            ? " Agency admins for: <strong>" + esc(d.agencySuffixes.join(", ")) + "</strong>."
            : " No agency admins selected for shared access.") +
          "</p>";

        if (IS_GLOBAL) {
          html += '<div class="row" style="flex-wrap:wrap;gap:8px;margin-bottom:14px;">';
          html += '<button type="button" class="btn" id="detailBtnEdit">Edit details</button>';
          html += '<button type="button" class="btn danger" id="detailBtnDelete">Delete</button>';
          html += "</div>";
        }

        html += '<div class="detail-section"><h3>Draft / unsigned file</h3>';
        if (d.draftFile) {
          html += "<p style=\"margin:0 0 8px 0;font-size:14px;\">" + esc(d.draftFile.fileName) + " · " + esc(formatBytes(d.draftFile.size)) + "</p>";
          html +=
            '<div class="row" style="flex-wrap:wrap;gap:8px;">' +
            '<a class="btn" href="' +
            fileDownloadUrl(d.id, "draft") +
            '">Download draft</a>';
          html += '<button type="button" class="btn success" id="btnEmailDraft">Email for signature</button>';
          if (IS_GLOBAL) {
            html += '<button type="button" class="btn" id="btnReplaceDraft">Replace draft</button>';
          }
          html += "</div>";
        } else {
          html += '<p class="muted">No draft uploaded yet.</p>';
          if (IS_GLOBAL) {
            html += '<button type="button" class="btn success" id="btnUploadDraft">Upload draft</button>';
          }
        }
        html += "</div>";

        html += '<div class="detail-section"><h3>Signed / executed file</h3>';
        if (d.signedFile) {
          html += "<p style=\"margin:0 0 8px 0;font-size:14px;\">" + esc(d.signedFile.fileName) + " · " + esc(formatBytes(d.signedFile.size)) + "</p>";
          html +=
            '<div class="row" style="flex-wrap:wrap;gap:8px;">' +
            '<a class="btn" href="' +
            fileDownloadUrl(d.id, "signed") +
            '">Download signed</a>';
          if (IS_GLOBAL) {
            html += '<button type="button" class="btn" id="btnReplaceSigned">Replace signed file</button>';
          }
          html += "</div>";
        } else {
          html += '<p class="muted">No signed copy uploaded yet.</p>';
          if (IS_GLOBAL) {
            html += '<button type="button" class="btn success" id="btnUploadSigned">Upload signed copy</button>';
          }
        }
        html += "</div>";

        body.innerHTML = html;

        var btnEd = document.getElementById("detailBtnEdit");
        if (btnEd) {
          btnEd.onclick = function () {
            document.getElementById("editDocId").value = d.id;
            document.getElementById("editTitle").value = d.title || "";
            document.getElementById("editCategory").value = d.category || "Other";
            document.getElementById("editStatus").value = st;
            document.getElementById("editDescription").value = d.description || "";
            document.getElementById("editAgencyInput").value = (d.agencySuffixes || []).join(",");
            if (editAgencyCtl && editAgencyCtl.syncFromInput) editAgencyCtl.syncFromInput();
            document.getElementById("editMsg").style.display = "none";
            closeOverlay(detailModal);
            openOverlay(editModal);
          };
        }
        var btnDel = document.getElementById("detailBtnDelete");
        if (btnDel) {
          btnDel.onclick = function () {
            document.getElementById("deleteModalText").textContent =
              'Delete "' + (d.title || "") + '" and all files? This cannot be undone.';
            deleteModal.dataset.docId = d.id;
            closeOverlay(detailModal);
            openOverlay(deleteModal);
          };
        }

        function openDraftUpload() {
          document.getElementById("draftUploadDocId").value = d.id;
          document.getElementById("draftUploadMsg").style.display = "none";
          document.getElementById("draftUploadForm").reset();
          document.getElementById("draftUploadDocId").value = d.id;
          closeOverlay(detailModal);
          openOverlay(draftUploadModal);
        }
        function openSignedUpload() {
          document.getElementById("signedUploadDocId").value = d.id;
          document.getElementById("signedUploadMsg").style.display = "none";
          document.getElementById("signedUploadForm").reset();
          document.getElementById("signedUploadDocId").value = d.id;
          closeOverlay(detailModal);
          openOverlay(signedUploadModal);
        }

        var b1 = document.getElementById("btnUploadDraft");
        if (b1) b1.onclick = openDraftUpload;
        var b2 = document.getElementById("btnReplaceDraft");
        if (b2) b2.onclick = openDraftUpload;
        var b3 = document.getElementById("btnUploadSigned");
        if (b3) b3.onclick = openSignedUpload;
        var b4 = document.getElementById("btnReplaceSigned");
        if (b4) b4.onclick = openSignedUpload;

        var emailBtn = document.getElementById("btnEmailDraft");
        if (emailBtn) {
          emailBtn.onclick = function () {
            document.getElementById("emailDocId").value = d.id;
            document.getElementById("emailTo").value = "";
            document.getElementById("emailNote").value = "";
            document.getElementById("emailMsg").style.display = "none";
            openOverlay(emailModal);
          };
        }
      })
      .catch(function (err) {
        body.innerHTML = '<p class="msg bad">' + esc(err.message) + "</p>";
      });
  }

  document.getElementById("draftUploadForm").addEventListener("submit", function (e) {
    e.preventDefault();
    var docId = document.getElementById("draftUploadDocId").value;
    var fd = new FormData();
    var fileInput = e.target.querySelector('input[type="file"]');
    if (!fileInput || !fileInput.files || !fileInput.files[0]) return;
    fd.append("file", fileInput.files[0]);
    var msg = document.getElementById("draftUploadMsg");
    msg.style.display = "block";
    msg.className = "msg";
    msg.textContent = "Uploading…";
    fetch(API + "/" + encodeURIComponent(docId) + "/draft", {
      method: "POST",
      body: fd,
      credentials: "same-origin",
    })
      .then(function (res) {
        return res.json().then(function (j) {
          if (!res.ok) throw new Error((j && j.error) || "Upload failed");
          return j.data;
        });
      })
      .then(function () {
        msg.className = "msg ok";
        msg.textContent = "Saved.";
        closeOverlay(draftUploadModal);
        loadList();
        openDetail(docId);
      })
      .catch(function (err) {
        msg.className = "msg bad";
        msg.textContent = err.message || "Failed";
      });
  });

  document.getElementById("signedUploadForm").addEventListener("submit", function (e) {
    e.preventDefault();
    var docId = document.getElementById("signedUploadDocId").value;
    var fd = new FormData();
    var fileInput = e.target.querySelector('input[type="file"]');
    if (!fileInput || !fileInput.files || !fileInput.files[0]) return;
    fd.append("file", fileInput.files[0]);
    var msg = document.getElementById("signedUploadMsg");
    msg.style.display = "block";
    msg.className = "msg";
    msg.textContent = "Uploading…";
    fetch(API + "/" + encodeURIComponent(docId) + "/signed", {
      method: "POST",
      body: fd,
      credentials: "same-origin",
    })
      .then(function (res) {
        return res.json().then(function (j) {
          if (!res.ok) throw new Error((j && j.error) || "Upload failed");
          return j.data;
        });
      })
      .then(function () {
        msg.className = "msg ok";
        msg.textContent = "Signed file saved.";
        closeOverlay(signedUploadModal);
        loadList();
        openDetail(docId);
      })
      .catch(function (err) {
        msg.className = "msg bad";
        msg.textContent = err.message || "Failed";
      });
  });

  document.getElementById("emailForm").addEventListener("submit", function (e) {
    e.preventDefault();
    var docId = document.getElementById("emailDocId").value;
    var payload = {
      to: document.getElementById("emailTo").value.trim(),
      message: document.getElementById("emailNote").value,
    };
    var msg = document.getElementById("emailMsg");
    msg.style.display = "block";
    msg.className = "msg";
    msg.textContent = "Sending…";
    fetch(API + "/" + encodeURIComponent(docId) + "/email", {
      method: "POST",
      headers: { "Content-Type": "application/json" },
      body: JSON.stringify(payload),
      credentials: "same-origin",
    })
      .then(function (res) {
        return res.json().then(function (j) {
          if (!res.ok) throw new Error((j && j.error) || "Failed");
          return j;
        });
      })
      .then(function (r) {
        msg.className = "msg ok";
        if (r.skipped) msg.textContent = "Email skipped (SMTP not enabled).";
        else msg.textContent = "Sent. Status set to pending signature.";
        closeOverlay(emailModal);
        loadList();
        openDetail(docId);
      })
      .catch(function (err) {
        msg.className = "msg bad";
        msg.textContent = err.message || "Failed";
      });
  });

  document.getElementById("editForm").addEventListener("submit", function (e) {
    e.preventDefault();
    if (editAgencyCtl && editAgencyCtl.syncInput) editAgencyCtl.syncInput();
    var docId = document.getElementById("editDocId").value;
    var payload = {
      title: document.getElementById("editTitle").value,
      category: document.getElementById("editCategory").value,
      status: document.getElementById("editStatus").value,
      description: document.getElementById("editDescription").value,
      agencySuffixes: parseCsv(document.getElementById("editAgencyInput").value),
    };
    var msg = document.getElementById("editMsg");
    msg.style.display = "block";
    msg.className = "msg";
    msg.textContent = "Saving…";
    fetch(API + "/" + encodeURIComponent(docId), {
      method: "PUT",
      headers: { "Content-Type": "application/json" },
      body: JSON.stringify(payload),
      credentials: "same-origin",
    })
      .then(function (res) {
        return res.json().then(function (j) {
          if (!res.ok) throw new Error((j && j.error) || "Failed");
          return j.data;
        });
      })
      .then(function () {
        msg.className = "msg ok";
        msg.textContent = "Saved.";
        closeOverlay(editModal);
        loadList();
        openDetail(docId);
      })
      .catch(function (err) {
        msg.className = "msg bad";
        msg.textContent = err.message || "Failed";
      });
  });

  var deleteConfirmBtn = document.getElementById("deleteConfirmBtn");
  if (deleteConfirmBtn) {
    deleteConfirmBtn.addEventListener("click", function () {
      var id = deleteModal.dataset.docId;
      if (!id) return;
      fetch(API + "/" + encodeURIComponent(id), {
        method: "DELETE",
        credentials: "same-origin",
      })
        .then(function (res) {
          return res.json().then(function (j) {
            if (!res.ok) throw new Error((j && j.error) || "Failed");
          });
        })
        .then(function () {
          closeOverlay(deleteModal);
          loadList();
        })
        .catch(function (err) {
          alert(err.message || "Delete failed");
        });
    });
  }
  document.getElementById("deleteCancelBtn").addEventListener("click", function () {
    closeOverlay(deleteModal);
  });
  document.getElementById("deleteModalClose").addEventListener("click", function () {
    closeOverlay(deleteModal);
  });

  loadList();
})();
</script>
