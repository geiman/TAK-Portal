<%- include("partials/header") %>
<%- include("partials/sidebar") %>

<main class="main">
  <h1>Templates</h1>
  <small>Templates allow quick assignment of multiple groups to a user upon creation. Editing a template does not edit previously created users.</small>

  <div class="card">
    <div class="row" style="justify-content: space-between; align-items: center;">
      <h2 style="margin:0;" id="formTitle">Create New Template</h2>
      <div class="row" style="gap:8px;">
        <button class="btn" id="cancelEditBtn" type="button" style="display:none;">Cancel Edit</button>
      </div>
    </div>

    <form id="form" class="templatesGrid" autocomplete="off">
      <label>Agency
        <select id="agency">
          <option value="">Select an agency</option>
        </select>
      </label>

      

      <label>Template Name
        <input id="name" placeholder="Template Name Here (ex. Patrol, Medic, etc...)" required />
      </label>

      <label>Color Override (optional)
        <select id="colorOverride">
          <option value="">Use Default Agency Color</option>
          <option value="Blue">Blue</option>
          <option value="Dark Blue">Dark Blue</option>
          <option value="Brown">Brown</option>
          <option value="Cyan">Cyan</option>
          <option value="Green">Green</option>
          <option value="Dark Green">Dark Green</option>
          <option value="Magenta">Magenta</option>
          <option value="Maroon">Maroon</option>
          <option value="Orange">Orange</option>
          <option value="Purple">Purple</option>
          <option value="Red">Red</option>
          <option value="Teal">Teal</option>
          <option value="White">White</option>
          <option value="Yellow">Yellow</option>
        </select>
      </label>

      <label>Default Template
        <select id="isDefault">
          <option value="no">No</option>
          <option value="yes">Yes</option>
        </select>
      </label>

      <div style="grid-column:1/-1;">
        <label>Groups
          <input id="groupSearch" placeholder="Search groups..." />
          <div class="row" style="gap:10px; margin-top:8px;">
            <button class="btn" type="button" id="selectAllBtn">Select All</button>
            <button class="btn" type="button" id="clearAllBtn">Clear</button>
          </div>

          <div id="groupsBox" class="groupsBox">
            <div id="groupsInner" class="groupsInner"></div>
          </div>
        </label>
      </div>

      <div style="grid-column:1/-1;" class="row">
        <button class="btn" id="submitBtn" type="submit">Create Template</button>
        <span id="msg" class="msg"></span>
      </div>
    </form>
  </div>

  <div class="card">
    <h2>Existing Templates</h2>
    <div class="tableWrap">
      <table class="table templatesTable">
        <thead>
          <tr>
            <th class="sortable" data-key="agency">Agency <span class="sortIndicator"></span></th>
            <th class="sortable" data-key="name">Name <span class="sortIndicator"></span></th>
            <th class="sortable" data-key="color">Color <span class="sortIndicator"></span></th>
            <th class="sortable" data-key="default">Default <span class="sortIndicator"></span></th>
            <th class="sortable" data-key="groups">Groups <span class="sortIndicator"></span></th>
            <th>Actions</th>
          </tr>
        </thead>
        <tbody id="tbody"></tbody>
      </table>
    </div>
  </div>
</main>

<script>
const msg = document.getElementById("msg");
const tbody = document.getElementById("tbody");
const form = document.getElementById("form");

// ---- sortable Existing Templates table ----
let viewTemplates = []; // [{ t, idx }] where idx is the original index in the stored templates array
let sortState = { key: "agency", dir: "asc" }; // default: agency, then name

function getAgencyDisplay(t){
  return t && t.agencySuffix ? (agencyAbbrFromSuffix(t.agencySuffix) || t.agencySuffix) : "";
}

function displayGroupName(name){
  return String(name || "").replace(/^tak_/, "");
}

function getSortValue(pair, key){
  const t = (pair && pair.t) || {};
  if (key === "agency") return String(getAgencyDisplay(t) || "");
  if (key === "name") return String(t.name || "");
  if (key === "color") return String(t.colorOverride || "");
  if (key === "default") return t.isDefault ? "1" : "";
  if (key === "groups") return String((t.groups || []).join(", "));
  return "";
}

function stableSort(arr, key, dir){
  const sign = (dir === "desc") ? -1 : 1;
  return arr
    .map((item, originalPos) => ({ item, originalPos }))
    .sort((a, b) => {
      const av = getSortValue(a.item, key);
      const bv = getSortValue(b.item, key);

      const aBlank = !String(av || "").trim();
      const bBlank = !String(bv || "").trim();
      if (aBlank && !bBlank) return 1 * sign;
      if (!aBlank && bBlank) return -1 * sign;

      let cmp = String(av).localeCompare(String(bv), undefined, { numeric: true, sensitivity: "base" });
      if (cmp !== 0) return cmp * sign;

      // Secondary key only for the default sort by agency: name asc within agency
      if (key === "agency") {
        const an = getSortValue(a.item, "name");
        const bn = getSortValue(b.item, "name");
        const cmp2 = String(an).localeCompare(String(bn), undefined, { numeric: true, sensitivity: "base" });
        if (cmp2 !== 0) return cmp2; // secondary always asc
      }

      return a.originalPos - b.originalPos;
    })
    .map(x => x.item);
}

function renderTemplates(list){
  tbody.innerHTML = (list || []).map(({t, idx}) => `
    <tr>
      <td>${t.agencySuffix ? esc(getAgencyDisplay(t) || t.agencySuffix) : "—"}</td>
      <td>${esc(t.name)}</td>
      <td>${t.colorOverride ? esc(t.colorOverride) : "—"}</td>
      <td>${t.isDefault ? "Yes" : ""}</td>
      <td class="groupsCell">${esc((t.groups || []).map(displayGroupName).join(", "))}</td>
      <td>
        <div class="actionsCell">
          <button class="btn" type="button" onclick="editTemplate(${idx})">Edit</button>
          <button class="btn danger" type="button" onclick="deleteTemplate(${idx})">Delete</button>
        </div>
      </td>
    </tr>
  `).join("");
}

function updateSortIndicators(){
  const table = document.querySelector("table.templatesTable");
  const thead = table ? table.querySelector("thead") : null;
  const ths = Array.from(thead ? thead.querySelectorAll("th.sortable") : []);
  ths.forEach(th => {
    const key = th.dataset.key;
    const indicator = th.querySelector(".sortIndicator");
    if (!indicator) return;
    indicator.textContent = (key === sortState.key) ? (sortState.dir === "asc" ? "▲" : "▼") : "";
  });
}

function applySortAndRender(){
  viewTemplates = stableSort(viewTemplates || [], sortState.key, sortState.dir);
  renderTemplates(viewTemplates);
  updateSortIndicators();
}

// click-to-sort headers
(() => {
  const table = document.querySelector("table.templatesTable");
  const thead = table ? table.querySelector("thead") : null;
  if (!thead) return;

  thead.addEventListener("click", (e) => {
    const th = e.target && e.target.closest ? e.target.closest("th.sortable") : null;
    if (!th) return;
    const key = th.dataset.key;
    if (!key) return;

    if (sortState.key === key) {
      sortState.dir = (sortState.dir === "asc") ? "desc" : "asc";
    } else {
      sortState.key = key;
      sortState.dir = "asc";
    }
    applySortAndRender();
  });
})();


const formTitle = document.getElementById("formTitle");
const submitBtn = document.getElementById("submitBtn");
const cancelEditBtn = document.getElementById("cancelEditBtn");

const nameEl = document.getElementById("name");
const agencyEl = document.getElementById("agency");
const isDefaultEl = document.getElementById("isDefault");
const colorOverrideEl = document.getElementById("colorOverride");

const groupSearch = document.getElementById("groupSearch");
const groupsBox = document.getElementById("groupsBox");
const selectAllBtn = document.getElementById("selectAllBtn");
const clearAllBtn = document.getElementById("clearAllBtn");
const groupsInner = document.getElementById("groupsInner");

groupsBox.addEventListener("change", (e) => {
  const cb = e.target;
  if (!cb || cb.tagName !== "INPUT" || cb.type !== "checkbox") return;

  const name = String(cb.value);

  if (cb.checked) pickedGroupNames.add(name);
  else pickedGroupNames.delete(name);
});

let allGroups = [];
let allTemplates = [];
let allAgencies = [];
let editingIndex = null;
let pickedGroupNames = new Set();

function setMsg(text, ok=true){
  msg.textContent = text || "";
  msg.className = "msg " + (ok ? "ok" : "bad");
}

function esc(s){
  return String(s ?? "")
    .replaceAll("&","&amp;")
    .replaceAll("<","&lt;")
    .replaceAll(">","&gt;")
    .replaceAll('"',"&quot;")
    .replaceAll("'","&#39;");
}

function renderGroups(filterText = ""){
  const q = String(filterText || "").trim().toLowerCase();

  const list = allGroups
    .map(g => String(g.name))
    .sort((a,b)=>a.localeCompare(b))
    .filter(rawName => {
      if (!q) return true;
      const raw = rawName.toLowerCase();
      const disp = displayGroupName(rawName).toLowerCase();
      return raw.includes(q) || disp.includes(q);
    });

  groupsInner.innerHTML = list.map(rawName => {
    const checked = pickedGroupNames.has(rawName) ? "checked" : "";
    return `
      <label class="groupItem">
        <input type="checkbox" value="${esc(rawName)}" ${checked} />
        <span>${esc(displayGroupName(rawName))}</span>
      </label>
    `;
  }).join("");
}

async function loadAgencies(){
  const res = await fetch("/api/agencies");
  const agencies = await res.json();

  allAgencies = Array.isArray(agencies) ? agencies : [];

  // Sort agencies alphabetically by name (case-insensitive)
  allAgencies.sort((a, b) =>
    String(a.name || "").localeCompare(
      String(b.name || ""),
      undefined,
      { sensitivity: "base", numeric: true }
    )
  );

  agencyEl.innerHTML = `<option value="">Select an agency</option>` +
    allAgencies.map(a => {
      const abbr = (a.groupPrefix || "").trim();
      const suffix = (a.suffix || "").trim();
      const name = (a.name || "").trim();

      return `<option value="${esc(suffix)}">
        ${esc(name)}${abbr ? ` (${esc(abbr)})` : ""}
      </option>`;
    }).join("");
}

async function loadGroups(){
  const res = await fetch("/api/users/groups");
  const groups = await res.json();
  if (!res.ok) throw new Error(groups.error || "Failed to load groups");
  allGroups = groups;
  renderGroups("");
}

function agencyAbbrFromSuffix(suffix){
  const s = String(suffix || "").trim().toLowerCase();
  const a = allAgencies.find(x => String(x.suffix || "").trim().toLowerCase() === s);
  return String(a?.groupPrefix || "").trim();
}

async function loadTemplates(){
  const res = await fetch("/api/templates");
  const templates = await res.json();
  if (!res.ok) throw new Error(templates.error || "Failed to load templates");
  allTemplates = templates;

  // Keep the real backing index (global templates array index) stable for Edit/Delete/Save.
  viewTemplates = allTemplates.map((t, listPos) => ({
    t,
    idx: (t && typeof t._index === "number") ? t._index : listPos
  }));

  // Default sort: agency asc, then name asc
  sortState.key = "agency";
  sortState.dir = "asc";
  applySortAndRender();
}

function setCreateMode(){
  editingIndex = null;
  formTitle.textContent = "Create New Template";
  submitBtn.textContent = "Create Template";
  cancelEditBtn.style.display = "none";
  setMsg("");

  nameEl.value = "";
  agencyEl.value = "";
  colorOverrideEl.value = "";
  isDefaultEl.value = "no";
  groupSearch.value = "";
  pickedGroupNames.clear();
  renderGroups("");
}

function setEditMode(idx){
  editingIndex = idx;
  const t = allTemplates.find(x => x && (x._index === idx)) || allTemplates[idx];

  formTitle.textContent = "Edit Template";
  submitBtn.textContent = "Save Changes";
  cancelEditBtn.style.display = "inline-block";
  setMsg("");

  nameEl.value = t.name || "";
  agencyEl.value = t.agencySuffix || "";
  colorOverrideEl.value = t.colorOverride || "";
  isDefaultEl.value = t.isDefault ? "yes" : "no";
  groupSearch.value = "";
  pickedGroupNames = new Set(t.groups || []);
  renderGroups("");

  window.scrollTo({ top: 0, behavior: "smooth" });
}

window.editTemplate = (idx) => setEditMode(idx);

window.deleteTemplate = async (idx) => {
  if(!confirm("Delete this template?")) return;
  setMsg("");

  const res = await fetch("/api/templates/" + idx, { method:"DELETE" });
  const out = await res.json();

  if(!res.ok){
    setMsg(out.error || "Delete failed", false);
    return;
  }

  setMsg("Template deleted", true);

  if (editingIndex === idx) setCreateMode();

  await loadTemplates();
};

groupSearch.oninput = () => {
  renderGroups(groupSearch.value);
};

selectAllBtn.onclick = () => {
  Array.from(groupsBox.querySelectorAll('input[type="checkbox"]')).forEach(cb => {
    cb.checked = true;
    pickedGroupNames.add(cb.value);
  });
};

clearAllBtn.onclick = () => {
  Array.from(groupsBox.querySelectorAll('input[type="checkbox"]')).forEach(cb => {
    cb.checked = false;
  });
  pickedGroupNames.clear();
};

cancelEditBtn.onclick = () => setCreateMode();

form.onsubmit = async (e) => {
  e.preventDefault();
  setMsg("");

  const payload = {
    name: nameEl.value.trim(),
    agencySuffix: agencyEl.value,
    colorOverride: (colorOverrideEl.value || ""),
    groups: Array.from(pickedGroupNames),
    isDefault: isDefaultEl.value === "yes"
  };

  if (!payload.name) return setMsg("Template name is required", false);
  if (!payload.groups.length) return setMsg("Select at least one group", false);

  const isEdit = editingIndex !== null;
  const url = isEdit ? ("/api/templates/" + editingIndex) : "/api/templates";
  const method = isEdit ? "PUT" : "POST";

  const res = await fetch(url, {
    method,
    headers: {"Content-Type":"application/json"},
    body: JSON.stringify(payload)
  });

  const out = await res.json();
  if(!res.ok){
    setMsg(out.error || (isEdit ? "Update failed" : "Create failed"), false);
    return;
  }

  setMsg(isEdit ? "Template updated" : "Template created", true);
  await loadTemplates();
  setCreateMode();
};

(async () => {
  try {
    await loadAgencies();
    await loadGroups();
    await loadTemplates();
    setCreateMode();
  } catch (err) {
    setMsg(err.message || "Failed to load page", false);
  }
})();
</script>

<style>
.templatesGrid {
  display: grid;
  gap: 12px;
  grid-template-columns: repeat(4, minmax(0, 1fr));
}

@media (max-width: 950px) {
  .templatesGrid {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }
}

.templatesTable th:nth-child(1),
.templatesTable td:nth-child(1){
  min-width: 45px;   
  width: 45px;       
  white-space: nowrap;
}


@media (max-width: 560px) {
  .templatesGrid {
    grid-template-columns: 1fr;
  }
}

.templatesGrid > label {
  min-width: 0;
}

.templatesGrid > label > input,
.templatesGrid > label > select {
  width: 100%;
  box-sizing: border-box;
  min-width: 0;
}

.groupsBox {
  margin-top: 10px;
  border: 1px solid var(--line);
  background: var(--panel);
  border-radius: 12px;
  padding: 10px;
  max-height: 320px;
  overflow-y: auto;
  overflow-x: hidden;
}

.groupsInner {
  column-width: 280px;
  column-gap: 14px;
  column-count: 4;
}

.groupItem{
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 8px;
  padding: 6px 8px;
  border-radius: 10px;
  cursor: pointer;
  user-select: none;
  white-space: nowrap;
}

.groupItem:hover{
  background: rgba(255,255,255,.06);
}

.groupItem input{
  margin: 0;
  width: 16px;
  height: 16px;
  flex: 0 0 auto;
}

.groupItem span{
  display: inline-block;
  overflow: hidden;
  text-overflow: ellipsis;
}

.tableWrap {
  width: 100%;
  overflow-x: auto;
}

@media (max-width: 768px) {
  .templatesTable th:nth-child(3),
  .templatesTable td:nth-child(3),
  .templatesTable th:nth-child(4),
  .templatesTable td:nth-child(4) {
    display: none;
  }
}

.templatesTable td {
  vertical-align: top;
}

.actionsCell{
  display: flex;
  gap: 8px;
  flex-wrap: wrap;
  align-items: center;
}

.groupsCell{
  white-space: normal;
  word-break: break-word;
}
</style>

</div></body></html>
