<%- include("partials/header") %>
<%- include("partials/sidebar") %>

<main class="main">
  <h1>Agency Templates</h1>
  <small>Templates allow quick assignment of multiple groups to a user upon creation. Editing a template does not edit previously created users.</small>

  <div class="card">
    <div class="row" style="justify-content: space-between; align-items: center;">
      <h2 style="margin:0;" id="formTitle">Create New Template</h2>
      <div class="row" style="gap:8px;">
        <button class="btn" id="cancelEditBtn" type="button" style="display:none;">Cancel Edit</button>
      </div>
    </div>

    <form id="form" class="templatesGrid" autocomplete="off">
      <label>Template Name
        <input id="name" placeholder="Template Name Here (ex. Patrol, Medic, etc...)" required />
      </label>

      <label>Agency
        <select id="agency">
          <option value="">Select an agency</option>
        </select>
      </label>

      <label>Color Override (optional)
        <select id="colorOverride">
          <option value="">Use Default Agency Color</option>
          <option value="Blue">Blue</option>
          <option value="Dark Blue">Dark Blue</option>
          <option value="Brown">Brown</option>
          <option value="Cyan">Cyan</option>
          <option value="Green">Green</option>
          <option value="Dark Green">Dark Green</option>
          <option value="Magenta">Magenta</option>
          <option value="Maroon">Maroon</option>
          <option value="Orange">Orange</option>
          <option value="Purple">Purple</option>
          <option value="Red">Red</option>
          <option value="Teal">Teal</option>
          <option value="White">White</option>
          <option value="Yellow">Yellow</option>
        </select>
      </label>

      <label>Default Template
        <select id="isDefault">
          <option value="no">No</option>
          <option value="yes">Yes</option>
        </select>
      </label>

      <div style="grid-column:1/-1;">
        <label>Groups
          <input id="groupSearch" placeholder="Search groups..." />
          <div class="row" style="gap:10px; margin-top:8px;">
            <button class="btn" type="button" id="selectAllBtn">Select All</button>
            <button class="btn" type="button" id="clearAllBtn">Clear</button>
          </div>

          <div id="groupsBox" class="groupsBox">
            <div id="groupsInner" class="groupsInner"></div>
          </div>
        </label>
      </div>

      <div style="grid-column:1/-1;" class="row">
        <button class="btn" id="submitBtn" type="submit">Create Template</button>
        <span id="msg" class="msg"></span>
      </div>
    </form>
  </div>

  <div class="card">
    <h2>Existing Templates</h2>
    <div class="tableWrap">
      <table class="table templatesTable">
        <thead id="templatesThead">
          <tr>
            <th class="sortable" data-key="name">Name <span class="sortIndicator" aria-hidden="true"></span></th>
            <th class="sortable" data-key="agency">Agency <span class="sortIndicator" aria-hidden="true"></span></th>
            <th class="sortable" data-key="color">Color <span class="sortIndicator" aria-hidden="true"></span></th>
            <th class="sortable" data-key="default">Default <span class="sortIndicator" aria-hidden="true"></span></th>
            <th class="sortable" data-key="groups">Groups <span class="sortIndicator" aria-hidden="true"></span></th>
            <th>Actions</th>
          </tr>
        </thead>
        <tbody id="tbody"></tbody>
      </table>
    </div>
  </div>
</main>

<script>
const msg = document.getElementById("msg");
const tbody = document.getElementById("tbody");
const form = document.getElementById("form");

const formTitle = document.getElementById("formTitle");
const submitBtn = document.getElementById("submitBtn");
const cancelEditBtn = document.getElementById("cancelEditBtn");

const nameEl = document.getElementById("name");
const agencyEl = document.getElementById("agency");
const isDefaultEl = document.getElementById("isDefault");
const colorOverrideEl = document.getElementById("colorOverride");

const groupSearch = document.getElementById("groupSearch");
const groupsBox = document.getElementById("groupsBox");
const selectAllBtn = document.getElementById("selectAllBtn");
const clearAllBtn = document.getElementById("clearAllBtn");
const groupsInner = document.getElementById("groupsInner");


// ------- Sorting state -------
let sortState = {
  key: "name",   // default sort
  dir: "asc"     // "asc" | "desc"
};

function normalizeSortValue(v){
  return String(v ?? "").trim().toLowerCase();
}

function getSortValue(t, key){
  if (key === "name") return normalizeSortValue(t.name);
  if (key === "agency") return normalizeSortValue(agencyAbbrFromSuffix(t.agencySuffix) || t.agencySuffix);
  if (key === "color") return normalizeSortValue(t.colorOverride);
  if (key === "default") return t.isDefault ? "yes" : "no";
  if (key === "groups") return normalizeSortValue((t.groups || []).join(", "));
  return "";
}

function stableSortedCopy(arr, key, dir){
  const sign = dir === "desc" ? -1 : 1;
  return (arr || [])
    .map((item, idx) => ({ item, idx }))
    .sort((a, b) => {
      const av = getSortValue(a.item, key);
      const bv = getSortValue(b.item, key);

      const cmp = av.localeCompare(bv, undefined, { numeric: true, sensitivity: "base" });
      if (cmp !== 0) return cmp * sign;
      return a.idx - b.idx;
    })
    .map(x => x.item);
}

function updateSortIndicators(){
  const thead = document.getElementById("templatesThead");
  const ths = Array.from(thead ? thead.querySelectorAll("th.sortable") : []);
  ths.forEach(th => {
    const key = th.dataset.key;
    const indicator = th.querySelector(".sortIndicator");
    if (!indicator) return;

    if (key === sortState.key) {
      indicator.textContent = sortState.dir === "asc" ? "▲" : "▼";
    } else {
      indicator.textContent = "";
    }
  });
}



const templatesThead = document.getElementById("templatesThead");
if (templatesThead){
  templatesThead.addEventListener("click", (e) => {
    const th = e.target && e.target.closest ? e.target.closest("th.sortable") : null;
    if (!th) return;

    const key = th.dataset.key;
    if (!key) return;

    if (sortState.key === key){
      sortState.dir = sortState.dir === "asc" ? "desc" : "asc";
    } else {
      sortState.key = key;
      sortState.dir = "asc";
    }

    loadTemplates();
  });
}
let allGroups = [];
let allTemplates = [];
let allAgencies = [];
let editingIndex = null;

function setMsg(text, ok=true){
  msg.textContent = text || "";
  msg.className = "msg " + (ok ? "ok" : "bad");
}

function esc(s){
  return String(s ?? "")
    .replaceAll("&","&amp;")
    .replaceAll("<","&lt;")
    .replaceAll(">","&gt;")
    .replaceAll('"',"&quot;")
    .replaceAll("'","&#39;");
}

function getCheckedGroupNames(){
  return Array.from(groupsBox.querySelectorAll('input[type="checkbox"]:checked'))
    .map(cb => cb.value);
}

function setCheckedGroupNames(names){
  const set = new Set((names || []).map(String));
  Array.from(groupsBox.querySelectorAll('input[type="checkbox"]')).forEach(cb => {
    cb.checked = set.has(cb.value);
  });
}

function renderGroups(filterText = ""){
  const q = String(filterText || "").trim().toLowerCase();

  const list = allGroups
    .map(g => String(g.name))
    .sort((a,b)=>a.localeCompare(b))
    .filter(name => !q || name.toLowerCase().includes(q));

  groupsInner.innerHTML = list.map(name => `
    <label class="groupItem">
      <input type="checkbox" value="${esc(name)}" />
      <span>${esc(name)}</span>
    </label>
  `).join("");

  if (editingIndex !== null) {
    const t = allTemplates[editingIndex];
    setCheckedGroupNames(t?.groups || []);
  }
}

async function loadAgencies(){
  const res = await fetch("/api/agencies");
  const agencies = await res.json();

  allAgencies = Array.isArray(agencies) ? agencies : [];

  agencyEl.innerHTML = `<option value="">Select an agency</option>` +
    allAgencies.map(a => {
      const abbr = (a.groupPrefix || "").trim();
      const suffix = (a.suffix || "").trim();
      const name = (a.name || "").trim();

      // value stays suffix (important: keeps existing behavior)
      // label can show abbreviation instead of suffix (optional)
      return `<option value="${esc(suffix)}">${esc(name)}${abbr ? ` (${esc(abbr)})` : ""}</option>`;
    }).join("");
}

async function loadGroups(){
  const res = await fetch("/api/users/groups");
  const groups = await res.json();
  if (!res.ok) throw new Error(groups.error || "Failed to load groups");
  allGroups = groups;
  renderGroups("");
}

function agencyAbbrFromSuffix(suffix){
  const s = String(suffix || "").trim().toLowerCase();
  const a = allAgencies.find(x => String(x.suffix || "").trim().toLowerCase() === s);
  return String(a?.groupPrefix || "").trim();
}

async function loadTemplates(){
  const res = await fetch("/api/templates");
  const templates = await res.json();
  if (!res.ok) throw new Error(templates.error || "Failed to load templates");
  allTemplates = templates;

  
  const sorted = (allTemplates || [])
    .map((t, idx) => ({ t, idx }))
    .sort((a, b) => {
      const sign = sortState.dir === "desc" ? -1 : 1;
      const av = getSortValue(a.t, sortState.key);
      const bv = getSortValue(b.t, sortState.key);

      const cmp = av.localeCompare(bv, undefined, { numeric: true, sensitivity: "base" });
      if (cmp !== 0) return cmp * sign;
      return a.idx - b.idx;
    });

  tbody.innerHTML = sorted.map(({t, idx})=>`
    <tr>
      <td>${esc(t.name)}</td>
      <td>${t.agencySuffix ? esc(agencyAbbrFromSuffix(t.agencySuffix) || t.agencySuffix): "—"}</td>
      <td>${t.colorOverride ? esc(t.colorOverride) : "—"}</td>
      <td>${t.isDefault ? "Yes" : ""}</td>
      <td class="groupsCell">${esc((t.groups || []).join(", "))}</td>
      <td>
        <div class="actionsCell">
          <button class="btn" type="button" onclick="editTemplate(${idx})">Edit</button>
          <button class="btn danger" type="button" onclick="deleteTemplate(${idx})">Delete</button>
        </div>
      </td>
    </tr>
  `).join("");

  updateSortIndicators();
}

function setCreateMode(){
  editingIndex = null;
  formTitle.textContent = "Create New Template";
  submitBtn.textContent = "Create Template";
  cancelEditBtn.style.display = "none";
  setMsg("");

  nameEl.value = "";
  agencyEl.value = "";
  colorOverrideEl.value = "";
  isDefaultEl.value = "no";
  groupSearch.value = "";
  renderGroups("");
  setCheckedGroupNames([]);
}

function setEditMode(idx){
  editingIndex = idx;
  const t = allTemplates[idx];

  formTitle.textContent = "Edit Template";
  submitBtn.textContent = "Save Changes";
  cancelEditBtn.style.display = "inline-block";
  setMsg("");

  nameEl.value = t.name || "";
  agencyEl.value = t.agencySuffix || "";
  colorOverrideEl.value = t.colorOverride || "";
  isDefaultEl.value = t.isDefault ? "yes" : "no";
  groupSearch.value = "";
  renderGroups("");
  setCheckedGroupNames(t.groups || []);

  window.scrollTo({ top: 0, behavior: "smooth" });
}

window.editTemplate = (idx) => setEditMode(idx);

window.deleteTemplate = async (idx) => {
  if(!confirm("Delete this template?")) return;
  setMsg("");

  const res = await fetch("/api/templates/" + idx, { method:"DELETE" });
  const out = await res.json();

  if(!res.ok){
    setMsg(out.error || "Delete failed", false);
    return;
  }

  setMsg("Template deleted", true);

  if (editingIndex === idx) setCreateMode();

  await loadTemplates();
};

groupSearch.oninput = () => {
  renderGroups(groupSearch.value);
};

selectAllBtn.onclick = () => {
  Array.from(groupsBox.querySelectorAll('input[type="checkbox"]')).forEach(cb => cb.checked = true);
};

clearAllBtn.onclick = () => {
  Array.from(groupsBox.querySelectorAll('input[type="checkbox"]')).forEach(cb => cb.checked = false);
};

cancelEditBtn.onclick = () => setCreateMode();

form.onsubmit = async (e) => {
  e.preventDefault();
  setMsg("");

  const payload = {
    name: nameEl.value.trim(),
    agencySuffix: agencyEl.value,
    colorOverride: (colorOverrideEl.value || ""),
    groups: getCheckedGroupNames(),
    isDefault: isDefaultEl.value === "yes"
  };

  if (!payload.name) return setMsg("Template name is required", false);
  if (!payload.groups.length) return setMsg("Select at least one group", false);

  const isEdit = editingIndex !== null;
  const url = isEdit ? ("/api/templates/" + editingIndex) : "/api/templates";
  const method = isEdit ? "PUT" : "POST";

  const res = await fetch(url, {
    method,
    headers: {"Content-Type":"application/json"},
    body: JSON.stringify(payload)
  });

  const out = await res.json();
  if(!res.ok){
    setMsg(out.error || (isEdit ? "Update failed" : "Create failed"), false);
    return;
  }

  setMsg(isEdit ? "Template updated" : "Template created", true);
  await loadTemplates();
  setCreateMode();
};

(async () => {
  try {
    await loadAgencies();
    await loadGroups();
    await loadTemplates();
    setCreateMode();
  } catch (err) {
    setMsg(err.message || "Failed to load page", false);
  }
})();
</script>

<style>
.templatesGrid {
  display: grid;
  gap: 12px;
  grid-template-columns: repeat(4, minmax(0, 1fr));
}

@media (max-width: 950px) {
  .templatesGrid {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }
}

@media (max-width: 560px) {
  .templatesGrid {
    grid-template-columns: 1fr;
  }
}

.templatesGrid > label {
  min-width: 0;
}

.templatesGrid > label > input,
.templatesGrid > label > select {
  width: 100%;
  box-sizing: border-box;
  min-width: 0;
}

.groupsBox {
  margin-top: 10px;
  border: 1px solid var(--line);
  background: var(--panel);
  border-radius: 12px;
  padding: 10px;
  max-height: 320px;
  overflow-y: auto;
  overflow-x: hidden;
}

.groupsInner {
  column-width: 280px;
  column-gap: 14px;
  column-count: 4;
}

.groupItem{
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 8px;
  padding: 6px 8px;
  border-radius: 10px;
  cursor: pointer;
  user-select: none;
  white-space: nowrap;
}

.groupItem:hover{
  background: rgba(255,255,255,.06);
}

.groupItem input{
  margin: 0;
  width: 16px;
  height: 16px;
  flex: 0 0 auto;
}

.groupItem span{
  display: inline-block;
  overflow: hidden;
  text-overflow: ellipsis;
}

.tableWrap {
  width: 100%;
  overflow-x: auto;
}

@media (max-width: 768px) {
  .templatesTable th:nth-child(3),
  .templatesTable td:nth-child(3),
  .templatesTable th:nth-child(4),
  .templatesTable td:nth-child(4) {
    display: none;
  }
}

.templatesTable td {
  vertical-align: top;
}

.actionsCell{
  display: flex;
  gap: 8px;
  flex-wrap: wrap;
  align-items: center;
}

.groupsCell{
  white-space: normal;
  word-break: break-word;
}
</style>

</div></body></html>
