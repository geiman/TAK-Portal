<%- include("partials/header") %>
<%- include("partials/sidebar") %>

<main class="main data-sync-page">
  <div class="data-sync-hero">
    <h1>Data Sync Mission Manager</h1>
  </div>

  <div id="statusBanner" class="card data-sync-status" style="display: none;" role="status"></div>

  <div class="card">
    <h2 style="margin-top: 0;">Create Data Sync Mission</h2>
    <div class="grid2">
      <label>Mission name
        <input type="text" id="createMissionName" autocomplete="off" placeholder="e.g. Incident Alpha" />
      </label>
      <label>Default role for subscribers
        <select id="createMissionDefaultRole" style="width: 100%; box-sizing: border-box;">
          <option value="MISSION_SUBSCRIBER">Mission subscriber (MISSION_SUBSCRIBER)</option>
          <option value="MISSION_OWNER">Mission owner (MISSION_OWNER)</option>
          <option value="MISSION_READONLY_SUBSCRIBER">Read-only (MISSION_READONLY_SUBSCRIBER)</option>
        </select>
      </label>
      <label style="grid-column: 1 / -1;">Description
        <textarea id="createMissionDescription" rows="2" placeholder="Mission description" style="width: 100%; box-sizing: border-box; resize: vertical;"></textarea>
      </label>
      <div class="create-mission-groups-wrap" style="grid-column: 1 / -1;">
        <label class="create-mission-groups-label">Groups with access
          <input type="search" id="createGroupFilter" placeholder="Search groups..." autocomplete="off" />
          <div id="createMissionGroupsBox" class="groupsBox">
            <div id="createMissionGroupsInner" class="groupsInner"></div>
          </div>
        </label>
      </div>
      <label>Password (optional)
        <div class="passwordWrap">
          <input type="password" id="createMissionPw" autocomplete="new-password" />
          <button type="button" id="createMissionPwToggle" class="passwordToggle" aria-label="Show password" title="Show password">👁</button>
        </div>
      </label>
      <div style="grid-column: 1 / -1; display: flex; align-items: center; gap: 10px; flex-wrap: wrap;">
        <button type="button" class="btn success" id="btnCreateMissionSubmit">Create mission</button>
        <span id="createMissionMsg" class="msg"></span>
      </div>
    </div>
  </div>

  <div class="card">
    <h2 style="margin-top: 0;">Existing Data Sync Missions</h2>

    <div class="data-sync-toolbar row" style="flex-wrap: wrap; align-items: flex-end; gap: 12px;">
      <label style="min-width: 140px;">
        List filter
        <input type="search" id="missionTableFilter" placeholder="Filter by name…" style="width: 100%; box-sizing: border-box;" autocomplete="off" />
      </label>
      <button type="button" class="btn" id="btnRefreshMissions">Refresh</button>
    </div>

    <div id="missionsMsg" class="msg" style="margin: 12px 0 0 0;"></div>

    <div style="overflow-x: auto; margin-top: 12px;">
      <table class="table data-sync-table">
        <thead>
          <tr>
            <th>Name</th>
            <th>Description</th>
            <th>Groups</th>
            <th>Password</th>
            <th>Created</th>
            <th style="min-width: 340px;">Actions</th>
          </tr>
        </thead>
        <tbody id="missionsTbody"></tbody>
      </table>
    </div>
  </div>

  <div class="card">
    <h2 style="margin-top: 0;">KML data sync packages</h2>
    <div class="row" style="flex-wrap: wrap; align-items: flex-end; gap: 14px;">
      <label style="min-width: 220px;">
        Mission
        <select id="kmlMissionSelect" style="min-width: 200px;">
          <option value="">Select a mission…</option>
        </select>
      </label>
      <label style="min-width: 240px;">
        KML package (.kml)
        <input type="file" id="kmlUploadInput" accept=".kml,application/vnd.google-earth.kml+xml,text/xml,application/xml" />
      </label>
      <label>
        &nbsp;
        <button type="button" class="btn success" id="btnKmlUpload">Upload KML</button>
      </label>
    </div>
    <div id="kmlUploadMsg" class="msg" style="margin-top: 10px;"></div>
  </div>
</main>

<!-- Create / Edit mission -->
<div class="modalOverlay" id="missionModal" style="display: none;">
  <div class="modal" role="dialog" aria-modal="true" aria-labelledby="missionModalTitle" style="width: min(900px, 96vw);">
    <div class="modalHeader">
      <h2 id="missionModalTitle" style="margin: 0;">Edit mission</h2>
      <button type="button" class="btn" id="missionModalClose">Close</button>
    </div>
    <div class="modalBody">
      <div id="missionModalMsg" class="msg" style="margin-bottom: 10px;"></div>

      <label style="display: block;">
        Mission name
        <input type="text" id="mName" readonly style="width: 100%; box-sizing: border-box; opacity: 0.85;" />
      </label>

      <label style="display: block; margin-top: 12px;">
        Description
        <textarea id="mDescription" rows="3" placeholder="Mission description" style="width: 100%; box-sizing: border-box; resize: vertical;"></textarea>
      </label>

      <label style="display: block; margin-top: 12px;">
        Default role for subscribers
        <select id="mDefaultRole" style="min-width: 280px;">
          <option value="MISSION_SUBSCRIBER">Mission subscriber (MISSION_SUBSCRIBER)</option>
          <option value="MISSION_OWNER">Mission owner (MISSION_OWNER)</option>
          <option value="MISSION_READONLY_SUBSCRIBER">Read-only subscriber (MISSION_READONLY_SUBSCRIBER)</option>
        </select>
      </label>
      <p class="muted" style="margin: 6px 0 0 0; font-size: 12px;">Tool is always <code>public</code> for Data Sync missions (not shown).</p>

      <div style="margin-top: 14px;">
        <div class="row" style="justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 8px;">
          <strong>Groups with access</strong>
          <input type="search" id="groupFilter" placeholder="Filter groups…" style="max-width: 260px; width: 100%; box-sizing: border-box;" />
        </div>
        <div id="mGroupsBox" class="groupsBox" style="margin-top: 8px;"></div>
      </div>

      <div class="card" style="margin-top: 16px; background: var(--card);">
        <h3 style="margin: 0 0 8px 0; font-size: 1rem;">Password (optional)</h3>
        <div class="row" style="flex-wrap: wrap; gap: 10px; align-items: flex-end;">
          <label style="flex: 1; min-width: 200px;">New password
            <div class="passwordWrap">
              <input type="password" id="mNewPw" autocomplete="new-password" style="width: 100%; box-sizing: border-box;" />
              <button type="button" id="mNewPwToggle" class="passwordToggle" aria-label="Show password" title="Show password">👁</button>
            </div>
          </label>
          <button type="button" class="btn success" id="mBtnSetPw">Set password</button>
          <button type="button" class="btn danger" id="mBtnClearPw">Remove password</button>
        </div>
      </div>

      <div id="mContentsWrap" style="margin-top: 16px; display: none;">
        <h3 style="margin: 0 0 8px 0; font-size: 1rem;">Contents</h3>
        <p class="muted" style="margin: 0 0 8px 0; font-size: 13px;">Per-item downloads use <code>GET /Marti/sync/content</code> (may not be KML). For a full package as KML, use the <strong>KML</strong> button on the mission row.</p>
        <div style="overflow-x: auto;">
          <table class="table" style="margin: 0;">
            <thead>
              <tr>
                <th>Label</th>
                <th style="min-width: 140px;">Download</th>
              </tr>
            </thead>
            <tbody id="mContentsTbody"></tbody>
          </table>
        </div>
      </div>

      <div class="row" style="margin-top: 18px; gap: 10px; flex-wrap: wrap;">
        <button type="button" class="btn success" id="mBtnSave">Save Mission</button>
        <span id="mSaveHint" class="muted" style="font-size: 13px;"></span>
      </div>
    </div>
  </div>
</div>

<!-- Delete confirm -->
<div class="modalOverlay" id="deleteModal" style="display: none;">
  <div class="modal" role="dialog" aria-modal="true" aria-labelledby="deleteTitle" style="width: min(480px, 94vw);">
    <div class="modalHeader">
      <h2 id="deleteTitle" style="margin: 0;">Delete mission</h2>
      <button type="button" class="btn" id="deleteModalClose">Cancel</button>
    </div>
    <div class="modalBody">
      <p id="deleteModalText" style="margin-top: 0;"></p>
      <div class="row" style="gap: 10px;">
        <button type="button" class="btn danger" id="deleteModalConfirm">Delete</button>
      </div>
    </div>
  </div>
</div>

<style>
  .data-sync-page .data-sync-lead { color: var(--muted); max-width: 72ch; line-height: 1.45; margin: 0.35rem 0 0 0; }
  .data-sync-page .data-sync-lead a { color: var(--btn); }
  .data-sync-status.msg { margin-left: 0; padding: 12px 14px; border-radius: 10px; border: 1px solid var(--line); }
  .data-sync-status.bad { border-color: rgba(255,80,80,.45); background: rgba(255,80,80,.08); }
  .data-sync-status.ok { border-color: rgba(24,179,90,.35); background: rgba(24,179,90,.08); }
  .chk-inline { display: inline-flex; align-items: center; gap: 8px; font-size: 13px; color: var(--muted); user-select: none; cursor: pointer; }
  .chk-inline input { margin: 0; }
  .data-sync-table code { font-size: 11px; }
  .mission-action-row { display: flex; flex-wrap: wrap; gap: 6px; }
  .muted { color: var(--muted); }

  /* Create card: manual groups picker — match users-manage.ejs (outer scroll + inner multicolumn) */
  .data-sync-page .create-mission-groups-label {
    display: block;
    font-weight: 600;
  }
  .data-sync-page .create-mission-groups-label input[type="search"] {
    display: block;
    width: 100%;
    max-width: 100%;
    box-sizing: border-box;
    margin-top: 6px;
  }
  .data-sync-page .create-mission-groups-wrap .groupsBox {
    margin-top: 10px;
    border: 1px solid var(--line);
    background: var(--panel);
    border-radius: 12px;
    padding: 10px;
    max-height: 320px;
    overflow-y: auto;
    overflow-x: hidden;
  }
  .data-sync-page .create-mission-groups-wrap .groupsInner {
    column-width: 310px;
    column-gap: 14px;
    column-count: 4;
  }
  .data-sync-page .create-mission-groups-wrap .groupItem {
    display: flex !important;
    flex-direction: row !important;
    align-items: center;
    gap: 8px;
    padding: 6px 8px;
    border-radius: 10px;
    cursor: pointer;
    user-select: none;
    white-space: nowrap;
    break-inside: avoid;
  }
  .data-sync-page .create-mission-groups-wrap .groupItem:hover {
    background: rgba(255, 255, 255, 0.06);
  }
  .data-sync-page .create-mission-groups-wrap .groupItem input {
    margin: 0;
    width: 16px;
    height: 16px;
    flex: 0 0 auto;
  }
  .data-sync-page .create-mission-groups-wrap .groupItem span {
    display: inline-block;
    overflow: hidden;
    text-overflow: ellipsis;
  }
</style>

<script>
(function () {
  var API = "/api/data-sync";

  var statusBanner = document.getElementById("statusBanner");
  var missionsMsg = document.getElementById("missionsMsg");
  var missionsTbody = document.getElementById("missionsTbody");
  var missionTableFilter = document.getElementById("missionTableFilter");
  var btnRefreshMissions = document.getElementById("btnRefreshMissions");
  var createMissionName = document.getElementById("createMissionName");
  var createMissionDescription = document.getElementById("createMissionDescription");
  var createMissionDefaultRole = document.getElementById("createMissionDefaultRole");
  var createGroupFilter = document.getElementById("createGroupFilter");
  var createMissionGroupsBox = document.getElementById("createMissionGroupsBox");
  var createMissionGroupsInner = document.getElementById("createMissionGroupsInner");
  var createMissionPw = document.getElementById("createMissionPw");
  var btnCreateMissionSubmit = document.getElementById("btnCreateMissionSubmit");
  var createMissionMsg = document.getElementById("createMissionMsg");

  var kmlMissionSelect = document.getElementById("kmlMissionSelect");
  var kmlUploadInput = document.getElementById("kmlUploadInput");
  var btnKmlUpload = document.getElementById("btnKmlUpload");
  var kmlUploadMsg = document.getElementById("kmlUploadMsg");
  var missionModal = document.getElementById("missionModal");
  var missionModalClose = document.getElementById("missionModalClose");
  var missionModalTitle = document.getElementById("missionModalTitle");
  var missionModalMsg = document.getElementById("missionModalMsg");
  var mName = document.getElementById("mName");
  var mDescription = document.getElementById("mDescription");
  var mDefaultRole = document.getElementById("mDefaultRole");
  var mGroupsBox = document.getElementById("mGroupsBox");
  var groupFilter = document.getElementById("groupFilter");
  var mNewPw = document.getElementById("mNewPw");
  var mBtnSetPw = document.getElementById("mBtnSetPw");
  var mBtnClearPw = document.getElementById("mBtnClearPw");
  var mContentsWrap = document.getElementById("mContentsWrap");
  var mContentsTbody = document.getElementById("mContentsTbody");
  var mBtnSave = document.getElementById("mBtnSave");
  var mSaveHint = document.getElementById("mSaveHint");

  var deleteModal = document.getElementById("deleteModal");
  var deleteModalClose = document.getElementById("deleteModalClose");
  var deleteModalText = document.getElementById("deleteModalText");
  var deleteModalConfirm = document.getElementById("deleteModalConfirm");

  var missionsCache = [];
  var groupsCache = [];
  var missionDetail = null;
  var editingOriginalName = "";
  var pendingDeleteName = "";
  var selectedGroupSet = new Set();
  var createSelectedGroupSet = new Set();

  function esc(s) {
    return String(s == null ? "" : s)
      .replace(/&/g, "&amp;")
      .replace(/</g, "&lt;")
      .replace(/>/g, "&gt;")
      .replace(/"/g, "&quot;");
  }

  function setMissionsMsg(text, ok) {
    missionsMsg.textContent = text || "";
    missionsMsg.className = "msg " + (ok === true ? "ok" : ok === false ? "bad" : "");
  }

  function setKmlUploadMsg(text, ok) {
    kmlUploadMsg.textContent = text || "";
    kmlUploadMsg.className = "msg " + (ok === true ? "ok" : ok === false ? "bad" : "");
  }

  function setMissionModalMsg(text, ok) {
    missionModalMsg.textContent = text || "";
    missionModalMsg.className = "msg " + (ok === true ? "ok" : ok === false ? "bad" : "");
  }

  function setCreateMissionMsg(text, ok) {
    if (!createMissionMsg) return;
    createMissionMsg.textContent = text || "";
    createMissionMsg.className = "msg " + (ok === true ? "ok" : ok === false ? "bad" : "");
  }

  function unwrapList(payload) {
    if (!payload) return [];
    if (Array.isArray(payload.data)) return payload.data;
    if (Array.isArray(payload)) return payload;
    return [];
  }

  function unwrapMission(payload) {
    if (!payload) return null;
    if (payload.data != null) {
      if (Array.isArray(payload.data) && payload.data.length) return payload.data[0];
      if (typeof payload.data === "object" && !Array.isArray(payload.data)) return payload.data;
    }
    if (payload.Mission && typeof payload.Mission === "object") return payload.Mission;
    return payload;
  }

  function buildDefaultRoleObject(roleType) {
    var t = roleType || "MISSION_SUBSCRIBER";
    if (t === "MISSION_READONLY_SUBSCRIBER") {
      return { type: t, permissions: ["MISSION_READ"] };
    }
    if (t === "MISSION_OWNER") {
      return {
        type: t,
        permissions: [
          "MISSION_MANAGE_FEEDS",
          "MISSION_SET_PASSWORD",
          "MISSION_WRITE",
          "MISSION_MANAGE_LAYERS",
          "MISSION_READ",
          "MISSION_SET_ROLE",
          "MISSION_DELETE",
        ],
      };
    }
    return { type: "MISSION_SUBSCRIBER", permissions: ["MISSION_WRITE", "MISSION_READ"] };
  }

  function syncDefaultRoleSelectFromMission(mission) {
    if (!mDefaultRole) return;
    var dr = mission && mission.defaultRole;
    var t = dr && dr.type ? String(dr.type) : "MISSION_SUBSCRIBER";
    var allowed = ["MISSION_SUBSCRIBER", "MISSION_OWNER", "MISSION_READONLY_SUBSCRIBER"];
    mDefaultRole.value = allowed.indexOf(t) >= 0 ? t : "MISSION_SUBSCRIBER";
  }

  function normalizeGroupNames(payload) {
    var raw = unwrapList(payload);
    return extractGroupNames(raw).sort(function (a, b) { return a.localeCompare(b); });
  }

  /** One entry from TAK: string or { name, groupName, … } — same shape as pagedmissions vs GET mission. */
  function entryToGroupName(entry) {
    if (entry == null) return "";
    if (typeof entry === "string") return entry.trim();
    if (typeof entry === "object") {
      return String(
        entry.name ||
          entry.groupName ||
          entry.group ||
          entry.title ||
          ""
      ).trim();
    }
    return String(entry).trim();
  }

  function extractGroupNames(arr) {
    if (!Array.isArray(arr)) return [];
    var out = [];
    for (var i = 0; i < arr.length; i++) {
      var n = entryToGroupName(arr[i]);
      if (n) out.push(n);
    }
    return out;
  }

  /** Map a TAK group name to the canonical string in groupsCache (for checkbox value match). */
  function resolveToGroupsCache(name) {
    var n = String(name || "").trim();
    if (!n) return null;
    if (groupsCache.indexOf(n) >= 0) return n;
    var nl = n.toLowerCase();
    for (var i = 0; i < groupsCache.length; i++) {
      if (groupsCache[i].toLowerCase() === nl) return groupsCache[i];
    }
    return null;
  }

  function missionRowFromCache(missionName) {
    var want = String(missionName || "");
    for (var i = 0; i < missionsCache.length; i++) {
      var m = missionsCache[i];
      if (m && String(m.name) === want) return m;
    }
    return null;
  }

  function applyMissionGroupsToSelection(rawGroupsArray) {
    selectedGroupSet = new Set();
    var names = extractGroupNames(rawGroupsArray);
    for (var j = 0; j < names.length; j++) {
      var canon = resolveToGroupsCache(names[j]);
      if (canon) selectedGroupSet.add(canon);
    }
  }

  async function loadStatus() {
    try {
      var res = await fetch(API + "/status");
      var j = await res.json();
      if (!res.ok) throw new Error((j && j.error) || "Status failed");
      if (!j.configured) {
        statusBanner.style.display = "block";
        statusBanner.className = "card data-sync-status msg bad";
        statusBanner.innerHTML =
          "<strong>TAK is not available from the portal.</strong> " +
          (j.bypassed
            ? "TAK_BYPASS_ENABLED is on, or TAK_URL / client certificates are not configured. " +
              "Configure <strong>Server Settings</strong> (TAK URL and API certificate) and disable bypass."
            : "Set <strong>TAK_URL</strong> and upload the <strong>TAK API PKCS#12</strong> (or PEM cert/key) so the portal can call Marti.");
        return false;
      }
      statusBanner.style.display = "none";
      statusBanner.innerHTML = "";
      return true;
    } catch (e) {
      statusBanner.style.display = "block";
      statusBanner.className = "card data-sync-status msg bad";
      statusBanner.textContent = e.message || "Could not load status.";
      return false;
    }
  }

  async function loadGroups() {
    var res = await fetch(API + "/groups");
    var j = await res.json();
    if (!res.ok) throw new Error((j && j.error) || "Failed to load groups");
    groupsCache = normalizeGroupNames(j);
    renderCreateGroupCheckboxes();
    return groupsCache;
  }

  function missionQueryParams() {
    return {};
  }

  function buildQueryString(obj) {
    var parts = [];
    Object.keys(obj).forEach(function (k) {
      parts.push(encodeURIComponent(k) + "=" + encodeURIComponent(obj[k]));
    });
    return parts.length ? "?" + parts.join("&") : "";
  }

  async function loadMissions(opts) {
    opts = opts || {};
    if (!opts.silent) setMissionsMsg("Loading missions…", undefined);
    try {
      var qs = buildQueryString(missionQueryParams());
      var res = await fetch(API + "/missions" + qs);
      var text = await res.text();
      var j;
      try {
        j = JSON.parse(text);
      } catch (_) {
        throw new Error("Invalid JSON from server");
      }
      if (!res.ok) throw new Error((j && j.error) || text.slice(0, 400));
      missionsCache = unwrapList(j);
      renderMissionsTable();
      populateKmlMissionSelects();
      setMissionsMsg(missionsCache.length ? "" : "No missions.", true);
    } catch (e) {
      setMissionsMsg(e.message || "Failed to load missions", false);
    }
  }

  function renderMissionsTable() {
    var filter = (missionTableFilter && missionTableFilter.value || "").trim().toLowerCase();
    missionsTbody.innerHTML = "";
    for (var i = 0; i < missionsCache.length; i++) {
      var m = missionsCache[i];
      var name = m && m.name != null ? String(m.name) : "";
      if (filter && name.toLowerCase().indexOf(filter) === -1) continue;

      var tr = document.createElement("tr");
      var groups = Array.isArray(m.groups) ? m.groups : [];
      var pw = m.passwordProtected === true ? "Yes" : "No";
      var ct = m.createTime ? String(m.createTime) : "";
      var desc = m.description != null ? String(m.description) : "";
      if (desc.length > 48) desc = desc.slice(0, 45) + "…";

      tr.innerHTML =
        "<td><strong>" + esc(name) + "</strong></td>" +
        "<td style=\"max-width:220px;font-size:13px;\">" + esc(desc) + "</td>" +
        "<td>" + groups.length + "</td>" +
        "<td>" + esc(pw) + "</td>" +
        "<td style=\"font-size:12px;white-space:nowrap;\">" + esc(ct) + "</td>" +
        "<td></td>";

      var tdAct = tr.querySelector("td:last-child");
      var wrap = document.createElement("div");
      wrap.className = "mission-action-row";

      var bEdit = document.createElement("button");
      bEdit.type = "button";
      bEdit.className = "btn";
      bEdit.textContent = "Edit";
      bEdit.addEventListener("click", function (nm) {
        return function () { openEditMission(nm); };
      }(name));

      var bDel = document.createElement("button");
      bDel.type = "button";
      bDel.className = "btn danger";
      bDel.textContent = "Delete";
      bDel.addEventListener("click", function (nm) {
        return function () { openDeleteMission(nm); };
      }(name));

      var bHtml = document.createElement("button");
      bHtml.type = "button";
      bHtml.className = "btn";
      bHtml.textContent = "HTML";
      bHtml.title = "Download mission archive (HTML)";
      bHtml.addEventListener("click", function (nm) {
        return function () {
          setMissionsMsg("Downloading HTML archive…", undefined);
          fetchMissionArchiveBlob(nm, "")
            .then(function (blob) {
              triggerBrowserHtmlDownload(blob, nm);
              setMissionsMsg("HTML download started.", true);
            })
            .catch(function (e) {
              setMissionsMsg(e.message || "HTML download failed", false);
            });
        };
      }(name));

      var bKml = document.createElement("button");
      bKml.type = "button";
      bKml.className = "btn";
      bKml.textContent = "KML";
      bKml.title = "Download Data Sync package as KML";
      bKml.addEventListener("click", function (nm) {
        return function () {
          setMissionsMsg("Downloading KML…", undefined);
          fetchMissionKmlBlob(nm, "")
            .then(function (blob) {
              triggerBrowserKmlDownload(blob, nm);
              setMissionsMsg("KML download started.", true);
            })
            .catch(function (e) {
              setMissionsMsg(e.message || "KML download failed", false);
            });
        };
      }(name));

      wrap.appendChild(bEdit);
      wrap.appendChild(bHtml);
      wrap.appendChild(bKml);
      wrap.appendChild(bDel);
      tdAct.appendChild(wrap);

      missionsTbody.appendChild(tr);
    }
  }

  function fillMissionSelect(selectEl, previousValue) {
    if (!selectEl) return;
    var v = previousValue !== undefined ? previousValue : selectEl.value;
    selectEl.innerHTML = "";
    var opt0 = document.createElement("option");
    opt0.value = "";
    opt0.textContent = "Select a mission…";
    selectEl.appendChild(opt0);
    for (var i = 0; i < missionsCache.length; i++) {
      var m = missionsCache[i];
      var name = m && m.name != null ? String(m.name) : "";
      if (!name) continue;
      var opt = document.createElement("option");
      opt.value = name;
      opt.textContent = name;
      selectEl.appendChild(opt);
    }
    if (v) selectEl.value = v;
  }

  function populateKmlMissionSelects() {
    var uv = kmlMissionSelect ? kmlMissionSelect.value : "";
    fillMissionSelect(kmlMissionSelect, uv);
  }

  function sanitizeKmlFilename(name) {
    var s = String(name || "mission")
      .replace(/[^\w.\- ()\[\]]+/g, "_")
      .trim()
      .slice(0, 120);
    return s || "mission";
  }

  async function fetchMissionArchiveBlob(missionName, password) {
    var url = API + "/missions/" + encodeURIComponent(missionName) + "/export-archive";
    var qs = [];
    if (password) qs.push("password=" + encodeURIComponent(password));
    if (qs.length) url += "?" + qs.join("&");
    var res = await fetch(url);
    if (!res.ok) {
      var text = await res.text().catch(function () { return ""; });
      var err = "Export failed (HTTP " + res.status + ")";
      try {
        var j = JSON.parse(text);
        if (j && j.error) err = j.error;
      } catch (_) {
        var m = text.match(/<title>([^<]+)<\/title>/i);
        if (m) err = m[1].trim();
      }
      throw new Error(err);
    }
    return res.blob();
  }

  function triggerBrowserHtmlDownload(blob, missionName) {
    var a = document.createElement("a");
    a.href = URL.createObjectURL(blob);
    a.download = sanitizeKmlFilename(missionName) + ".html";
    document.body.appendChild(a);
    a.click();
    a.remove();
    setTimeout(function () {
      try {
        URL.revokeObjectURL(a.href);
      } catch (_) {
        /* ignore */
      }
    }, 2500);
  }

  async function fetchMissionKmlBlob(missionName, password) {
    var url = API + "/missions/" + encodeURIComponent(missionName) + "/export-kml";
    var qs = [];
    if (password) qs.push("password=" + encodeURIComponent(password));
    if (qs.length) url += "?" + qs.join("&");
    var res = await fetch(url);
    if (!res.ok) {
      var text = await res.text().catch(function () { return ""; });
      var err = "Export failed (HTTP " + res.status + ")";
      try {
        var j = JSON.parse(text);
        if (j && j.error) err = j.error;
      } catch (_) {
        var m = text.match(/<title>([^<]+)<\/title>/i);
        if (m) err = m[1].trim();
      }
      throw new Error(err);
    }
    return res.blob();
  }

  function triggerBrowserKmlDownload(blob, missionName) {
    var a = document.createElement("a");
    a.href = URL.createObjectURL(blob);
    a.download = sanitizeKmlFilename(missionName) + ".kml";
    document.body.appendChild(a);
    a.click();
    a.remove();
    setTimeout(function () {
      try {
        URL.revokeObjectURL(a.href);
      } catch (_) {
        /* ignore */
      }
    }, 2500);
  }

  function renderGroupCheckboxes() {
    var filt = (groupFilter && groupFilter.value || "").trim().toLowerCase();
    mGroupsBox.innerHTML = "";
    for (var i = 0; i < groupsCache.length; i++) {
      var g = groupsCache[i];
      if (filt && g.toLowerCase().indexOf(filt) === -1) continue;
      var label = document.createElement("label");
      label.className = "groupItem";
      var cb = document.createElement("input");
      cb.type = "checkbox";
      cb.value = g;
      cb.checked = selectedGroupSet.has(g);
      var span = document.createElement("span");
      span.textContent = g;
      label.appendChild(cb);
      label.appendChild(span);
      mGroupsBox.appendChild(label);
    }
  }

  function getSelectedGroupsFromBox() {
    return Array.from(selectedGroupSet);
  }

  function renderCreateGroupCheckboxes() {
    var host = createMissionGroupsInner || createMissionGroupsBox;
    if (!host) return;
    var filt = (createGroupFilter && createGroupFilter.value || "").trim().toLowerCase();
    host.innerHTML = "";
    for (var i = 0; i < groupsCache.length; i++) {
      var g = groupsCache[i];
      if (filt && g.toLowerCase().indexOf(filt) === -1) continue;
      var label = document.createElement("label");
      label.className = "groupItem";
      var cb = document.createElement("input");
      cb.type = "checkbox";
      cb.value = g;
      cb.checked = createSelectedGroupSet.has(g);
      var span = document.createElement("span");
      span.textContent = g;
      label.appendChild(cb);
      label.appendChild(span);
      host.appendChild(label);
    }
  }

  function clearCreateMissionForm() {
    if (createMissionName) createMissionName.value = "";
    if (createMissionDescription) createMissionDescription.value = "";
    if (createMissionDefaultRole) createMissionDefaultRole.value = "MISSION_SUBSCRIBER";
    if (createMissionPw) createMissionPw.value = "";
    if (createGroupFilter) createGroupFilter.value = "";
    createSelectedGroupSet = new Set();
    renderCreateGroupCheckboxes();
  }

  async function submitCreateMission() {
    var name = (createMissionName && createMissionName.value || "").trim();
    if (!name) {
      setCreateMissionMsg("Mission name is required.", false);
      return;
    }
    setCreateMissionMsg("Creating…", undefined);
    try {
      var payload = {
        name: name,
        tool: "public",
        description: createMissionDescription ? String(createMissionDescription.value || "") : "",
        defaultRole: buildDefaultRoleObject(createMissionDefaultRole && createMissionDefaultRole.value),
        groups: Array.from(createSelectedGroupSet),
        keywords: [],
        inviteOnly: false,
      };
      var url = API + "/missions/" + encodeURIComponent(payload.name);
      var res = await fetch(url, {
        method: "PUT",
        headers: { "Content-Type": "application/json", Accept: "application/json" },
        body: JSON.stringify(payload),
      });
      var text = await res.text();
      var j;
      try {
        j = JSON.parse(text);
      } catch (_) {
        j = { raw: text };
      }
      if (!res.ok) throw new Error((j && j.error) || text.slice(0, 500) || "Create failed");

      var pwApply = (createMissionPw && createMissionPw.value) || "";
      if (pwApply) {
        var pr = await fetch(API + "/missions/" + encodeURIComponent(payload.name) + "/password", {
          method: "PUT",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({ password: pwApply }),
        });
        var ptext = await pr.text();
        var pj;
        try {
          pj = JSON.parse(ptext);
        } catch (_) {
          pj = {};
        }
        if (!pr.ok) {
          throw new Error((pj && pj.error) || "Mission created but password could not be set.");
        }
        if (createMissionPw) createMissionPw.value = "";
      }

      clearCreateMissionForm();
      setCreateMissionMsg("Mission created.", true);
      loadMissions({ silent: true });
    } catch (e) {
      setCreateMissionMsg(e.message || "Create failed", false);
    }
  }

  function openModal() {
    missionModal.style.display = "flex";
    document.body.classList.add("noScroll");
  }

  function closeModal() {
    missionModal.style.display = "none";
    document.body.classList.remove("noScroll");
    missionDetail = null;
    editingOriginalName = "";
  }

  async function openEditMission(name) {
    missionModalTitle.textContent = "Edit mission";
    mName.readOnly = true;
    setMissionModalMsg("Loading…", undefined);
    mSaveHint.textContent = "";
    mNewPw.value = "";
    openModal();
    try {
      if (!groupsCache.length) await loadGroups();
      var res = await fetch(API + "/missions/" + encodeURIComponent(name));
      var text = await res.text();
      var j = JSON.parse(text);
      if (!res.ok) throw new Error((j && j.error) || text.slice(0, 400));
      missionDetail = unwrapMission(j);
      if (!missionDetail || !missionDetail.name) missionDetail = { name: name };

      editingOriginalName = String(missionDetail.name);
      mName.value = missionDetail.name;
      if (mDescription) mDescription.value = missionDetail.description != null ? String(missionDetail.description) : "";
      syncDefaultRoleSelectFromMission(missionDetail);

      /* GET /missions/:name often returns groups as {name:"…"} objects; list endpoint uses strings. */
      var mg = Array.isArray(missionDetail.groups) ? missionDetail.groups : [];
      applyMissionGroupsToSelection(mg);
      if (selectedGroupSet.size === 0) {
        var row = missionRowFromCache(name);
        if (row && Array.isArray(row.groups)) applyMissionGroupsToSelection(row.groups);
      }

      groupFilter.value = "";
      renderGroupCheckboxes();

      mContentsTbody.innerHTML = "";
      var contents = Array.isArray(missionDetail.contents) ? missionDetail.contents : [];
      if (contents.length) {
        mContentsWrap.style.display = "block";
        for (var c = 0; c < contents.length; c++) {
          var item = contents[c];
          var tr = document.createElement("tr");
          var label = (item && (item.name || item.filename || item.downloadName)) || ("Item " + (c + 1));
          var hash =
            (item && (item.hash || item.Hash || item.contentHash || item.uid || item.UUID)) || "";
          var linkHtml = "";
          if (hash) {
            var u = API + "/sync/content?hash=" + encodeURIComponent(String(hash));
            linkHtml =
              "<a href=\"" +
              u.replace(/&/g, "&amp;").replace(/"/g, "&quot;") +
              "\" target=\"_blank\" rel=\"noopener\">Download</a>";
          } else {
            linkHtml = "<span class=\"muted\">No hash in payload</span>";
          }
          tr.innerHTML = "<td>" + esc(label) + "</td><td>" + linkHtml + "</td>";
          mContentsTbody.appendChild(tr);
        }
      } else {
        mContentsWrap.style.display = "none";
      }

      setMissionModalMsg("", true);
    } catch (e) {
      setMissionModalMsg(e.message || "Failed to load mission", false);
    }
  }

  function buildSavePayload() {
    var name = (mName.value || "").trim();
    var kw = missionDetail && Array.isArray(missionDetail.keywords) ? missionDetail.keywords.slice() : [];
    return {
      name: name,
      tool: "public",
      description: mDescription ? String(mDescription.value || "") : "",
      defaultRole: buildDefaultRoleObject(mDefaultRole && mDefaultRole.value),
      groups: getSelectedGroupsFromBox(),
      keywords: kw,
      inviteOnly: false,
    };
  }

  async function saveMission() {
    setMissionModalMsg("Saving…", undefined);
    try {
      var payload = buildSavePayload();
      if (!payload.name) throw new Error("Mission name is required.");

      var url = API + "/missions/" + encodeURIComponent(payload.name);
      /* TAK Marti: POST is used for changing an existing mission; fat GET payloads on PUT caused
         "Illegal attempt to change Mission groups" when merged with UI state. */
      var res = await fetch(url, {
        method: "POST",
        headers: { "Content-Type": "application/json", Accept: "application/json" },
        body: JSON.stringify(payload),
      });
      var text = await res.text();
      var j;
      try {
        j = JSON.parse(text);
      } catch (_) {
        j = { raw: text };
      }
      if (!res.ok) throw new Error((j && j.error) || text.slice(0, 500) || "Save failed");

      var pwApply = (mNewPw && mNewPw.value) || "";
      if (pwApply) {
        var pr = await fetch(API + "/missions/" + encodeURIComponent(payload.name) + "/password", {
          method: "PUT",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({ password: pwApply }),
        });
        var ptext = await pr.text();
        var pj;
        try {
          pj = JSON.parse(ptext);
        } catch (_) {
          pj = {};
        }
        if (!pr.ok) {
          throw new Error((pj && pj.error) || "Mission saved but password could not be set.");
        }
        mNewPw.value = "";
      }

      closeModal();
      setMissionsMsg("Mission saved.", true);
      loadMissions({ silent: true });
    } catch (e) {
      setMissionModalMsg(e.message || "Save failed", false);
    }
  }

  async function setMissionPassword() {
    var name = (mName.value || "").trim();
    if (!name) return setMissionModalMsg("Mission name missing.", false);
    var pw = mNewPw.value || "";
    setMissionModalMsg("Setting password…", undefined);
    try {
      var res = await fetch(API + "/missions/" + encodeURIComponent(name) + "/password", {
        method: "PUT",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ password: pw }),
      });
      var j = await res.json().catch(function () { return {}; });
      if (!res.ok) throw new Error((j && j.error) || "Request failed");
      mNewPw.value = "";
      setMissionModalMsg("Password updated.", true);
      await Promise.all([loadMissions({ silent: true }), openEditMission(name)]);
    } catch (e) {
      setMissionModalMsg(e.message || "Failed to set password", false);
    }
  }

  async function clearMissionPassword() {
    var name = (mName.value || "").trim();
    if (!name) return setMissionModalMsg("Mission name missing.", false);
    setMissionModalMsg("Removing password…", undefined);
    try {
      var res = await fetch(API + "/missions/" + encodeURIComponent(name) + "/password", {
        method: "DELETE",
      });
      var j = await res.json().catch(function () { return {}; });
      if (!res.ok) throw new Error((j && j.error) || "Request failed");
      setMissionModalMsg("Password removed.", true);
      await Promise.all([loadMissions({ silent: true }), openEditMission(name)]);
    } catch (e) {
      setMissionModalMsg(e.message || "Failed to remove password", false);
    }
  }

  function openDeleteMission(name) {
    pendingDeleteName = name;
    deleteModalText.textContent = "Delete mission \"" + name + "\" on the TAK Server? This cannot be undone.";
    deleteModal.style.display = "flex";
    document.body.classList.add("noScroll");
  }

  function closeDeleteModal() {
    deleteModal.style.display = "none";
    document.body.classList.remove("noScroll");
    pendingDeleteName = "";
  }

  async function confirmDelete() {
    var name = pendingDeleteName;
    if (!name) return;
    try {
      var res = await fetch(API + "/missions/" + encodeURIComponent(name), { method: "DELETE" });
      var j = await res.json().catch(function () { return {}; });
      if (!res.ok) throw new Error((j && j.error) || "Delete failed");
      closeDeleteModal();
      setMissionsMsg("Mission deleted.", true);
      await loadMissions();
    } catch (e) {
      setMissionsMsg(e.message || "Delete failed", false);
      closeDeleteModal();
    }
  }

  async function doKmlUpload() {
    setKmlUploadMsg("Uploading…", undefined);
    try {
      var missionName = (kmlMissionSelect && kmlMissionSelect.value) || "";
      var file = kmlUploadInput && kmlUploadInput.files && kmlUploadInput.files[0];
      if (!missionName) throw new Error("Select a mission.");
      if (!file) throw new Error("Choose a .kml Data Sync package.");
      var fn = (file.name || "").toLowerCase();
      if (!fn.endsWith(".kml")) throw new Error("Only .kml files are allowed.");

      var fd = new FormData();
      fd.append("file", file, file.name);
      fd.append("mission", missionName);

      var res = await fetch(API + "/sync/upload", {
        method: "POST",
        body: fd,
      });
      var text = await res.text();
      var j;
      try {
        j = JSON.parse(text);
      } catch (_) {
        j = { raw: text };
      }
      if (!res.ok) throw new Error((j && j.error) || text.slice(0, 600) || "Upload failed");
      setKmlUploadMsg("KML package uploaded.", true);
      kmlUploadInput.value = "";
      await loadMissions();
    } catch (e) {
      setKmlUploadMsg(e.message || "Upload failed", false);
    }
  }

  if (missionModalClose) missionModalClose.addEventListener("click", closeModal);
  if (missionModal) {
    missionModal.addEventListener("click", function (e) {
      if (e.target === missionModal) closeModal();
    });
  }
  if (mBtnSave) mBtnSave.addEventListener("click", saveMission);
  if (mBtnSetPw) mBtnSetPw.addEventListener("click", setMissionPassword);
  if (mBtnClearPw) mBtnClearPw.addEventListener("click", clearMissionPassword);
  if (groupFilter) {
    groupFilter.addEventListener("input", function () {
      renderGroupCheckboxes();
    });
  }

  if (mGroupsBox) {
    mGroupsBox.addEventListener("change", function (e) {
      var t = e.target;
      if (!t || t.type !== "checkbox") return;
      if (t.checked) selectedGroupSet.add(t.value);
      else selectedGroupSet.delete(t.value);
    });
  }

  if (btnRefreshMissions) btnRefreshMissions.addEventListener("click", loadMissions);
  if (missionTableFilter) missionTableFilter.addEventListener("input", renderMissionsTable);
  if (btnCreateMissionSubmit) btnCreateMissionSubmit.addEventListener("click", submitCreateMission);
  if (createGroupFilter) {
    createGroupFilter.addEventListener("input", function () {
      renderCreateGroupCheckboxes();
    });
  }
  if (createMissionGroupsBox) {
    createMissionGroupsBox.addEventListener("change", function (e) {
      var t = e.target;
      if (!t || t.type !== "checkbox") return;
      if (t.checked) createSelectedGroupSet.add(t.value);
      else createSelectedGroupSet.delete(t.value);
    });
  }

  if (btnKmlUpload) btnKmlUpload.addEventListener("click", doKmlUpload);

  function wirePasswordToggle(inputEl, toggleEl) {
    if (!inputEl || !toggleEl) return;
    toggleEl.textContent = "👁";
    toggleEl.setAttribute("aria-label", "Show password");
    toggleEl.title = "Show password";
    toggleEl.addEventListener("click", function () {
      var isHidden = inputEl.type === "password";
      inputEl.type = isHidden ? "text" : "password";
      toggleEl.setAttribute("aria-label", isHidden ? "Hide password" : "Show password");
      toggleEl.title = isHidden ? "Hide password" : "Show password";
    });
  }
  wirePasswordToggle(document.getElementById("createMissionPw"), document.getElementById("createMissionPwToggle"));
  wirePasswordToggle(document.getElementById("mNewPw"), document.getElementById("mNewPwToggle"));

  if (deleteModalClose) deleteModalClose.addEventListener("click", closeDeleteModal);
  if (deleteModalConfirm) deleteModalConfirm.addEventListener("click", confirmDelete);
  if (deleteModal) {
    deleteModal.addEventListener("click", function (e) {
      if (e.target === deleteModal) closeDeleteModal();
    });
  }

  loadStatus().then(function (ok) {
    if (ok) {
      loadGroups()
        .catch(function () { /* sidebar may still work */ })
        .finally(function () {
          loadMissions();
        });
    }
  });
})();
</script>
